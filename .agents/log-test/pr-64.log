{"type":"item.completed","item":{"id":"item_39","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/validation/scanner.py | sed -n '1,240p'\"","aggregated_output":"     1\t\"\"\"Line-based scanner for forbidden raw data access in generated experiment code.\n     2\t\n     3\tThe scanner is intended for scripts under ``applications/*/experiments/``.\n     4\tSkill helper scripts may legitimately read experiment artifacts with APIs such\n     5\tas ``pd.read_csv`` and are not the target of this validator.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\timport re\n    11\tfrom dataclasses import dataclass\n    12\tfrom pathlib import Path\n    13\t\n    14\tfrom gl_tabular.constant import ValidationScannerMessages\n    15\t\n    16\t\n    17\t@dataclass(frozen=True)\n    18\tclass Violation:\n    19\t    \"\"\"Forbidden data-access pattern found in a Python file.\"\"\"\n    20\t\n    21\t    path: Path\n    22\t    line_number: int\n    23\t    pattern: str\n    24\t    message: str\n    25\t\n    26\t\n    27\t_REMEDIATION = ValidationScannerMessages.REMEDIATION\n    28\t\n    29\t_FORBIDDEN_PATTERNS: tuple[tuple[str, re.Pattern[str]], ...] = (\n    30\t    (\"pd.read_csv\", re.compile(r\"\\bpd\\s*\\.\\s*read_csv\\s*\\(\")),\n    31\t    (\"pd.read_parquet\", re.compile(r\"\\bpd\\s*\\.\\s*read_parquet\\s*\\(\")),\n    32\t    (\"pd.read_json\", re.compile(r\"\\bpd\\s*\\.\\s*read_json\\s*\\(\")),\n    33\t    (\"pandas.read_csv\", re.compile(r\"\\bpandas\\s*\\.\\s*read_csv\\s*\\(\")),\n    34\t    (\"pandas.read_parquet\", re.compile(r\"\\bpandas\\s*\\.\\s*read_parquet\\s*\\(\")),\n    35\t    (\"pandas.read_json\", re.compile(r\"\\bpandas\\s*\\.\\s*read_json\\s*\\(\")),\n    36\t    (\"polars.read_csv\", re.compile(r\"\\bpolars\\s*\\.\\s*read_csv\\s*\\(\")),\n    37\t    (\"polars.read_parquet\", re.compile(r\"\\bpolars\\s*\\.\\s*read_parquet\\s*\\(\")),\n    38\t    (\"pl.read_csv\", re.compile(r\"\\bpl\\s*\\.\\s*read_csv\\s*\\(\")),\n    39\t    (\"pl.read_parquet\", re.compile(r\"\\bpl\\s*\\.\\s*read_parquet\\s*\\(\")),\n    40\t    (\"sqlite3.connect\", re.compile(r\"\\bsqlite3\\s*\\.\\s*connect\\s*\\(\")),\n    41\t    (\"duckdb.connect\", re.compile(r\"\\bduckdb\\s*\\.\\s*connect\\s*\\(\")),\n    42\t    (\"sqlalchemy.create_engine\", re.compile(r\"\\bsqlalchemy\\s*\\.\\s*create_engine\\s*\\(\")),\n    43\t    (\"create_engine(\", re.compile(r\"\\bcreate_engine\\s*\\(\")),\n    44\t    (\"psycopg2.connect\", re.compile(r\"\\bpsycopg2\\s*\\.\\s*connect\\s*\\(\")),\n    45\t    (\"pymysql.connect\", re.compile(r\"\\bpymysql\\s*\\.\\s*connect\\s*\\(\")),\n    46\t    (\"mysql.connector.connect\", re.compile(r\"\\bmysql\\s*\\.\\s*connector\\s*\\.\\s*connect\\s*\\(\")),\n    47\t    (\"open(\", re.compile(r\"(?<!\\.)\\bopen\\s*\\(\")),\n    48\t    (\"Path.open\", re.compile(r\"\\.\\s*open\\s*\\(\")),\n    49\t)\n    50\t\n    51\t_ARTIFACT_OPEN_PATTERNS: tuple[re.Pattern[str], ...] = (\n    52\t    re.compile(r\"\"\"['\"][^'\"]*artifacts[/\\\\][^'\"]*\\.(?:pkl|json|csv)['\"]\"\"\", re.IGNORECASE),\n    53\t    re.compile(r\"\"\"(?:ARTIFACTS|OUTPUT_DIR)\\s*/\\s*['\"][^'\"]+\\.(?:pkl|json|csv)['\"]\"\"\", re.IGNORECASE),\n    54\t    re.compile(r\"\"\"['\"][^'\"]*\\{(?:ARTIFACTS|OUTPUT_DIR)\\}[^'\"]*\\.(?:pkl|json|csv)['\"]\"\"\", re.IGNORECASE),\n    55\t)\n    56\t\n    57\t\n    58\tdef _is_artifact_open(line: str, pattern_name: str) -> bool:\n    59\t    \"\"\"Check whether an open()/Path.open() call is targeting an experiment artifact.\n    60\t\n    61\t    Per templates/AGENTS.md, ``open()`` is permitted for reading and writing\n    62\t    experiment artifacts (``.pkl``, ``.json``, ``.csv`` outputs in\n    63\t    ``OUTPUT_DIR`` or ``artifacts/``).  It is forbidden only for accessing\n    64\t    raw data sources.  We suppress the violation when the call clearly\n    65\t    references an artifact path.\n    66\t\n    67\t    This is a line-based heuristic, not a full data-flow proof. Rebinding\n    68\t    ``ARTIFACTS`` or ``OUTPUT_DIR`` to a raw-data location can still fool the\n    69\t    scanner and should be treated as invalid generated code.\n    70\t    \"\"\"\n    71\t    if pattern_name not in (\"open(\", \"Path.open\"):\n    72\t        return False\n    73\t    return any(pat.search(line) for pat in _ARTIFACT_OPEN_PATTERNS)\n    74\t\n    75\t\n    76\tdef scan_python_file(path: Path) -> list[Violation]:\n    77\t    \"\"\"Scan a Python file for forbidden direct data-access calls.\"\"\"\n    78\t    violations: list[Violation] = []\n    79\t\n    80\t    try:\n    81\t        lines = path.read_text(encoding=\"utf-8\").splitlines()\n    82\t    except (OSError, UnicodeDecodeError):\n    83\t        return [Violation(path, 0, \"read\", ValidationScannerMessages.FILE_UNREADABLE)]\n    84\t\n    85\t    for line_number, line in enumerate(lines, start=1):\n    86\t        code = line.split(\"#\", 1)[0]\n    87\t        if not code.strip():\n    88\t            continue\n    89\t        for pattern, regex in _FORBIDDEN_PATTERNS:\n    90\t            if regex.search(code):\n    91\t                if _is_artifact_open(code, pattern):\n    92\t                    continue\n    93\t                violations.append(Violation(path, line_number, pattern, _REMEDIATION))\n    94\t                break\n    95\t\n    96\t    return violations\n    97\t\n    98\t\n    99\t_DUPLICATE_FILE_PATTERNS: tuple[re.Pattern[str], ...] = (\n   100\t    re.compile(r\"_v\\d+\\.(py|ipynb|json|csv|parquet|joblib|pkl)$\", re.IGNORECASE),\n   101\t    re.compile(r\"_copy\\.(py|ipynb|json|csv|parquet|joblib|pkl)$\", re.IGNORECASE),\n   102\t    re.compile(r\"copy\\.(py|ipynb|json|csv|parquet|joblib|pkl)$\", re.IGNORECASE),\n   103\t    re.compile(r\"_new\\.(py|ipynb|json|csv|parquet|joblib|pkl)$\", re.IGNORECASE),\n   104\t    re.compile(r\"_final\\.(py|ipynb|json|csv|parquet|joblib|pkl)$\", re.IGNORECASE),\n   105\t    re.compile(r\"_old\\.(py|ipynb|json|csv|parquet|joblib|pkl)$\", re.IGNORECASE),\n   106\t    re.compile(r\"_backup\\d*\\.(py|ipynb|json|csv|parquet|joblib|pkl)$\", re.IGNORECASE),\n   107\t    re.compile(r\"\\d+\\.(py|ipynb|json|csv|parquet|joblib|pkl)$\", re.IGNORECASE),\n   108\t)\n   109\t\n   110\t\n   111\tdef has_duplicate_versioned_files(experiments_dir: Path) -> list[str]:\n   112\t    \"\"\"Detect unexpected duplicate/versioned experiment files.\n   113\t\n   114\t    Args:\n   115\t        experiments_dir: Path to experiments directory.\n   116\t\n   117\t    Returns:\n   118\t        List of file paths that match duplicate/versioned patterns.\n   119\t    \"\"\"\n   120\t    if not experiments_dir.exists():\n   121\t        return []\n   122\t\n   123\t    duplicates = []\n   124\t    for f in experiments_dir.rglob(\"*\"):\n   125\t        if f.is_file() and any(pattern.search(f.name) for pattern in _DUPLICATE_FILE_PATTERNS):\n   126\t            duplicates.append(str(f.relative_to(experiments_dir)))\n   127\t    return duplicates\n   128\t\n   129\t\n   130\t__all__ = [\"Violation\", \"has_duplicate_versioned_files\", \"scan_python_file\"]\n","exit_code":0,"status":"completed"}}
