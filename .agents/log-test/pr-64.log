{"type":"item.completed","item":{"id":"item_31","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/experiment/delegation.py | sed -n '1,260p'\"","aggregated_output":"     1\t\"\"\"Typed delegation packet for experiment stage handoffs.\n     2\t\n     3\tThe DelegationPacket is emitted by 'experiment next' and provides all\n     4\trequired inputs for a specialist skill: task context, stage metadata,\n     5\tscript paths, memory files, and validation command.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\tfrom pathlib import Path\n    11\t\n    12\tfrom pydantic import BaseModel, Field\n    13\t\n    14\tfrom gl_tabular.cli.utils.experiment.stage import StageMetadata, assigned_script_path, validation_command\n    15\t\n    16\t\n    17\tclass DelegationPacket(BaseModel):\n    18\t    \"\"\"Structured handoff from orchestrator to specialist skill.\n    19\t\n    20\t    Emitted by 'experiment next' and consumed by skills to get all\n    21\t    required inputs in one typed object instead of loose prompt expectations.\n    22\t    \"\"\"\n    23\t\n    24\t    task_name: str = Field(description=\"Task name from task.yml\")\n    25\t    stage: str = Field(description=\"Current stage name\")\n    26\t    script_path: Path | None = Field(default=None, description=\"Assigned script path, if any\")\n    27\t    skill_path: str = Field(description=\"Path to the skill SKILL.md\")\n    28\t    writable_memory_files: list[str] = Field(default_factory=list)\n    29\t    expected_artifacts: list[str] = Field(default_factory=list)\n    30\t    validation_command: str = Field(description=\"CLI command to verify stage completion\")\n    31\t    references: list[str] = Field(default_factory=list)\n    32\t\n    33\t    model_config = {\"arbitrary_types_allowed\": True}\n    34\t\n    35\t\n    36\tdef build_delegation_packet(\n    37\t    task_name: str,\n    38\t    stage_meta: StageMetadata,\n    39\t    project_root: Path,\n    40\t) -> DelegationPacket:\n    41\t    \"\"\"Build a delegation packet from stage metadata and paths.\n    42\t\n    43\t    Args:\n    44\t        task_name: Task name identifier.\n    45\t        stage_meta: StageMetadata for the current stage.\n    46\t        project_root: Root path of the project.\n    47\t\n    48\t    Returns:\n    49\t        Populated DelegationPacket.\n    50\t    \"\"\"\n    51\t    script = assigned_script_path(project_root, task_name, stage_meta.name)\n    52\t\n    53\t    return DelegationPacket(\n    54\t        task_name=task_name,\n    55\t        stage=stage_meta.name,\n    56\t        script_path=script,\n    57\t        skill_path=stage_meta.skill_path,\n    58\t        writable_memory_files=stage_meta.writable_memory_files,\n    59\t        expected_artifacts=stage_meta.expected_artifacts,\n    60\t        validation_command=validation_command(task_name),\n    61\t        references=stage_meta.references,\n    62\t    )\n","exit_code":0,"status":"completed"}}
