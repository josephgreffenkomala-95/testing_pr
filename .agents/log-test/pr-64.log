{"type":"item.completed","item":{"id":"item_38","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/commands/query.py | sed -n '1,220p'\"","aggregated_output":"     1\t\"\"\"Register the query command for secure data access.\n     2\t\n     3\tProvides the query command for querying databases (SQL) and file sources (pandas query),\n     4\trouted through gl_tabular.data_access for safety checks, masking, and audit logging.\n     5\t\"\"\"\n     6\t\n     7\tfrom __future__ import annotations\n     8\t\n     9\timport os\n    10\tfrom pathlib import Path\n    11\t\n    12\timport click\n    13\t\n    14\tfrom gl_tabular.cli.models.source import source_payload_to_dict\n    15\tfrom gl_tabular.cli.utils.formatting import (\n    16\t    DEFAULT_ROW_LIMIT,\n    17\t    format_dataframe_markdown,\n    18\t    format_result_json,\n    19\t    format_result_markdown,\n    20\t    mask_dataframe,\n    21\t)\n    22\tfrom gl_tabular.cli.utils.project_context import resolve_project_root\n    23\tfrom gl_tabular.cli.utils.source.config import connect_source, get_source_entry, get_source_type\n    24\tfrom gl_tabular.constant import GroupNames, QueryMessages\n    25\tfrom gl_tabular.data_access.database import (\n    26\t    execute_query,\n    27\t    is_safe_query,\n    28\t)\n    29\tfrom gl_tabular.data_access.file_reader import (\n    30\t    validate_extension,\n    31\t)\n    32\tfrom gl_tabular.data_access.masking import MaskingContext\n    33\tfrom gl_tabular.data_access.source_reader import read_source\n    34\t\n    35\t__all__ = [\"register\"]\n    36\t\n    37\t\n    38\tdef _run_file_source_query(  # noqa: PLR0912, PLR0915\n    39\t    source_name: str,\n    40\t    query_str: str,\n    41\t    row_limit: int,\n    42\t    output_format: str,\n    43\t    task_name: str | None,\n    44\t) -> None:\n    45\t    \"\"\"Load a file source and apply a pandas query with masking.\"\"\"\n    46\t    source_cfg = get_source_entry(source_name)\n    47\t    source_dict = source_payload_to_dict(source_cfg)\n    48\t    file_path_str = source_dict.get(\"path\")\n    49\t    if not file_path_str:\n    50\t        raise click.ClickException(QueryMessages.SOURCE_NO_PATH.format(source_name=source_name))\n    51\t\n    52\t    project_root = resolve_project_root().resolve()\n    53\t    raw_path = Path(file_path_str)\n    54\t    if raw_path.is_absolute():\n    55\t        raise click.ClickException(QueryMessages.SOURCE_ABSOLUTE_PATH.format(source_name=source_name))\n    56\t\n    57\t    file_path = (project_root / raw_path).resolve()\n    58\t    try:\n    59\t        file_path.relative_to(project_root)\n    60\t    except ValueError as exc:\n    61\t        raise click.ClickException(QueryMessages.SOURCE_PATH_TRAVERSAL.format(source_name=source_name)) from exc\n    62\t\n    63\t    try:\n    64\t        validate_extension(file_path.name)\n    65\t    except ValueError as exc:\n    66\t        raise click.ClickException(str(exc)) from exc\n    67\t\n    68\t    try:\n    69\t        df = read_source(source_name, row_limit=row_limit, task_name=task_name)\n    70\t    except (PermissionError, FileNotFoundError, ValueError, ImportError) as exc:\n    71\t        raise click.ClickException(str(exc)) from exc\n    72\t\n    73\t    if query_str and query_str.strip():\n    74\t        normalized_query = query_str.strip()\n    75\t        if \"__\" in normalized_query or \"@\" in normalized_query:\n    76\t            raise click.ClickException(QueryMessages.INVALID_PANDAS_QUERY)\n    77\t        try:\n    78\t            df = df.query(normalized_query, parser=\"pandas\")\n    79\t        except Exception as exc:\n    80\t            raise click.ClickException(QueryMessages.PANDAS_QUERY_ERROR.format(exc=exc)) from exc\n    81\t\n    82\t    if len(df) > row_limit:\n    83\t        df = df.head(row_limit)\n    84\t\n    85\t    salt = os.getenv(\"MASKING_SALT\", \"\")\n    86\t    if not salt.strip():\n    87\t        raise click.ClickException(QueryMessages.MASKING_SALT_REQUIRED)\n    88\t    ctx = MaskingContext(salt=salt, enabled=True)\n    89\t    df = mask_dataframe(df, ctx)\n    90\t\n    91\t    click.echo(f\"### File source: `{source_name}` ({file_path_str})\")\n    92\t    if query_str and query_str.strip():\n    93\t        click.echo(f\"> Query: `{query_str}`\")\n    94\t    click.echo(f\"> Rows: {len(df)} | Columns: {len(df.columns)}\")\n    95\t\n    96\t    if output_format == \"json\":\n    97\t        click.echo(df.to_json(orient=\"records\", indent=2))\n    98\t    else:\n    99\t        click.echo(format_dataframe_markdown(df))\n   100\t    click.echo()\n   101\t\n   102\t\n   103\tdef register(root: click.Group) -> None:  # noqa: PLR0915\n   104\t    \"\"\"Register the query command.\"\"\"\n   105\t\n   106\t    @root.command(GroupNames.QUERY, help=\"Query a database source (SQL) or file source (pandas query).\")\n   107\t    @click.argument(\"source_name\", type=str)\n   108\t    @click.argument(\"query_str\", type=str)\n   109\t    @click.option(\n   110\t        \"--row-limit\",\n   111\t        \"-n\",\n   112\t        default=DEFAULT_ROW_LIMIT,\n   113\t        type=click.IntRange(min=1),\n   114\t        help=\"Max rows to return.\",\n   115\t    )\n   116\t    @click.option(\n   117\t        \"--format\",\n   118\t        \"output_format\",\n   119\t        type=click.Choice([\"markdown\", \"json\"]),\n   120\t        default=\"markdown\",\n   121\t        help=\"Output format.\",\n   122\t    )\n   123\t    @click.option(\"--task\", \"task_name\", default=None, help=\"Task name for source access tracking.\")\n   124\t    def query_cmd(source_name: str, query_str: str, row_limit: int, output_format: str, task_name: str | None) -> None:\n   125\t        \"\"\"Query a database or file source with safety checks and masking.\n   126\t\n   127\t        SOURCE_NAME is the registered source alias. QUERY_STR is a SQL query\n   128\t        for database sources, or a pandas query string for file sources.\n   129\t        \"\"\"\n   130\t        source_type = get_source_type(source_name)\n   131\t\n   132\t        if source_type == \"file\":\n   133\t            _run_file_source_query(source_name, query_str, row_limit, output_format, task_name)\n   134\t            return\n   135\t\n   136\t        if source_type == \"api\":\n   137\t            raise click.ClickException(QueryMessages.SOURCE_IS_API.format(source_name=source_name))\n   138\t\n   139\t        if not is_safe_query(query_str):\n   140\t            raise click.ClickException(QueryMessages.QUERY_BLOCKED)\n   141\t\n   142\t        conn = connect_source(source_name)\n   143\t        try:\n   144\t            result = execute_query(conn, query_str, row_limit=row_limit, masking_enabled=True)\n   145\t        finally:\n   146\t            try:\n   147\t                conn.close()\n   148\t            except Exception:\n   149\t                pass\n   150\t\n   151\t        click.echo(f\"### Query result from `{source_name}`\")\n   152\t        if output_format == \"json\":\n   153\t            click.echo(format_result_json(result))\n   154\t        else:\n   155\t            click.echo(format_result_markdown(result))\n   156\t        click.echo()\n","exit_code":0,"status":"completed"}}
