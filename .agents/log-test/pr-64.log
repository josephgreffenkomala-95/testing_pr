{"type":"item.completed","item":{"id":"item_37","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/data_access/database.py | sed -n '1,320p'\"","aggregated_output":"     1\t\"\"\"Database connection management with safety checks and audit logging.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\timport os\n     6\timport re\n     7\timport time\n     8\tfrom dataclasses import dataclass\n     9\tfrom pathlib import Path\n    10\tfrom typing import Any\n    11\t\n    12\tfrom gl_tabular.data_access.masking import (\n    13\t    MaskingContext,\n    14\t    detect_string_columns,\n    15\t    is_schema_query,\n    16\t    mask_rows,\n    17\t)\n    18\t\n    19\t\n    20\tdef get_connection(source_config: dict[str, Any], credentials: dict[str, str]) -> Any:\n    21\t    \"\"\"Create a database connection based on source configuration.\n    22\t\n    23\t    Args:\n    24\t        source_config: Dictionary with database connection metadata (type, host, port, database).\n    25\t        credentials: Dictionary with resolved credentials (username, password).\n    26\t\n    27\t    Returns:\n    28\t        Database connection object.\n    29\t\n    30\t    Raises:\n    31\t        KeyError: If required credentials are missing for PostgreSQL/MySQL.\n    32\t        ValueError: If database type is unsupported.\n    33\t    \"\"\"\n    34\t    db_type = source_config.get(\"type\")\n    35\t\n    36\t    if db_type == \"sqlite\":\n    37\t        import sqlite3  # noqa: PLC0415 - Lazy import for optional dependency\n    38\t\n    39\t        database = source_config.get(\"database\", \":memory:\")\n    40\t        return sqlite3.connect(database, timeout=30)\n    41\t\n    42\t    if db_type == \"duckdb\":\n    43\t        try:\n    44\t            import duckdb  # noqa: PLC0415 - Lazy import for optional dependency\n    45\t        except ImportError as exc:\n    46\t            raise ImportError(\"DuckDB support requires installing the 'database' extra.\") from exc\n    47\t\n    48\t        database = source_config.get(\"database\", \":memory:\")\n    49\t        return duckdb.connect(database)\n    50\t\n    51\t    if db_type == \"postgresql\":\n    52\t        host = source_config[\"host\"]\n    53\t        port = source_config.get(\"port\", 5432)\n    54\t        database = source_config[\"database\"]\n    55\t        username = credentials[\"username\"]\n    56\t        password = credentials[\"password\"]\n    57\t\n    58\t        try:\n    59\t            import psycopg2  # noqa: PLC0415 - Lazy import for optional dependency\n    60\t        except ImportError as exc:\n    61\t            raise ImportError(\"PostgreSQL support requires installing the 'database' extra.\") from exc\n    62\t\n    63\t        return psycopg2.connect(\n    64\t            host=host,\n    65\t            port=port,\n    66\t            database=database,\n    67\t            user=username,\n    68\t            password=password,\n    69\t            connect_timeout=30,\n    70\t        )\n    71\t\n    72\t    if db_type == \"mysql\":\n    73\t        host = source_config[\"host\"]\n    74\t        port = source_config.get(\"port\", 3306)\n    75\t        database = source_config[\"database\"]\n    76\t        username = credentials[\"username\"]\n    77\t        password = credentials[\"password\"]\n    78\t\n    79\t        try:\n    80\t            import pymysql  # noqa: PLC0415 - Lazy import for optional dependency\n    81\t        except ImportError as exc:\n    82\t            raise ImportError(\"MySQL support requires installing the 'database' extra.\") from exc\n    83\t\n    84\t        return pymysql.connect(\n    85\t            host=host,\n    86\t            port=port,\n    87\t            database=database,\n    88\t            user=username,\n    89\t            password=password,\n    90\t            connect_timeout=30,\n    91\t        )\n    92\t\n    93\t    raise ValueError(f\"Unsupported database type: {db_type}\")\n    94\t\n    95\t\n    96\t# Keywords that indicate write/DDL operations - these should be blocked\n    97\t_BLOCKED_KEYWORDS = re.compile(\n    98\t    r\"\\b(INSERT|UPDATE|DELETE|DROP|CREATE|ALTER|TRUNCATE|GRANT|REVOKE)\\b\",\n    99\t    re.IGNORECASE,\n   100\t)\n   101\t\n   102\t_ALLOWED_QUERY_PREFIXES = {\n   103\t    \"DESC\",\n   104\t    \"DESCRIBE\",\n   105\t    \"EXPLAIN\",\n   106\t    \"PRAGMA\",\n   107\t    \"SELECT\",\n   108\t    \"SHOW\",\n   109\t    \"WITH\",\n   110\t}\n   111\t\n   112\t\n   113\tdef _normalize_sql(sql: str) -> str:\n   114\t    \"\"\"Strip SQL comments and quoted literals so keyword checks are not spoofed.\n   115\t\n   116\t    Args:\n   117\t        sql: Raw SQL query string.\n   118\t\n   119\t    Returns:\n   120\t        Normalized SQL with comments and quoted content replaced by placeholders.\n   121\t    \"\"\"\n   122\t    # Remove block comments /* ... */\n   123\t    normalized = re.sub(r\"/\\*.*?\\*/\", \" \", sql, flags=re.DOTALL)\n   124\t    # Remove line comments -- ...\n   125\t    normalized = re.sub(r\"--[^\\n]*\", \" \", normalized)\n   126\t    # Replace single-quoted literals with empty string placeholder\n   127\t    normalized = re.sub(r\"'([^']|'')*'\", \"''\", normalized)\n   128\t    # Replace double-quoted identifiers with empty string placeholder\n   129\t    normalized = re.sub(r'\"([^\"]|\"\")*\"', '\"\"', normalized)\n   130\t    return normalized\n   131\t\n   132\t\n   133\tdef is_safe_query(sql: str) -> bool:\n   134\t    \"\"\"Return True if the SQL contains no write/DDL keywords.\n   135\t\n   136\t    Normalizes the SQL by stripping comments and quoted literals before\n   137\t    checking for blocked keywords, and rejects multi-statement input.\n   138\t\n   139\t    Args:\n   140\t        sql: SQL query string.\n   141\t\n   142\t    Returns:\n   143\t        True if the query is safe (read-only), False otherwise.\n   144\t    \"\"\"\n   145\t    normalized = _normalize_sql(sql)\n   146\t\n   147\t    # Reject multi-statement queries (e.g. \"SELECT 1; DELETE FROM users\")\n   148\t    statements = [part.strip() for part in normalized.split(\";\") if part.strip()]\n   149\t    if len(statements) != 1:\n   150\t        return False\n   151\t\n   152\t    statement = statements[0]\n   153\t    prefix_match = re.match(r\"^[A-Za-z]+\", statement)\n   154\t    if prefix_match is None:\n   155\t        return False\n   156\t\n   157\t    if prefix_match.group(0).upper() not in _ALLOWED_QUERY_PREFIXES:\n   158\t        return False\n   159\t\n   160\t    return not _BLOCKED_KEYWORDS.search(statement)\n   161\t\n   162\t\n   163\t# Pattern to match existing LIMIT clause\n   164\t_LIMIT_PATTERN = re.compile(r\"\\bLIMIT\\s+(\\d+)\\s*$\", re.IGNORECASE)\n   165\t\n   166\t\n   167\tdef enforce_limit(sql: str, row_limit: int) -> str:\n   168\t    \"\"\"Append or tighten LIMIT on a SQL query string.\n   169\t\n   170\t    Args:\n   171\t        sql: SQL query string.\n   172\t        row_limit: Maximum number of rows to return.\n   173\t\n   174\t    Returns:\n   175\t        SQL query with enforced LIMIT clause.\n   176\t    \"\"\"\n   177\t    # Remove trailing semicolon if present\n   178\t    sql = sql.rstrip().rstrip(\";\")\n   179\t\n   180\t    normalized = _normalize_sql(sql).rstrip()\n   181\t    match = _LIMIT_PATTERN.search(normalized)\n   182\t    if not match:\n   183\t        return f\"{sql} LIMIT {row_limit}\"\n   184\t\n   185\t    existing_limit = int(match.group(1))\n   186\t    if existing_limit > row_limit:\n   187\t        return _LIMIT_PATTERN.sub(f\"LIMIT {row_limit}\", sql)\n   188\t\n   189\t    return sql\n   190\t\n   191\t\n   192\t# Common SQL keywords that should not be used as identifiers\n   193\t_SQL_KEYWORDS = {\n   194\t    \"SELECT\",\n   195\t    \"FROM\",\n   196\t    \"WHERE\",\n   197\t    \"INSERT\",\n   198\t    \"UPDATE\",\n   199\t    \"DELETE\",\n   200\t    \"CREATE\",\n   201\t    \"DROP\",\n   202\t    \"ALTER\",\n   203\t    \"TRUNCATE\",\n   204\t    \"GRANT\",\n   205\t    \"REVOKE\",\n   206\t    \"JOIN\",\n   207\t    \"INNER\",\n   208\t    \"OUTER\",\n   209\t    \"LEFT\",\n   210\t    \"RIGHT\",\n   211\t    \"ON\",\n   212\t    \"AND\",\n   213\t    \"OR\",\n   214\t    \"NOT\",\n   215\t    \"IN\",\n   216\t    \"IS\",\n   217\t    \"NULL\",\n   218\t    \"ORDER\",\n   219\t    \"BY\",\n   220\t    \"GROUP\",\n   221\t    \"HAVING\",\n   222\t    \"LIMIT\",\n   223\t    \"OFFSET\",\n   224\t}\n   225\t\n   226\t\n   227\tdef validate_sql_identifier(identifier: str) -> str:\n   228\t    \"\"\"Validate that a string is a safe SQL identifier.\n   229\t\n   230\t    Args:\n   231\t        identifier: String to validate as an SQL identifier.\n   232\t\n   233\t    Returns:\n   234\t        The validated identifier.\n   235\t\n   236\t    Raises:\n   237\t        ValueError: If the identifier is not a valid SQL identifier.\n   238\t    \"\"\"\n   239\t    # Check if it's a SQL keyword\n   240\t    if identifier.upper() in _SQL_KEYWORDS:\n   241\t        raise ValueError(f\"Invalid SQL identifier: '{identifier}' is a reserved keyword\")\n   242\t\n   243\t    # Check for valid identifier pattern (letters, numbers, underscores, must start with letter or underscore)\n   244\t    if not re.match(r\"^[a-zA-Z_][a-zA-Z0-9_]*$\", identifier):\n   245\t        raise ValueError(f\"Invalid SQL identifier: '{identifier}' contains invalid characters\")\n   246\t\n   247\t    return identifier\n   248\t\n   249\t\n   250\t@dataclass\n   251\tclass MaskedResult:\n   252\t    \"\"\"Result of a secure query execution with masked data.\n   253\t\n   254\t    Attributes:\n   255\t        columns: List of column names.\n   256\t        rows: List of row tuples with masked string values.\n   257\t        masking_ctx: MaskingContext containing token-to-original mapping.\n   258\t        row_count: Number of rows returned.\n   259\t        was_truncated: Whether the result was truncated due to row limit.\n   260\t    \"\"\"\n   261\t\n   262\t    columns: list[str]\n   263\t    rows: list[tuple[Any, ...]]\n   264\t    masking_ctx: MaskingContext\n   265\t    row_count: int\n   266\t    was_truncated: bool = False\n   267\t\n   268\t    def to_markdown(self) -> str:\n   269\t        \"\"\"Convert the result to a markdown table.\n   270\t\n   271\t        Returns:\n   272\t            Markdown table representation of the result.\n   273\t        \"\"\"\n   274\t        if not self.rows:\n   275\t            return \"No results\"\n   276\t\n   277\t        header = \"| \" + \" | \".join(self.columns) + \" |\"\n   278\t        separator = \"| \" + \" | \".join([\"---\"] * len(self.columns)) + \" |\"\n   279\t\n   280\t        lines = [header, separator]\n   281\t        for row in self.rows:\n   282\t            row_str = \"| \" + \" | \".join(str(val) for val in row) + \" |\"\n   283\t            lines.append(row_str)\n   284\t\n   285\t        if self.was_truncated:\n   286\t            lines.append(f\"\\n*Result truncated to {self.row_count} rows*\")\n   287\t\n   288\t        return \"\\n\".join(lines)\n   289\t\n   290\t\n   291\tdef _write_audit(message: str) -> None:\n   292\t    \"\"\"Write an audit log entry to a file.\n   293\t\n   294\t    Args:\n   295\t        message: Audit log message.\n   296\t    \"\"\"\n   297\t    audit_path = Path.cwd() / \"data_access_audit.log\"\n   298\t    timestamp = time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime())\n   299\t    with audit_path.open(\"a\") as fh:\n   300\t        fh.write(f\"{timestamp} {message}\\n\")\n   301\t\n   302\t\n   303\tdef _sanitize_audit_error(exc: Exception) -> str:\n   304\t    \"\"\"Return a minimal audit-safe error identifier.\"\"\"\n   305\t    return type(exc).__name__\n   306\t\n   307\t\n   308\tdef execute_query(\n   309\t    conn: Any,\n   310\t    sql: str,\n   311\t    row_limit: int = 200,\n   312\t    masking_enabled: bool = True,\n   313\t) -> MaskedResult:\n   314\t    \"\"\"Execute a SQL query with limit enforcement, safety checks, masking, and audit logging.\n   315\t\n   316\t    Args:\n   317\t        conn: Live database connection (from `get_connection()`).\n   318\t        sql: SQL query string. Do NOT include sensitive data in query text.\n   319\t        row_limit: Maximum number of rows to return.\n   320\t        masking_enabled: Whether to apply data masking to string columns.\n","exit_code":0,"status":"completed"}}
