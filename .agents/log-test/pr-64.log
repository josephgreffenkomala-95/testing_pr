    89\t        missing, unknown = check_source_coverage(artifacts_dir, source_yaml_path)\n    90\t        task_name = task_dir.name\n    91\t        status_map = get_source_access(artifacts_dir)\n    92\t        accessed_count = len(status_map)\n    93\t        registered_count = accessed_count + len(missing)\n    94\t\n    95\t        if missing:\n    96\t            any_missing = True\n    97\t            output_lines.append(\n    98\t                f\"{ValidateStatus.PASS} \"\n    99\t                f\"{task_name}/experiments: source coverage \"\n   100\t                f\"{accessed_count}/{registered_count} accessed\"\n   101\t            )\n   102\t            for alias in missing:\n   103\t                output_lines.append(f\"  source '{alias}' registered but not yet accessed\")\n   104\t        if unknown:\n   105\t            any_failed = True\n   106\t            output_lines.append(f\"{ValidateStatus.FAIL} {task_name}/experiments: unknown sources accessed\")\n   107\t            for alias in unknown:\n   108\t                output_lines.append(\n   109\t                    f\"  {ValidateMessages.MISSING_LABEL} source '{alias}' accessed but not in source.yaml\"\n   110\t                )\n   111\t\n   112\t    if not any_failed and not any_missing and task_dirs:\n   113\t        output_lines.append(f\"{ValidateStatus.PASS} source coverage: all registered sources accessed\")\n   114\t\n   115\t    return not any_failed, output_lines\n   116\t\n   117\t\n   118\tdef _iter_task_dirs(project_root: Path, task: str | None) -> list[Path]:\n   119\t    apps_dir = project_root / ProjectDirs.APPLICATIONS\n   120\t    if not apps_dir.is_dir():\n   121\t        return []\n   122\t\n   123\t    task_dirs = sorted(d for d in apps_dir.iterdir() if d.is_dir() and not d.name.startswith(\".\"))\n   124\t    if task:\n   125\t        if not task or task != task.strip() or task.startswith(\".\"):\n   126\t            return []\n   127\t        candidate = apps_dir / task\n   128\t        if not candidate.is_dir():\n   129\t            return []\n   130\t        return [candidate]\n   131\t    return task_dirs\n   132\t\n   133\t\n   134\tdef _load_task_type(task_dir: Path) -> str | None:\n   135\t    task_file = task_dir / TaskArtifacts.TASK_FILE\n   136\t    if not task_file.exists():\n   137\t        return None\n   138\t    try:\n   139\t        task_data = yaml.safe_load(task_file.read_text(encoding=\"utf-8\")) or {}\n   140\t    except (OSError, yaml.YAMLError):\n   141\t        return None\n   142\t    task_type = task_data.get(TaskFieldNames.TASK_TYPE)\n   143\t    return str(task_type) if task_type else None\n   144\t\n   145\t\n   146\tdef _validate_known_experiment_artifacts(project_root: Path, task: str | None) -> tuple[bool, list[str]]:\n   147\t    any_failed = False\n   148\t    output_lines: list[str] = []\n   149\t\n   150\t    for task_dir in _iter_task_dirs(project_root, task):\n   151\t        artifacts_dir = task_dir / \"experiments\" / \"artifacts\"\n   152\t        if not artifacts_dir.is_dir():\n   153\t            continue\n   154\t        passed, lines = validate_known_artifacts(artifacts_dir, task_type=_load_task_type(task_dir))\n   155\t        if not passed:\n   156\t            any_failed = True\n   157\t        output_lines.extend(f\"{task_dir.name}: {line}\" for line in lines)\n   158\t\n   159\t    return not any_failed, output_lines\n   160\t\n   161\t\n   162\tdef _validate_markdown_file(path: Path, root: Path, extractor: MarkdownExtractor) -> tuple[bool, list[str]]:\n   163\t    \"\"\"Validate a single markdown file against its registered template headings.\n   164\t\n   165\t    Args:\n   166\t        path: Absolute path to the file to validate.\n   167\t        root: Project root for computing relative paths.\n   168\t        extractor: MarkdownExtractor instance.\n   169\t\n   170\t    Returns:\n   171\t        Tuple of (passed: bool, output_lines: list[str]).\n   172\t    \"\"\"\n   173\t    rel = path.relative_to(root)\n   174\t\n   175\t    if not path.exists():\n   176\t        return False, [f\"{ValidateStatus.FAIL} {ValidateMessages.REQUIRED_FILES_MISSING} {rel}\"]\n   177\t\n   178\t    required = lookup_required_headings(str(path))\n   179\t\n   180\t    if not required:\n   181\t        # Only show skip for memory scope - experiments/production should be silent\n   182\t        return True, []\n   183\t\n   184\t    try:\n   185\t        content = extractor.read_file(path)\n   186\t    except (OSError, UnicodeDecodeError):\n   187\t        return False, [f\"{ValidateStatus.FAIL} {rel} — {ValidateMessages.READ_FAILURE}\"]\n   188\t\n   189\t    sections = extractor.extract_sections(content)\n   190\t    present_headings = collect_headings(sections)\n   191\t    missing = [h for h in required if h not in present_headings]\n   192\t\n   193\t    if missing:\n   194\t        lines = [f\"{ValidateStatus.FAIL} {rel}\"]\n   195\t        for h in missing:\n   196\t            lines.append(f\"  {ValidateMessages.MISSING_LABEL} {h}\")\n   197\t        lines.append(ValidateMessages.REPAIR_UPDATE.format(rel=rel))\n   198\t        lines.append(ValidateMessages.ADD_MISSING_HEADINGS)\n   199\t        for h in missing:\n   200\t            lines.append(f\"    ## {h}\")\n   201\t        lines.append(ValidateMessages.PRESERVE_CONTENT)\n   202\t        return False, lines\n   203\t\n   204\t    return True, [f\"{ValidateStatus.PASS} {rel}: {ValidateMessages.CONTEXT_VALIDATED}\"]\n   205\t\n   206\t\n   207\tdef _get_required_interfaces(script_name: str) -> tuple[FunctionInterface, ...]:\n   208\t    \"\"\"Get required function interfaces for a script name.\n   209\t\n   210\t    Args:\n   211\t        script_name: Name of the script file.\n   212\t\n   213\t    Returns:\n   214\t        Tuple of required FunctionInterface definitions.\n   215\t    \"\"\"\n   216\t    for meta in STAGE_METADATA.values():\n   217\t        if meta.script_name == script_name:\n   218\t            return meta.required_interfaces\n   219\t    return ()\n   220\t\n   221\t\n   222\tdef _validate_function_interface(tree: ast.Module, required: FunctionInterface) -> tuple[bool, list[str]]:\n   223\t    \"\"\"Validate that a required function exists with correct signature.\n   224\t\n   225\t    Checks parameter names and order only. Return type annotations and\n   226\t    parameter type hints are explicitly out-of-scope for validation.\n   227\t\n   228\t    Args:\n   229\t        tree: Parsed AST of the Python file.\n   230\t        required: Required function interface definition.\n   231\t\n   232\t    Returns:\n   233\t        Tuple of (passed: bool, error_messages: list[str]).\n   234\t    \"\"\"\n   235\t    for node in tree.body:\n   236\t        if isinstance(node, ast.FunctionDef) and node.name == required.name:\n   237\t            args = node.args\n   238\t            disallowed = None\n   239\t            if args.posonlyargs:\n   240\t                disallowed = \"positional-only arguments\"\n   241\t            elif args.vararg is not None:\n   242\t                disallowed = \"*args\"\n   243\t            elif args.kwarg is not None:\n   244\t                disallowed = \"**kwargs\"\n   245\t            elif args.kwonlyargs:\n   246\t                disallowed = \"keyword-only arguments\"\n   247\t\n   248\t            if disallowed is not None:\n   249\t                message = f\"  {ValidateMessages.DISALLOWED_SIGNATURE}: function '{required.name}' has {disallowed}\"\n   250\t                return False, [message]\n   251\t\n   252\t            actual_params = [arg.arg for arg in args.args]\n   253\t\n   254\t            expected_params = list(required.parameters)\n   255\t            if actual_params != expected_params:\n   256\t                return False, [\n   257\t                    f\"  {ValidateMessages.INCORRECT_PARAMETERS}: function '{required.name}'\",\n   258\t                    f\"    expected: {expected_params}\",\n   259\t                    f\"    actual:   {actual_params}\",\n   260\t                ]\n   261\t\n   262\t            return True, []\n   263\t\n   264\t    return False, [f\"  {ValidateMessages.MISSING_FUNCTION}: '{required.name}'\"]\n   265\t\n   266\t\n   267\tdef _validate_python_file(path: Path, root: Path) -> tuple[bool, list[str]]:\n   268\t    \"\"\"Validate a single Python file for forbidden data access patterns and interface compliance.\n   269\t\n   270\t    Args:\n   271\t        path: Absolute path to the file to validate.\n   272\t        root: Project root for computing relative paths.\n   273\t\n   274\t    Returns:\n   275\t        Tuple of (passed: bool, output_lines: list[str]).\n   276\t    \"\"\"\n   277\t    rel = path.relative_to(root)\n   278\t\n   279\t    if not path.exists():\n   280\t        return False, [ValidateMessages.FILE_NOT_FOUND.format(status=ValidateStatus.FAIL, rel=rel)]\n   281\t\n   282\t    output_lines: list[str] = []\n   283\t    passed = True\n   284\t\n   285\t    if path.name not in _EXPECTED_SCRIPT_NAMES:\n   286\t        passed = False\n   287\t        output_lines.extend(\n   288\t            [\n   289\t                f\"{ValidateStatus.FAIL} {rel}\",\n   290\t                f\"  {ValidateMessages.UNEXPECTED_SCRIPT_NAME}: {path.name}\",\n   291\t                f\"  {ValidateMessages.EXPECTED_SCRIPT_NAMES} {', '.join(_EXPECTED_SCRIPT_NAMES)}\",\n   292\t            ]\n   293\t        )\n   294\t\n   295\t    violations = scan_python_file(path)\n   296\t\n   297\t    if violations:\n   298\t        passed = False\n   299\t        lines = [f\"{ValidateStatus.FAIL} {rel}\"]\n   300\t        for v in violations:\n   301\t            if v.line_number == 0:\n   302\t                lines.append(f\"  {v.message}\")\n   303\t                continue\n   304\t            lines.append(f\"  line {v.line_number}: {ValidateMessages.FORBIDDEN_PATTERN}: {v.pattern}\")\n   305\t            lines.append(f\"  {v.message}\")\n   306\t        output_lines.extend(lines)\n   307\t\n   308\t    # Validate required function interfaces using AST\n   309\t    required_interfaces = _get_required_interfaces(path.name)\n   310\t    if required_interfaces:\n   311\t        try:\n   312\t            source = path.read_text(encoding=\"utf-8\")\n   313\t            tree = ast.parse(source)\n   314\t        except (OSError, UnicodeDecodeError, SyntaxError) as e:\n   315\t            passed = False\n   316\t            output_lines.append(f\"{ValidateStatus.FAIL} {rel}\")\n   317\t            output_lines.append(ValidateMessages.PARSE_ERROR.format(error=e))\n   318\t        else:\n   319\t            interface_errors: list[str] = []\n   320\t            for required in required_interfaces:\n   321\t                ok, errors = _validate_function_interface(tree, required)\n   322\t                if not ok:\n   323\t                    passed = False\n   324\t                    interface_errors.extend(errors)\n   325\t\n   326\t            if interface_errors:\n   327\t                output_lines.append(f\"{ValidateStatus.FAIL} {rel}\")\n   328\t                output_lines.extend(interface_errors)\n   329\t\n   330\t    if output_lines:\n   331\t        return passed, output_lines\n   332\t\n   333\t    return True, [f\"{ValidateStatus.PASS} {rel}: {ValidateMessages.SECURE_ACCESS_VALIDATED}\"]\n   334\t\n   335\t\n   336\tdef run_validate(target: str, task: str | None, path: str | None, project_root: Path) -> tuple[bool, list[str]]:\n   337\t    \"\"\"Run validation logic and return results without side effects.\n   338\t\n   339\t    Args:\n   340\t        target: Validation target (all, memory, code, experiments, production).\n   341\t        task: Optional task name to narrow scope.\n   342\t        path: Optional path to narrow to a single file.\n   343\t        project_root: Resolved project root directory.\n   344\t\n   345\t    Returns:\n   346\t        Tuple of (passed: bool, output_lines: list[str]).\n   347\t    \"\"\"\n   348\t    paths = resolve_scope(target, task, path, project_root)\n   349\t    extractor = MarkdownExtractor()\n   350\t    any_failed = False\n   351\t    output_lines: list[str] = []\n   352\t\n   353\t    target_value = target.lower()\n   354\t\n   355\t    if not paths:\n   356\t        if path:\n   357\t            output_lines.append(f\"{ValidateMessages.NO_FILES_MATCHED} path={path} under {project_root}\")\n   358\t        else:\n   359\t            output_lines.append(\n   360\t                f\"{ValidateMessages.NO_FILES_MATCHED} target={target_value} task={task or '-'} under {project_root}\"\n","exit_code":0,"status":"completed"}}
