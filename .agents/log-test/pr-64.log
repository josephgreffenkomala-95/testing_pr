       output_lines.extend(artifact_lines)\n   395\t\n   396\t    # Forecast artifact re-verification for experiments and all scopes\n   397\t    if target_value in _SCOPES_WITH_SOURCE_COVERAGE:\n   398\t        fc_passed, fc_lines = _validate_forecast_artifacts(project_root, task)\n   399\t        if not fc_passed:\n   400\t            any_failed = True\n   401\t        output_lines.extend(fc_lines)\n   402\t\n   403\t    return not any_failed, output_lines\n   404\t\n   405\t\n   406\tdef _validate_forecast_artifacts(project_root: Path, task: str | None) -> tuple[bool, list[str]]:\n   407\t    \"\"\"Re-verify forecast_review.json values against prediction data.\n   408\t\n   409\t    When both forecast_review.json and test_predictions.csv exist for a\n   410\t    task, re-runs scale/variation/flatline checks from forecast_validators\n   411\t    and reports mismatches with stored values.\n   412\t\n   413\t    Args:\n   414\t        project_root: Resolved project root directory.\n   415\t        task: Optional task name to narrow scope.\n   416\t\n   417\t    Returns:\n   418\t        Tuple of (passed: bool, output_lines: list[str]).\n   419\t    \"\"\"\n   420\t    any_failed = False\n   421\t    output_lines: list[str] = []\n   422\t\n   423\t    for task_dir in _iter_task_dirs(project_root, task):\n   424\t        artifacts_dir = task_dir / \"experiments\" / \"artifacts\"\n   425\t        if not artifacts_dir.is_dir():\n   426\t            continue\n   427\t\n   428\t        review_path = artifacts_dir / \"forecast_review.json\"\n   429\t\n   430\t        if not review_path.exists():\n   431\t            continue\n   432\t\n   433\t        try:\n   434\t            review_data = json.loads(review_path.read_text(encoding=\"utf-8\"))\n   435\t            review = ForecastReviewSchema.model_validate(review_data)\n   436\t        except Exception as exc:\n   437\t            any_failed = True\n   438\t            output_lines.append(f\"{ValidateStatus.FAIL} {task_dir.name}/experiments: forecast review cannot re-verify\")\n   439\t            output_lines.append(f\"  forecast_review.json invalid: {exc}\")\n   440\t            continue\n   441\t\n   442\t        context = review.verification_context\n   443\t        preds_path = artifacts_dir / context.predictions_file\n   444\t        try:\n   445\t            resolved_preds_path = preds_path.resolve()\n   446\t            resolved_artifacts_dir = artifacts_dir.resolve()\n   447\t            resolved_preds_path.relative_to(resolved_artifacts_dir)\n   448\t        except ValueError:\n   449\t            any_failed = True\n   450\t            output_lines.append(f\"{ValidateStatus.FAIL} {task_dir.name}/experiments: forecast review path invalid\")\n   451\t            output_lines.append(f\"  predictions_file must stay under artifacts/: {context.predictions_file}\")\n   452\t            continue\n   453\t\n   454\t        if Path(context.predictions_file).is_absolute() or \"..\" in Path(context.predictions_file).parts:\n   455\t            any_failed = True\n   456\t            output_lines.append(f\"{ValidateStatus.FAIL} {task_dir.name}/experiments: forecast review path invalid\")\n   457\t            output_lines.append(f\"  predictions_file must be a safe relative path: {context.predictions_file}\")\n   458\t            continue\n   459\t\n   460\t        try:\n   461\t            import pandas as pd  # noqa: PLC0415\n   462\t\n   463\t            if not preds_path.exists():\n   464\t                raise FileNotFoundError(preds_path)\n   465\t            df = pd.read_csv(preds_path)\n   466\t            if context.prediction_column not in df.columns:\n   467\t                any_failed = True\n   468\t                output_lines.append(\n   469\t                    f\"{ValidateStatus.FAIL} {task_dir.name}/experiments: forecast review prediction column missing\"\n   470\t                )\n   471\t                output_lines.append(\n   472\t                    f\"  verification_context.prediction_column {context.prediction_column!r} \"\n   473\t                    f\"not found in {context.predictions_file}\"\n   474\t                )\n   475\t                continue\n   476\t            predictions = df[context.prediction_column].dropna().values\n   477\t            preds = np.array(predictions, dtype=float)\n   478\t        except Exception as exc:\n   479\t            any_failed = True\n   480\t            output_lines.append(f\"{ValidateStatus.FAIL} {task_dir.name}/experiments: forecast review cannot re-verify\")\n   481\t            output_lines.append(f\"  could not load numeric predictions: {exc}\")\n   482\t            continue\n   483\t\n   484\t        if len(preds) == 0:\n   485\t            any_failed = True\n   486\t            output_lines.append(f\"{ValidateStatus.FAIL} {task_dir.name}/experiments: forecast review predictions empty\")\n   487\t            continue\n   488\t\n   489\t        task_name = task_dir.name\n   490\t\n   491\t        scale_result = check_scale(preds, context.train_mean)\n   492\t        stored_scale = review.scale_check.prediction_scale_ratio\n   493\t        computed_scale = scale_result.get(\"prediction_scale_ratio\")\n   494\t        if _numeric_mismatch(stored_scale, computed_scale):\n   495\t            any_failed = True\n   496\t            output_lines.append(f\"{ValidateStatus.FAIL} {task_name}/experiments: forecast review scale ratio mismatch\")\n   497\t            output_lines.append(f\"  stored={stored_scale}, recomputed={computed_scale}\")\n   498\t        if review.scale_check.passed != scale_result.get(\"passed\"):\n   499\t            any_failed = True\n   500\t            output_lines.append(f\"{ValidateStatus.FAIL} {task_name}/experiments: forecast review scale passed mismatch\")\n   501\t            output_lines.append(f\"  stored={review.scale_check.passed}, recomputed={scale_result.get('passed')}\")\n   502\t\n   503\t        var_result = check_variation(preds, context.train_std)\n   504\t        stored_var = review.variation_check.variation_ratio\n   505\t        computed_var = var_result.get(\"variation_ratio\")\n   506\t        if _numeric_mismatch(stored_var, computed_var):\n   507\t            any_failed = True\n   508\t            output_lines.append(\n   509\t                f\"{ValidateStatus.FAIL} {task_name}/experiments: forecast review variation ratio mismatch\"\n   510\t            )\n   511\t            output_lines.append(f\"  stored={stored_var}, recomputed={computed_var}\")\n   512\t        if review.variation_check.passed != var_result.get(\"passed\"):\n   513\t            any_failed = True\n   514\t            output_lines.append(\n   515\t                f\"{ValidateStatus.FAIL} {task_name}/experiments: forecast review variation passed mismatch\"\n   516\t            )\n   517\t            output_lines.append(f\"  stored={review.variation_check.passed}, recomputed={var_result.get('passed')}\")\n   518\t\n   519\t        flat_result = check_flatline(preds, context.train_mean)\n   520\t        stored_flat = review.flatline_check.min_max_spread_ratio\n","exit_code":0,"status":"completed"}}
