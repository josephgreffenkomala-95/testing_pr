{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/data_access/source_tracker.py | sed -n '1,320p'\"","aggregated_output":"     1\t\"\"\"Track which data sources have been accessed during experiment iterations.\n     2\t\n     3\tRecords source access events in ``source_access.json`` under the task\n     4\tartifacts directory so that ``validate experiments`` can compare accessed\n     5\tsources against ``source.yaml`` entries.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\timport json\n    11\timport tempfile\n    12\tfrom enum import StrEnum\n    13\tfrom pathlib import Path\n    14\tfrom typing import Any\n    15\t\n    16\timport yaml\n    17\t\n    18\t\n    19\tclass SourceStatus(StrEnum):\n    20\t    \"\"\"Machine-readable status for a source in the coverage tracker.\"\"\"\n    21\t\n    22\t    PENDING = \"pending\"\n    23\t    EXPLORING = \"exploring\"\n    24\t    COMPLETE = \"complete\"\n    25\t    BLOCKED = \"blocked\"\n    26\t    NOT_RELEVANT = \"not_relevant\"\n    27\t\n    28\t\n    29\t_COVERED_STATUSES: frozenset[SourceStatus] = frozenset(\n    30\t    {SourceStatus.COMPLETE, SourceStatus.BLOCKED, SourceStatus.NOT_RELEVANT}\n    31\t)\n    32\t\n    33\t\n    34\tdef source_access_path(artifacts_dir: Path) -> Path:\n    35\t    \"\"\"Return the path to ``source_access.json`` for a given artifacts directory.\n    36\t\n    37\t    Args:\n    38\t        artifacts_dir: Path to the task artifacts directory\n    39\t            (e.g. ``applications/{task}/experiments/artifacts``).\n    40\t\n    41\t    Returns:\n    42\t        Path to the ``source_access.json`` file.\n    43\t    \"\"\"\n    44\t    return artifacts_dir / \"source_access.json\"\n    45\t\n    46\t\n    47\tdef _read_access_data(path: Path) -> dict[str, Any]:\n    48\t    \"\"\"Read and return the source access JSON data, or empty dict.\"\"\"\n    49\t    if not path.exists():\n    50\t        return {}\n    51\t    try:\n    52\t        return json.loads(path.read_text(encoding=\"utf-8\"))\n    53\t    except (json.JSONDecodeError, OSError):\n    54\t        return {}\n    55\t\n    56\t\n    57\tdef _write_access_data(path: Path, data: dict[str, Any]) -> None:\n    58\t    \"\"\"Atomically write source access data to JSON.\"\"\"\n    59\t    path.parent.mkdir(parents=True, exist_ok=True)\n    60\t    with tempfile.NamedTemporaryFile(\"w\", encoding=\"utf-8\", dir=path.parent, delete=False) as tmp:\n    61\t        tmp.write(json.dumps(data, indent=2, sort_keys=True) + \"\\n\")\n    62\t        tmp_path = Path(tmp.name)\n    63\t    tmp_path.replace(path)\n    64\t\n    65\t\n    66\tdef record_source_access(artifacts_dir: Path, source_alias: str) -> None:\n    67\t    \"\"\"Record that a source was accessed during an experiment iteration.\n    68\t\n    69\t    Atomically updates ``source_access.json`` in the artifacts directory.\n    70\t    If the file does not exist, creates it. If the source was already\n    71\t    recorded, increments the access count.\n    72\t\n    73\t    Args:\n    74\t        artifacts_dir: Path to the task artifacts directory.\n    75\t        source_alias: The alias of the source as registered in ``source.yaml``.\n    76\t    \"\"\"\n    77\t    path = source_access_path(artifacts_dir)\n    78\t    access = _read_access_data(path)\n    79\t\n    80\t    if source_alias in access:\n    81\t        entry = access[source_alias]\n    82\t        entry[\"access_count\"] = entry.get(\"access_count\", 0) + 1\n    83\t    else:\n    84\t        access[source_alias] = {\"access_count\": 1}\n    85\t\n    86\t    _write_access_data(path, access)\n    87\t\n    88\t\n    89\tdef get_source_access(artifacts_dir: Path) -> dict[str, int]:\n    90\t    \"\"\"Read the source access tracker and return a mapping of alias to count.\n    91\t\n    92\t    Args:\n    93\t        artifacts_dir: Path to the task artifacts directory.\n    94\t\n    95\t    Returns:\n    96\t        Dictionary mapping source alias to total access count.\n    97\t        Empty dict if the file does not exist.\n    98\t    \"\"\"\n    99\t    access = _read_access_data(source_access_path(artifacts_dir))\n   100\t    return {alias: entry.get(\"access_count\", 0) for alias, entry in access.items() if isinstance(entry, dict)}\n   101\t\n   102\t\n   103\tdef set_source_status(artifacts_dir: Path, source_alias: str, status: SourceStatus, reason: str = \"\") -> None:\n   104\t    \"\"\"Set the machine-readable status for a source.\n   105\t\n   106\t    Args:\n   107\t        artifacts_dir: Path to the task artifacts directory.\n   108\t        source_alias: The alias of the source.\n   109\t        status: New status value.\n   110\t        reason: Optional reason string (e.g. why blocked or not relevant).\n   111\t    \"\"\"\n   112\t    path = source_access_path(artifacts_dir)\n   113\t    access = _read_access_data(path)\n   114\t\n   115\t    if source_alias not in access:\n   116\t        access[source_alias] = {\"access_count\": 0}\n   117\t\n   118\t    access[source_alias][\"status\"] = str(status)\n   119\t    if reason:\n   120\t        access[source_alias][\"status_reason\"] = reason\n   121\t    elif \"status_reason\" in access[source_alias]:\n   122\t        del access[source_alias][\"status_reason\"]\n   123\t\n   124\t    _write_access_data(path, access)\n   125\t\n   126\t\n   127\tdef get_source_status_map(artifacts_dir: Path) -> dict[str, dict[str, Any]]:\n   128\t    \"\"\"Read the source access tracker and return a mapping with status info.\n   129\t\n   130\t    Args:\n   131\t        artifacts_dir: Path to the task artifacts directory.\n   132\t\n   133\t    Returns:\n   134\t        Dictionary mapping source alias to dict with keys:\n   135\t        access_count, status, status_reason.\n   136\t    \"\"\"\n   137\t    access = _read_access_data(source_access_path(artifacts_dir))\n   138\t    result: dict[str, dict[str, Any]] = {}\n   139\t    for alias, entry in access.items():\n   140\t        if not isinstance(entry, dict):\n   141\t            continue\n   142\t        result[alias] = {\n   143\t            \"access_count\": entry.get(\"access_count\", 0),\n   144\t            \"status\": entry.get(\"status\", SourceStatus.PENDING),\n   145\t            \"status_reason\": entry.get(\"status_reason\", \"\"),\n   146\t        }\n   147\t    return result\n   148\t\n   149\t\n   150\tdef check_source_coverage(artifacts_dir: Path, source_yaml_path: Path) -> tuple[list[str], list[str]]:\n   151\t    \"\"\"Compare accessed sources against registered sources.\n   152\t\n   153\t    Sources with status ``blocked`` or ``not_relevant`` are treated as covered\n   154\t    and do not appear in missing_accesses.\n   155\t\n   156\t    Args:\n   157\t        artifacts_dir: Path to the task artifacts directory.\n   158\t        source_yaml_path: Path to the project ``source.yaml`` file.\n   159\t\n   160\t    Returns:\n   161\t        Tuple of (missing_accesses, unknown_sources):\n   162\t        - missing_accesses: source aliases in source.yaml that were never accessed and not marked blocked/not_relevant\n   163\t        - unknown_sources: source aliases in source_access.json not found in source.yaml\n   164\t    \"\"\"\n   165\t    status_map = get_source_status_map(artifacts_dir)\n   166\t\n   167\t    if not source_yaml_path.exists():\n   168\t        return [], list(status_map.keys())\n   169\t\n   170\t    try:\n   171\t        registered = yaml.safe_load(source_yaml_path.read_text(encoding=\"utf-8\")) or {}\n   172\t    except (yaml.YAMLError, OSError):\n   173\t        return [], list(status_map.keys())\n   174\t\n   175\t    registered_aliases = set(registered.keys())\n   176\t    covered_aliases = {\n   177\t        alias for alias, info in status_map.items() if info[\"access_count\"] > 0 or info[\"status\"] in _COVERED_STATUSES\n   178\t    }\n   179\t    accessed_aliases = set(status_map.keys())\n   180\t\n   181\t    missing_accesses = sorted(registered_aliases - covered_aliases)\n   182\t    unknown_sources = sorted(accessed_aliases - registered_aliases)\n   183\t\n   184\t    return missing_accesses, unknown_sources\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_23","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/data_access/source_reader.py | sed -n '1,260p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/data_access/source_reader.py | sed -n '1,260p'\"","aggregated_output":"     1\t\"\"\"Convenience helpers for reading registered and local data sources.\n     2\t\n     3\tThese wrappers compose the lower-level config, database, and file_reader\n     4\tmodules so that skill templates can access data with a single call.\n     5\t\"\"\"\n     6\t\n     7\tfrom __future__ import annotations\n     8\t\n     9\timport os\n    10\tfrom pathlib import Path\n    11\tfrom typing import Any\n    12\t\n    13\timport pandas as pd\n    14\t\n    15\tfrom gl_tabular.data_access.config import _resolve_project_root, load_source_config, resolve_credentials\n    16\tfrom gl_tabular.data_access.database import (\n    17\t    MaskedResult,\n    18\t    enforce_limit,\n    19\t    execute_query,\n    20\t    get_connection,\n    21\t    get_schema_info,\n    22\t    validate_sql_identifier,\n    23\t)\n    24\tfrom gl_tabular.data_access.file_reader import (\n    25\t    read_csv_safe,\n    26\t    read_json_safe,\n    27\t    read_parquet_safe,\n    28\t)\n    29\tfrom gl_tabular.data_access.source_tracker import SourceStatus, record_source_access, set_source_status\n    30\t\n    31\t_SUPPORTED_DB_TYPES = (\"postgresql\", \"mysql\", \"duckdb\", \"sqlite\")\n    32\t_SUPPORTED_EXTENSIONS = (\".csv\", \".parquet\", \".json\")\n    33\t_TASK_ENV_VAR = \"GL_TABULAR_TASK\"\n    34\t\n    35\t\n    36\tdef resolve_tracking_artifacts_dir(project_root: Path, task_name: str | None) -> Path | None:\n    37\t    \"\"\"Resolve source tracking artifacts directory for an explicit task.\"\"\"\n    38\t    if task_name is None:\n    39\t        return None\n    40\t    normalized = task_name.strip()\n    41\t    if not normalized or normalized.startswith(\".\") or \"/\" in normalized or \"\\\\\" in normalized:\n    42\t        return None\n    43\t\n    44\t    task_dir = project_root / \"applications\" / normalized\n    45\t    if not task_dir.is_dir():\n    46\t        return None\n    47\t    return task_dir / \"experiments\" / \"artifacts\"\n    48\t\n    49\t\n    50\tdef _infer_single_task_name(project_root: Path) -> str | None:\n    51\t    apps_dir = project_root / \"applications\"\n    52\t    if not apps_dir.is_dir():\n    53\t        return None\n    54\t    task_dirs = sorted(d for d in apps_dir.iterdir() if d.is_dir() and not d.name.startswith(\".\"))\n    55\t    if len(task_dirs) != 1:\n    56\t        return None\n    57\t    return task_dirs[0].name\n    58\t\n    59\t\n    60\tdef _resolve_artifacts_dir(task_name: str | None = None) -> Path | None:\n    61\t    \"\"\"Resolve the task artifacts directory for source access tracking.\"\"\"\n    62\t    project_root = _resolve_project_root()\n    63\t    resolved_task = task_name or os.getenv(_TASK_ENV_VAR) or _infer_single_task_name(project_root)\n    64\t    return resolve_tracking_artifacts_dir(project_root, resolved_task)\n    65\t\n    66\t\n    67\tdef _read_file(fp: Path, allowed_paths: list[Path], row_limit: int, **kwargs: Any) -> pd.DataFrame:\n    68\t    \"\"\"Dispatch a file read based on extension using the safe readers.\n    69\t\n    70\t    Args:\n    71\t        fp: Resolved file path.\n    72\t        allowed_paths: Allowlist for path validation.\n    73\t        row_limit: Maximum rows to return.\n    74\t        **kwargs: Extra args forwarded to the reader.\n    75\t\n    76\t    Returns:\n    77\t        A pandas DataFrame with the file data.\n    78\t\n    79\t    Raises:\n    80\t        ValueError: If the file extension is unsupported.\n    81\t        PermissionError: If the path is outside the allowlist.\n    82\t        FileNotFoundError: If the file does not exist.\n    83\t    \"\"\"\n    84\t    suffix = fp.suffix.lower()\n    85\t    if suffix == \".csv\":\n    86\t        return read_csv_safe(fp, allowed_paths, row_limit=row_limit, **kwargs)\n    87\t    elif suffix == \".parquet\":\n    88\t        return read_parquet_safe(fp, allowed_paths, row_limit=row_limit, **kwargs)\n    89\t    elif suffix == \".json\":\n    90\t        return read_json_safe(fp, allowed_paths, row_limit=row_limit, **kwargs)\n    91\t    else:\n    92\t        raise ValueError(f\"Unsupported file extension '{suffix}'.\")\n    93\t\n    94\t\n    95\tdef _execute_source_query(source_config: dict[str, Any], sql: str, row_limit: int) -> MaskedResult:\n    96\t    credentials = resolve_credentials(source_config)\n    97\t    conn = get_connection(source_config, credentials)\n    98\t    try:\n    99\t        return execute_query(conn, sql, row_limit=row_limit)\n   100\t    finally:\n   101\t        conn.close()\n   102\t\n   103\t\n   104\tdef _record_access(artifacts_dir: Path | None, source_name: str, exc: BaseException | None = None) -> None:\n   105\t    if artifacts_dir is None:\n   106\t        return\n   107\t    record_source_access(artifacts_dir, source_name)\n   108\t    if exc is None:\n   109\t        set_source_status(artifacts_dir, source_name, SourceStatus.COMPLETE)\n   110\t    else:\n   111\t        set_source_status(artifacts_dir, source_name, SourceStatus.BLOCKED, reason=str(exc))\n   112\t\n   113\t\n   114\tdef query_source(source_name: str, sql: str, row_limit: int = 200, *, task_name: str | None = None) -> MaskedResult:\n   115\t    \"\"\"Execute a read-only SQL query against a registered source.\n   116\t\n   117\t    Args:\n   118\t        source_name: The alias registered in source.yaml.\n   119\t        sql: SQL query string (SELECT only).\n   120\t        row_limit: Maximum rows to return.\n   121\t        task_name: Optional task name used for source access tracking.\n   122\t\n   123\t    Returns:\n   124\t        MaskedResult with columns, rows, and masking context.\n   125\t    \"\"\"\n   126\t    source_config = load_source_config(source_name)\n   127\t    artifacts_dir = _resolve_artifacts_dir(task_name)\n   128\t    try:\n   129\t        result = _execute_source_query(source_config, sql, row_limit)\n   130\t        _record_access(artifacts_dir, source_name)\n   131\t        return result\n   132\t    except BaseException as exc:\n   133\t        _record_access(artifacts_dir, source_name, exc=exc)\n   134\t        raise\n   135\t\n   136\t\n   137\tdef schema_source(source_name: str, table_name: str, *, task_name: str | None = None) -> dict[str, Any] | None:\n   138\t    \"\"\"Retrieve schema information for a table from a registered source.\n   139\t\n   140\t    Args:\n   141\t        source_name: The alias registered in source.yaml.\n   142\t        table_name: Name of the table to inspect.\n   143\t        task_name: Optional task name used for source access tracking.\n   144\t\n   145\t    Returns:\n   146\t        Dictionary with table schema, or None if table doesn't exist.\n   147\t    \"\"\"\n   148\t    source_config = load_source_config(source_name)\n   149\t    artifacts_dir = _resolve_artifacts_dir(task_name)\n   150\t    credentials = resolve_credentials(source_config)\n   151\t    conn = get_connection(source_config, credentials)\n   152\t    try:\n   153\t        result = get_schema_info(conn, table_name)\n   154\t    except BaseException as exc:\n   155\t        conn.close()\n   156\t        _record_access(artifacts_dir, source_name, exc=exc)\n   157\t        raise\n   158\t    else:\n   159\t        conn.close()\n   160\t        _record_access(artifacts_dir, source_name)\n   161\t        return result\n   162\t\n   163\t\n   164\tdef read_source(source_name: str, row_limit: int = 200, *, task_name: str | None = None, **kwargs: Any) -> pd.DataFrame:\n   165\t    \"\"\"Read a registered source through the secure reader.\n   166\t\n   167\t    For file sources, resolves the file path from source.yaml and reads\n   168\t    through the appropriate safe reader based on file extension.\n   169\t    For database sources, executes a SELECT * FROM <table> query.\n   170\t\n   171\t    Args:\n   172\t        source_name: The alias registered in source.yaml.\n   173\t        row_limit: Maximum rows to return.\n   174\t        task_name: Optional task name used for source access tracking.\n   175\t        **kwargs: Additional arguments passed to the reader.\n   176\t\n   177\t    Returns:\n   178\t        A pandas DataFrame with the source data.\n   179\t\n   180\t    Raises:\n   181\t        FileNotFoundError: If the file does not exist.\n   182\t        PermissionError: If the path is outside the allowlist.\n   183\t        ValueError: If the file extension is unsupported or required config keys are missing.\n   184\t    \"\"\"\n   185\t    source_config = load_source_config(source_name)\n   186\t    source_type = source_config.get(\"type\", \"\")\n   187\t    artifacts_dir = _resolve_artifacts_dir(task_name)\n   188\t\n   189\t    try:\n   190\t        if source_type in _SUPPORTED_DB_TYPES:\n   191\t            table = source_config.get(\"table\", \"\")\n   192\t            if not table:\n   193\t                raise ValueError(f\"Source '{source_name}' is a database source but 'table' is not configured.\")\n   194\t            validated_table = validate_sql_identifier(table)\n   195\t            sql = enforce_limit(f\"SELECT * FROM {validated_table}\", row_limit)\n   196\t            result = _execute_source_query(source_config, sql, row_limit)\n   197\t            _record_access(artifacts_dir, source_name)\n   198\t            return pd.DataFrame(result.rows, columns=result.columns)\n   199\t\n   200\t        project_root = _resolve_project_root()\n   201\t        file_path_str = source_config.get(\"path\", \"\")\n   202\t        if not file_path_str:\n   203\t            raise ValueError(f\"Source '{source_name}' is missing 'path' in its configuration.\")\n   204\t        fp = (project_root / file_path_str).resolve()\n   205\t        allowed_paths = [project_root.resolve()]\n   206\t\n   207\t        result = _read_file(fp, allowed_paths, row_limit, **kwargs)\n   208\t        _record_access(artifacts_dir, source_name)\n   209\t        return result\n   210\t    except BaseException as exc:\n   211\t        _record_access(artifacts_dir, source_name, exc=exc)\n   212\t        raise\n   213\t\n   214\t\n   215\tdef read_local(file_path: str | Path, row_limit: int = 200, **kwargs: Any) -> pd.DataFrame:\n   216\t    \"\"\"Read a local file through the secure file reader.\n   217\t\n   218\t    Args:\n   219\t        file_path: Path to the local file.\n   220\t        row_limit: Maximum rows to return.\n   221\t        **kwargs: Additional arguments passed to the reader.\n   222\t\n   223\t    Returns:\n   224\t        A pandas DataFrame with the file data.\n   225\t\n   226\t    Raises:\n   227\t        PermissionError: If the path is outside the allowlist.\n   228\t        FileNotFoundError: If the file does not exist.\n   229\t    \"\"\"\n   230\t    project_root = _resolve_project_root()\n   231\t    fp = Path(file_path).resolve()\n   232\t    allowed_paths = [project_root.resolve()]\n   233\t\n   234\t    return _read_file(fp, allowed_paths, row_limit, **kwargs)\n","exit_code":0,"status":"completed"}}
