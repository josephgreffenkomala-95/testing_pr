{"type":"item.completed","item":{"id":"item_56","type":"command_execution","command":"/bin/bash -lc \"nl -ba tests/unit/data_access/test_database.py | sed -n '80,220p'\"","aggregated_output":"    80\t        \"host\": \"localhost\",\n    81\t    }\n    82\t    credentials = {}\n    83\t\n    84\t    with pytest.raises(ValueError, match=\"Unsupported database type\"):\n    85\t        get_connection(source_config, credentials)\n    86\t\n    87\t\n    88\tdef test_is_safe_query_select() -> None:\n    89\t    \"\"\"Test that SELECT queries are considered safe.\"\"\"\n    90\t    assert is_safe_query(\"SELECT * FROM users\")\n    91\t    assert is_safe_query(\"SELECT name, age FROM users WHERE age > 25\")\n    92\t\n    93\t\n    94\tdef test_is_safe_query_schema_prefixes_allowed() -> None:\n    95\t    \"\"\"Test that supported read-only metadata statements are considered safe.\"\"\"\n    96\t    assert is_safe_query(\"PRAGMA table_info(users)\")\n    97\t    assert is_safe_query(\"SHOW TABLES\")\n    98\t    assert is_safe_query(\"DESCRIBE users\")\n    99\t\n   100\t\n   101\tdef test_is_safe_query_insert_blocked() -> None:\n   102\t    \"\"\"Test that INSERT queries are blocked.\"\"\"\n   103\t    assert not is_safe_query(\"INSERT INTO users (name) VALUES ('Alice')\")\n   104\t\n   105\t\n   106\tdef test_is_safe_query_update_blocked() -> None:\n   107\t    \"\"\"Test that UPDATE queries are blocked.\"\"\"\n   108\t    assert not is_safe_query(\"UPDATE users SET age = 30 WHERE name = 'Alice'\")\n   109\t\n   110\t\n   111\tdef test_is_safe_query_delete_blocked() -> None:\n   112\t    \"\"\"Test that DELETE queries are blocked.\"\"\"\n   113\t    assert not is_safe_query(\"DELETE FROM users WHERE age < 18\")\n   114\t\n   115\t\n   116\tdef test_is_safe_query_drop_blocked() -> None:\n   117\t    \"\"\"Test that DROP queries are blocked.\"\"\"\n   118\t    assert not is_safe_query(\"DROP TABLE users\")\n   119\t    assert not is_safe_query(\"DROP DATABASE analytics\")\n   120\t\n   121\t\n   122\tdef test_is_safe_query_create_blocked() -> None:\n   123\t    \"\"\"Test that CREATE queries are blocked.\"\"\"\n   124\t    assert not is_safe_query(\"CREATE TABLE users (id INT, name VARCHAR)\")\n   125\t\n   126\t\n   127\tdef test_is_safe_query_alter_blocked() -> None:\n   128\t    \"\"\"Test that ALTER queries are blocked.\"\"\"\n   129\t    assert not is_safe_query(\"ALTER TABLE users ADD COLUMN age INT\")\n   130\t\n   131\t\n   132\tdef test_is_safe_query_case_insensitive() -> None:\n   133\t    \"\"\"Test that keyword blocking is case-insensitive.\"\"\"\n   134\t    assert not is_safe_query(\"insert into users (name) values ('Alice')\")\n   135\t    assert not is_safe_query(\"UPDATE users SET age = 30\")\n   136\t    assert not is_safe_query(\"delete from users\")\n   137\t\n   138\t\n   139\tdef test_is_safe_query_comment_keyword_ignored() -> None:\n   140\t    \"\"\"Test that blocked keywords inside comments are correctly ignored (not executable).\"\"\"\n   141\t    # Keywords in comments are not executable, normalization correctly strips them\n   142\t    assert is_safe_query(\"SELECT * FROM users /* DELETE */ WHERE id = 1\")\n   143\t    assert is_safe_query(\"SELECT * FROM users -- DROP TABLE\\nWHERE id = 1\")\n   144\t\n   145\t\n   146\tdef test_is_safe_query_comment_obfuscated_multi_statement_blocked() -> None:\n   147\t    \"\"\"Test that comment-obfuscated multi-statement injection is still blocked.\"\"\"\n   148\t    # Multi-statement with comment obfuscation is blocked by semicolon check\n   149\t    assert not is_safe_query(\"SELECT 1; /* safe */ DELETE FROM users\")\n   150\t    assert not is_safe_query(\"SELECT * FROM users; -- bypass\\nDROP TABLE users\")\n   151\t\n   152\t\n   153\tdef test_is_safe_query_blocked_keyword_in_string_literal() -> None:\n   154\t    \"\"\"Test that blocked keywords inside string literals are not false positives.\"\"\"\n   155\t    # \"DELETE\" inside a string value should NOT block the query\n   156\t    assert is_safe_query(\"SELECT * FROM users WHERE name = 'DELETE me'\")\n   157\t\n   158\t\n   159\tdef test_is_safe_query_multi_statement_rejected() -> None:\n   160\t    \"\"\"Test that multi-statement queries (SQL injection) are rejected.\"\"\"\n   161\t    assert not is_safe_query(\"SELECT 1; DELETE FROM users\")\n   162\t    assert not is_safe_query(\"SELECT * FROM users; DROP TABLE users\")\n   163\t\n   164\t\n   165\tdef test_is_safe_query_trailing_semicolon_ok() -> None:\n   166\t    \"\"\"Test that a single statement with trailing semicolon is allowed.\"\"\"\n   167\t    assert is_safe_query(\"SELECT * FROM users;\")\n   168\t\n   169\t\n   170\tdef test_is_safe_query_non_read_only_prefixes_blocked() -> None:\n   171\t    \"\"\"Test that statements outside the read-only allowlist are blocked.\"\"\"\n   172\t    assert not is_safe_query(\"ATTACH DATABASE 'other.db' AS other\")\n   173\t    assert not is_safe_query(\"VACUUM\")\n   174\t    assert not is_safe_query(\"CALL do_work()\")\n   175\t\n   176\t\n   177\tdef test_enforce_limit_no_existing_limit() -> None:\n   178\t    \"\"\"Test that enforce_limit adds LIMIT clause to query without existing LIMIT.\"\"\"\n   179\t    query = \"SELECT * FROM users\"\n   180\t    result = enforce_limit(query, 100)\n   181\t    assert result == \"SELECT * FROM users LIMIT 100\"\n   182\t\n   183\t\n   184\tdef test_enforce_limit_existing_limit_smaller() -> None:\n   185\t    \"\"\"Test that enforce_limit keeps existing LIMIT if it's smaller.\"\"\"\n   186\t    query = \"SELECT * FROM users LIMIT 50\"\n   187\t    result = enforce_limit(query, 100)\n   188\t    assert result == \"SELECT * FROM users LIMIT 50\"\n   189\t\n   190\t\n   191\tdef test_enforce_limit_existing_limit_larger() -> None:\n   192\t    \"\"\"Test that enforce_limit tightens existing LIMIT if it's larger.\"\"\"\n   193\t    query = \"SELECT * FROM users LIMIT 500\"\n   194\t    result = enforce_limit(query, 100)\n   195\t    assert result == \"SELECT * FROM users LIMIT 100\"\n   196\t\n   197\t\n   198\tdef test_enforce_limit_with_semicolon() -> None:\n   199\t    \"\"\"Test that enforce_limit handles queries with trailing semicolon.\"\"\"\n   200\t    query = \"SELECT * FROM users;\"\n   201\t    result = enforce_limit(query, 100)\n   202\t    assert result == \"SELECT * FROM users LIMIT 100\"\n   203\t\n   204\t\n   205\tdef test_enforce_limit_complex_query() -> None:\n   206\t    \"\"\"Test that enforce_limit works with complex queries.\"\"\"\n   207\t    query = \"SELECT name, age FROM users WHERE age > 25 ORDER BY name\"\n   208\t    result = enforce_limit(query, 100)\n   209\t    assert result == \"SELECT name, age FROM users WHERE age > 25 ORDER BY name LIMIT 100\"\n   210\t\n   211\t\n   212\tdef test_validate_sql_identifier_valid() -> None:\n   213\t    \"\"\"Test that valid SQL identifiers pass validation.\"\"\"\n   214\t    assert validate_sql_identifier(\"users\") == \"users\"\n   215\t    assert validate_sql_identifier(\"user_table\") == \"user_table\"\n   216\t    assert validate_sql_identifier(\"UserTable\") == \"UserTable\"\n   217\t\n   218\t\n   219\tdef test_validate_sql_identifier_sql_keyword() -> None:\n   220\t    \"\"\"Test that SQL keywords are rejected.\"\"\"\n","exit_code":0,"status":"completed"}}
