{"type":"item.completed","item":{"id":"item_34","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/experiment/policy.py | sed -n '1,260p'\"","aggregated_output":"     1\t\"\"\"Canonical deterministic policy for experiment workflow routing and run ids.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\timport re\n     6\tfrom collections.abc import Iterable\n     7\tfrom pathlib import Path\n     8\t\n     9\tfrom gl_tabular.cli.utils.experiment.routing import route_after_leakage_guard_post\n    10\t\n    11\tRUN_ID_PATTERN = re.compile(r\"run-(\\d{3})$\")\n    12\tRUN_DETAIL_PATH_PATTERN = re.compile(r\"run-(\\d{3})\\.md$\")\n    13\t\n    14\tCHECKPOINT_STAGES: tuple[str, ...] = (\n    15\t    \"data-explorer\",\n    16\t    \"data-cleaner\",\n    17\t    \"data-analysis\",\n    18\t)\n    19\t\n    20\tITERATION_RESET_STAGES: tuple[str, ...] = (\n    21\t    \"data-explorer\",\n    22\t    \"data-cleaner\",\n    23\t    \"data-analysis\",\n    24\t    \"feature-engineer\",\n    25\t    \"modeling\",\n    26\t)\n    27\t\n    28\tPOST_LEAKAGE_GUARD_MODELING_FAIL_CONDITIONS: frozenset[str] = frozenset(\n    29\t    {\n    30\t        \"val_uses_teacher_forcing\",\n    31\t    }\n    32\t)\n    33\t\n    34\t\n    35\tdef format_run_id(number: int) -> str:\n    36\t    \"\"\"Return the canonical run id string.\"\"\"\n    37\t    if number < 1:\n    38\t        msg = \"Run id number must be >= 1\"\n    39\t        raise ValueError(msg)\n    40\t    return f\"run-{number:03d}\"\n    41\t\n    42\t\n    43\tINITIAL_RUN_ID = format_run_id(1)\n    44\t\n    45\t\n    46\tdef parse_run_id(value: str) -> int | None:\n    47\t    \"\"\"Parse a canonical run id string and return its numeric component.\"\"\"\n    48\t    match = RUN_ID_PATTERN.fullmatch(value.strip())\n    49\t    if match is None:\n    50\t        return None\n    51\t    return int(match.group(1))\n    52\t\n    53\t\n    54\tdef is_valid_run_id(value: str) -> bool:\n    55\t    \"\"\"Return whether a string matches the canonical run id format.\"\"\"\n    56\t    return parse_run_id(value) is not None\n    57\t\n    58\t\n    59\tdef validate_run_id(value: str) -> str:\n    60\t    \"\"\"Return a normalized canonical run id or raise for invalid input.\"\"\"\n    61\t    run_number = parse_run_id(value)\n    62\t    if run_number is None:\n    63\t        msg = f\"Invalid run id '{value}'. Expected format: run-001\"\n    64\t        raise ValueError(msg)\n    65\t    return format_run_id(run_number)\n    66\t\n    67\t\n    68\tdef is_checkpoint_stage(stage_name: str) -> bool:\n    69\t    \"\"\"Return whether the stage requires a human validation pause.\"\"\"\n    70\t    return stage_name in CHECKPOINT_STAGES\n    71\t\n    72\t\n    73\tdef route_post_leakage_guard_failure(fail_conditions: Iterable[str]) -> str:\n    74\t    \"\"\"Return the canonical stage to revisit after a post leakage-guard failure.\n    75\t\n    76\t    Delegates to routing.route_after_leakage_guard_post for the actual logic.\n    77\t    \"\"\"\n    78\t    return route_after_leakage_guard_post(list(fail_conditions))\n    79\t\n    80\t\n    81\tdef next_run_id(memory_path: Path) -> str:\n    82\t    \"\"\"Allocate the next sequential run id from memory/runs.\"\"\"\n    83\t    runs_dir = memory_path / \"runs\"\n    84\t    max_run_number = 0\n    85\t    if runs_dir.exists():\n    86\t        for path in runs_dir.glob(\"run-*.md\"):\n    87\t            match = RUN_DETAIL_PATH_PATTERN.fullmatch(path.name)\n    88\t            if match is None:\n    89\t                continue\n    90\t            max_run_number = max(max_run_number, int(match.group(1)))\n    91\t    return format_run_id(max_run_number + 1)\n","exit_code":0,"status":"completed"}}
