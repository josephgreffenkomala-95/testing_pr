{"type":"item.completed","item":{"id":"item_36","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/data_access/config.py | sed -n '1,260p'\"","aggregated_output":"     1\t\"\"\"Configuration loading for source.yaml and credential resolution.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\timport os\n     6\tfrom pathlib import Path\n     7\t\n     8\timport yaml\n     9\tfrom dotenv import load_dotenv\n    10\t\n    11\tfrom gl_tabular.constant import FileNames\n    12\t\n    13\t\n    14\tdef _resolve_project_root(start_path: Path | None = None) -> Path:\n    15\t    \"\"\"Resolve the nearest ancestor containing the project config file.\"\"\"\n    16\t    current_path = (start_path or Path.cwd()).resolve()\n    17\t\n    18\t    for candidate in (current_path, *current_path.parents):\n    19\t        if (candidate / FileNames.PROJECT_CONFIG).is_file():\n    20\t            return candidate\n    21\t\n    22\t    raise FileNotFoundError(f\"Project file not found: {FileNames.PROJECT_CONFIG}\")\n    23\t\n    24\t\n    25\tdef _load_config() -> dict[str, object]:\n    26\t    \"\"\"Load source.yaml from the current project root.\n    27\t\n    28\t    Returns:\n    29\t        Parsed configuration dictionary.\n    30\t\n    31\t    Raises:\n    32\t        FileNotFoundError: If source.yaml does not exist in the project root.\n    33\t        yaml.YAMLError: If source.yaml contains invalid YAML.\n    34\t    \"\"\"\n    35\t    project_root = _resolve_project_root()\n    36\t    config_path = project_root / FileNames.SOURCE\n    37\t\n    38\t    if not config_path.exists():\n    39\t        raise FileNotFoundError(f\"Config file not found: {config_path}\")\n    40\t\n    41\t    with config_path.open() as fh:\n    42\t        return yaml.safe_load(fh) or {}\n    43\t\n    44\t\n    45\tdef load_source_config(source_name: str) -> dict[str, object]:\n    46\t    \"\"\"Load configuration for a registered source by alias from source.yaml.\n    47\t\n    48\t    Args:\n    49\t        source_name: The alias registered in source.yaml.\n    50\t\n    51\t    Returns:\n    52\t        The source configuration dictionary.\n    53\t\n    54\t    Raises:\n    55\t        FileNotFoundError: If source.yaml does not exist in the project root.\n    56\t        KeyError: If the alias is not found in source.yaml.\n    57\t    \"\"\"\n    58\t    config = _load_config()\n    59\t    if source_name not in config:\n    60\t        raise KeyError(f\"Source alias '{source_name}' not found in source.yaml\")\n    61\t    return config[source_name]\n    62\t\n    63\t\n    64\tdef resolve_credentials(source_config: dict[str, str]) -> dict[str, str]:\n    65\t    \"\"\"Resolve database credentials from environment variables.\n    66\t\n    67\t    Args:\n    68\t        source_config: Dictionary that may contain env-backed credential keys.\n    69\t\n    70\t    Returns:\n    71\t        Dictionary with resolved username and password.\n    72\t\n    73\t    Raises:\n    74\t        KeyError: If a configured environment variable is not set.\n    75\t    \"\"\"\n    76\t    project_root = _resolve_project_root()\n    77\t    load_dotenv(project_root / FileNames.ENV, override=False)\n    78\t\n    79\t    env_user = source_config.get(\"env_user\")\n    80\t    env_password = source_config.get(\"env_password\")\n    81\t\n    82\t    if env_user is None and env_password is None:\n    83\t        return {}\n    84\t    if env_user is None or env_password is None:\n    85\t        raise KeyError(\"Both env_user and env_password must be configured for database sources.\")\n    86\t\n    87\t    username = os.getenv(env_user)\n    88\t    password = os.getenv(env_password)\n    89\t\n    90\t    if username is None:\n    91\t        raise KeyError(f\"Environment variable not set: {env_user}\")\n    92\t    if password is None:\n    93\t        raise KeyError(f\"Environment variable not set: {env_password}\")\n    94\t\n    95\t    return {\"username\": username, \"password\": password}\n","exit_code":0,"status":"completed"}}
