{"type":"item.completed","item":{"id":"item_43","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/data_access/database.py | sed -n '308,520p'\"","aggregated_output":"   308\tdef execute_query(\n   309\t    conn: Any,\n   310\t    sql: str,\n   311\t    row_limit: int = 200,\n   312\t    masking_enabled: bool = True,\n   313\t) -> MaskedResult:\n   314\t    \"\"\"Execute a SQL query with limit enforcement, safety checks, masking, and audit logging.\n   315\t\n   316\t    Args:\n   317\t        conn: Live database connection (from `get_connection()`).\n   318\t        sql: SQL query string. Do NOT include sensitive data in query text.\n   319\t        row_limit: Maximum number of rows to return.\n   320\t        masking_enabled: Whether to apply data masking to string columns.\n   321\t\n   322\t    Returns:\n   323\t        MaskedResult with masked rows and masking context.\n   324\t\n   325\t    Raises:\n   326\t        PermissionError: If the query contains unsafe keywords.\n   327\t        ValueError: If row_limit is invalid or masking is enabled without MASKING_SALT.\n   328\t    \"\"\"\n   329\t    if row_limit < 1:\n   330\t        raise ValueError(\"row_limit must be at least 1\")\n   331\t\n   332\t    # Safety check\n   333\t    if not is_safe_query(sql):\n   334\t        _write_audit(\"QUERY verdict=BLOCKED reason=unsafe_statement duration_ms=0\")\n   335\t        raise PermissionError(\"Query blocked: contains unsafe or non-read-only SQL.\")\n   336\t\n   337\t    salt = \"\"\n   338\t    if masking_enabled:\n   339\t        salt = os.getenv(\"MASKING_SALT\", \"\")\n   340\t        if not salt.strip():\n   341\t            raise ValueError(\"MASKING_SALT must be set to a non-empty value when masking is enabled.\")\n   342\t    masking_ctx = MaskingContext(salt=salt, enabled=masking_enabled)\n   343\t\n   344\t    safe_sql = sql\n   345\t\n   346\t    # Enforce limit (fetch one extra row to detect truncation)\n   347\t    # Skip for schema queries (PRAGMA, SHOW, etc.) where LIMIT is invalid\n   348\t    if not is_schema_query(sql):\n   349\t        safe_sql = enforce_limit(safe_sql, row_limit + 1)\n   350\t\n   351\t    t0 = time.monotonic()\n   352\t    try:\n   353\t        cursor = conn.cursor()\n   354\t        cursor.execute(safe_sql)\n   355\t        raw_rows = cursor.fetchall()\n   356\t        columns = [d[0] for d in cursor.description]\n   357\t        duration_ms = int((time.monotonic() - t0) * 1000)\n   358\t    except Exception as e:\n   359\t        duration_ms = int((time.monotonic() - t0) * 1000)\n   360\t        error_name = _sanitize_audit_error(e)\n   361\t        _write_audit(f\"QUERY verdict=ERROR duration_ms={duration_ms} error_type={error_name}\")\n   362\t        raise\n   363\t\n   364\t    # Extract table names for audit (best-effort)\n   365\t    table_names = re.findall(r\"\\bFROM\\s+(\\S+)\", safe_sql, re.IGNORECASE)\n   366\t    table_names += re.findall(r\"\\bJOIN\\s+(\\S+)\", safe_sql, re.IGNORECASE)\n   367\t    tables_str = \",\".join(set(table_names)) or \"unknown\"\n   368\t\n   369\t    # Check for truncation\n   370\t    was_truncated = len(raw_rows) > row_limit\n   371\t    if was_truncated:\n   372\t        raw_rows = raw_rows[:row_limit]\n   373\t\n   374\t    # Apply masking (skip for schema queries to preserve column names)\n   375\t    if masking_enabled and not is_schema_query(sql):\n   376\t        string_cols = detect_string_columns(columns, raw_rows)\n   377\t        masked_rows, masking_ctx = mask_rows(raw_rows, columns, string_cols, masking_ctx)\n   378\t    else:\n   379\t        masked_rows = raw_rows\n   380\t\n   381\t    _write_audit(\n   382\t        f\"QUERY tables=[{tables_str}] rows={len(masked_rows)} duration_ms={duration_ms} truncated={was_truncated}\"\n   383\t    )\n   384\t\n   385\t    return MaskedResult(\n   386\t        columns=columns,\n   387\t        rows=masked_rows,\n   388\t        masking_ctx=masking_ctx,\n   389\t        row_count=len(masked_rows),\n   390\t        was_truncated=was_truncated,\n   391\t    )\n   392\t\n   393\t\n   394\tdef get_schema_info(conn: Any, table_name: str) -> dict[str, Any] | None:\n   395\t    \"\"\"Retrieve schema information for a table.\n   396\t\n   397\t    Args:\n   398\t        conn: Live database connection.\n   399\t        table_name: Name of the table to get schema info for.\n   400\t\n   401\t    Returns:\n   402\t        Dictionary with table schema information, or None if table doesn't exist.\n   403\t    \"\"\"\n   404\t    try:\n   405\t        cursor = conn.cursor()\n   406\t\n   407\t        # Try to get column information using PRAGMA for SQLite\n   408\t        cursor.execute(f\"PRAGMA table_info({validate_sql_identifier(table_name)})\")\n   409\t        columns_info = cursor.fetchall()\n   410\t\n   411\t        if not columns_info:\n   412\t            return None\n   413\t\n   414\t        columns = []\n   415\t        for col in columns_info:\n   416\t            columns.append(\n   417\t                {\n   418\t                    \"name\": col[1],\n   419\t                    \"type\": col[2],\n   420\t                    \"not_null\": bool(col[3]),\n   421\t                    \"primary_key\": bool(col[5]),\n   422\t                }\n   423\t            )\n   424\t\n   425\t        return {\n   426\t            \"table_name\": table_name,\n   427\t            \"columns\": columns,\n   428\t        }\n   429\t    except Exception:\n   430\t        # If PRAGMA fails, table might not exist or database doesn't support PRAGMA\n   431\t        return None\n","exit_code":0,"status":"completed"}}
