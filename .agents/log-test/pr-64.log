  95\t    passed, output_lines = run_validate(\"memory\", task_name, str(run_detail_path), project_root)\n    96\t    if not passed:\n    97\t        raise click.ClickException(\n    98\t            f\"Run detail validation failed for {run_detail_path.relative_to(project_root)}:\\n\" + \"\\n\".join(output_lines)\n    99\t        )\n   100\t\n   101\t\n   102\tdef _check_task_exists(root: Path, task: str) -> None:\n   103\t    \"\"\"Check if task exists and raise if not.\"\"\"\n   104\t    task_file = root / ProjectDirs.APPLICATIONS / task / TaskArtifacts.TASK_FILE\n   105\t    if not task_file.exists():\n   106\t        raise click.ClickException(ExperimentMessages.TASK_NOT_FOUND.format(task=task, task_file=task_file))\n   107\t\n   108\t\n   109\tdef _check_memory_dir(root: Path, task: str) -> Path:\n   110\t    \"\"\"Check memory dir exists and return memory path.\"\"\"\n   111\t    memory_dir = task_memory_dir(root, task)\n   112\t    if not memory_dir.exists():\n   113\t        raise click.ClickException(ExperimentMessages.MEMORY_DIR_NOT_FOUND.format(memory_dir=memory_dir))\n   114\t    return memory_dir\n   115\t\n   116\t\n   117\tdef _check_experiments_dir(root: Path, task: str) -> Path:\n   118\t    \"\"\"Get experiments dir, create if needed.\"\"\"\n   119\t    experiments_dir = task_experiments_dir(root, task)\n   120\t    experiments_dir.mkdir(parents=True, exist_ok=True)\n   121\t    return experiments_dir\n   122\t\n   123\t\n   124\tdef _get_memory_current(root: Path, task: str) -> Path:\n   125\t    \"\"\"Get path to memory/current.md.\"\"\"\n   126\t    return task_memory_dir(root, task) / \"current.md\"\n   127\t\n   128\t\n   129\tdef _run_next_preflight(project_root: Path, task_name: str) -> None:\n   130\t    \"\"\"Validate task memory and existing experiment code before emitting next work.\"\"\"\n   131\t    failures = []\n   132\t\n   133\t    memory_passed, memory_lines = run_validate(\"memory\", task_name, None, project_root)\n   134\t    memory_status = \"PASS\" if memory_passed else \"FAIL\"\n   135\t    click.echo(f'Check: validation memory --task \"{task_name}\" - {memory_status}')\n   136\t    if not memory_passed:\n   137\t        failures.append(\"memory validation failed\")\n   138\t        for line in memory_lines:\n   139\t            click.echo(f\"  {line}\")\n   140\t\n   141\t    code_paths = resolve_scope(\"code\", task_name, None, project_root)\n   142\t    if code_paths:\n   143\t        code_passed, code_lines = run_validate(\"code\", task_name, None, project_root)\n   144\t        code_status = \"PASS\" if code_passed else \"FAIL\"\n   145\t        click.echo(f'Check: validation code --task \"{task_name}\" - {code_status}')\n   146\t        if not code_passed:\n   147\t            failures.append(\"code validation failed\")\n   148\t            for line in code_lines:\n   149\t                click.echo(f\"  {line}\")\n   150\t            wrong_name_files = [p for p in code_paths if p.suffix == \".py\" and p.name not in _REGISTERED_SCRIPT_NAMES]\n   151\t            if wrong_name_files and not any(\n   152\t                p.suffix == \".py\" and p.name in _REGISTERED_SCRIPT_NAMES for p in code_paths\n   153\t            ):\n   154\t                names = \", \".join(str(p.name) for p in wrong_name_files)\n   155\t                click.echo(\n   156\t                    f\"  Hint: experiment Python files exist but have wrong names ({names}). \"\n   157\t                    \"Run 'experiment scaffold-stage' to create correctly named scripts first.\"\n   158\t                )\n   159\t    else:\n   160\t        click.echo(f'Check: validation code --task \"{task_name}\" - SKIP (no experiment Python files yet)')\n   161\t\n   162\t    if failures:\n   163\t        raise SystemExit(1)\n   164\t\n   165\t\n   166\tdef _handle_status(task_name: str) -> None:\n   167\t    \"\"\"Handle experiment status command.\"\"\"\n   168\t    project_root = resolve_project_root()\n   169\t    _check_task_exists(project_root, task_name)\n   170\t    _check_memory_dir(project_root, task_name)\n   171\t\n   172\t    task_config = load_task_config(project_root, task_name)\n   173\t    memory_path = _get_memory_current(project_root, task_name)\n   174\t\n   175\t    parsed = parse_current_memory(memory_path)\n   176\t    completed = {s for s, done in parsed.stage_status.items() if done}\n   177\t\n   178\t    current_stage = resolve_current_stage(parsed.current_status, parsed.current_stage, completed)\n   179\t    is_blocked = parsed.current_status == ExperimentStatus.BLOCKED\n   180\t\n   181\t    latest_completed = None\n   182\t    for stage in reversed(get_all_stages()):\n   183\t        if stage in completed:\n   184\t            latest_completed = stage\n   185\t            break\n   186\t\n   187\t    next_stage = current_stage\n   188\t    blocker = parsed.blocker_reason if is_blocked else \"None\"\n   189\t\n   190\t    script_path = assigned_script_path(project_root, task_name, current_stage) if current_stage else None\n   191\t    script_str = str(script_path) if script_path else \"None\"\n   192\t\n   193\t    val_cmd = validation_command(task_name)\n   194\t\n   195\t    click.echo(f\"Task: {task_name}\")\n   196\t    click.echo(f\"Iteration: {get_iteration(task_config)}\")\n   197\t    click.echo(f\"Current stage: {current_stage or 'None'}\")\n   198\t    click.echo(f\"Latest completed stage: {latest_completed or 'None'}\")\n   199\t    click.echo(f\"Next stage: {next_stage or 'None'}\")\n   200\t    click.echo(f\"Blocked: {'yes' if is_blocked else 'no'}\")\n   201\t    click.echo(f\"Blocker: {blocker}\")\n   202\t    click.echo(f\"Assigned script: {script_str}\")\n   203\t    click.echo(f\"Validation command: {val_cmd}\")\n   204\t\n   205\t\n   206\tdef _scaffold_stage_command(task_name: str, stage_name: str) -> str:\n   207\t    \"\"\"Build the scaffold command shown for scripted stages.\"\"\"\n   208\t    return f\"uv run gl-tabular experiment scaffold