{"type":"item.completed","item":{"id":"item_53","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/validation/scope.py | sed -n '1,260p'\"","aggregated_output":"     1\t\"\"\"Scope resolver for the validate command.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\tfrom pathlib import Path\n     6\t\n     7\tfrom gl_tabular.cli.utils.validation.registry import TASK_MEMORY_FILENAMES\n     8\tfrom gl_tabular.constant import ProjectDirs, TaskDirs, ValidateTargets\n     9\t\n    10\t\n    11\tdef resolve_scope(\n    12\t    target: str,\n    13\t    task: str | None,\n    14\t    path: str | None,\n    15\t    root: Path,\n    16\t) -> list[Path]:\n    17\t    \"\"\"Resolve target/task/path to a concrete list of file paths.\n    18\t\n    19\t    Args:\n    20\t        target: One of the ValidateTargets values (``all``, ``memory``,\n    21\t            ``code``, ``experiments``, ``production``).\n    22\t        task: Optional task name to narrow scope to a single application.\n    23\t        path: Optional relative or absolute path to further narrow results.\n    24\t        root: Project root directory.\n    25\t\n    26\t    Returns:\n    27\t        Sorted list of Path objects matching the resolution rules.\n    28\t        Empty list when no files match.\n    29\t    \"\"\"\n    30\t    if not root.is_dir():\n    31\t        return []\n    32\t\n    33\t    paths: list[Path] = []\n    34\t\n    35\t    if target == ValidateTargets.ALL:\n    36\t        paths.extend(_task_memory_paths(root, task))\n    37\t        paths.extend(_experiments_paths(root, task))\n    38\t        paths.extend(_production_paths(root, task))\n    39\t\n    40\t    elif target == ValidateTargets.MEMORY:\n    41\t        paths.extend(_task_memory_paths(root, task))\n    42\t\n    43\t    elif target == ValidateTargets.CODE:\n    44\t        paths.extend(_code_paths(root, task))\n    45\t\n    46\t    elif target == ValidateTargets.EXPERIMENTS:\n    47\t        paths.extend(_experiments_paths(root, task))\n    48\t\n    49\t    elif target == ValidateTargets.PRODUCTION:\n    50\t        paths.extend(_production_paths(root, task))\n    51\t\n    52\t    if path is not None:\n    53\t        target_path = Path(path)\n    54\t        if not target_path.is_absolute():\n    55\t            target_path = root / target_path\n    56\t        target_path = target_path.resolve()\n    57\t        paths = [p for p in paths if p.resolve() == target_path]\n    58\t\n    59\t    return sorted(paths)\n    60\t\n    61\t\n    62\tdef _task_memory_paths(root: Path, task: str | None) -> list[Path]:\n    63\t    \"\"\"Return canonical task-local memory file paths, optionally filtered by task name.\"\"\"\n    64\t    apps_dir = root / ProjectDirs.APPLICATIONS\n    65\t    if not apps_dir.is_dir():\n    66\t        return []\n    67\t\n    68\t    paths: list[Path] = []\n    69\t    task_dirs = _app_dirs(apps_dir, task)\n    70\t    for app_dir in task_dirs:\n    71\t        memory_dir = app_dir / ProjectDirs.MEMORY\n    72\t        paths.extend(memory_dir / name for name in TASK_MEMORY_FILENAMES)\n    73\t        runs_dir = memory_dir / \"runs\"\n    74\t        if runs_dir.is_dir():\n    75\t            paths.extend(p for p in runs_dir.rglob(\"*.md\") if p.is_file())\n    76\t    return paths\n    77\t\n    78\t\n    79\tdef _code_paths(root: Path, task: str | None) -> list[Path]:\n    80\t    \"\"\"Return Python files under applications/{task}/experiments for code validation.\"\"\"\n    81\t    apps_dir = root / ProjectDirs.APPLICATIONS\n    82\t    if not apps_dir.is_dir():\n    83\t        return []\n    84\t\n    85\t    paths: list[Path] = []\n    86\t    task_dirs = _app_dirs(apps_dir, task)\n    87\t    for app_dir in task_dirs:\n    88\t        exp_dir = app_dir / TaskDirs.EXPERIMENTS\n    89\t        if exp_dir.is_dir():\n    90\t            paths.extend(_collect_python_files(exp_dir))\n    91\t    return paths\n    92\t\n    93\t\n    94\tdef _experiments_paths(root: Path, task: str | None) -> list[Path]:\n    95\t    \"\"\"Return experiment directory paths for code and markdown validation.\"\"\"\n    96\t    apps_dir = root / ProjectDirs.APPLICATIONS\n    97\t    if not apps_dir.is_dir():\n    98\t        return []\n    99\t\n   100\t    paths: list[Path] = []\n   101\t    task_dirs = _app_dirs(apps_dir, task)\n   102\t    for app_dir in task_dirs:\n   103\t        exp_dir = app_dir / TaskDirs.EXPERIMENTS\n   104\t        if exp_dir.is_dir():\n   105\t            # Python files\n   106\t            paths.extend(_collect_python_files(exp_dir))\n   107\t            # Markdown files\n   108\t            paths.extend(_collect_markdown_files(exp_dir))\n   109\t    return paths\n   110\t\n   111\t\n   112\tdef _production_paths(root: Path, task: str | None) -> list[Path]:\n   113\t    \"\"\"Return production directory paths for validation.\"\"\"\n   114\t    apps_dir = root / ProjectDirs.APPLICATIONS\n   115\t    if not apps_dir.is_dir():\n   116\t        return []\n   117\t\n   118\t    paths: list[Path] = []\n   119\t    task_dirs = _app_dirs(apps_dir, task)\n   120\t    for app_dir in task_dirs:\n   121\t        prod_dir = app_dir / TaskDirs.PRODUCTION\n   122\t        if prod_dir.is_dir():\n   123\t            paths.extend(_collect_markdown_files(prod_dir))\n   124\t    return paths\n   125\t\n   126\t\n   127\tdef _collect_files(directory: Path, suffix: str) -> list[Path]:\n   128\t    \"\"\"Collect files with the given suffix under directory, excluding artifacts and cache.\n   129\t\n   130\t    Ignores:\n   131\t        - artifacts/ directories\n   132\t        - __pycache__/ directories\n   133\t        - Hidden files (starting with .)\n   134\t    \"\"\"\n   135\t    paths: list[Path] = []\n   136\t    for p in directory.rglob(f\"*{suffix}\"):\n   137\t        try:\n   138\t            relative_parts = p.relative_to(directory).parts\n   139\t            if any(part in {\"artifacts\", \"__pycache__\"} or part.startswith(\".\") for part in relative_parts):\n   140\t                continue\n   141\t        except ValueError:\n   142\t            pass\n   143\t        if p.is_file():\n   144\t            paths.append(p)\n   145\t    return paths\n   146\t\n   147\t\n   148\tdef _collect_python_files(directory: Path) -> list[Path]:\n   149\t    \"\"\"Collect Python files under directory, excluding artifacts and cache.\"\"\"\n   150\t    return _collect_files(directory, \".py\")\n   151\t\n   152\t\n   153\tdef _collect_markdown_files(directory: Path) -> list[Path]:\n   154\t    \"\"\"Collect markdown files under directory, excluding artifacts and hidden.\"\"\"\n   155\t    return _collect_files(directory, \".md\")\n   156\t\n   157\t\n   158\tdef _app_dirs(apps_dir: Path, task: str | None) -> list[Path]:\n   159\t    \"\"\"Return application directories, optionally filtered by task name.\"\"\"\n   160\t    if task:\n   161\t        if not _is_safe_task_name(task):\n   162\t            return []\n   163\t        candidate = apps_dir / task\n   164\t        try:\n   165\t            if candidate.resolve().parent != apps_dir.resolve():\n   166\t                return []\n   167\t        except OSError:\n   168\t            return []\n   169\t        return [candidate] if candidate.is_dir() else []\n   170\t    return sorted(d for d in apps_dir.iterdir() if d.is_dir())\n   171\t\n   172\t\n   173\tdef _is_safe_task_name(task: str) -> bool:\n   174\t    \"\"\"Return whether task names are direct, non-hidden application directory names.\"\"\"\n   175\t    if not task or task != task.strip() or task.startswith(\".\"):\n   176\t        return False\n   177\t\n   178\t    candidate = Path(task)\n   179\t    return not (\n   180\t        candidate.is_absolute() or \"/\" in task or \"\\\\\" in task or \".\" in candidate.parts or \"..\" in candidate.parts\n   181\t    )\n   182\t\n   183\t\n   184\t__all__ = [\"resolve_scope\"]\n","exit_code":0,"status":"completed"}}
