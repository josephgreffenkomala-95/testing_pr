pend(\n   547\t                f\"{ValidateStatus.FAIL} {task_name}/experiments: forecast review staircase passed mismatch\"\n   548\t            )\n   549\t            output_lines.append(\n   550\t                f\"  stored={review.staircase_check.passed}, recomputed={staircase_result.get('passed')}\"\n   551\t            )\n   552\t        if review.staircase_check.skipped != staircase_result.get(\"skipped\"):\n   553\t            any_failed = True\n   554\t            output_lines.append(\n   555\t                f\"{ValidateStatus.FAIL} {task_name}/experiments: forecast review staircase skipped mismatch\"\n   556\t            )\n   557\t            output_lines.append(\n   558\t                f\"  stored={review.staircase_check.skipped}, recomputed={staircase_result.get('skipped')}\"\n   559\t            )\n   560\t\n   561\t    return not any_failed, output_lines\n   562\t\n   563\t\n   564\tdef _numeric_mismatch(stored: float | None, computed: object) -> bool:\n   565\t    if stored is None or computed is None:\n   566\t        return stored is not computed\n   567\t    if not isinstance(computed, int | float):\n   568\t        return True\n   569\t    return abs(float(stored) - float(computed)) > _FORECAST_REVERIFY_TOLERANCE\n   570\t\n   571\t\n   572\tdef register(root: click.Group) -> None:\n   573\t    \"\"\"Register the validate command on the root Click group.\"\"\"\n   574\t\n   575\t    @root.command(\n   576\t        CommandNames.VALIDATE,\n   577\t        help=\"Validate project artifacts against their templates and security policies.\",\n   578\t    )\n   579\t    @click.argument(\"target\", type=_SCOPE_CHOICES, default=ValidateTargets.ALL.value)\n   580\t    @click.option(\n   581\t        CliOptionFlag.TASK,\n   582\t        \"task\",\n   583\t        default=None,\n   584\t        metavar=_METAVAR_NAME,\n   585\t        help=\"Restrict validation to a specific task.\",\n   586\t    )\n   587\t    @click.option(\n   588\t        CliOptionFlag.