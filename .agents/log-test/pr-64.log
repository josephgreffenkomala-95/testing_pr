{"type":"item.completed","item":{"id":"item_44","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/source/config.py | sed -n '1,220p'\"","aggregated_output":"     1\t\"\"\"Shared source configuration loading and connection helpers.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\tfrom pathlib import Path\n     6\tfrom typing import Any\n     7\t\n     8\timport click\n     9\timport yaml\n    10\tfrom pydantic import ValidationError\n    11\t\n    12\tfrom gl_tabular.cli.models.source import ConnectionsConfig, SourcePayload\n    13\tfrom gl_tabular.cli.utils.project_context import resolve_project_root\n    14\tfrom gl_tabular.cli.utils.source.connect import get_connection, resolve_credentials\n    15\tfrom gl_tabular.constant import LEGACY_SOURCE_FILE, FileNames, SourceMessages, SourceTypes\n    16\t\n    17\t\n    18\tdef missing_source_message(source_path: Path) -> str:\n    19\t    \"\"\"Return a user-facing message when source.yaml is unavailable.\"\"\"\n    20\t    legacy_path = source_path.with_name(LEGACY_SOURCE_FILE)\n    21\t    if legacy_path.exists():\n    22\t        return SourceMessages.LEGACY_SOURCE_FOUND.format(source_path=source_path, legacy_path=legacy_path.name)\n    23\t    return SourceMessages.NO_SOURCE_YAML.format(source_path=source_path)\n    24\t\n    25\t\n    26\tdef default_schema_name(source_cfg: SourcePayload) -> str:\n    27\t    \"\"\"Choose the default schema/database name for schema inspection.\"\"\"\n    28\t    if source_cfg.type == SourceTypes.MYSQL:\n    29\t        return source_cfg.database\n    30\t    return \"public\"\n    31\t\n    32\t\n    33\tdef load_source_config_or_empty(source_path: Path) -> ConnectionsConfig:\n    34\t    \"\"\"Load source.yaml, returning an empty config when the file is missing.\n    35\t\n    36\t    Used by the register command which creates source.yaml on first use.\n    37\t    \"\"\"\n    38\t    if not source_path.exists():\n    39\t        return ConnectionsConfig({})\n    40\t\n    41\t    try:\n    42\t        data = yaml.safe_load(source_path.read_text(encoding=\"utf-8\")) or {}\n    43\t    except yaml.YAMLError as exc:\n    44\t        raise click.ClickException(SourceMessages.FAILED_TO_PARSE.format(source_path=source_path, exc=exc)) from exc\n    45\t    except OSError as exc:\n    46\t        raise click.ClickException(SourceMessages.FAILED_TO_READ.format(source_path=source_path, exc=exc)) from exc\n    47\t\n    48\t    if not isinstance(data, dict):\n    49\t        raise click.ClickException(SourceMessages.MUST_BE_MAPPING.format(source_path=source_path))\n    50\t\n    51\t    try:\n    52\t        return ConnectionsConfig.model_validate(data)\n    53\t    except ValidationError as exc:\n    54\t        raise click.ClickException(SourceMessages.INVALID_CONFIG.format(source_path=source_path, exc=exc)) from exc\n    55\t\n    56\t\n    57\tdef load_source_config() -> ConnectionsConfig:\n    58\t    \"\"\"Load and validate source.yaml from the project root.\n    59\t\n    60\t    Raises:\n    61\t        click.ClickException: If the file is missing, unreadable, or invalid.\n    62\t    \"\"\"\n    63\t    project_root = resolve_project_root()\n    64\t    source_path = project_root / FileNames.SOURCE\n    65\t\n    66\t    if not source_path.exists():\n    67\t        raise click.ClickException(SourceMessages.NO_SOURCE_YAML.format(source_path=source_path))\n    68\t\n    69\t    try:\n    70\t        data = yaml.safe_load(source_path.read_text(encoding=\"utf-8\")) or {}\n    71\t    except yaml.YAMLError as exc:\n    72\t        raise click.ClickException(SourceMessages.FAILED_TO_PARSE.format(source_path=source_path, exc=exc)) from exc\n    73\t    except OSError as exc:\n    74\t        raise click.ClickException(SourceMessages.FAILED_TO_READ.format(source_path=source_path, exc=exc)) from exc\n    75\t\n    76\t    if not isinstance(data, dict):\n    77\t        raise click.ClickException(SourceMessages.MUST_BE_MAPPING.format(source_path=source_path))\n    78\t\n    79\t    try:\n    80\t        return ConnectionsConfig.model_validate(data)\n    81\t    except ValidationError as exc:\n    82\t        raise click.ClickException(SourceMessages.INVALID_CONFIG.format(source_path=source_path, exc=exc)) from exc\n    83\t\n    84\t\n    85\tdef get_source_entry(source_name: str) -> SourcePayload:\n    86\t    \"\"\"Look up a source entry by name from source.yaml.\n    87\t\n    88\t    Args:\n    89\t        source_name: Registered source alias.\n    90\t\n    91\t    Returns:\n    92\t        The validated SourcePayload for the given alias.\n    93\t\n    94\t    Raises:\n    95\t        click.ClickException: If the config is missing, invalid, or the alias is not found.\n    96\t    \"\"\"\n    97\t    config = load_source_config()\n    98\t\n    99\t    if not config.root:\n   100\t        raise click.ClickException(SourceMessages.NO_SOURCES_REGISTERED.format(source_path=\"<source.yaml>\"))\n   101\t\n   102\t    if source_name not in config.root:\n   103\t        available = list(config.root.keys())\n   104\t        raise click.ClickException(SourceMessages.SOURCE_NOT_FOUND.format(source_name=source_name, available=available))\n   105\t\n   106\t    return config.root[source_name]\n   107\t\n   108\t\n   109\tdef connect_source(source_name: str) -> Any:\n   110\t    \"\"\"Create a database connection for the named source.\n   111\t\n   112\t    Raises:\n   113\t        click.ClickException: If the source is a file/api type, not found, or connection fails.\n   114\t    \"\"\"\n   115\t    source_cfg = get_source_entry(source_name)\n   116\t    source_type = source_cfg.type\n   117\t\n   118\t    if source_type == SourceTypes.FILE:\n   119\t        raise click.ClickException(SourceMessages.SOURCE_IS_FILE.format(source_name=source_name))\n   120\t\n   121\t    if source_type == SourceTypes.API:\n   122\t        raise click.ClickException(SourceMessages.SOURCE_IS_API.format(source_name=source_name))\n   123\t\n   124\t    if source_type in {SourceTypes.BIGQUERY, SourceTypes.SNOWFLAKE}:\n   125\t        raise click.ClickException(SourceMessages.SOURCE_TYPE_UNSUPPORTED.format(source_type=source_type))\n   126\t\n   127\t    credentials = resolve_credentials(source_cfg)\n   128\t    try:\n   129\t        return get_connection(source_cfg, credentials)\n   130\t    except ImportError as exc:\n   131\t        raise click.ClickException(str(exc)) from exc\n   132\t\n   133\t\n   134\tdef get_source_type(source_name: str) -> str:\n   135\t    \"\"\"Get the type string of a registered source.\n   136\t\n   137\t    Args:\n   138\t        source_name: Registered source alias.\n   139\t\n   140\t    Returns:\n   141\t        Source type as a string (e.g. 'file', 'postgresql').\n   142\t    \"\"\"\n   143\t    return get_source_entry(source_name).type\n","exit_code":0,"status":"completed"}}
