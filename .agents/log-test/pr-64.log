42\t                \"username\": os.environ[source_cfg.env_user],\n    43\t                \"password\": os.environ[source_cfg.env_password],\n    44\t            }\n    45\t        except KeyError as exc:\n    46\t            raise click.ClickException(ConnectMessages.ENV_VAR_NOT_SET.format(var_name=exc.args[0])) from exc\n    47\t\n    48\t    return {}\n    49\t\n    50\t\n    51\tdef _require_client(module_name: str, source_type: str) -> Any:\n    52\t    \"\"\"Import an optional database client and raise a CLI-friendly error if missing.\"\"\"\n    53\t    try:\n    54\t        return importlib.import_module(module_name)\n    55\t    except ModuleNotFoundError as exc:\n    56\t        raise click.ClickException(\n    57\t            ConnectMessages.CLIENT_LIBRARY_MISSING.format(module_name=module_name, source_type=source_type)\n    58\t        ) from exc\n    59\t\n    60\t\n    61\tdef get_connection(source_cfg: SourcePayload, credentials: dict[str, str]) -> Any:\n    62\t    \"\"\"Create a live database connection for a source payload.\"\"\"\n    63\t    if isinstance(source_cfg, EmbeddedDatabaseSourcePayload):\n    64\t        if source_cfg.type == SourceTypes.SQLITE:\n    65\t            conn = sqlite3.connect(source_cfg.database, timeout=30)\n    66\t            conn.row_factory = sqlite3.Row\n    67\t            return conn\n    68\t\n    69\t        if source_cfg.type == SourceTypes.DUCKDB:\n    70\t            duckdb = _require_client(\"duckdb\", source_cfg.type)\n    71\t            return duckdb.connect(source_cfg.database)\n    72\t\n    73\t    if isinstance(source_cfg, DatabaseSourcePayload):\n    74\t        if source_cfg.type == SourceTypes.POSTGRESQL:\n    75\t            psycopg2 = _require_client(\"psycopg2\", source_cfg.type)\n    76\t            return psycopg2.connect(\n    77\t                host=source_cfg.host,\n    78\t                port=source_cfg.port,\n    79\t                dbname=source_cfg.database,\n    80\t                user=credentials[\"username\"],\n    81\t                password=credentials[\"password\"],\n    82\t            )\n    83\t\n    84\t        if source_cfg.type == SourceTypes.MYSQL:\n    85\t            pymysql = _require_client(\"pymysql\", source_cfg.type)\n    86\t            return pymysql.connect(\n    87\t                host=source_cfg.host,\n    88\t                port=source_cfg.port,\n    89\t                database=source_cfg.database,\n    90\t                user=credentials[\"username\"],\n    91\t                password=credentials[\"password\"],\n    92\t                connect_timeout=30,\n    93\t            )\n    94\t\n    95\t    raise click.ClickException(ConnectMessages.SOURCE_TYPE_UNSUPPORTED.format(source_type=source_cfg.type))\n","exit_code":0,"status":"completed"}}
