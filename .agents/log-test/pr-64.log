{"type":"item.completed","item":{"id":"item_41","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/data_access/masking.py | sed -n '1,260p'\"","aggregated_output":"     1\t\"\"\"Data masking using HMAC tokenization for PII protection.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\timport hashlib\n     6\timport hmac\n     7\timport re\n     8\tfrom dataclasses import dataclass, field\n     9\tfrom typing import Any\n    10\t\n    11\t\n    12\t@dataclass\n    13\tclass MaskingContext:\n    14\t    \"\"\"Context for data masking operations.\n    15\t\n    16\t    Attributes:\n    17\t        salt: Secret salt for HMAC tokenization.\n    18\t        enabled: Whether masking is enabled.\n    19\t        token_map: Mapping of generated tokens to original values for filter rewriting.\n    20\t    \"\"\"\n    21\t\n    22\t    salt: str\n    23\t    enabled: bool = True\n    24\t    token_map: dict[str, str] = field(default_factory=dict)\n    25\t\n    26\t\n    27\tdef detect_string_columns(columns: list[str], rows: list[tuple[Any, ...]]) -> list[str]:\n    28\t    \"\"\"Identify which columns contain string or categorical data.\n    29\t\n    30\t    Args:\n    31\t        columns: List of column names.\n    32\t        rows: List of row tuples containing the data.\n    33\t\n    34\t    Returns:\n    35\t        List of column names that contain string data.\n    36\t    \"\"\"\n    37\t    if not rows:\n    38\t        return []\n    39\t\n    40\t    string_cols = []\n    41\t    for col_index, col_name in enumerate(columns):\n    42\t        # Check if any non-null value in this column is a string\n    43\t        is_string = False\n    44\t        for row in rows:\n    45\t            value = row[col_index]\n    46\t            if value is not None:\n    47\t                if isinstance(value, str):\n    48\t                    is_string = True\n    49\t                    break\n    50\t                # Don't consider bool, int, float as strings\n    51\t                if isinstance(value, (bool, int, float)):\n    52\t                    break\n    53\t        if is_string:\n    54\t            string_cols.append(col_name)\n    55\t\n    56\t    return string_cols\n    57\t\n    58\t\n    59\tdef mask_rows(\n    60\t    rows: list[tuple[Any, ...]],\n    61\t    columns: list[str],\n    62\t    string_cols: list[str],\n    63\t    masking_ctx: MaskingContext,\n    64\t) -> tuple[list[tuple[Any, ...]], MaskingContext]:\n    65\t    \"\"\"Apply HMAC tokenization to string columns in rows.\n    66\t\n    67\t    Args:\n    68\t        rows: List of row tuples to mask.\n    69\t        columns: List of column names.\n    70\t        string_cols: List of column names that contain string data.\n    71\t        masking_ctx: MaskingContext with salt and token map.\n    72\t\n    73\t    Returns:\n    74\t        Tuple of (masked rows, updated MaskingContext with token map).\n    75\t    \"\"\"\n    76\t    if not masking_ctx.enabled or not string_cols:\n    77\t        return rows, masking_ctx\n    78\t\n    79\t    masked_rows = []\n    80\t    string_col_indices = {i for i, col in enumerate(columns) if col in string_cols}\n    81\t\n    82\t    for row in rows:\n    83\t        masked_row = list(row)\n    84\t        for col_index in string_col_indices:\n    85\t            value = masked_row[col_index]\n    86\t            if value is not None and isinstance(value, str):\n    87\t                # Generate deterministic token using HMAC\n    88\t                token = _hmac_token(value, masking_ctx.salt)\n    89\t                masked_row[col_index] = token\n    90\t                # Store mapping for filter rewriting\n    91\t                masking_ctx.token_map[token] = value\n    92\t        masked_rows.append(tuple(masked_row))\n    93\t\n    94\t    return masked_rows, masking_ctx\n    95\t\n    96\t\n    97\tdef _hmac_token(value: str, salt: str) -> str:\n    98\t    \"\"\"Generate deterministic HMAC token for a value.\n    99\t\n   100\t    Args:\n   101\t        value: String value to tokenize.\n   102\t        salt: Secret salt for HMAC.\n   103\t\n   104\t    Returns:\n   105\t        Hexadecimal HMAC token.\n   106\t    \"\"\"\n   107\t    return hmac.new(salt.encode(), value.encode(), hashlib.sha256).hexdigest()[:16]\n   108\t\n   109\t\n   110\t# Query patterns that are schema/metadata queries and should not be masked\n   111\t_SCHEMA_QUERY_PATTERNS = [\n   112\t    re.compile(r\"\\binformation_schema\\.\", re.IGNORECASE),\n   113\t    re.compile(r\"\\bPRAGMA\\s+\", re.IGNORECASE),\n   114\t    re.compile(r\"\\bDESCRIBE\\s+\", re.IGNORECASE),\n   115\t    re.compile(r\"\\bDESC\\s+\", re.IGNORECASE),\n   116\t    re.compile(r\"\\bSHOW\\s+(COLUMNS|TABLES|SCHEMAS|DATABASES|CREATE TABLE)\", re.IGNORECASE),\n   117\t    re.compile(r\"\\bEXPLAIN\\s+\", re.IGNORECASE),\n   118\t    re.compile(r\"\\bsqlite_master\\b\", re.IGNORECASE),\n   119\t    re.compile(r\"\\bpg_catalog\\.\", re.IGNORECASE),\n   120\t    re.compile(r\"\\bsys\\.\", re.IGNORECASE),  # MySQL sys schema\n   121\t]\n   122\t\n   123\t\n   124\tdef is_schema_query(sql: str) -> bool:\n   125\t    \"\"\"Return True if the SQL query is a schema/metadata inspection query.\n   126\t\n   127\t    Schema queries should not have their results masked because the\n   128\t    column names and metadata are essential for exploration.\n   129\t\n   130\t    Args:\n   131\t        sql: SQL query string.\n   132\t\n   133\t    Returns:\n   134\t        True if the query is a schema query, False otherwise.\n   135\t    \"\"\"\n   136\t    return any(pattern.search(sql) for pattern in _SCHEMA_QUERY_PATTERNS)\n   137\t\n   138\t\n   139\tdef rewrite_filter(sql: str, masking_ctx: MaskingContext) -> str:\n   140\t    \"\"\"Rewrite SQL query by replacing tokens with original values.\n   141\t\n   142\t    This enables filter clauses to work with original values after\n   143\t    data has been masked.\n   144\t\n   145\t    Args:\n   146\t        sql: SQL query string that may contain masked tokens.\n   147\t        masking_ctx: MaskingContext containing token-to-original mapping.\n   148\t\n   149\t    Returns:\n   150\t        SQL query string with tokens replaced by original values.\n   151\t    \"\"\"\n   152\t    if not masking_ctx.enabled or not masking_ctx.token_map:\n   153\t        return sql\n   154\t\n   155\t    rewritten = sql\n   156\t    for token, original in masking_ctx.token_map.items():\n   157\t        escaped = original.replace(\"'\", \"''\")\n   158\t        quoted_original = f\"'{escaped}'\"\n   159\t        rewritten = rewritten.replace(f\"'{token}'\", quoted_original)\n   160\t        rewritten = rewritten.replace(f'\"{token}\"', quoted_original)\n   161\t\n   162\t    return rewritten\n","exit_code":0,"status":"completed"}}
