{"type":"item.completed","item":{"id":"item_27","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/experiment/artifact_validation.py | sed -n '1,320p'\"","aggregated_output":"     1\t\"\"\"Deterministic validators for canonical experiment JSON artifacts.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\timport json\n     6\tfrom pathlib import Path\n     7\tfrom typing import Any\n     8\t\n     9\tfrom pydantic import BaseModel, ValidationError\n    10\t\n    11\tfrom gl_tabular.cli.utils.experiment.artifact_schemas import (\n    12\t    EvaluationSchema,\n    13\t    ForecastReviewSchema,\n    14\t    LeakageGuardPostSchema,\n    15\t    LeakageGuardPreSchema,\n    16\t)\n    17\tfrom gl_tabular.cli.utils.experiment.policy import is_valid_run_id\n    18\tfrom gl_tabular.cli.utils.experiment.routing import (\n    19\t    route_after_evaluator,\n    20\t    route_after_forecast_review,\n    21\t    route_after_leakage_guard_post,\n    22\t    route_after_leakage_guard_post_pass,\n    23\t)\n    24\t\n    25\t\n    26\tdef validate_known_artifacts(artifacts_dir: Path, *, task_type: str | None = None) -> tuple[bool, list[str]]:\n    27\t    \"\"\"Validate canonical experiment artifacts that are present on disk.\"\"\"\n    28\t    if not artifacts_dir.exists():\n    29\t        return True, []\n    30\t\n    31\t    validators = (\n    32\t        (\"forecast_review.json\", lambda path: validate_forecast_review_json(path)),\n    33\t        (\"leakage_guard_pre.json\", lambda path: validate_leakage_guard_pre_json(path)),\n    34\t        (\"leakage_guard_post.json\", lambda path: validate_leakage_guard_post_json(path, task_type=task_type)),\n    35\t        (\"evaluation.json\", lambda path: validate_evaluation_json(path, task_type=task_type)),\n    36\t    )\n    37\t\n    38\t    passed = True\n    39\t    lines: list[str] = []\n    40\t    for filename, validator in validators:\n    41\t        path = artifacts_dir / filename\n    42\t        if not path.exists():\n    43\t            continue\n    44\t        ok, errors = validator(path)\n    45\t        if ok:\n    46\t            lines.append(f\"Check: artifacts/{filename} schema - PASS\")\n    47\t            continue\n    48\t        passed = False\n    49\t        lines.append(f\"Check: artifacts/{filename} schema - FAIL\")\n    50\t        lines.extend(f\"  {error}\" for error in errors)\n    51\t    return passed, lines\n    52\t\n    53\t\n    54\tdef validate_forecast_review_json(path: Path) -> tuple[bool, list[str]]:\n    55\t    \"\"\"Validate forecast_review.json structure and routing.\"\"\"\n    56\t    data, errors = _load_json_object(path, \"forecast_review.json\")\n    57\t    if data is None:\n    58\t        return False, errors\n    59\t\n    60\t    errors.extend(_require_filename(path, \"forecast_review.json\"))\n    61\t    schema = _validate_schema(ForecastReviewSchema, data, \"forecast_review.json\", errors)\n    62\t    if schema is not None:\n    63\t        errors.extend(_require_run_id(schema.iteration_id, \"iteration_id\"))\n    64\t        expected_next = route_after_forecast_review(schema.verdict.value)\n    65\t        if schema.recommended_next.value != expected_next:\n    66\t            errors.append(\n    67\t                \"recommended_next must match canonical route: \"\n    68\t                f\"stored={schema.recommended_next.value!r}, expected={expected_next!r}\"\n    69\t            )\n    70\t\n    71\t    return (not errors), errors\n    72\t\n    73\t\n    74\tdef validate_leakage_guard_pre_json(path: Path) -> tuple[bool, list[str]]:\n    75\t    \"\"\"Validate leakage_guard_pre.json structure.\"\"\"\n    76\t    data, errors = _load_json_object(path, \"leakage_guard_pre.json\")\n    77\t    if data is None:\n    78\t        return False, errors\n    79\t\n    80\t    errors.extend(_require_filename(path, \"leakage_guard_pre.json\"))\n    81\t    schema = _validate_schema(LeakageGuardPreSchema, data, \"leakage_guard_pre.json\", errors)\n    82\t    if schema is not None:\n    83\t        errors.extend(_require_run_id(schema.iteration_id, \"iteration_id\"))\n    84\t    return (not errors), errors\n    85\t\n    86\t\n    87\tdef validate_leakage_guard_post_json(path: Path, *, task_type: str | None = None) -> tuple[bool, list[str]]:\n    88\t    \"\"\"Validate leakage_guard_post.json structure and routing consistency.\"\"\"\n    89\t    data, errors = _load_json_object(path, \"leakage_guard_post.json\")\n    90\t    if data is None:\n    91\t        return False, errors\n    92\t\n    93\t    errors.extend(_require_filename(path, \"leakage_guard_post.json\"))\n    94\t    schema = _validate_schema(LeakageGuardPostSchema, data, \"leakage_guard_post.json\", errors)\n    95\t    if schema is not None:\n    96\t        errors.extend(_require_run_id(schema.iteration_id, \"iteration_id\"))\n    97\t        if schema.verdict.value == \"fail\":\n    98\t            expected_next = route_after_leakage_guard_post(schema.fail_conditions)\n    99\t            if schema.recommended_next.value != expected_next:\n   100\t                errors.append(\n   101\t                    \"recommended_next must match canonical route: \"\n   102\t                    f\"stored={schema.recommended_next.value!r}, expected={expected_next!r}\"\n   103\t                )\n   104\t        elif task_type is None:\n   105\t            errors.append(\"task_type is required to validate leakage_guard_post.json pass routing\")\n   106\t        else:\n   107\t            expected_next = route_after_leakage_guard_post_pass(task_type)\n   108\t            if schema.recommended_next.value != expected_next:\n   109\t                errors.append(\n   110\t                    \"recommended_next must match canonical route: \"\n   111\t                    f\"stored={schema.recommended_next.value!r}, expected={expected_next!r}\"\n   112\t                )\n   113\t    return (not errors), errors\n   114\t\n   115\t\n   116\tdef validate_evaluation_json(path: Path, *, task_type: str | None = None) -> tuple[bool, list[str]]:\n   117\t    \"\"\"Validate evaluation.json structure and routing.\"\"\"\n   118\t    data, errors = _load_json_object(path, \"evaluation.json\")\n   119\t    if data is None:\n   120\t        return False, errors\n   121\t\n   122\t    errors.extend(_require_filename(path, \"evaluation.json\"))\n   123\t    schema = _validate_schema(EvaluationSchema, data, \"evaluation.json\", errors)\n   124\t    if schema is not None:\n   125\t        has_forecast_parity_fields = all(\n   126\t            value is not None\n   127\t            for value in (\n   128\t                schema.reported_mape,\n   129\t                schema.honest_recursive_mape,\n   130\t                schema.mape_delta,\n   131\t                schema.recursive_parity_check,\n   132\t            )\n   133\t        )\n   134\t        if task_type == \"time_series\" or has_forecast_parity_fields:\n   135\t            errors.extend(_require_non_null(schema.reported_mape, \"reported_mape\"))\n   136\t            errors.extend(_require_non_null(schema.honest_recursive_mape, \"honest_recursive_mape\"))\n   137\t            errors.extend(_require_non_null(schema.mape_delta, \"mape_delta\"))\n   138\t            errors.extend(_require_non_null(schema.recursive_parity_check, \"recursive_parity_check\"))\n   139\t        if task_type is None:\n   140\t            errors.append(\"task_type is required to validate evaluation.json routing\")\n   141\t        else:\n   142\t            expected_next = route_after_evaluator(schema.verdict.value, task_type, schema.fail_reason)\n   143\t            if schema.recommended_next.value != expected_next:\n   144\t                errors.append(\n   145\t                    \"recommended_next must match canonical route: \"\n   146\t                    f\"stored={schema.recommended_next.value!r}, expected={expected_next!r}\"\n   147\t                )\n   148\t    return (not errors), errors\n   149\t\n   150\t\n   151\tdef _load_json_object(path: Path, expected_filename: str) -> tuple[dict[str, Any] | None, list[str]]:\n   152\t    try:\n   153\t        data = json.loads(path.read_text(encoding=\"utf-8\"))\n   154\t    except (OSError, UnicodeDecodeError, json.JSONDecodeError) as exc:\n   155\t        return None, [f\"{expected_filename}: could not be parsed as JSON ({exc})\"]\n   156\t\n   157\t    if not isinstance(data, dict):\n   158\t        return None, [f\"{expected_filename}: top-level JSON value must be an object\"]\n   159\t    return data, []\n   160\t\n   161\t\n   162\tdef _validate_schema(\n   163\t    schema_type: type[BaseModel],\n   164\t    data: dict[str, Any],\n   165\t    filename: str,\n   166\t    errors: list[str],\n   167\t) -> BaseModel | None:\n   168\t    try:\n   169\t        return schema_type.model_validate(data)\n   170\t    except ValidationError as exc:\n   171\t        errors.extend(_format_pydantic_errors(filename, exc))\n   172\t        return None\n   173\t\n   174\t\n   175\tdef _format_pydantic_errors(filename: str, exc: ValidationError) -> list[str]:\n   176\t    lines: list[str] = []\n   177\t    for error in exc.errors():\n   178\t        loc = \".\".join(str(part) for part in error[\"loc\"])\n   179\t        message = error[\"msg\"]\n   180\t        field = loc or \"<root>\"\n   181\t        lines.append(f\"{filename}: {field}: {message}\")\n   182\t    return lines\n   183\t\n   184\t\n   185\tdef _require_filename(path: Path, expected_filename: str) -> list[str]:\n   186\t    if path.name == expected_filename:\n   187\t        return []\n   188\t    return [f\"expected filename {expected_filename}, found {path.name}\"]\n   189\t\n   190\t\n   191\tdef _require_run_id(value: Any, field_name: str) -> list[str]:\n   192\t    if isinstance(value, str) and is_valid_run_id(value):\n   193\t        return []\n   194\t    return [f\"{field_name} must use canonical format run-001\"]\n   195\t\n   196\t\n   197\tdef _require_non_null(value: Any, field_name: str) -> list[str]:\n   198\t    if value is not None:\n   199\t        return []\n   200\t    return [f\"{field_name} must not be null\"]\n","exit_code":0,"status":"completed"}}
