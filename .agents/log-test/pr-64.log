{"type":"item.completed","item":{"id":"item_33","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/experiment/stage.py | sed -n '1,320p'\"","aggregated_output":"     1\t\"\"\"Stage metadata and helpers for experiment workflow.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\timport shutil\n     6\tfrom dataclasses import dataclass\n     7\tfrom importlib import resources\n     8\tfrom pathlib import Path\n     9\t\n    10\tfrom gl_tabular.constant import ExperimentStatus, ProjectDirs, TaskDirs\n    11\t\n    12\t_PACKAGE_ROOT = Path(__file__).resolve().parent.parent.parent.parent\n    13\t\n    14\t\n    15\tdef _get_template_path(relative_path: str) -> Path:\n    16\t    \"\"\"Get canonical package-relative path to a stage template.\n    17\t\n    18\t    Args:\n    19\t        relative_path: Path relative to package root.\n    20\t\n    21\t    Returns:\n    22\t        Package-relative Path to template.\n    23\t\n    24\t    Raises:\n    25\t        FileNotFoundError: If template does not exist in installed package.\n    26\t    \"\"\"\n    27\t    try:\n    28\t        ref = resources.files(\"gl_tabular\").joinpath(relative_path)\n    29\t    except (ModuleNotFoundError, TypeError) as exc:\n    30\t        raise FileNotFoundError(\n    31\t            f\"Cannot resolve template path: {relative_path}. \" \"Ensure gl_tabular is installed correctly.\"\n    32\t        ) from exc\n    33\t    if not ref.is_file():\n    34\t        raise FileNotFoundError(\n    35\t            f\"Template not found: {relative_path}. Ensure gl_tabular is installed with template data.\"\n    36\t        )\n    37\t    return Path(relative_path)\n    38\t\n    39\t\n    40\tdef skill_path_for(stage_name: str) -> str:\n    41\t    \"\"\"Resolve skill SKILL.md path relative to the packaged templates directory.\n    42\t\n    43\t    Args:\n    44\t        stage_name: Stage name (e.g. 'data-explorer').\n    45\t\n    46\t    Returns:\n    47\t        Relative path string like 'templates/skills/data-explorer/SKILL.md'.\n    48\t    \"\"\"\n    49\t    return f\"templates/skills/{stage_name}/SKILL.md\"\n    50\t\n    51\t\n    52\t@dataclass\n    53\tclass FunctionInterface:\n    54\t    \"\"\"Required function interface definition.\n    55\t\n    56\t    Type hint validation is explicitly out-of-scope: only parameter names\n    57\t    and their order are checked. Return type annotations are not validated.\n    58\t    \"\"\"\n    59\t\n    60\t    name: str\n    61\t    parameters: tuple[str, ...]\n    62\t\n    63\t\n    64\t@dataclass\n    65\tclass StageMetadata:\n    66\t    \"\"\"Metadata for a single experiment stage.\"\"\"\n    67\t\n    68\t    name: str\n    69\t    script_name: str | None\n    70\t    template_path: Path | None\n    71\t    writable_memory_files: list[str]\n    72\t    expected_artifacts: list[str]\n    73\t    output_checklist: list[str]\n    74\t    skill_path: str\n    75\t    references: list[str]\n    76\t    required_interfaces: tuple[FunctionInterface, ...]\n    77\t\n    78\t\n    79\tITERATION_RESET_STAGES = (\n    80\t    \"data-explorer\",\n    81\t    \"data-cleaner\",\n    82\t    \"data-analysis\",\n    83\t    \"feature-engineer\",\n    84\t    \"modeling\",\n    85\t)\n    86\t\n    87\tSTALE_ITERATION_SECTIONS = (\n    88\t    \"Hypothesis\",\n    89\t    \"Active Challenger\",\n    90\t    \"Latest Run Result\",\n    91\t    \"Decision\",\n    92\t    \"Completed This Session\",\n    93\t    \"Pending Work\",\n    94\t    \"Next Actions\",\n    95\t    \"Blockers\",\n    96\t)\n    97\t\n    98\t\n    99\tSTAGE_ORDER: tuple[str, ...] = (\n   100\t    \"bootstrap\",\n   101\t    \"data-explorer\",\n   102\t    \"data-cleaner\",\n   103\t    \"data-analysis\",\n   104\t    \"feature-engineer\",\n   105\t    \"modeling\",\n   106\t    \"evaluator\",\n   107\t    \"experiment-review\",\n   108\t)\n   109\t\n   110\tSTAGE_METADATA: dict[str, StageMetadata] = {\n   111\t    \"bootstrap\": StageMetadata(\n   112\t        name=\"bootstrap\",\n   113\t        script_name=None,\n   114\t        template_path=None,\n   115\t        writable_memory_files=[\n   116\t            \"MEMORY.md\",\n   117\t            \"data_schema.md\",\n   118\t            \"data_exploration.md\",\n   119\t            \"features.md\",\n   120\t            \"current.md\",\n   121\t            \"runs.md\",\n   122\t        ],\n   123\t        expected_artifacts=[],\n   124\t        output_checklist=[\"Memory structure initialized\", \"Task context documented\"],\n   125\t        skill_path=skill_path_for(\"bootstrap\"),\n   126\t        references=[\"AGENTS.md\", \"memory/bootstrap/current.md\"],\n   127\t        required_interfaces=(),\n   128\t    ),\n   129\t    \"data-explorer\": StageMetadata(\n   130\t        name=\"data-explorer\",\n   131\t        script_name=\"explore.py\",\n   132\t        template_path=_get_template_path(\"templates/codes/explore.py\"),\n   133\t        writable_memory_files=[\"data_schema.md\", \"data_exploration.md\", \"current.md\"],\n   134\t        expected_artifacts=[],\n   135\t        output_checklist=[\"Data profile generated\", \"Exploration notes written\"],\n   136\t        skill_path=skill_path_for(\"data-explorer\"),\n   137\t        references=[\"data_access.md\", \"exploration_checklist.md\"],\n   138\t        required_interfaces=(FunctionInterface(name=\"explore\", parameters=(\"df\",)),),\n   139\t    ),\n   140\t    \"data-cleaner\": StageMetadata(\n   141\t        name=\"data-cleaner\",\n   142\t        script_name=\"clean.py\",\n   143\t        template_path=_get_template_path(\"templates/codes/clean.py\"),\n   144\t        writable_memory_files=[\"data_exploration.md\", \"current.md\"],\n   145\t        expected_artifacts=[],\n   146\t        output_checklist=[\"Cleaning script executed\", \"Cleaned data written\"],\n   147\t        skill_path=skill_path_for(\"data-cleaner\"),\n   148\t        references=[\"data_quality.md\", \"cleaning_patterns.md\"],\n   149\t        required_interfaces=(FunctionInterface(name=\"clean\", parameters=(\"df\",)),),\n   150\t    ),\n   151\t    \"data-analysis\": StageMetadata(\n   152\t        name=\"data-analysis\",\n   153\t        script_name=\"analyze.py\",\n   154\t        template_path=_get_template_path(\"templates/codes/analyze.py\"),\n   155\t        writable_memory_files=[\"data_exploration.md\", \"current.md\"],\n   156\t        expected_artifacts=[],\n   157\t        output_checklist=[\"Analysis script executed\", \"Findings documented\"],\n   158\t        skill_path=skill_path_for(\"data-analysis\"),\n   159\t        references=[\"statistical_tests.md\", \"visualization_guide.md\"],\n   160\t        required_interfaces=(\n   161\t            FunctionInterface(\n   162\t                name=\"analyze\",\n   163\t                parameters=(\"source_name\", \"output_dir\", \"focus\", \"row_limit\"),\n   164\t            ),\n   165\t        ),\n   166\t    ),\n   167\t    \"feature-engineer\": StageMetadata(\n   168\t        name=\"feature-engineer\",\n   169\t        script_name=\"features.py\",\n   170\t        template_path=_get_template_path(\"templates/codes/features.py\"),\n   171\t        writable_memory_files=[\"features.md\", \"current.md\"],\n   172\t        expected_artifacts=[],\n   173\t        output_checklist=[\"Feature script executed\", \"Features written\"],\n   174\t        skill_path=skill_path_for(\"feature-engineer\"),\n   175\t        references=[\"feature_engineering.md\", \"leakage_prevention.md\"],\n   176\t        required_interfaces=(\n   177\t            FunctionInterface(\n   178\t                name=\"create_features\",\n   179\t                parameters=(\"data\", \"target_column\", \"task_type\"),\n   180\t            ),\n   181\t        ),\n   182\t    ),\n   183\t    \"modeling\": StageMetadata(\n   184\t        name=\"modeling\",\n   185\t        script_name=\"train.py\",\n   186\t        template_path=_get_template_path(\"templates/codes/modelling.py\"),\n   187\t        writable_memory_files=[\"current.md\"],\n   188\t        expected_artifacts=[\"metrics.json\"],\n   189\t        output_checklist=[\"Models trained\", \"Metrics captured\"],\n   190\t        skill_path=skill_path_for(\"modeling\"),\n   191\t        references=[\"model_selection.md\", \"cross_validation.md\"],\n   192\t        required_interfaces=(\n   193\t            FunctionInterface(name=\"split\", parameters=(\"data\", \"target_column\")),\n   194\t            FunctionInterface(name=\"train\", parameters=(\"data\", \"target_column\", \"model_path\")),\n   195\t            FunctionInterface(name=\"predict\", parameters=(\"data\", \"target_column\", \"model_path\")),\n   196\t        ),\n   197\t    ),\n   198\t    \"evaluator\": StageMetadata(\n   199\t        name=\"evaluator\",\n   200\t        script_name=\"evaluate.py\",\n   201\t        template_path=_get_template_path(\"templates/codes/evaluate.py\"),\n   202\t        writable_memory_files=[\"current.md\"],\n   203\t        expected_artifacts=[\"evaluation.json\"],\n   204\t        output_checklist=[\"Evaluation script executed\", \"Results documented\"],\n   205\t        skill_path=skill_path_for(\"evaluator\"),\n   206\t        references=[\"evaluation_metrics.md\", \"model_validation.md\"],\n   207\t        required_interfaces=(\n   208\t            FunctionInterface(\n   209\t                name=\"evaluate\",\n   210\t                parameters=(\"data\", \"metrics\", \"predictions\", \"target_column\"),\n   211\t            ),\n   212\t        ),\n   213\t    ),\n   214\t    \"experiment-review\": StageMetadata(\n   215\t        name=\"experiment-review\",\n   216\t        script_name=None,\n   217\t        template_path=None,\n   218\t        writable_memory_files=[\"current.md\", \"runs.md\", \"runs/{run_id}.md\"],\n   219\t        expected_artifacts=[],\n   220\t        output_checklist=[\"Review completed\", \"Decision recorded\"],\n   221\t        skill_path=skill_path_for(\"experiment-review\"),\n   222\t        references=[\"experiment_review.md\", \"deployment_checklist.md\"],\n   223\t        required_interfaces=(),\n   224\t    ),\n   225\t}\n   226\t\n   227\t\n   228\tdef validate_stage(stage: str) -> bool:\n   229\t    \"\"\"Check if stage name is valid.\n   230\t\n   231\t    Args:\n   232\t        stage: Stage name to validate.\n   233\t\n   234\t    Returns:\n   235\t        True if stage exists in workflow.\n   236\t    \"\"\"\n   237\t    return stage in STAGE_METADATA\n   238\t\n   239\t\n   240\tdef get_stage(stage: str) -> StageMetadata:\n   241\t    \"\"\"Get metadata for a stage.\n   242\t\n   243\t    Args:\n   244\t        stage: Stage name.\n   245\t\n   246\t    Returns:\n   247\t        StageMetadata for the stage.\n   248\t\n   249\t    Raises:\n   250\t        ValueError: If stage doesn't exist.\n   251\t    \"\"\"\n   252\t    if not validate_stage(stage):\n   253\t        raise ValueError(f\"Invalid stage: {stage}\")\n   254\t    return STAGE_METADATA[stage]\n   255\t\n   256\t\n   257\tdef resolve_current_stage(current_status: str | None, current_stage: str | None, completed: set[str]) -> str | None:\n   258\t    \"\"\"Determine the current stage from memory state and completed set.\"\"\"\n   259\t    if current_status == ExperimentStatus.BLOCKED and current_stage:\n   260\t        return current_stage\n   261\t    return first_incomplete(completed)\n   262\t\n   263\t\n   264\tdef first_incomplete(completed: set[str]) -> str | None:\n   265\t    \"\"\"Find first incomplete stage.\n   266\t\n   267\t    Args:\n   268\t        completed: Set of completed stage names.\n   269\t\n   270\t    Returns:\n   271\t        First stage not in completed, or None if all complete.\n   272\t    \"\"\"\n   273\t    for stage in STAGE_ORDER:\n   274\t        if stage not in completed:\n   275\t            return stage\n   276\t    return None\n   277\t\n   278\t\n   279\tdef validation_command(task: str) -> str:\n   280\t    \"\"\"Get the validation command for a task.\n   281\t\n   282\t    Args:\n   283\t        task: Task name.\n   284\t\n   285\t    Returns:\n   286\t        Validation command string.\n   287\t    \"\"\"\n   288\t    return f'uv run gl-tabular validate experiments --task \"{task}\"'\n   289\t\n   290\t\n   291\tdef assigned_script_path(root: Path, task: str, stage: str) -> Path | None:\n   292\t    \"\"\"Get path to assigned script for a stage.\n   293\t\n   294\t    Args:\n   295\t        root: Project root.\n   296\t        task: Task name.\n   297\t        stage: Stage name.\n   298\t\n   299\t    Returns:\n   300\t        Path to script or None if stage has no script.\n   301\t    \"\"\"\n   302\t    meta = get_stage(stage)\n   303\t    if meta.script_name is None:\n   304\t        return None\n   305\t    return root / ProjectDirs.APPLICATIONS / task / TaskDirs.EXPERIMENTS / meta.script_name\n   306\t\n   307\t\n   308\tdef template_path(stage: str) -> Path | None:\n   309\t    \"\"\"Get package-relative template path for a stage.\n   310\t\n   311\t    Args:\n   312\t        stage: Stage name.\n   313\t\n   314\t    Returns:\n   315\t        Path to template file or None.\n   316\t    \"\"\"\n   317\t    meta = get_stage(stage)\n   318\t    return meta.template_path\n   319\t\n   320\t\n","exit_code":0,"status":"completed"}}
