{"type":"item.completed","item":{"id":"item_40","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/data_access/file_reader.py | sed -n '1,260p'\"","aggregated_output":"     1\t\"\"\"Secure file I/O with path validation and row limits.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\tfrom pathlib import Path\n     6\tfrom typing import Any\n     7\t\n     8\timport pandas as pd\n     9\t\n    10\t\n    11\tdef _validate_row_limit(row_limit: int) -> None:\n    12\t    \"\"\"Validate that row limits are positive.\"\"\"\n    13\t    if row_limit < 1:\n    14\t        raise ValueError(\"row_limit must be at least 1\")\n    15\t\n    16\t\n    17\tdef validate_path(file_path: Path, allowlist: list[Path]) -> Path:\n    18\t    \"\"\"Validate that a file path is within the allowed directories.\n    19\t\n    20\t    Args:\n    21\t        file_path: Path to the file to validate.\n    22\t        allowlist: List of allowed directory paths.\n    23\t\n    24\t    Returns:\n    25\t        The resolved absolute path if valid.\n    26\t\n    27\t    Raises:\n    28\t        PermissionError: If the path is outside the allowlist.\n    29\t        FileNotFoundError: If the file does not exist.\n    30\t    \"\"\"\n    31\t    # Resolve to absolute path\n    32\t    abs_path = file_path.resolve()\n    33\t\n    34\t    # Check if file exists\n    35\t    if not abs_path.exists():\n    36\t        raise FileNotFoundError(f\"File not found: {abs_path}\")\n    37\t\n    38\t    # Check if path is within any allowed directory\n    39\t    for allowed_dir in allowlist:\n    40\t        allowed_abs = allowed_dir.resolve()\n    41\t        try:\n    42\t            abs_path.relative_to(allowed_abs)\n    43\t            return abs_path\n    44\t        except ValueError:\n    45\t            continue\n    46\t\n    47\t    raise PermissionError(f\"Path outside allowlist: {abs_path}\")\n    48\t\n    49\t\n    50\t# Allowed file extensions for secure file access\n    51\t_ALLOWED_EXTENSIONS = {\".csv\", \".parquet\", \".json\"}\n    52\t\n    53\t\n    54\tdef validate_extension(filename: str) -> str:\n    55\t    \"\"\"Validate that a file has an allowed extension.\n    56\t\n    57\t    Args:\n    58\t        filename: Name of the file to validate.\n    59\t\n    60\t    Returns:\n    61\t        The extension without the leading dot (e.g., \"csv\", \"parquet\").\n    62\t\n    63\t    Raises:\n    64\t        ValueError: If the file extension is not allowed.\n    65\t    \"\"\"\n    66\t    suffix = Path(filename).suffix.lower()\n    67\t    if suffix not in _ALLOWED_EXTENSIONS:\n    68\t        raise ValueError(f\"Disallowed file extension: {suffix}\")\n    69\t\n    70\t    return suffix[1:]  # Remove the leading dot\n    71\t\n    72\t\n    73\tdef read_csv_safe(\n    74\t    file_path: Path,\n    75\t    allowlist: list[Path],\n    76\t    row_limit: int = 200,\n    77\t    **kwargs: Any,\n    78\t) -> pd.DataFrame:\n    79\t    \"\"\"Read a CSV file with path validation and row limits.\n    80\t\n    81\t    Args:\n    82\t        file_path: Path to the CSV file.\n    83\t        allowlist: List of allowed directory paths.\n    84\t        row_limit: Maximum number of rows to read.\n    85\t        **kwargs: Additional arguments to pass to pd.read_csv.\n    86\t\n    87\t    Returns:\n    88\t        DataFrame with the CSV data, limited to row_limit rows.\n    89\t\n    90\t    Raises:\n    91\t        PermissionError: If the path is outside the allowlist.\n    92\t        FileNotFoundError: If the file does not exist.\n    93\t    \"\"\"\n    94\t    _validate_row_limit(row_limit)\n    95\t\n    96\t    # Validate path\n    97\t    validated_path = validate_path(file_path, allowlist)\n    98\t\n    99\t    # Validate extension\n   100\t    validate_extension(validated_path.name)\n   101\t\n   102\t    # Read CSV with row limit\n   103\t    df = pd.read_csv(validated_path, nrows=row_limit, **kwargs)\n   104\t\n   105\t    return df\n   106\t\n   107\t\n   108\tdef read_parquet_safe(\n   109\t    file_path: Path,\n   110\t    allowlist: list[Path],\n   111\t    row_limit: int = 200,\n   112\t    **kwargs: Any,\n   113\t) -> pd.DataFrame:\n   114\t    \"\"\"Read a Parquet file with path validation and row limits.\n   115\t\n   116\t    Args:\n   117\t        file_path: Path to the Parquet file.\n   118\t        allowlist: List of allowed directory paths.\n   119\t        row_limit: Maximum number of rows to read.\n   120\t        **kwargs: Additional arguments to pass to pd.read_parquet.\n   121\t\n   122\t    Returns:\n   123\t        DataFrame with the Parquet data, limited to row_limit rows.\n   124\t\n   125\t        When pyarrow dataset scanning is available and only simple column\n   126\t        selection is requested, the limit is enforced during the read instead\n   127\t        of after loading the full file into memory.\n   128\t\n   129\t    Raises:\n   130\t        PermissionError: If the path is outside the allowlist.\n   131\t        FileNotFoundError: If the file does not exist.\n   132\t        ImportError: If pyarrow or fastparquet is not installed.\n   133\t    \"\"\"\n   134\t    _validate_row_limit(row_limit)\n   135\t\n   136\t    # Validate path\n   137\t    validated_path = validate_path(file_path, allowlist)\n   138\t\n   139\t    # Validate extension\n   140\t    validate_extension(validated_path.name)\n   141\t\n   142\t    columns = kwargs.get(\"columns\")\n   143\t    unsupported_kwargs = {key: value for key, value in kwargs.items() if key != \"columns\"}\n   144\t\n   145\t    if not unsupported_kwargs:\n   146\t        try:\n   147\t            import pyarrow.dataset as ds  # noqa: PLC0415 - Optional dependency\n   148\t        except ImportError:\n   149\t            pass\n   150\t        else:\n   151\t            dataset = ds.dataset(validated_path, format=\"parquet\")\n   152\t            return dataset.scanner(columns=columns).head(row_limit).to_pandas()\n   153\t\n   154\t    try:\n   155\t        df = pd.read_parquet(validated_path, **kwargs)\n   156\t    except ImportError as e:\n   157\t        raise ImportError(\n   158\t            \"Parquet support requires pyarrow or fastparquet. Install with: uv pip install pyarrow\"\n   159\t        ) from e\n   160\t\n   161\t    # Apply row limit\n   162\t    if len(df) > row_limit:\n   163\t        df = df.head(row_limit)\n   164\t\n   165\t    return df\n   166\t\n   167\t\n   168\tdef read_json_safe(\n   169\t    file_path: Path,\n   170\t    allowlist: list[Path],\n   171\t    row_limit: int = 200,\n   172\t    **kwargs: Any,\n   173\t) -> pd.DataFrame:\n   174\t    \"\"\"Read a JSON file with path validation and row limits.\n   175\t\n   176\t    Args:\n   177\t        file_path: Path to the JSON file.\n   178\t        allowlist: List of allowed directory paths.\n   179\t        row_limit: Maximum number of rows to read.\n   180\t        **kwargs: Additional arguments to pass to pd.read_json.\n   181\t\n   182\t    Returns:\n   183\t        DataFrame with the JSON data, limited to row_limit rows.\n   184\t\n   185\t    Raises:\n   186\t        PermissionError: If the path is outside the allowlist.\n   187\t        FileNotFoundError: If the file does not exist.\n   188\t    \"\"\"\n   189\t    _validate_row_limit(row_limit)\n   190\t\n   191\t    # Validate path\n   192\t    validated_path = validate_path(file_path, allowlist)\n   193\t\n   194\t    # Validate extension\n   195\t    validate_extension(validated_path.name)\n   196\t\n   197\t    # Read JSON\n   198\t    df = pd.read_json(validated_path, **kwargs)\n   199\t\n   200\t    # Apply row limit\n   201\t    if len(df) > row_limit:\n   202\t        df = df.head(row_limit)\n   203\t\n   204\t    return df\n","exit_code":0,"status":"completed"}}
