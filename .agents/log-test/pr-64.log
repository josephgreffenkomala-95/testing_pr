ource_reader.load_source_config\")\n   274\t    def test_query_source_closes_connection_on_error(self, mock_config, mock_creds, mock_conn):\n   275\t        source_config = {\"type\": \"sqlite\", \"database\": \":memory:\"}\n   276\t        mock_config.return_value = source_config\n   277\t        mock_creds.return_value = {}\n   278\t        mock_connection = MagicMock()\n   279\t        mock_conn.return_value = mock_connection\n   280\t        with patch(\"gl_tabular.data_access.source_reader.execute_query\", side_effect=RuntimeError(\"boom\")):\n   281\t            with pytest.raises(RuntimeError, match=\"boom\"):\n   282\t                query_source(\"testdb\", \"SELECT * FROM t\")\n   283\t        mock_connection.close.assert_called_once()\n   284\t\n   285\t\n   286\tclass TestSchemaSource:\n   287\t    \"\"\"Tests for schema_source().\"\"\"\n   288\t\n   289\t    @patch(\"gl_tabular.data_access.source_reader.get_schema_info\")\n   290\t    @patch(\"gl_tabular.data_access.source_reader.get_connection\")\n   291\t    @patch(\"gl_tabular.data_access.source_reader.resolve_credentials\")\n   292\t    @patch(\"gl_tabular.data_access.source_reader.load_source_config\")\n   293\t    def test_schema_source_happy_path(self, mock_config, mock_creds, mock_conn, mock_schema):\n   294\t        source_config = {\"type\": \"sqlite\", \"database\": \":memory:\"}\n   295\t        mock_config.return_value = source_config\n   296\t        mock_creds.return_value = {}\n   297\t        mock_connection = MagicMock()\n   298\t        mock_conn.return_value = mock_connection\n   299\t        expected = {\"table_name\": \"users\", \"columns\": [{\"name\": \"id\", \"type\": \"INTEGER\"}]}\n   300\t        mock_schema.return_value = expected\n   301\t        result = schema_source(\"testdb\", \"users\")\n   302\t        assert result == expected\n   303\t        mock_connection.close.assert_called_once()\n   304\t\n   305\t    @patch(\"gl_tabular.data_access.source_reader.get_schema_in