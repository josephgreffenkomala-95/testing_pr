{"type":"item.completed","item":{"id":"item_28","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/experiment/forecast_validators.py | sed -n '1,360p'\"","aggregated_output":"     1\t\"\"\"Consolidated forecasting validation rules — single owner for all deterministic thresholds and checks.\n     2\t\n     3\tThis module is the canonical source for:\n     4\t- Prediction scale, variation, flatline, staircase, and lag-dominance thresholds\n     5\t- Inference mode validation rules\n     6\t- Anchor integrity checks\n     7\t- Recursive parity and stub detection\n     8\t- Transform inversion mappings\n     9\t\n    10\tSkills reference this module instead of restating rules in prose.\n    11\t\"\"\"\n    12\t\n    13\tfrom __future__ import annotations\n    14\t\n    15\timport pickle\n    16\tfrom pathlib import Path\n    17\tfrom typing import Callable\n    18\t\n    19\timport numpy as np\n    20\t\n    21\t# ---------------------------------------------------------------------------\n    22\t# Constants — single definition, canonical values\n    23\t# ---------------------------------------------------------------------------\n    24\t\n    25\tSCALE_RATIO_MIN = 0.5\n    26\tSCALE_RATIO_MAX = 2.0\n    27\tVARIATION_RATIO_MIN = 0.1\n    28\tUNIQUE_RATIO_MIN = 0.05\n    29\tFLATLINE_SPREAD_RATIO_MIN = 0.02\n    30\tSTAIRCASE_WITHIN_PERIOD_RATIO_MIN = 0.05\n    31\tLAG_DOMINANCE_THRESHOLD = 0.7\n    32\tPARITY_DELTA_THRESHOLD = 1.0\n    33\tVAL_TRAIN_RATIO_SUSPICIOUS = 0.5\n    34\tVAL_TRAIN_RATIO_WARNING_UPPER = 0.7\n    35\t\n    36\t_NEAR_ZERO = 1e-10\n    37\t\n    38\tLAG_PREFIXES = (\"lag_\", \"rolling_\", \"shift_\", \"ewm_\", \"diff_\")\n    39\t\n    40\tTRANSFORM_INVERSION_MAP: dict[str, Callable[[np.ndarray, np.ndarray | None], np.ndarray]] = {\n    41\t    \"log1p\": lambda pred, _: np.expm1(pred),\n    42\t    \"log\": lambda pred, _: np.exp(pred),\n    43\t    \"diff\": lambda pred, last_values: last_values + pred,\n    44\t    \"log_return\": lambda pred, last_values: last_values * np.exp(pred),\n    45\t    \"none\": lambda pred, _: pred,\n    46\t}\n    47\t\n    48\t\n    49\t# ---------------------------------------------------------------------------\n    50\t# Remediation hints\n    51\t# ---------------------------------------------------------------------------\n    52\t\n    53\tREMEDIATION_HINTS: dict[str, str] = {\n    54\t    \"scale_check\": (\n    55\t        \"Check for sentinel fill contamination, wrong target column, \"\n    56\t        \"inverse transform not applied, or data split boundary bug. \"\n    57\t        \"See references/forecast-anti-patterns.md → Sentinel Fill Contamination.\"\n    58\t    ),\n    59\t    \"variation_check\": (\n    60\t        \"Predictions collapsed to near-constant. \"\n    61\t        \"Check lag recursion collapse, model predicting mean, or rolling window exhaustion. \"\n    62\t        \"See references/forecast-anti-patterns.md → Lag Feature Dominance.\"\n    63\t    ),\n    64\t    \"flatline_check\": (\n    65\t        \"Predictions are effectively constant across the horizon. \"\n    66\t        \"Check inference code for repeated seed value or single-leaf tree. \"\n    67\t        \"See references/forecast-anti-patterns.md → Sentinel Fill Contamination.\"\n    68\t    ),\n    69\t    \"staircase_check\": (\n    70\t        \"Predictions vary only at period boundaries (staircase pattern). \"\n    71\t        \"Check for monthly-only seasonal factor with no daily/weekly sub-pattern, \"\n    72\t        \"or a ratio model that does not update within a calendar period.\"\n    73\t    ),\n    74\t}\n    75\t\n    76\t\n    77\t# ---------------------------------------------------------------------------\n    78\t# Prediction sanity checks — moved from review_forecast.py\n    79\t# ---------------------------------------------------------------------------\n    80\t\n    81\t\n    82\tdef check_scale(predictions: np.ndarray, train_mean: float) -> dict:\n    83\t    \"\"\"Return scale ratio check result.\n    84\t\n    85\t    Fails if train_mean ≈ 0 or ratio outside [SCALE_RATIO_MIN, SCALE_RATIO_MAX].\n    86\t    \"\"\"\n    87\t    if abs(train_mean) < _NEAR_ZERO:\n    88\t        return {\n    89\t            \"prediction_scale_ratio\": None,\n    90\t            \"passed\": False,\n    91\t            \"_note\": \"train_mean ~0; ratio undefined\",\n    92\t        }\n    93\t    ratio = _safe(float(np.mean(predictions)) / train_mean)\n    94\t    passed = ratio is not None and SCALE_RATIO_MIN <= ratio <= SCALE_RATIO_MAX\n    95\t    return {\"prediction_scale_ratio\": ratio, \"passed\": passed}\n    96\t\n    97\t\n    98\tdef check_variation(predictions: np.ndarray, train_std: float) -> dict:\n    99\t    \"\"\"Return variation ratio and uniqueness check result.\n   100\t\n   101\t    Fails if variation_ratio < VARIATION_RATIO_MIN or unique_ratio < UNIQUE_RATIO_MIN.\n   102\t    \"\"\"\n   103\t    ratio = _safe(float(np.std(predictions)) / train_std) if train_std > _NEAR_ZERO else 0.0\n   104\t    unique_ratio = _safe(len(np.unique(predictions)) / len(predictions))\n   105\t    passed = (ratio is not None and ratio >= VARIATION_RATIO_MIN) and (\n   106\t        unique_ratio is not None and unique_ratio >= UNIQUE_RATIO_MIN\n   107\t    )\n   108\t    return {\"variation_ratio\": ratio, \"unique_ratio\": unique_ratio, \"passed\": passed}\n   109\t\n   110\t\n   111\tdef check_flatline(predictions: np.ndarray, train_mean: float) -> dict:\n   112\t    \"\"\"Return flatline (min-max spread) check result.\n   113\t\n   114\t    Fails if spread_ratio < FLATLINE_SPREAD_RATIO_MIN.\n   115\t    \"\"\"\n   116\t    if abs(train_mean) < _NEAR_ZERO:\n   117\t        return {\"min_max_spread_ratio\": None, \"passed\": False, \"_note\": \"train_mean ~0\"}\n   118\t    spread_ratio = _safe(float(np.max(predictions) - np.min(predictions)) / abs(train_mean))\n   119\t    passed = spread_ratio is not None and spread_ratio >= FLATLINE_SPREAD_RATIO_MIN\n   120\t    return {\"min_max_spread_ratio\": spread_ratio, \"passed\": passed}\n   121\t\n   122\t\n   123\tdef check_staircase(predictions: np.ndarray, window: int) -> dict:\n   124\t    \"\"\"Return staircase pattern check result.\n   125\t\n   126\t    Fails if within-window variation ratio < STAIRCASE_WITHIN_PERIOD_RATIO_MIN.\n   127\t    Skipped if too few predictions for windowing.\n   128\t    \"\"\"\n   129\t    n = len(predictions)\n   130\t    if n < window * 2:\n   131\t        return {\"within_period_variation_ratio\": None, \"passed\": True, \"skipped\": True}\n   132\t    global_std = float(np.std(predictions))\n   133\t    if global_std < _NEAR_ZERO:\n   134\t        return {\"within_period_variation_ratio\": 0.0, \"passed\": False}\n   135\t    n_windows = n // window\n   136\t    per_window_stds = [float(np.std(predictions[i * window : (i + 1) * window])) for i in range(n_windows)]\n   137\t    within_ratio = _safe(float(np.mean(per_window_stds)) / global_std)\n   138\t    passed = within_ratio is not None and within_ratio >= STAIRCASE_WITHIN_PERIOD_RATIO_MIN\n   139\t    return {\"within_period_variation_ratio\": within_ratio, \"passed\": passed}\n   140\t\n   141\t\n   142\tdef check_lag_dominance(\n   143\t    feature_importance: dict[str, float] | None,\n   144\t    inference_mode: str,\n   145\t) -> dict:\n   146\t    \"\"\"Return lag dominance flag.\n   147\t\n   148\t    Flagged if lag feature importance share > LAG_DOMINANCE_THRESHOLD in recursive mode.\n   149\t    \"\"\"\n   150\t    if not feature_importance or inference_mode != \"recursive\":\n   151\t        return {\"lag_importance_share\": None, \"flagged\": False}\n   152\t    total = sum(feature_importance.values())\n   153\t    if total < _NEAR_ZERO:\n   154\t        return {\"lag_importance_share\": 0.0, \"flagged\": False}\n   155\t    lag_sum = sum(v for k, v in feature_importance.items() if any(k.startswith(p) for p in LAG_PREFIXES))\n   156\t    share = _safe(lag_sum / total)\n   157\t    return {\"lag_importance_share\": share, \"flagged\": share is not None and share > LAG_DOMINANCE_THRESHOLD}\n   158\t\n   159\t\n   160\t# ---------------------------------------------------------------------------\n   161\t# Inference mode validation\n   162\t# ---------------------------------------------------------------------------\n   163\t\n   164\t\n   165\tdef validate_inference_mode(\n   166\t    mode: str,\n   167\t    has_lag_features: bool,\n   168\t    forecast_horizon: int,\n   169\t) -> list[str]:\n   170\t    \"\"\"Validate inference mode declaration against pipeline constraints.\n   171\t\n   172\t    Returns a list of violation strings. Empty list means valid.\n   173\t\n   174\t    Rules:\n   175\t    - forecast_horizon > 1 with lag features: mode must be 'recursive' or 'direct_multi_step'\n   176\t    - 'one_step' or 'direct' with forecast_horizon > 1 and lag features is forbidden\n   177\t    \"\"\"\n   178\t    violations: list[str] = []\n   179\t    valid_modes = {\"one_step\", \"recursive\", \"direct_multi_step\", \"seq2seq_or_global\", \"direct\"}\n   180\t\n   181\t    if mode not in valid_modes:\n   182\t        violations.append(f\"inference_mode '{mode}' is not a recognized mode\")\n   183\t        return violations\n   184\t\n   185\t    if forecast_horizon > 1 and has_lag_features and mode in (\"one_step\", \"direct\"):\n   186\t        violations.append(\n   187\t            f\"inference_mode '{mode}' is forbidden when forecast_horizon={forecast_horizon} \"\n   188\t            f\"with lag features; must be 'recursive' or 'direct_multi_step'\"\n   189\t        )\n   190\t\n   191\t    return violations\n   192\t\n   193\t\n   194\t# ---------------------------------------------------------------------------\n   195\t# Anchor integrity validation\n   196\t# ---------------------------------------------------------------------------\n   197\t\n   198\t\n   199\tdef validate_anchor(\n   200\t    anchor_path: Path,\n   201\t    max_lag: int,\n   202\t) -> list[str]:\n   203\t    \"\"\"Validate anchor.pkl existence, entity coverage, and history depth.\n   204\t\n   205\t    Returns a list of violation strings. Empty list means valid.\n   206\t    \"\"\"\n   207\t    violations: list[str] = []\n   208\t\n   209\t    if not anchor_path.exists():\n   210\t        violations.append(\"anchor.pkl is missing\")\n   211\t        return violations\n   212\t\n   213\t    try:\n   214\t        with open(anchor_path, \"rb\") as f:\n   215\t            anchor = pickle.load(f)  # noqa: S301\n   216\t    except Exception as exc:\n   217\t        violations.append(f\"anchor.pkl could not be loaded: {exc}\")\n   218\t        return violations\n   219\t\n   220\t    if not isinstance(anchor, dict):\n   221\t        violations.append(\"anchor.pkl must be a dict mapping entity keys to value lists\")\n   222\t        return violations\n   223\t\n   224\t    if not anchor:\n   225\t        violations.append(\"anchor.pkl is empty\")\n   226\t        return violations\n   227\t\n   228\t    for entity_key, values in anchor.items():\n   229\t        if not isinstance(values, (list, np.ndarray)):\n   230\t            violations.append(f\"anchor.pkl entity {entity_key!r}: values must be a list or array\")\n   231\t            continue\n   232\t\n   233\t        if len(values) < max_lag:\n   234\t            violations.append(\n   235\t                f\"anchor.pkl entity {entity_key!r}: has {len(values)} values, \"\n   236\t                f\"needs >= {max_lag} (max lag requirement)\"\n   237\t            )\n   238\t\n   239\t        if isinstance(values, (list, np.ndarray)) and len(values) > 0:\n   240\t            arr = np.array(values, dtype=float)\n   241\t            if np.any(np.isnan(arr)):\n   242\t                violations.append(f\"anchor.pkl entity {entity_key!r}: contains NaN values\")\n   243\t\n   244\t    return violations\n   245\t\n   246\t\n   247\t# ---------------------------------------------------------------------------\n   248\t# Recursive parity checks\n   249\t# ---------------------------------------------------------------------------\n   250\t\n   251\t\n   252\tdef check_recursive_parity(\n   253\t    mape_delta: float | None,\n   254\t    reported_mape: float | None,\n   255\t    honest_recursive_mape: float | None,\n   256\t) -> list[str]:\n   257\t    \"\"\"Validate recursive parity check result.\n   258\t\n   259\t    Checks:\n   260\t    - Stub detection: mape_delta == 0.0 AND reported_mape == honest_recursive_mape\n   261\t    - Delta threshold: abs(mape_delta) > PARITY_DELTA_THRESHOLD\n   262\t    - Missing: honest_recursive_mape is None\n   263\t\n   264\t    Returns a list of violation strings. Empty list means valid.\n   265\t    \"\"\"\n   266\t    violations: list[str] = []\n   267\t\n   268\t    if honest_recursive_mape is None:\n   269\t        violations.append(\"honest_recursive_mape is missing — parity check cannot be verified\")\n   270\t        return violations\n   271\t\n   272\t    if reported_mape is None:\n   273\t        violations.append(\"reported_mape is missing — parity check cannot be verified\")\n   274\t        return violations\n   275\t\n   276\t    if mape_delta is None:\n   277\t        violations.append(\"mape_delta is missing — parity check cannot be verified\")\n   278\t        return violations\n   279\t\n   280\t    # Stub detection: identical values mean simulation was never actually run\n   281\t    if mape_delta == 0.0 and honest_recursive_mape == reported_mape:\n   282\t        violations.append(\n   283\t            \"stub detected: mape_delta=0.0 and honest_recursive_mape equals reported_mape \"\n   284\t            \"— recursive simulation was not actually performed\"\n   285\t        )\n   286\t\n   287\t    # Delta threshold\n   288\t    if abs(mape_delta) > PARITY_DELTA_THRESHOLD:\n   289\t        violations.append(\n   290\t            f\"parity delta exceeds threshold: |mape_delta|={abs(mape_delta):.2f} > \"\n   291\t            f\"{PARITY_DELTA_THRESHOLD} percentage point(s)\"\n   292\t        )\n   293\t\n   294\t    return violations\n   295\t\n   296\t\n   297\t# ---------------------------------------------------------------------------\n   298\t# Transform inversion\n   299\t# ---------------------------------------------------------------------------\n   300\t\n   301\t\n   302\tdef get_inversion_function(transform_type: str) -> Callable[[np.ndarray, np.ndarray | None], np.ndarray]:\n   303\t    \"\"\"Return the inverse transform function for the given transform type.\n   304\t\n   305\t    Supported types: 'log1p', 'log', 'diff', 'log_return', 'none'.\n   306\t    For 'diff' and 'log_return', last_values (raw scale) must be provided.\n   307\t    \"\"\"\n   308\t    if transform_type not in TRANSFORM_INVERSION_MAP:\n   309\t        raise ValueError(\n   310\t            f\"Unknown transform type '{transform_type}'. \" f\"Supported: {sorted(TRANSFORM_INVERSION_MAP.keys())}\"\n   311\t        )\n   312\t    return TRANSFORM_INVERSION_MAP[transform_type]\n   313\t\n   314\t\n   315\tdef invert_predictions(\n   316\t    predictions: np.ndarray,\n   317\t    transform_type: str,\n   318\t    last_values: np.ndarray | None = None,\n   319\t) -> np.ndarray:\n   320\t    \"\"\"Apply inverse transform to predictions.\n   321\t\n   322\t    For 'diff' and 'log_return', last_values must be provided (raw scale prior values).\n   323\t    \"\"\"\n   324\t    inversion_fn = get_inversion_function(transform_type)\n   325\t\n   326\t    if transform_type in (\"diff\", \"log_return\") and last_values is None:\n   327\t        raise ValueError(f\"transform_type '{transform_type}' requires last_values for inversion\")\n   328\t\n   329\t    return inversion_fn(predictions, last_values)\n   330\t\n   331\t\n   332\t# ---------------------------------------------------------------------------\n   333\t# Helpers\n   334\t# ---------------------------------------------------------------------------\n   335\t\n   336\t\n   337\tdef _safe(value: float) -> float | None:\n   338\t    \"\"\"Convert nan/inf to None for JSON serialisation.\"\"\"\n   339\t    if value is None:\n   340\t        return None\n   341\t    if not isinstance(value, float):\n   342\t        value = float(value)\n   343\t    return None if (np.isnan(value) or np.isinf(value)) else round(value, 4)\n","exit_code":0,"status":"completed"}}
