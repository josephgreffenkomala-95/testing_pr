{"type":"item.completed","item":{"id":"item_42","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/experiment/artifact_schemas.py | sed -n '1,320p'\"","aggregated_output":"     1\t\"\"\"Typed Pydantic schemas for canonical experiment JSON artifacts.\n     2\t\n     3\tSingle owner of field names, types, enums, and recommended_next values.\n     4\tSkills and CLI validators reference these schemas instead of restating\n     5\tfield lists or enum values in prose.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\tfrom enum import StrEnum\n    11\tfrom typing import Any\n    12\t\n    13\tfrom pydantic import BaseModel, Field\n    14\t\n    15\t# ---------------------------------------------------------------------------\n    16\t# Canonical enums\n    17\t# ---------------------------------------------------------------------------\n    18\t\n    19\t\n    20\tclass InferenceMode(StrEnum):\n    21\t    \"\"\"Allowed inference_mode values across all artifacts.\"\"\"\n    22\t\n    23\t    ONE_STEP = \"one_step\"\n    24\t    RECURSIVE = \"recursive\"\n    25\t    DIRECT_MULTI_STEP = \"direct_multi_step\"\n    26\t    SEQ2SEQ_OR_GLOBAL = \"seq2seq_or_global\"\n    27\t    DIRECT = \"direct\"\n    28\t\n    29\t\n    30\tclass Verdict(StrEnum):\n    31\t    \"\"\"Allowed verdict values across all artifacts.\"\"\"\n    32\t\n    33\t    PASS = \"pass\"\n    34\t    FAIL = \"fail\"\n    35\t\n    36\t\n    37\tclass ForecastRecommendedNext(StrEnum):\n    38\t    \"\"\"Allowed recommended_next values in forecast_review.json.\"\"\"\n    39\t\n    40\t    EVALUATOR = \"evaluator\"\n    41\t    MODELING = \"modeling\"\n    42\t\n    43\t\n    44\tclass LeakagePostRecommendedNext(StrEnum):\n    45\t    \"\"\"Allowed recommended_next values in leakage_guard_post.json.\"\"\"\n    46\t\n    47\t    FORECAST_REVIEWER = \"forecast-reviewer\"\n    48\t    EVALUATOR = \"evaluator\"\n    49\t    MODELING = \"modeling\"\n    50\t    FEATURE_ENGINEER = \"feature-engineer\"\n    51\t\n    52\t\n    53\tclass EvaluationRecommendedNext(StrEnum):\n    54\t    \"\"\"Allowed recommended_next values in evaluation.json.\"\"\"\n    55\t\n    56\t    EXPERIMENT_REVIEW = \"experiment-review\"\n    57\t    EVALUATOR = \"evaluator\"\n    58\t    FORECAST_REVIEWER = \"forecast-reviewer\"\n    59\t\n    60\t\n    61\t# ---------------------------------------------------------------------------\n    62\t# Forecast review\n    63\t# ---------------------------------------------------------------------------\n    64\t\n    65\t\n    66\tclass ScaleCheck(BaseModel):\n    67\t    \"\"\"Scale ratio check result.\"\"\"\n    68\t\n    69\t    prediction_scale_ratio: float | None = None\n    70\t    passed: bool\n    71\t\n    72\t\n    73\tclass VariationCheck(BaseModel):\n    74\t    \"\"\"Variation ratio and uniqueness check result.\"\"\"\n    75\t\n    76\t    variation_ratio: float | None = None\n    77\t    unique_ratio: float | None = None\n    78\t    passed: bool | None = None\n    79\t\n    80\t\n    81\tclass FlatlineCheck(BaseModel):\n    82\t    \"\"\"Flatline (min-max spread) check result.\"\"\"\n    83\t\n    84\t    min_max_spread_ratio: float | None = None\n    85\t    passed: bool | None = None\n    86\t\n    87\t\n    88\tclass StaircaseCheck(BaseModel):\n    89\t    \"\"\"Staircase pattern (within-period variation) check result.\"\"\"\n    90\t\n    91\t    within_period_variation_ratio: float | None = None\n    92\t    passed: bool | None = None\n    93\t    skipped: bool | None = None\n    94\t\n    95\t\n    96\tclass LagDominanceCheck(BaseModel):\n    97\t    \"\"\"Lag dominance flag result.\"\"\"\n    98\t\n    99\t    lag_importance_share: float | None = None\n   100\t    flagged: bool\n   101\t\n   102\t\n   103\tclass ForecastVerificationContext(BaseModel):\n   104\t    \"\"\"Inputs needed to independently re-verify forecast checks.\"\"\"\n   105\t\n   106\t    predictions_file: str\n   107\t    prediction_column: str\n   108\t    train_mean: float\n   109\t    train_std: float = Field(gt=0)\n   110\t    staircase_window: int = Field(ge=1)\n   111\t\n   112\t\n   113\tclass ForecastReviewSchema(BaseModel):\n   114\t    \"\"\"Schema for forecast_review.json.\"\"\"\n   115\t\n   116\t    iteration_id: str\n   117\t    inference_mode: InferenceMode\n   118\t    scale_check: ScaleCheck\n   119\t    variation_check: VariationCheck\n   120\t    flatline_check: FlatlineCheck\n   121\t    staircase_check: StaircaseCheck\n   122\t    lag_dominance_check: LagDominanceCheck\n   123\t    verdict: Verdict\n   124\t    fail_reason: str | None = None\n   125\t    remediation_hypothesis: str | None = None\n   126\t    recommended_next: ForecastRecommendedNext\n   127\t    verification_context: ForecastVerificationContext\n   128\t\n   129\t    model_config = {\"populate_by_name\": True}\n   130\t\n   131\t\n   132\t# ---------------------------------------------------------------------------\n   133\t# Leakage guard pre\n   134\t# ---------------------------------------------------------------------------\n   135\t\n   136\t\n   137\tclass LeakageGuardPreSchema(BaseModel):\n   138\t    \"\"\"Schema for leakage_guard_pre.json.\"\"\"\n   139\t\n   140\t    phase: str = Field(pattern=r\"^pre$\")\n   141\t    iteration_id: str\n   142\t    classification: dict[str, Any]\n   143\t    allowed_features: list[str]\n   144\t    verdict: Verdict\n   145\t    fail_conditions: list[str] = Field(default_factory=list)\n   146\t    warnings: list[str] = Field(default_factory=list)\n   147\t\n   148\t\n   149\t# ---------------------------------------------------------------------------\n   150\t# Leakage guard post\n   151\t# ---------------------------------------------------------------------------\n   152\t\n   153\t\n   154\tclass LeakageGuardPostSchema(BaseModel):\n   155\t    \"\"\"Schema for leakage_guard_post.json.\"\"\"\n   156\t\n   157\t    phase: str = Field(pattern=r\"^post$\")\n   158\t    iteration_id: str\n   159\t    features_in_model: list[str] = Field(default_factory=list)\n   160\t    unauthorized_features: list[str] = Field(default_factory=list)\n   161\t    lag_too_short_in_model: list[str] = Field(default_factory=list)\n   162\t    val_uses_teacher_forcing: bool\n   163\t    recursive_loop_broken: bool\n   164\t    target_transform_not_inverted: bool\n   165\t    anchor_missing: bool\n   166\t    anchor_stores_transformed_values: bool\n   167\t    verdict: Verdict\n   168\t    fail_conditions: list[str] = Field(default_factory=list)\n   169\t    warnings: list[str] = Field(default_factory=list)\n   170\t    remediation_hypothesis: str | None = None\n   171\t    recommended_next: LeakagePostRecommendedNext\n   172\t\n   173\t\n   174\t# ---------------------------------------------------------------------------\n   175\t# Evaluation\n   176\t# ---------------------------------------------------------------------------\n   177\t\n   178\t\n   179\tclass EvaluationSchema(BaseModel):\n   180\t    \"\"\"Schema for evaluation.json.\"\"\"\n   181\t\n   182\t    inference_mode: InferenceMode\n   183\t    reported_mape: float | None = None\n   184\t    honest_recursive_mape: float | None = None\n   185\t    mape_delta: float | None = None\n   186\t    naive_mape: float | None = None\n   187\t    last_promoted_mape: float | None = None\n   188\t    beats_last_promoted: bool | None = None\n   189\t    recursive_parity_check: str | None = None\n   190\t    naive_baseline_check: str | None = None\n   191\t    future_feature_coverage_check: str | None = None\n   192\t    leakage_suspected: bool | None = None\n   193\t    verdict: Verdict\n   194\t    fail_conditions: list[str] = Field(default_factory=list)\n   195\t    fail_reason: str | None = None\n   196\t    recommended_next: EvaluationRecommendedNext = EvaluationRecommendedNext.EXPERIMENT_REVIEW\n","exit_code":0,"status":"completed"}}
