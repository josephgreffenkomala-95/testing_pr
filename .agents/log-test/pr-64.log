{"type":"item.completed","item":{"id":"item_32","type":"command_execution","command":"/bin/bash -lc \"nl -ba gl_tabular/cli/utils/experiment/routing.py | sed -n '1,320p'\"","aggregated_output":"     1\t\"\"\"Canonical routing matrix — single owner for all stage transition rules.\n     2\t\n     3\tSkills and CLI commands reference these functions instead of restating\n     4\trouting logic in prose or duplicating hardcoded stage names.\n     5\t\"\"\"\n     6\t\n     7\tfrom __future__ import annotations\n     8\t\n     9\timport json\n    10\tfrom pathlib import Path\n    11\t\n    12\tfrom gl_tabular.cli.utils.experiment.stage import first_incomplete\n    13\t\n    14\t\n    15\tclass Verdict:\n    16\t    \"\"\"Verdict constants matching artifact_schemas.Verdict values.\"\"\"\n    17\t\n    18\t    PASS = \"pass\"\n    19\t    FAIL = \"fail\"\n    20\t\n    21\t\n    22\tdef route_after_forecast_review(verdict: str) -> str:\n    23\t    \"\"\"Route after forecast-reviewer verdict.\n    24\t\n    25\t    Args:\n    26\t        verdict: 'pass' or 'fail'.\n    27\t\n    28\t    Returns:\n    29\t        'evaluator' on pass, 'modeling' on fail.\n    30\t    \"\"\"\n    31\t    if verdict == Verdict.PASS:\n    32\t        return \"evaluator\"\n    33\t    return \"modeling\"\n    34\t\n    35\t\n    36\tdef route_after_leakage_guard_post_pass(task_type: str) -> str:\n    37\t    \"\"\"Route after leakage-guard post-phase pass.\n    38\t\n    39\t    Args:\n    40\t        task_type: Task type ('classification', 'regression', 'time_series').\n    41\t\n    42\t    Returns:\n    43\t        'forecast-reviewer' for time_series, 'evaluator' otherwise.\n    44\t    \"\"\"\n    45\t    if task_type == \"time_series\":\n    46\t        return \"forecast-reviewer\"\n    47\t    return \"evaluator\"\n    48\t\n    49\t\n    50\tdef route_after_leakage_guard_post(fail_conditions: list[str] | tuple[str, ...]) -> str:\n    51\t    \"\"\"Route after leakage-guard post-phase failure.\n    52\t\n    53\t    If any fail condition indicates modeling-only issues (e.g., teacher forcing),\n    54\t    route back to modeling. Otherwise route to feature-engineer.\n    55\t\n    56\t    Args:\n    57\t        fail_conditions: List of fail condition strings from leakage_guard_post.json.\n    58\t\n    59\t    Returns:\n    60\t        Stage name to route to.\n    61\t    \"\"\"\n    62\t    modeling_conditions = {\"val_uses_teacher_forcing\"}\n    63\t    normalized = {condition.strip() for condition in fail_conditions if condition.strip()}\n    64\t    if normalized & modeling_conditions:\n    65\t        return \"modeling\"\n    66\t    return \"feature-engineer\"\n    67\t\n    68\t\n    69\tdef route_after_leakage_guard_pre(verdict: str) -> str:\n    70\t    \"\"\"Route after leakage-guard pre-phase.\n    71\t\n    72\t    Args:\n    73\t        verdict: 'pass' or 'fail'.\n    74\t\n    75\t    Returns:\n    76\t        'feature-engineer' on pass. On fail, no route — iteration must revise hypothesis.\n    77\t    \"\"\"\n    78\t    if verdict == \"pass\":\n    79\t        return \"feature-engineer\"\n    80\t    return \"stop\"\n    81\t\n    82\t\n    83\tdef route_after_evaluator(verdict: str, task_type: str, fail_reason: str | None = None) -> str:\n    84\t    \"\"\"Route after evaluator verdict.\n    85\t\n    86\t    Args:\n    87\t        verdict: 'pass' or 'fail'.\n    88\t        task_type: Task type ('classification', 'regression', 'time_series').\n    89\t        fail_reason: Primary failure reason if verdict is 'fail'.\n    90\t\n    91\t    Returns:\n    92\t        Recommended next stage.\n    93\t    \"\"\"\n    94\t    if verdict == \"pass\":\n    95\t        return \"experiment-review\"\n    96\t\n    97\t    code_bug_patterns = (\"inference_mode_mismatch\", \"recursive_parity_stub_detected\")\n    98\t    if fail_reason and any(pattern in fail_reason for pattern in code_bug_patterns):\n    99\t        return \"evaluator\"\n   100\t\n   101\t    if task_type == \"time_series\":\n   102\t        return \"forecast-reviewer\"\n   103\t\n   104\t    return \"experiment-review\"\n   105\t\n   106\t\n   107\tdef _read_json_safe(path: Path) -> dict | None:\n   108\t    \"\"\"Read a JSON file, returning None on any failure.\"\"\"\n   109\t    if not path.exists():\n   110\t        return None\n   111\t    try:\n   112\t        return json.loads(path.read_text(encoding=\"utf-8\"))\n   113\t    except (json.JSONDecodeError, OSError):\n   114\t        return None\n   115\t\n   116\t\n   117\tdef _check_evaluator_gate(completed: set[str], artifacts_dir: Path, task_type: str) -> str | None:\n   118\t    \"\"\"Check evaluator artifact for non-linear routing.\"\"\"\n   119\t    if \"evaluator\" not in completed or not task_type:\n   120\t        return None\n   121\t    eval_data = _read_json_safe(artifacts_dir / \"evaluation.json\")\n   122\t    if eval_data is None:\n   123\t        return None\n   124\t    verdict = eval_data.get(\"verdict\", \"pass\")\n   125\t    fail_reason = eval_data.get(\"fail_reason\")\n   126\t    routed = route_after_evaluator(verdict, task_type, fail_reason)\n   127\t    if routed != \"experiment-review\":\n   128\t        return routed\n   129\t    return None\n   130\t\n   131\t\n   132\tdef _check_leakage_guard_post_gate(completed: set[str], artifacts_dir: Path) -> str | None:\n   133\t    \"\"\"Check leakage_guard_post artifact for non-linear routing.\"\"\"\n   134\t    if \"modeling\" not in completed:\n   135\t        return None\n   136\t    lg_data = _read_json_safe(artifacts_dir / \"leakage_guard_post.json\")\n   137\t    if lg_data is None or lg_data.get(\"verdict\") != \"fail\":\n   138\t        return None\n   139\t    return route_after_leakage_guard_post(lg_data.get(\"fail_conditions\", []))\n   140\t\n   141\t\n   142\tdef _check_leakage_guard_pre_gate(linear: str | None, artifacts_dir: Path) -> str | None:\n   143\t    \"\"\"Check leakage_guard_pre artifact for non-linear routing.\"\"\"\n   144\t    if linear != \"feature-engineer\":\n   145\t        return None\n   146\t    lg_data = _read_json_safe(artifacts_dir / \"leakage_guard_pre.json\")\n   147\t    if lg_data is None or lg_data.get(\"verdict\") != \"fail\":\n   148\t        return None\n   149\t    return \"stop\"\n   150\t\n   151\t\n   152\tdef resolve_next_stage(\n   153\t    completed: set[str],\n   154\t    artifacts_dir: Path | None = None,\n   155\t    task_type: str | None = None,\n   156\t) -> str | None:\n   157\t    \"\"\"Resolve the next stage after checkpoint, honouring out-of-band gates.\n   158\t\n   159\t    Checks for gate artifacts (forecast_review.json, leakage_guard_pre.json,\n   160\t    leakage_guard_post.json) that determine non-linear routing. Falls back\n   161\t    to linear ``first_incomplete`` for ungated stages.\n   162\t\n   163\t    Args:\n   164\t        completed: Set of stage names already marked complete.\n   165\t        artifacts_dir: Path to ``applications/{task}/experiments/artifacts``.\n   166\t            Required for gate artifact checks.\n   167\t        task_type: Task type string. Required for evaluator routing.\n   168\t\n   169\t    Returns:\n   170\t        Next stage name, or None if all stages complete.\n   171\t    \"\"\"\n   172\t    linear = first_incomplete(completed)\n   173\t\n   174\t    if linear is None or artifacts_dir is None:\n   175\t        return linear\n   176\t\n   177\t    if task_type:\n   178\t        gated = _check_evaluator_gate(completed, artifacts_dir, task_type)\n   179\t        if gated is not None:\n   180\t            return gated\n   181\t\n   182\t    gated = _check_leakage_guard_post_gate(completed, artifacts_dir)\n   183\t    if gated is not None:\n   184\t        return gated\n   185\t\n   186\t    gated = _check_leakage_guard_pre_gate(linear, artifacts_dir)\n   187\t    if gated is not None:\n   188\t        return gated\n   189\t\n   190\t    return linear\n","exit_code":0,"status":"completed"}}
