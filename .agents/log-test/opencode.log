{"type":"tool_use","timestamp":1782271719277,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_xlqv4fbw","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/review_events.py"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/review_events.py</path>\n<type>file</type>\n<content>\n1: \"\"\"In-process coordination for poller and per-PR operations.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import threading\n6: import time\n7: from collections import deque\n8: from dataclasses import asdict, dataclass\n9: from typing import Callable, cast\n10: \n11: from pr_review.log import get_logger\n12: \n13: log = get_logger()\n14: \n15: \n16: @dataclass\n17: class PollerStatus:\n18:     \"\"\"Runtime status for the singleton review-all poller.\"\"\"\n19: \n20:     running: bool = False\n21:     started_at: str = \"\"\n22:     finished_at: str = \"\"\n23:     error: str = \"\"\n24:     result: str = \"\"\n25: \n26: \n27: @dataclass(frozen=True)\n28: class PrOperation:\n29:     \"\"\"One active operation for a specific PR.\"\"\"\n30: \n31:     operation: str\n32:     source: str\n33:     started_at: str\n34: \n35: \n36: _STREAM_MAX_PER_PR = 5000\n37: \n38: \n39: class StreamBus:\n40:     \"\"\"Thread-safe event bus that publishes per-PR streaming events for SSE.\"\"\"\n41: \n42:     def __init__(self, maxlen: int = _STREAM_MAX_PER_PR) -> None:\n43:         \"\"\"Initialize bounded in-memory event storage.\"\"\"\n44:         self._lock = threading.Lock()\n45:         self._events: dict[int, deque[dict[str, object]]] = {}\n46:         self._maxlen = maxlen\n47: \n48:     def publish(self, pr_number: int, event_type: str, data: dict[str, object] | None = None) -> None:\n49:         \"\"\"Publish a streaming event for a PR.\"\"\"\n50:         entry: dict[str, object] = {\"type\": event_type, \"ts\": time.time()}\n51:         if data:\n52:             entry.update(data)\n53:         with self._lock:\n54:             if pr_number not in self._events:\n55:                 self._events[pr_number] = deque(maxlen=self._maxlen)\n56:             self._events[pr_number].append(entry)\n57: \n58:     def get_events(self, pr_number: int, since: float = 0.0) -> list[dict[str, object]]:\n59:         \"\"\"Return all stored events for a PR newer than *since* timestamp.\"\"\"\n60:         with self._lock:\n61:             events = list(self._events.get(pr_number, []))\n62:         return [event for event in events if isinstance(event.get(\"ts\"), float) and cast(float, event[\"ts\"]) > since]\n63: \n64:     def prune(self, pr_number: int) -> None:\n65:         \"\"\"Remove stored events for a PR.\"\"\"\n66:         with self._lock:\n67:             self._events.pop(pr_number, None)\n68: \n69: \n70: class RuntimeCoordinator:\n71:     \"\"\"Coordinate one poller and one active operation per PR.\"\"\"\n72: \n73:     def __init__(self, now: Callable[[], str]) -> None:\n74:         \"\"\"Initialize the in-memory coordinator.\"\"\"\n75:         self._now = now\n76:         self._lock = threading.Lock()\n77:         self._poller_thread: threading.Thread | None = None\n78:         self._poller = PollerStatus()\n79:         self._active: dict[int, PrOperation] = {}\n80:         self.stream_bus = StreamBus()\n81: \n82:     def try_start_poller(self, fn: Callable[[], str]) -> tuple[bool, str]:\n83:         \"\"\"Start the singleton poller if it is not already running.\"\"\"\n84:         with self._lock:\n85:             if self._poller_thread and self._poller_thread.is_alive():\n86:                 log.info(\"poller start rejected: already active\")\n87:                 return False, \"Review-all poller is already active\"\n88:             self._poller = PollerStatus(running=True, started_at=self._now())\n89:             self._poller_thread = threading.Thread(target=self._run_poller, args=(fn,), daemon=True)\n90:             self._poller_thread.start()\n91:         log.info(\"poller started\")\n92:         return True, \"Started review-all poller\"\n93: \n94:     def _run_poller(self, fn: Callable[[], str]) -> None:\n95:         try:\n96:             result = fn()\n97:         except Exception as exc:\n98:             log.error(\"poller failed: %s\", exc)\n99:             self._finish_poller(error=str(exc)[:500], result=\"Failed\")\n100:         else:\n101:             log.info(\"poller finished: %s\", str(result)[:200])\n102:             self._finish_poller(result=str(result)[:500] or \"Done\")\n103: \n104:     def _finish_poller(self, *, error: str = \"\", result: str = \"\") -> None:\n105:         with self._lock:\n106:             self._poller.running = False\n107:             self._poller.finished_at = self._now()\n108:             self._poller.error = error\n109:             self._poller.result = result\n110: \n111:     def try_acquire_pr(self, pr_number: int, operation: str, source: str) -> tuple[bool, str]:\n112:         \"\"\"Acquire the operation slot for one PR.\"\"\"\n113:         with self._lock:\n114:             current = self._active.get(pr_number)\n115:             if current is not None:\n116:                 log.debug(\"PR #%d acquire rejected: busy with %s\", pr_number, current.operation)\n117:                 return False, f\"PR #{pr_number} is busy with {current.operation}\"\n118:             self._active[pr_number] = PrOperation(operation=operation, source=source, started_at=self._now())\n119:         log.debug(\"PR #%d acquired for %s by %s\", pr_number, operation, source)\n120:         return True, \"\"\n121: \n122:     def release_pr(self, pr_number: int) -> None:\n123:         \"\"\"Release the operation slot for one PR.\"\"\"\n124:         with self._lock:\n125:             self._active.pop(pr_number, None)\n126: \n127:     def try_start_pr_operation(\n128:         self,\n129:         pr_number: int,\n130:         operation: str,\n131:         source: str,\n132:         fn: Callable[[], str],\n133:     ) -> tuple[bool, str]:\n134:         \"\"\"Start one background operation for one PR.\"\"\"\n135:         ok, message = self.try_acquire_pr(pr_number, operation, source)\n136:         if not ok:\n137:             return False, message\n138:         thread = threading.Thread(\n139:             target=self._run_pr_operation,\n140:             args=(pr_number, fn),\n141:             daemon=True,\n142:         )\n143:         thread.start()\n144:         return True, f\"Started {operation} for PR #{pr_number}\"\n145: \n146:     def _run_pr_operation(self, pr_number: int, fn: Callable[[], str]) -> None:\n147:         try:\n148:             fn()\n149:         finally:\n150:             self.release_pr(pr_number)\n151: \n152:     def snapshot(self) -> dict[str, object]:\n153:         \"\"\"Return poller and active PR operation snapshots.\"\"\"\n154:         with self._lock:\n155:             active = {str(pr_number): asdict(operation) for pr_number, operation in self._active.items()}\n156:             return {\"poller\": asdict(self._poller), \"active_prs\": active}\n\n(End of file - total 156 lines)\n</content>","metadata":{"preview":"\"\"\"In-process coordination for poller and per-PR operations.\"\"\"\n\nfrom __future__ import annotations\n\nimport threading\nimport time\nfrom collections import deque\nfrom dataclasses import asdict, dataclass\nfrom typing import Callable, cast\n\nfrom pr_review.log import get_logger\n\nlog = get_logger()\n\n\n@dataclass\nclass PollerStatus:\n    \"\"\"Runtime status for the singleton review-all poller.\"\"\"\n\n    running: bool = False","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/review_events.py","text":"\"\"\"In-process coordination for poller and per-PR operations.\"\"\"\n\nfrom __future__ import annotations\n\nimport threading\nimport time\nfrom collections import deque\nfrom dataclasses import asdict, dataclass\nfrom typing import Callable, cast\n\nfrom pr_review.log import get_logger\n\nlog = get_logger()\n\n\n@dataclass\nclass PollerStatus:\n    \"\"\"Runtime status for the singleton review-all poller.\"\"\"\n\n    running: bool = False\n    started_at: str = \"\"\n    finished_at: str = \"\"\n    error: str = \"\"\n    result: str = \"\"\n\n\n@dataclass(frozen=True)\nclass PrOperation:\n    \"\"\"One active operation for a specific PR.\"\"\"\n\n    operation: str\n    source: str\n    started_at: str\n\n\n_STREAM_MAX_PER_PR = 5000\n\n\nclass StreamBus:\n    \"\"\"Thread-safe event bus that publishes per-PR streaming events for SSE.\"\"\"\n\n    def __init__(self, maxlen: int = _STREAM_MAX_PER_PR) -> None:\n        \"\"\"Initialize bounded in-memory event storage.\"\"\"\n        self._lock = threading.Lock()\n        self._events: dict[int, deque[dict[str, object]]] = {}\n        self._maxlen = maxlen\n\n    def publish(self, pr_number: int, event_type: str, data: dict[str, object] | None = None) -> None:\n        \"\"\"Publish a streaming event for a PR.\"\"\"\n        entry: dict[str, object] = {\"type\": event_type, \"ts\": time.time()}\n        if data:\n            entry.update(data)\n        with self._lock:\n            if pr_number not in self._events:\n                self._events[pr_number] = deque(maxlen=self._maxlen)\n            self._events[pr_number].append(entry)\n\n    def get_events(self, pr_number: int, since: float = 0.0) -> list[dict[str, object]]:\n        \"\"\"Return all stored events for a PR newer than *since* timestamp.\"\"\"\n        with self._lock:\n            events = list(self._events.get(pr_number, []))\n        return [event for event in events if isinstance(event.get(\"ts\"), float) and cast(float, event[\"ts\"]) > since]\n\n    def prune(self, pr_number: int) -> None:\n        \"\"\"Remove stored events for a PR.\"\"\"\n        with self._lock:\n            self._events.pop(pr_number, None)\n\n\nclass RuntimeCoordinator:\n    \"\"\"Coordinate one poller and one active operation per PR.\"\"\"\n\n    def __init__(self, now: Callable[[], str]) -> None:\n        \"\"\"Initialize the in-memory coordinator.\"\"\"\n        self._now = now\n        self._lock = threading.Lock()\n        self._poller_thread: threading.Thread | None = None\n        self._poller = PollerStatus()\n        self._active: dict[int, PrOperation] = {}\n        self.stream_bus = StreamBus()\n\n    def try_start_poller(self, fn: Callable[[], str]) -> tuple[bool, str]:\n        \"\"\"Start the singleton poller if it is not already running.\"\"\"\n        with self._lock:\n            if self._poller_thread and self._poller_thread.is_alive():\n                log.info(\"poller start rejected: already active\")\n                return False, \"Review-all poller is already active\"\n            self._poller = PollerStatus(running=True, started_at=self._now())\n            self._poller_thread = threading.Thread(target=self._run_poller, args=(fn,), daemon=True)\n            self._poller_thread.start()\n        log.info(\"poller started\")\n        return True, \"Started review-all poller\"\n\n    def _run_poller(self, fn: Callable[[], str]) -> None:\n        try:\n            result = fn()\n        except Exception as exc:\n            log.error(\"poller failed: %s\", exc)\n            self._finish_poller(error=str(exc)[:500], result=\"Failed\")\n        else:\n            log.info(\"poller finished: %s\", str(result)[:200])\n            self._finish_poller(result=str(result)[:500] or \"Done\")\n\n    def _finish_poller(self, *, error: str = \"\", result: str = \"\") -> None:\n        with self._lock:\n            self._poller.running = False\n            self._poller.finished_at = self._now()\n            self._poller.error = error\n            self._poller.result = result\n\n    def try_acquire_pr(self, pr_number: int, operation: str, source: str) -> tuple[bool, str]:\n        \"\"\"Acquire the operation slot for one PR.\"\"\"\n        with self._lock:\n            current = self._active.get(pr_number)\n            if current is not None:\n                log.debug(\"PR #%d acquire rejected: busy with %s\", pr_number, current.operation)\n                return False, f\"PR #{pr_number} is busy with {current.operation}\"\n            self._active[pr_number] = PrOperation(operation=operation, source=source, started_at=self._now())\n        log.debug(\"PR #%d acquired for %s by %s\", pr_number, operation, source)\n        return True, \"\"\n\n    def release_pr(self, pr_number: int) -> None:\n        \"\"\"Release the operation slot for one PR.\"\"\"\n        with self._lock:\n            self._active.pop(pr_number, None)\n\n    def try_start_pr_operation(\n        self,\n        pr_number: int,\n        operation: str,\n        source: str,\n        fn: Callable[[], str],\n    ) -> tuple[bool, str]:\n        \"\"\"Start one background operation for one PR.\"\"\"\n        ok, message = self.try_acquire_pr(pr_number, operation, source)\n        if not ok:\n            return False, message\n        thread = threading.Thread(\n            target=self._run_pr_operation,\n            args=(pr_number, fn),\n            daemon=True,\n        )\n        thread.start()\n        return True, f\"Started {operation} for PR #{pr_number}\"\n\n    def _run_pr_operation(self, pr_number: int, fn: Callable[[], str]) -> None:\n        try:\n            fn()\n        finally:\n            self.release_pr(pr_number)\n\n    def snapshot(self) -> dict[str, object]:\n        \"\"\"Return poller and active PR operation snapshots.\"\"\"\n        with self._lock:\n            active = {str(pr_number): asdict(operation) for pr_number, operation in self._active.items()}\n            return {\"poller\": asdict(self._poller), \"active_prs\": active}","lineStart":1,"lineEnd":156,"totalLines":156,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/services/review_events.py","time":{"start":1782271719244,"end":1782271719269}},"id":"prt_ef7ac374100186AGAILExTiifQ","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7abce1d001Pv5ZMBtnSlRno5"}}
