{"type":"tool_use","timestamp":1782271679381,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_jiiuollk","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/git_worktree.py"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/git_worktree.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Concrete git worktree service.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import shutil\n6: from collections.abc import Callable\n7: from pathlib import Path\n8: \n9: from pr_review.adapters.process.subprocess_runner import run_command\n10: from pr_review.config import Config\n11: from pr_review.core.ports import CommandResult\n12: from pr_review.log import get_logger\n13: from pr_review.paths import APP_ROOT, REPO_ROOT, WORKTREES_DIR\n14: \n15: log = get_logger()\n16: Runner = Callable[..., CommandResult]\n17: GIT_TIMEOUT = 120\n18: \n19: AGENT_ASSETS = (\".opencode\", \"opencode.json\", \".agents\", \".pi\")\n20: \n21: \n22: def remove_path(path: Path) -> None:\n23:     \"\"\"Remove a file, symlink, or directory if present.\"\"\"\n24:     if not path.exists() and not path.is_symlink():\n25:         return\n26:     if path.is_symlink() or path.is_file():\n27:         path.unlink()\n28:         return\n29:     shutil.rmtree(path, ignore_errors=True)\n30: \n31: \n32: def copy_path(source: Path, destination: Path) -> None:\n33:     \"\"\"Copy one file or directory if it exists.\"\"\"\n34:     if not source.exists():\n35:         return\n36:     if source.is_dir():\n37:         shutil.copytree(source, destination, dirs_exist_ok=True)\n38:         return\n39:     shutil.copy2(source, destination)\n40: \n41: \n42: class GitWorktreeService:\n43:     \"\"\"Own git worktree lifecycle and runtime asset sync.\"\"\"\n44: \n45:     def __init__(\n46:         self,\n47:         *,\n48:         runner: Runner = run_command,\n49:         app_root: Path = APP_ROOT,\n50:         repo_root: Path = REPO_ROOT,\n51:         worktrees_dir: Path = WORKTREES_DIR,\n52:     ) -> None:\n53:         \"\"\"Initialize worktree dependencies.\"\"\"\n54:         self._runner = runner\n55:         self._app_root = app_root\n56:         self._repo_root = repo_root\n57:         self._worktrees_dir = worktrees_dir\n58: \n59:     def setup(self, pr_number: int, config: Config) -> Path | None:\n60:         \"\"\"Create or update the worktree for a pull request.\"\"\"\n61:         worktree = self._worktrees_dir / f\"pr-{pr_number}\"\n62:         if worktree.is_dir() and (worktree / \".git\").exists():\n63:             log.debug(\"PR #%d reusing existing worktree\", pr_number)\n64:             if not self._fetch_pr_head(pr_number, config):\n65:                 return None\n66:             result = self._runner(\n67:                 [\"git\", \"-C\", str(worktree), \"reset\", \"--hard\", \"FETCH_HEAD\"],\n68:                 timeout=GIT_TIMEOUT,\n69:             )\n70:             if not result.ok:\n71:                 return None\n72:             self.sync_agent_config(worktree, config)\n73:             self._ensure_draft_file(worktree, pr_number)\n74:             return worktree\n75: \n76:         self._cleanup_worktree_path(worktree)\n77:         if not self._fetch_pr_head(pr_number, config):\n78:             return None\n79: \n80:         log.debug(\"PR #%d creating new worktree\", pr_number)\n81:         add = self._git([\"worktree\", \"add\", \"--detach\", str(worktree), \"FETCH_HEAD\"])\n82:         if not add.ok:\n83:             self._cleanup_worktree_path(worktree)\n84:             return None\n85:         self.sync_agent_config(worktree, config)\n86:         self._ensure_draft_file(worktree, pr_number)\n87:         return worktree\n88: \n89:     def remove(self, pr_number: int) -> None:\n90:         \"\"\"Remove a PR worktree.\"\"\"\n91:         log.debug(\"remove_worktree: PR #%d\", pr_number)\n92:         worktree = self._worktrees_dir / f\"pr-{pr_number}\"\n93:         self._git([\"worktree\", \"remove\", \"--force\", str(worktree)])\n94:         if worktree.exists():\n95:             shutil.rmtree(worktree, ignore_errors=True)\n96: \n97:     def sync_agent_config(self, worktree: Path, _config: Config) -> None:\n98:         \"\"\"Copy all agent config assets from app root into the worktree.\"\"\"\n99:         self._prune_runtime_paths(worktree, AGENT_ASSETS)\n100:         paths = tuple(\n101:             (self._app_root / name, worktree / name) for name in AGENT_ASSETS if (self._app_root / name).exists()\n102:         )\n103:         self._copy_runtime_paths(worktree, paths)\n104: \n105:     def _ensure_draft_file(self, worktree: Path, pr_number: int) -> None:\n106:         \"\"\"Create an empty draft file so the agent's edit tool sees it exists.\"\"\"\n107:         draft_file = worktree / \".pr-review\" / f\"pr-{pr_number}-review.md\"\n108:         draft_file.parent.mkdir(parents=True, exist_ok=True)\n109:         if not draft_file.exists():\n110:             draft_file.touch()\n111: \n112:     def _git(self, args: list[str]) -> CommandResult:\n113:         return self._runner([\"git\", \"-C\", str(self._repo_root), *args], cwd=self._repo_root, timeout=GIT_TIMEOUT)\n114: \n115:     def _fetch_pr_head(self, pr_number: int, config: Config) -> bool:\n116:         result = self._git([\"fetch\", config.remote, f\"pull/{pr_number}/head\"])\n117:         return result.ok\n118: \n119:     def _cleanup_worktree_path(self, worktree: Path) -> None:\n120:         if worktree.exists():\n121:             shutil.rmtree(worktree, ignore_errors=True)\n122:         self._git([\"worktree\", \"remove\", \"--force\", str(worktree)])\n123:         self._git([\"worktree\", \"prune\"])\n124: \n125:     def _copy_runtime_paths(self, worktree: Path, paths: tuple[tuple[Path, Path], ...]) -> None:\n126:         for source, destination in paths:\n127:             parent = destination\n128:             while parent not in (worktree, parent.parent):\n129:                 if parent.is_symlink():\n130:                     remove_path(parent)\n131:                     break\n132:                 parent = parent.parent\n133:             if destination.is_symlink():\n134:                 target = destination.resolve(strict=False)\n135:                 if source.exists() and target == source.resolve():\n136:                     remove_path(destination)\n137:             if destination.exists() and source.exists() and source.is_file() != destination.is_file():\n138:                 remove_path(destination)\n139:             if source.is_dir():\n140:                 destination.mkdir(parents=True, exist_ok=True)\n141:             else:\n142:                 destination.parent.mkdir(parents=True, exist_ok=True)\n143:             copy_path(source, destination)\n144: \n145:     def _prune_runtime_paths(self, worktree: Path, names: tuple[str, ...]) -> None:\n146:         for name in names:\n147:             remove_path(worktree / name)\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"\"\"\"Concrete git worktree service.\"\"\"\n\nfrom __future__ import annotations\n\nimport shutil\nfrom collections.abc import Callable\nfrom pathlib import Path\n\nfrom pr_review.adapters.process.subprocess_runner import run_command\nfrom pr_review.config import Config\nfrom pr_review.core.ports import CommandResult\nfrom pr_review.log import get_logger\nfrom pr_review.paths import APP_ROOT, REPO_ROOT, WORKTREES_DIR\n\nlog = get_logger()\nRunner = Callable[..., CommandResult]\nGIT_TIMEOUT = 120\n\nAGENT_ASSETS = (\".opencode\", \"opencode.json\", \".agents\", \".pi\")\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/git_worktree.py","text":"\"\"\"Concrete git worktree service.\"\"\"\n\nfrom __future__ import annotations\n\nimport shutil\nfrom collections.abc import Callable\nfrom pathlib import Path\n\nfrom pr_review.adapters.process.subprocess_runner import run_command\nfrom pr_review.config import Config\nfrom pr_review.core.ports import CommandResult\nfrom pr_review.log import get_logger\nfrom pr_review.paths import APP_ROOT, REPO_ROOT, WORKTREES_DIR\n\nlog = get_logger()\nRunner = Callable[..., CommandResult]\nGIT_TIMEOUT = 120\n\nAGENT_ASSETS = (\".opencode\", \"opencode.json\", \".agents\", \".pi\")\n\n\ndef remove_path(path: Path) -> None:\n    \"\"\"Remove a file, symlink, or directory if present.\"\"\"\n    if not path.exists() and not path.is_symlink():\n        return\n    if path.is_symlink() or path.is_file():\n        path.unlink()\n        return\n    shutil.rmtree(path, ignore_errors=True)\n\n\ndef copy_path(source: Path, destination: Path) -> None:\n    \"\"\"Copy one file or directory if it exists.\"\"\"\n    if not source.exists():\n        return\n    if source.is_dir():\n        shutil.copytree(source, destination, dirs_exist_ok=True)\n        return\n    shutil.copy2(source, destination)\n\n\nclass GitWorktreeService:\n    \"\"\"Own git worktree lifecycle and runtime asset sync.\"\"\"\n\n    def __init__(\n        self,\n        *,\n        runner: Runner = run_command,\n        app_root: Path = APP_ROOT,\n        repo_root: Path = REPO_ROOT,\n        worktrees_dir: Path = WORKTREES_DIR,\n    ) -> None:\n        \"\"\"Initialize worktree dependencies.\"\"\"\n        self._runner = runner\n        self._app_root = app_root\n        self._repo_root = repo_root\n        self._worktrees_dir = worktrees_dir\n\n    def setup(self, pr_number: int, config: Config) -> Path | None:\n        \"\"\"Create or update the worktree for a pull request.\"\"\"\n        worktree = self._worktrees_dir / f\"pr-{pr_number}\"\n        if worktree.is_dir() and (worktree / \".git\").exists():\n            log.debug(\"PR #%d reusing existing worktree\", pr_number)\n            if not self._fetch_pr_head(pr_number, config):\n                return None\n            result = self._runner(\n                [\"git\", \"-C\", str(worktree), \"reset\", \"--hard\", \"FETCH_HEAD\"],\n                timeout=GIT_TIMEOUT,\n            )\n            if not result.ok:\n                return None\n            self.sync_agent_config(worktree, config)\n            self._ensure_draft_file(worktree, pr_number)\n            return worktree\n\n        self._cleanup_worktree_path(worktree)\n        if not self._fetch_pr_head(pr_number, config):\n            return None\n\n        log.debug(\"PR #%d creating new worktree\", pr_number)\n        add = self._git([\"worktree\", \"add\", \"--detach\", str(worktree), \"FETCH_HEAD\"])\n        if not add.ok:\n            self._cleanup_worktree_path(worktree)\n            return None\n        self.sync_agent_config(worktree, config)\n        self._ensure_draft_file(worktree, pr_number)\n        return worktree\n\n    def remove(self, pr_number: int) -> None:\n        \"\"\"Remove a PR worktree.\"\"\"\n        log.debug(\"remove_worktree: PR #%d\", pr_number)\n        worktree = self._worktrees_dir / f\"pr-{pr_number}\"\n        self._git([\"worktree\", \"remove\", \"--force\", str(worktree)])\n        if worktree.exists():\n            shutil.rmtree(worktree, ignore_errors=True)\n\n    def sync_agent_config(self, worktree: Path, _config: Config) -> None:\n        \"\"\"Copy all agent config assets from app root into the worktree.\"\"\"\n        self._prune_runtime_paths(worktree, AGENT_ASSETS)\n        paths = tuple(\n            (self._app_root / name, worktree / name) for name in AGENT_ASSETS if (self._app_root / name).exists()\n        )\n        self._copy_runtime_paths(worktree, paths)\n\n    def _ensure_draft_file(self, worktree: Path, pr_number: int) -> None:\n        \"\"\"Create an empty draft file so the agent's edit tool sees it exists.\"\"\"\n        draft_file = worktree / \".pr-review\" / f\"pr-{pr_number}-review.md\"\n        draft_file.parent.mkdir(parents=True, exist_ok=True)\n        if not draft_file.exists():\n            draft_file.touch()\n\n    def _git(self, args: list[str]) -> CommandResult:\n        return self._runner([\"git\", \"-C\", str(self._repo_root), *args], cwd=self._repo_root, timeout=GIT_TIMEOUT)\n\n    def _fetch_pr_head(self, pr_number: int, config: Config) -> bool:\n        result = self._git([\"fetch\", config.remote, f\"pull/{pr_number}/head\"])\n        return result.ok\n\n    def _cleanup_worktree_path(self, worktree: Path) -> None:\n        if worktree.exists():\n            shutil.rmtree(worktree, ignore_errors=True)\n        self._git([\"worktree\", \"remove\", \"--force\", str(worktree)])\n        self._git([\"worktree\", \"prune\"])\n\n    def _copy_runtime_paths(self, worktree: Path, paths: tuple[tuple[Path, Path], ...]) -> None:\n        for source, destination in paths:\n            parent = destination\n            while parent not in (worktree, parent.parent):\n                if parent.is_symlink():\n                    remove_path(parent)\n                    break\n                parent = parent.parent\n            if destination.is_symlink():\n                target = destination.resolve(strict=False)\n                if source.exists() and target == source.resolve():\n                    remove_path(destination)\n            if destination.exists() and source.exists() and source.is_file() != destination.is_file():\n                remove_path(destination)\n            if source.is_dir():\n                destination.mkdir(parents=True, exist_ok=True)\n            else:\n                destination.parent.mkdir(parents=True, exist_ok=True)\n            copy_path(source, destination)\n\n    def _prune_runtime_paths(self, worktree: Path, names: tuple[str, ...]) -> None:\n        for name in names:\n            remove_path(worktree / name)","lineStart":1,"lineEnd":147,"totalLines":147,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/services/git_worktree.py","time":{"start":1782271679360,"end":1782271679376}},"id":"prt_ef7ab9b75001NcSqeaeBLRrS6E","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab8a1c001Xqy924xzPwxOih"}}
