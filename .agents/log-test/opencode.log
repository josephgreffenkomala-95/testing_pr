s\n\nfrom collections.abc import Sequence\nfrom pathlib import Path\nfrom typing import TYPE_CHECKING, Callable\n\nfrom pr_review.adapters.agents.factory import AgentBackendFactory\nfrom pr_review.adapters.process.subprocess_runner import SubprocessCommandRunner, run_command\nfrom pr_review.config import Config\nfrom pr_review.core.models import ReviewRequest\nfrom pr_review.core.ports import CommandResult\nfrom pr_review.core.review_pipeline import ReviewPipeline, snapshot_from_state\nfrom pr_review.log import get_logger\nfrom pr_review.paths import DATA_DIR, DRAFTS_DIR, LOGS_DIR\nfrom pr_review.services.file_drafts import FileDraftStore\nfrom pr_review.services.state_store import StateStore\n\nif TYPE_CHECKING:","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/review_execution.py","text":"\"\"\"Provider-agnostic review execution and draft management.\"\"\"\n\nfrom __future__ import annotations\n\nfrom collections.abc import Sequence\nfrom pathlib import Path\nfrom typing import TYPE_CHECKING, Callable\n\nfrom pr_review.adapters.agents.factory import AgentBackendFactory\nfrom pr_review.adapters.process.subprocess_runner import SubprocessCommandRunner, run_command\nfrom pr_review.config import Config\nfrom pr_review.core.models import ReviewRequest\nfrom pr_review.core.ports import CommandResult\nfrom pr_review.core.review_pipeline import ReviewPipeline, snapshot_from_state\nfrom pr_review.log import get_logger\nfrom pr_review.paths import DATA_DIR, DRAFTS_DIR, LOGS_DIR\nfrom pr_review.services.file_drafts import FileDraftStore\nfrom pr_review.services.state_store import StateStore\n\nif TYPE_CHECKING:\n    from pr_review.services.review_events import StreamBus\n\nlog = get_logger()\n\nRunner = Callable[..., CommandResult]\n\n__all__ = [\n    \"run_review\",\n    \"run_review_streaming\",\n]\n\n\nclass _CallableCommandRunner:\n    \"\"\"Adapt legacy runner callables to the command runner port.\"\"\"\n\n    def __init__(self, runner: Runner) -> None:\n        \"\"\"Initialize the adapter.\"\"\"\n        self._runner = runner\n\n    def run(\n        self,\n        args: Sequence[str],\n        *,\n        cwd: Path | str | None = None,\n        timeout: int | float | None = None,\n        input_text: str | None = None,\n    ) -> CommandResult:\n        \"\"\"Run a command through the legacy callable.\"\"\"\n        return self._runner(args, cwd=cwd, timeout=timeout, input_text=input_text)\n\n    def stream(\n        self,\n        args: Sequence[str],\n        *,\n        cwd: Path | str | None = None,\n        timeout: int | float | None = None,\n        input_text: str | None = None,\n        on_line: Callable[[str], None] | None = None,\n    ) -> CommandResult:\n        \"\"\"Run a command through the legacy callable without live line callbacks.\"\"\"\n        _ = on_line\n        return self.run(args, cwd=cwd, timeout=timeout, input_text=input_text)\n\n\ndef _review_request(\n    pr_number: int,\n    worktree: Path,\n    config: Config,\n    state: StateStore,\n    feedback: str | None,\n) -> ReviewRequest:\n    return ReviewRequest(\n        pr=snapshot_from_state(pr_number, state),\n        repo=config.repo,\n        worktree=worktree,\n        feedback=feedback,\n        existing_draft=_load_existing_draft(pr_number, state, feedback),\n        session_id=str(state.get(pr_number, \"session_id\", \"\")),\n    )\n\n\ndef _load_existing_draft(pr_number: int, state: StateStore, feedback: str | None) -> str:\n    \"\"\"Load the previous draft text when the user is requesting a revision.\"\"\"\n    if not feedback:\n        return \"\"\n    draft_file_value = state.get(pr_number, \"draft_file\")\n    if not draft_file_value:\n        return \"\"\n    draft_path = Path(str(draft_file_value))\n    if not draft_path.exists():\n        return \"\"\n    return draft_path.read_text(encoding=\"utf-8\")\n\n\ndef run_review(\n    pr_number: int,\n    worktree: Path,\n    config: Config,\n    state: StateStore,\n    *,\n    feedback: str | None = None,\n    runner: Runner = run_command,\n    backend_factory: AgentBackendFactory | None = None,\n) -> bool:\n    \"\"\"Run or revise a provider-backed review and save its draft.\"\"\"\n    backend = (backend_factory or AgentBackendFactory()).create(config.provider)\n    pipeline = ReviewPipeline(\n        config=config,\n        backend=backend,\n        command_runner=_CallableCommandRunner(runner),\n        draft_store=FileDraftStore(DRAFTS_DIR),\n        state=state,\n        data_dir=DATA_DIR,\n        logs_dir=LOGS_DIR,\n    )\n    return pipeline.run(_review_request(pr_number, worktree, config, state, feedback)).ok\n\n\ndef run_review_streaming(\n    pr_number: int,\n    worktree: Path,\n    config: Config,\n    state: StateStore,\n    stream_bus: StreamBus,\n    *,\n    feedback: str | None = None,\n    backend_factory: AgentBackendFactory | None = None,\n) -> bool:\n    \"\"\"Run or revise a review with real-time streaming events published to *stream_bus*.\"\"\"\n    backend = (backend_factory or AgentBackendFactory()).create(config.provider)\n    pipeline = ReviewPipeline(\n        config=config,\n        backend=backend,\n        command_runner=SubprocessCommandRunner(),\n        draft_store=FileDraftStore(DRAFTS_DIR),\n        state=state,\n        data_dir=DATA_DIR,\n        logs_dir=LOGS_DIR,\n    )\n    return pipeline.run(_review_request(pr_number, worktree, config, state, feedback), events=stream_bus).ok","lineStart":1,"lineEnd":140,"totalLines":140,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/services/review_execution.py","time":{"start":1782271747282,"end":1782271747303}},"id":"prt_ef7aca4bd001a5pwRmJmqOezpj","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ac9a8d0018cAKIdiUItMrVb"}}
