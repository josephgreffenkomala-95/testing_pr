rt | None = None,\n41:     setup: Callable[[int, Config], Path | None] = setup_worktree,\n42:     reviewer: Callable[[int, Path, Config, StateStore], bool] = run_review,\n43:     stream_bus: StreamBus | None = None,\n44: ) -> PrPollingService:\n45:     return PrPollingService(\n46:         config=config,\n47:         state=state,\n48:         pr_port=pr_port or GhCliPullRequestAdapter(),\n49:         setup_worktree=setup,\n50:         remove_worktree=remove_worktree,\n51:         reviewer=reviewer,\n52:         streaming_reviewer=run_review_streaming,\n53:         stream_bus=stream_bus,\n54:     )\n55: \n56: \n57: def detect_changes(\n58:     config: Config,\n59:     state: StateStore,\n60:     *,\n61:     pr_port: PullRequestPort | None = None,\n62: ) -> tuple[int, int]:\n63:     \"\"\"Queue new or updated eligible PRs and clean closed worktrees.\"\"\"\n64:     return _polling_service(config, state, pr_port=pr_port).detect_changes()\n65: \n66: \n67: def process_pending_prs(  # noqa: PLR0913\n68:     config: Config,\n69:     state: StateStore,\n70:     *,\n71:     setup: Callable[[int, Config], Path | None] = setup_worktree,\n72:     reviewer: Callable[[int, Path, Config, StateStore], bool] = run_review,\n73:     max_workers: int | None = None,\n74:     claim_pr: Callable[[int], bool] | None = None,\n75:     release_pr: Callable[[int], None] | None = None,\n76:     stream_bus: StreamBus | None = None,\n77:     stop_event: Event | None = None,\n78: ) -> tuple[int, int]:\n79:     \"\"\"Review every pending PR with a bounded worker pool.\"\"\"\n80:     return _polling_service(\n81:         config,\n82:         state,\n83:         setup=setup,\n84:         reviewer=reviewer,\n85:         stream_bus=stream_bus,\n86:     ).process_pending(\n87:         max_workers=max_workers,\n88:         claim_pr=claim_pr,\n89:         release_pr=release_pr,\n90:         stop_event=stop_event,\n91:     )\n92: \n93: \n94: def load_runtime() -> tuple[Config, StateStore]:\n95:     \"\"\"Load config and initialize state store.\"\"\"\n96:     config = load_config()\n97:     state = StateStore(STATE_FILE, config.repo)\n98:     state.initialize()\n99:     return config, state\n100: \n101: \n102: def run_once(\n103:     config: Config,\n104:     state: StateStore,\n105:     *,\n106:     claim_pr: Callable[[int], bool] | None = None,\n107:     release_pr: Callable[[int], None] | None = None,\n108:     stream_bus: StreamBus | None = None,\n109:     pr_port: PullRequestPort | None = None,\n110: ) -> tuple[int, int, int, int]:\n111:     \"\"\"Detect changes and process pending PRs once.\"\"\"\n112:     queued, skipped = detect_changes(config, state, pr_port=pr_port)\n113:     reviewed, failed = process_pending_prs(\n114:         config,\n115:         state,\n116:         max_workers=config.max_workers,\n117:         claim_pr=claim_pr,\n118:         release_pr=release_pr,\n119:         stream_bus=stream_bus,\n120:     )\n121:     return queued, skipped, reviewed, failed\n\n(End of file - total 121 lines)\n</content>","metadata":{"preview":"\"\"\"PR polling and parallel queue processing.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom threading import Event\nfrom typing import TYPE_CHECKING, Callable\n\nfrom pr_review.adapters.github.gh_cli import GhCliPullRequestAdapter\nfrom pr_review.config import Config, load_config\nfrom pr_review.core.polling import PrPollingService\nfrom pr_review.core.ports import PullRequestPort\nfrom pr_review.log import get_logger\nfrom pr_review.paths import STATE_FILE\nfrom pr_review.services.git_worktree import GitWorktreeService\nfrom pr_review.services.review_execution import run_review, run_review_streaming\nfrom pr_review.services.state_store import StateStore\n\nif TYPE_CHECKING:\n    from pr_review.services.review_events import StreamBus","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/polling_runtime.py","text":"\"\"\"PR polling and parallel queue processing.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom threading import Event\nfrom typing import TYPE_CHECKING, Callable\n\nfrom pr_review.adapters.github.gh_cli import GhCliPullRequestAdapter\nfrom pr_review.config import Config, load_config\nfrom pr_review.core.polling import PrPollingService\nfrom pr_review.core.ports import PullRequestPort\nfrom pr_review.log import get_logger\nfrom pr_review.paths import STATE_FILE\nfrom pr_review.services.git_worktree import GitWorktreeService\nfrom pr_review.services.review_execution import run_review, run_review_streaming\nfrom pr_review.services.state_store import StateStore\n\nif TYPE_CHECKING:\n    from pr_review.services.review_events import StreamBus\n\nlog = get_logger()\n_WORKTREE_SERVICE = GitWorktreeService()\n\n\ndef setup_worktree(pr_number: int, config: Config) -> Path | None:\n    \"\"\"Create or update the worktree for a pull request.\"\"\"\n    return _WORKTREE_SERVICE.setup(pr_number, config)\n\n\ndef remove_worktree(pr_number: int) -> None:\n    \"\"\"Remove a PR worktree.\"\"\"\n    _WORKTREE_SERVICE.remove(pr_number)\n\n\ndef _polling_service(\n    config: Config,\n    state: StateStore,\n    *,\n    pr_port: PullRequestPort | None = None,\n    setup: Callable[[int, Config], Path | None] = setup_worktree,\n    reviewer: Callable[[int, Path, Config, StateStore], bool] = run_review,\n    stream_bus: StreamBus | None = None,\n) -> PrPollingService:\n    return PrPollingService(\n        config=config,\n        state=state,\n        pr_port=pr_port or GhCliPullRequestAdapter(),\n        setup_worktree=setup,\n        remove_worktree=remove_worktree,\n        reviewer=reviewer,\n        streaming_reviewer=run_review_streaming,\n        stream_bus=stream_bus,\n    )\n\n\ndef detect_changes(\n    config: Config,\n    state: StateStore,\n    *,\n    pr_port: PullRequestPort | None = None,\n) -> tuple[int, int]:\n    \"\"\"Queue new or updated eligible PRs and clean closed worktrees.\"\"\"\n    return _polling_service(config, state, pr_port=pr_port).detect_changes()\n\n\ndef process_pending_prs(  # noqa: PLR0913\n    config: Config,\n    state: StateStore,\n    *,\n    setup: Callable[[int, Config], Path | None] = setup_worktree,\n    reviewer: Callable[[int, Path, Config, StateStore], bool] = run_review,\n    max_workers: int | None = None,\n    claim_pr: Callable[[int], bool] | None = None,\n    release_pr: Callable[[int], None] | None = None,\n    stream_bus: StreamBus | None = None,\n    stop_event: Event | None = None,\n) -> tuple[int, int]:\n    \"\"\"Review every pending PR with a bounded worker pool.\"\"\"\n    return _polling_service(\n        config,\n        state,\n        setup=setup,\n        reviewer=reviewer,\n        stream_bus=stream_bus,\n    ).process_pending(\n        max_workers=max_workers,\n        claim_pr=claim_pr,\n        release_pr=release_pr,\n        stop_event=stop_event,\n    )\n\n\ndef load_runtime() -> tuple[Config, StateStore]:\n    \"\"\"Load config and initialize state store.\"\"\"\n    config = load_config()\n    state = StateStore(STATE_FILE, config.repo)\n    state.initialize()\n    return config, state\n\n\ndef run_once(\n    config: Config,\n    state: StateStore,\n    *,\n    claim_pr: Callable[[int], bool] | None = None,\n    release_pr: Callable[[int], None] | None = None,\n    stream_bus: StreamBus | None = None,\n    pr_port: PullRequestPort | None = None,\n) -> tuple[int, int, int, int]:\n    \"\"\"Detect changes and process pending PRs once.\"\"\"\n    queued, skipped = detect_changes(config, state, pr_port=pr_port)\n    reviewed, failed = process_pending_prs(\n        config,\n        state,\n        max_workers=config.max_workers,\n        claim_pr=claim_pr,\n        release_pr=release_pr,\n        stream_bus=stream_bus,\n    )\n    return queued, skipped, reviewed, failed","lineStart":1,"lineEnd":121,"totalLines":121,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/services/polling_runtime.py","time":{"start":1782271679694,"end":1782271679710}},"id":"prt_ef7ab9cc5001DLApxpwS8sd3rK","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab8a1c001Xqy924xzPwxOih"}}
{"type":"tool_use","timestamp":1782271680088,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_6ef9bydz","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/core/polling.py"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/core/polling.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Pull request polling and queue processing service.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from collections.abc import Callable\n6: from concurrent.futures import ThreadPoolExecutor, as_completed\n7: from pathlib import Path\n8: from threading import Event\n9: from typing import Any\n10: \n11: from pr_review.config import Config\n12: from pr_review.core.models import PullRequestSnapshot\n13: from pr_review.core.ports import PullRequestPort\n14: from pr_review.log import get_logger\n15: from pr_review.services.file_drafts import utc_now\n16: from pr_review.services.state_store import StateStore\n17: \n18: log = get_logger()\n19: \n20: ACTIVE_REVIEW_STATUSES = {\"reviewing\", \"revision_requested\", \"accepting\"}\n21: \n22: \n23: def pending_record(pr: PullRequestSnapshot, review_count: int = 0) -> dict[str, object]:\n24:     \"\"\"Build persisted pending state for one PR snapshot.\"\"\"\n25:     return {\n26:         \"pr_number\": pr.number,\n27:         \"status\": \"pending\",\n28:         \"head_sha\": pr.head_sha,\n29:         \"base_sha\": pr.base_sha,\n30:         \"updated_at\": utc_now(),\n31:         \"title\": pr.title,\n32:         \"author\": pr.author_login,\n33:         \"branch\": pr.branch,\n34:         \"worktree_path\": \"\",\n35:         \"draft_file\": \"\",\n36:         \"review_count\": review_count,\n37:         \"review_provider\": \"\",\n38:         \"pr_state\": pr.state,\n39:         \"needs_review\": False,\n40:         \"session_id\": \"\",\n41:     }\n42: \n43: \n44: class PrPollingService:\n45:     \"\"\"Queue and process pull requests through a review callable.\"\"\"\n46: \n47:     def __init__(  # noqa: PLR0913\n48:         self,\n49:         *,\n50:         config: Config,\n51:         state: StateStore,\n52:         pr_port: PullRequestPort,\n53:         setup_worktree: Callable[[int, Config], Path | None],\n54:         remove_worktree: Callable[[int], None],\n55:         reviewer: Callable[[int, Path, Config, StateStore], bool],\n56:         streaming_reviewer: Callable[[int, Path, Config, StateStore, Any], bool],\n57:         stream_bus: Any | None = None,\n58:     ) -> None:\n59:         \"\"\"Initialize polling dependencies.\"\"\"\n60:         self._config = config\n61:         self._state = state\n62:         self._pr_port = pr_port\n63:         self._setup_worktree = setup_worktree\n64:         self._remove_worktree = remove_worktree\n65:         self._reviewer = reviewer\n66:         self._streaming_reviewer = streaming_reviewer\n67:         self._stream_bus = stream_bus\n68: \n69:     def detect_changes(self) -> tuple[int, int]:\n70:         \"\"\"Queue new or updated eligible PRs and clean closed worktrees.\"\"\"\n71:         pull_requests = self._pr_port.list_open(self._config.repo)\n72:         open_numbers = {pr.number for pr in pull_requests}\n73:         queued = 0\n74:         skipped = 0\n75:         for pr in pull_requests:\n76:             status = self._state.get(pr.number, \"status\")\n77:             old_sha = self._state.get(pr.number, \"head_sha\")\n78:             old_base_sha = self._state.get(pr.number, \"base_sha\")\n79:             sha_changed = old_sha != pr.head_sha or old_base_sha != pr.base_sha\n80:             if not status or status == \"skipped\":\n81:                 self._state.replace_pr(pr.number, pending_record(pr))\n82:                 queued += 1\n83:             elif status in {\"submitted\", \"failed\", \"drafted\"} and sha_changed:\n84:                 count = int(self._state.get(pr.number, \"review_count\", 0))\n85:                 self._state.replace_pr(pr.number, pending_record(pr, count))\n86:                 queued += 1\n87:             elif status == \"pending\" and sha_changed:\n88:                 self._state.update_pr(\n89:                     pr.number,\n90:                     head_sha=pr.head_sha,\n91:                     base_sha=pr.base_sha,\n92:                     branch=pr.branch,\n93:                     title=pr.title,\n94:                     author=pr.author_login,\n95:                     updated_at=utc_now(),\n96:                 )\n97:             elif status in ACTIVE_REVIEW_STATUSES and sha_changed:\n98:                 self._state.update_pr(pr.number, needs_review=True, updated_at=utc_now())\n99: \n100:         for pr_number in self._state.pr_numbers():\n101:             if pr_number not in open_numbers and self._state.get(pr_number, \"status\") != \"closed\":\n102:                 log.info(\"PR #%d closed, removing worktree\", pr_number)\n103:                 self._remove_worktree(pr_number)\n104:                 self._state.update_pr(pr_number, status=\"closed\", pr_state=\"closed\", updated_at=utc_now())\n105:         self._state.flush()\n106:         log.info(\"detect_changes: queued=%d skipped=%d open=%d\", queued, skipped, len(open_numbers))\n107:         return queued, skipped\n108: \n109:     def process_pending(  # noqa: PLR0913\n110:         self,\n111:         *,\n112:         max_workers: int | None = None,\n113:         claim_pr: Callable[[int], bool] | None = None,\n114:         release_pr: Callable[[int], None] | None = None,\n115:         stop_event: Event | None = None,\n116:     ) -> tuple[int, int]:\n117:         \"\"\"Review every pending PR with a bounded worker pool.\"\"\"\n118:         pending_numbers = [\n119:             pr_number for pr_number in self._state.pr_numbers() if self._state.get(pr_number, \"status\") == \"pending\"\n120:         ]\n121:         if claim_pr is not None:\n122:             pending_numbers = [pr_number for pr_number in pending_numbers if claim_pr(pr_number)]\n123:         if not pending_numbers:\n124:             return 0, 0\n125: \n126:         reviewed = 0\n127:         failed = 0\n128:         worker_count = max(1, min(max_workers or self._config.max_workers, len(pending_numbers)))\n129:         log.info(\"process_pending_prs: %d pending, %d workers\", len(pending_numbers), worker_count)\n130: \n131:         def process_one(pr_number: int) -> tuple[int, bool]:\n132:             try:\n133:                 if stop_event is not None and stop_event.is_set():\n134:                     return pr_number, False\n135:                 worktree = self._setup_worktree(pr_number, self._config)\n136:                 if worktree is None or not worktree.is_dir():\n137:                     self._state.update_pr(\n138:                         pr_number,\n139:                         status=\"failed\",\n140:                         error_message=\"Worktree setup failed\",\n141:                         updated_at=utc_now(),\n142:                     )\n143:                     self._state.flush()\n144:                     return pr_number, False\n145:                 self._state.update_pr(pr_number, worktree_path=str(worktree))\n146:                 self._state.flush()\n147:                 if self._stream_bus is not None:\n148:                     success = self._streaming_reviewer(pr_number, worktree, self._config, self._state, self._stream_bus)\n149:                 else:\n150:                     success = self._reviewer(pr_number, worktree, self._config, self._state)\n151:                 return pr_number, success\n152:             except Exception as exc:\n153:                 log.error(\"PR #%d review error: %s\", pr_number, exc)\n154:                 self._state.update_pr(pr_number, status=\"failed\", error_message=str(exc)[:500], updated_at=utc_now())\n155:                 self._state.flush()\n156:                 return pr_number, False\n157:             finally:\n158:                 if release_pr is not None:\n159:                     release_pr(pr_number)\n160: \n161:         with ThreadPoolExecutor(max_workers=worker_count) as executor:\n162:             futures = {executor.submit(process_one, pr_number): pr_number for pr_number in pending_numbers}\n163:             for future in as_completed(futures):\n164:                 _pr_number, success = future.result()\n165:                 if success:\n166:                     reviewed += 1\n167:                 else:\n168:                     failed += 1\n169:                 if stop_event is not None and stop_event.is_set():\n170:                     for pending in futures:\n171:                         pending.cancel()\n172:                     break\n173: \n174:         log.info(\"process_pending_prs done: reviewed=%d failed=%d\", reviewed, failed)\n175:         return reviewed, failed\n176: \n177:     def run_once(\n178:         self,\n179:         *,\n180:         claim_pr: Callable[[int], bool] | None = None,\n181:         release_pr: Callable[[int], None] | None = None,\n182:     ) -> tuple[int, int, int, int]:\n183:         \"\"\"Detect changes and process pending PRs once.\"\"\"\n184:         queued, skipped = self.detect_changes()\n185:         reviewed, failed = self.process_pending(\n186:             max_workers=self._config.max_workers,\n187:             claim_pr=claim_pr,\n188:             release_pr=release_pr,\n189:         )\n190:         return queued, skipped, reviewed, failed\n\n(End of file - total 190 lines)\n</content>","metadata":{"preview":"\"\"\"Pull request polling and queue processing service.\"\"\"\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom pathlib import Path\nfrom threading import Event\nfrom typing import Any\n\nfrom pr_review.config import Config\nfrom pr_review.core.models import PullRequestSnapshot\nfrom pr_review.core.ports import PullRequestPort\nfrom pr_review.log import get_logger\nfrom pr_review.services.file_drafts import utc_now\nfrom pr_review.services.state_store import StateStore\n\nlog = get_logger()\n\nACTIVE_REVIEW_STATUSES = {\"reviewing\", \"revision_requested\", \"accepting\"}","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/core/polling.py","text":"\"\"\"Pull request polling and queue processing service.\"\"\"\n\nfrom __future__ import annotations\n\nfrom collections.abc import Callable\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom pathlib import Path\nfrom threading import Event\nfrom typing import Any\n\nfrom pr_review.config import Config\nfrom pr_review.core.models import PullRequestSnapshot\nfrom pr_review.core.ports import PullRequestPort\nfrom pr_review.log import get_logger\nfrom pr_review.services.file_drafts import utc_now\nfrom pr_review.services.state_store import StateStore\n\nlog = get_logger()\n\nACTIVE_REVIEW_STATUSES = {\"reviewing\", \"revision_requested\", \"accepting\"}\n\n\ndef pending_record(pr: PullRequestSnapshot, review_count: int = 0) -> dict[str, object]:\n    \"\"\"Build persisted pending state for one PR snapshot.\"\"\"\n    return {\n        \"pr_number\": pr.number,\n        \"status\": \"pending\",\n        \"head_sha\": pr.head_sha,\n        \"base_sha\": pr.base_sha,\n        \"updated_at\": utc_now(),\n        \"title\": pr.title,\n        \"author\": pr.author_login,\n        \"branch\": pr.branch,\n        \"worktree_path\": \"\",\n        \"draft_file\": \"\",\n        \"review_count\": review_count,\n        \"review_provider\": \"\",\n        \"pr_state\": pr.state,\n        \"needs_review\": False,\n        \"session_id\": \"\",\n    }\n\n\nclass PrPollingService:\n    \"\"\"Queue and process pull requests through a review callable.\"\"\"\n\n    def __init__(  # noqa: PLR0913\n        self,\n        *,\n        config: Config,\n        state: StateStore,\n        pr_port: PullRequestPort,\n        setup_worktree: Callable[[int, Config], Path | None],\n        remove_worktree: Callable[[int], None],\n        reviewer: Callable[[int, Path, Config, StateStore], bool],\n        streaming_reviewer: Callable[[int, Path, Config, StateStore, Any], bool],\n        stream_bus: Any | None = None,\n    ) -> None:\n        \"\"\"Initialize polling dependencies.\"\"\"\n        self._config = config\n        self._state = state\n        self._pr_port = pr_port\n        self._setup_worktree = setup_worktree\n        self._remove_worktree = remove_worktree\n        self._reviewer = reviewer\n        self._streaming_reviewer = streaming_reviewer\n        self._stream_bus = stream_bus\n\n    def detect_changes(self) -> tuple[int, int]:\n        \"\"\"Queue new or updated eligible PRs and clean closed worktrees.\"\"\"\n        pull_requests = self._pr_port.list_open(self._config.repo)\n        open_numbers = {pr.number for pr in pull_requests}\n        queued = 0\n        skipped = 0\n        for pr in pull_requests:\n            status = self._state.get(pr.number, \"status\")\n            old_sha = self._state.get(pr.number, \"head_sha\")\n            old_base_sha = self._state.get(pr.number, \"base_sha\")\n            sha_changed = old_sha != pr.head_sha or old_base_sha != pr.base_sha\n            if not status or status == \"skipped\":\n                self._state.replace_pr(pr.number, pending_record(pr))\n                queued += 1\n            elif status in {\"submitted\", \"failed\", \"drafted\"} and sha_changed:\n                count = int(self._state.get(pr.number, \"review_count\", 0))\n                self._state.replace_pr(pr.number, pending_record(pr, count))\n                queued += 1\n            elif status == \"pending\" and sha_changed:\n                self._state.update_pr(\n                    pr.number,\n                    head_sha=pr.head_sha,\n                    base_sha=pr.base_sha,\n                    branch=pr.branch,\n                    title=pr.title,\n                    author=pr.author_login,\n                    updated_at=utc_now(),\n                )\n            elif status in ACTIVE_REVIEW_STATUSES and sha_changed:\n                self._state.update_pr(pr.number, needs_review=True, updated_at=utc_now())\n\n        for pr_number in self._state.pr_numbers():\n            if pr_number not in open_numbers and self._state.get(pr_number, \"status\") != \"closed\":\n                log.info(\"PR #%d closed, removing worktree\", pr_number)\n                self._remove_worktree(pr_number)\n                self._state.update_pr(pr_number, status=\"closed\", pr_state=\"closed\", updated_at=utc_now())\n        self._state.flush()\n        log.info(\"detect_changes: queued=%d skipped=%d open=%d\", queued, skipped, len(open_numbers))\n        return queued, skipped\n\n    def process_pending(  # noqa: PLR0913\n        self,\n        *,\n        max_workers: int | None = None,\n        claim_pr: Callable[[int], bool] | None = None,\n        release_pr: Callable[[int], None] | None = None,\n        stop_event: Event | None = None,\n    ) -> tuple[int, int]:\n        \"\"\"Review every pending PR with a bounded worker pool.\"\"\"\n        pending_numbers = [\n            pr_number for pr_number in self._state.pr_numbers() if self._state.get(pr_number, \"status\") == \"pending\"\n        ]\n        if claim_pr is not None:\n            pending_numbers = [pr_number for pr_number in pending_numbers if claim_pr(pr_number)]\n        if not pending_numbers:\n            return 0, 0\n\n        reviewed = 0\n        failed = 0\n        worker_count = max(1, min(max_workers or self._config.max_workers, len(pending_numbers)))\n        log.info(\"process_pending_prs: %d pending, %d workers\", len(pending_numbers), worker_count)\n\n        def process_one(pr_number: int) -> tuple[int, bool]:\n            try:\n                if stop_event is not None and stop_event.is_set():\n                    return pr_number, False\n                worktree = self._setup_worktree(pr_number, self._config)\n                if worktree is None or not worktree.is_dir():\n                    self._state.update_pr(\n                        pr_number,\n                        status=\"failed\",\n                        error_message=\"Worktree setup failed\",\n                        updated_at=utc_now(),\n                    )\n                    self._state.flush()\n                    return pr_number, False\n                self._state.update_pr(pr_number, worktree_path=str(worktree))\n                self._state.flush()\n                if self._stream_bus is not None:\n                    success = self._streaming_reviewer(pr_number, worktree, self._config, self._state, self._stream_bus)\n                else:\n                    success = self._reviewer(pr_number, worktree, self._config, self._state)\n                return pr_number, success\n            except Exception as exc:\n                log.error(\"PR #%d review error: %s\", pr_number, exc)\n                self._state.update_pr(pr_number, status=\"failed\", error_message=str(exc)[:500], updated_at=utc_now())\n                self._state.flush()\n                return pr_number, False\n            finally:\n                if release_pr is not None:\n                    release_pr(pr_number)\n\n        with ThreadPoolExecutor(max_workers=worker_count) as executor:\n            futures = {executor.submit(process_one, pr_number): pr_number for pr_number in pending_numbers}\n            for future in as_completed(futures):\n                _pr_number, success = future.result()\n                if success:\n                    reviewed += 1\n                else:\n                    failed += 1\n                if stop_event is not None and stop_event.is_set():\n                    for pending in futures:\n                        pending.cancel()\n                    break\n\n        log.info(\"process_pending_prs done: reviewed=%d failed=%d\", reviewed, failed)\n        return reviewed, failed\n\n    def run_once(\n        self,\n        *,\n        claim_pr: Callable[[int], bool] | None = None,\n        release_pr: Callable[[int], None] | None = None,\n    ) -> tuple[int, int, int, int]:\n        \"\"\"Detect changes and process pending PRs once.\"\"\"\n        queued, skipped = self.detect_changes()\n        reviewed, failed = self.process_pending(\n            max_workers=self._config.max_workers,\n            claim_pr=claim_pr,\n            release_pr=release_pr,\n        )\n        return queued, skipped, reviewed, failed","lineStart":1,"lineEnd":190,"totalLines":190,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/core/polling.py","time":{"start":1782271680059,"end":1782271680075}},"id":"prt_ef7ab9e310018iondfj8ePJ30w","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab8a1c001Xqy924xzPwxOih"}}
