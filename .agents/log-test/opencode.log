{"type":"tool_use","timestamp":1782271650763,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_rxx4woaw","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/state_store.py"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/state_store.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Cached and atomic runtime state persistence.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import json\n6: import os\n7: import threading\n8: from pathlib import Path\n9: from typing import Any\n10: \n11: from pr_review import VERSION\n12: \n13: \n14: class StateStore:\n15:     \"\"\"In-memory state with explicit atomic flushes and thread safety.\"\"\"\n16: \n17:     _flush_lock = threading.Lock()\n18: \n19:     def __init__(self, path: Path, repository: str) -> None:\n20:         \"\"\"Load state for a repository.\"\"\"\n21:         self.path = path\n22:         self.repository = repository\n23:         self.data: dict[str, Any] = self._load()\n24:         self.dirty = False\n25:         self._lock = threading.RLock()\n26: \n27:     def _empty(self) -> dict[str, Any]:\n28:         return {\"version\": VERSION, \"repository\": self.repository, \"pr_states\": {}}\n29: \n30:     def _load(self) -> dict[str, Any]:\n31:         if not self.path.exists():\n32:             return self._empty()\n33:         try:\n34:             data = json.loads(self.path.read_text(encoding=\"utf-8\"))\n35:         except (json.JSONDecodeError, OSError):\n36:             return self._empty()\n37:         if data.get(\"version\") != VERSION or not isinstance(data.get(\"pr_states\"), dict):\n38:             return self._empty()\n39:         data[\"repository\"] = self.repository\n40:         return data\n41: \n42:     def initialize(self) -> None:\n43:         \"\"\"Persist initial state when no state file exists.\"\"\"\n44:         with self._lock:\n45:             if not self.path.exists():\n46:                 self.dirty = True\n47:                 self.flush()\n48: \n49:     def pr_numbers(self) -> list[int]:\n50:         \"\"\"Return tracked PR numbers.\"\"\"\n51:         with self._lock:\n52:             return [int(number) for number in self.data[\"pr_states\"]]\n53: \n54:     def get(self, pr_number: int, key: str, default: Any = \"\") -> Any:\n55:         \"\"\"Read a PR state field.\"\"\"\n56:         with self._lock:\n57:             return self.data[\"pr_states\"].get(str(pr_number), {}).get(key, default)\n58: \n59:     def replace_pr(self, pr_number: int, values: dict[str, Any]) -> None:\n60:         \"\"\"Replace one PR state record.\"\"\"\n61:         with self._lock:\n62:             key = str(pr_number)\n63:             self.data[\"pr_states\"][key] = values\n64:             self.dirty = True\n65: \n66:     def update_pr(self, pr_number: int, **values: Any) -> None:\n67:         \"\"\"Update fields on one PR state record.\"\"\"\n68:         with self._lock:\n69:             key = str(pr_number)\n70:             record = self.data[\"pr_states\"].setdefault(key, {})\n71:             record.update(values)\n72:             self.dirty = True\n73: \n74:     def remove_pr(self, pr_number: int) -> None:\n75:         \"\"\"Remove one PR state record.\"\"\"\n76:         with self._lock:\n77:             key = str(pr_number)\n78:             if self.data[\"pr_states\"].pop(key, None) is not None:\n79:                 self.dirty = True\n80: \n81:     def flush(self) -> None:\n82:         \"\"\"Atomically persist current in-memory state with last-write-wins semantics.\"\"\"\n83:         with self._lock:\n84:             if not self.dirty:\n85:                 return\n86:             data = json.loads(json.dumps(self.data))\n87:             data[\"repository\"] = self.repository\n88:             self.path.parent.mkdir(parents=True, exist_ok=True)\n89:             with self._flush_lock:\n90:                 temporary = self.path.with_name(f\"{self.path.name}.tmp.{os.getpid()}\")\n91:                 temporary.write_text(json.dumps(data, indent=2) + \"\\n\", encoding=\"utf-8\")\n92:                 os.replace(temporary, self.path)\n93:                 self.data = data\n94:                 self.dirty = False\n\n(End of file - total 94 lines)\n</content>","metadata":{"preview":"\"\"\"Cached and atomic runtime state persistence.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport threading\nfrom pathlib import Path\nfrom typing import Any\n\nfrom pr_review import VERSION\n\n\nclass StateStore:\n    \"\"\"In-memory state with explicit atomic flushes and thread safety.\"\"\"\n\n    _flush_lock = threading.Lock()\n\n    def __init__(self, path: Path, repository: str) -> None:\n        \"\"\"Load state for a repository.\"\"\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/state_store.py","text":"\"\"\"Cached and atomic runtime state persistence.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport threading\nfrom pathlib import Path\nfrom typing import Any\n\nfrom pr_review import VERSION\n\n\nclass StateStore:\n    \"\"\"In-memory state with explicit atomic flushes and thread safety.\"\"\"\n\n    _flush_lock = threading.Lock()\n\n    def __init__(self, path: Path, repository: str) -> None:\n        \"\"\"Load state for a repository.\"\"\"\n        self.path = path\n        self.repository = repository\n        self.data: dict[str, Any] = self._load()\n        self.dirty = False\n        self._lock = threading.RLock()\n\n    def _empty(self) -> dict[str, Any]:\n        return {\"version\": VERSION, \"repository\": self.repository, \"pr_states\": {}}\n\n    def _load(self) -> dict[str, Any]:\n        if not self.path.exists():\n            return self._empty()\n        try:\n            data = json.loads(self.path.read_text(encoding=\"utf-8\"))\n        except (json.JSONDecodeError, OSError):\n            return self._empty()\n        if data.get(\"version\") != VERSION or not isinstance(data.get(\"pr_states\"), dict):\n            return self._empty()\n        data[\"repository\"] = self.repository\n        return data\n\n    def initialize(self) -> None:\n        \"\"\"Persist initial state when no state file exists.\"\"\"\n        with self._lock:\n            if not self.path.exists():\n                self.dirty = True\n                self.flush()\n\n    def pr_numbers(self) -> list[int]:\n        \"\"\"Return tracked PR numbers.\"\"\"\n        with self._lock:\n            return [int(number) for number in self.data[\"pr_states\"]]\n\n    def get(self, pr_number: int, key: str, default: Any = \"\") -> Any:\n        \"\"\"Read a PR state field.\"\"\"\n        with self._lock:\n            return self.data[\"pr_states\"].get(str(pr_number), {}).get(key, default)\n\n    def replace_pr(self, pr_number: int, values: dict[str, Any]) -> None:\n        \"\"\"Replace one PR state record.\"\"\"\n        with self._lock:\n            key = str(pr_number)\n            self.data[\"pr_states\"][key] = values\n            self.dirty = True\n\n    def update_pr(self, pr_number: int, **values: Any) -> None:\n        \"\"\"Update fields on one PR state record.\"\"\"\n        with self._lock:\n            key = str(pr_number)\n            record = self.data[\"pr_states\"].setdefault(key, {})\n            record.update(values)\n            self.dirty = True\n\n    def remove_pr(self, pr_number: int) -> None:\n        \"\"\"Remove one PR state record.\"\"\"\n        with self._lock:\n            key = str(pr_number)\n            if self.data[\"pr_states\"].pop(key, None) is not None:\n                self.dirty = True\n\n    def flush(self) -> None:\n        \"\"\"Atomically persist current in-memory state with last-write-wins semantics.\"\"\"\n        with self._lock:\n            if not self.dirty:\n                return\n            data = json.loads(json.dumps(self.data))\n            data[\"repository\"] = self.repository\n            self.path.parent.mkdir(parents=True, exist_ok=True)\n            with self._flush_lock:\n                temporary = self.path.with_name(f\"{self.path.name}.tmp.{os.getpid()}\")\n                temporary.write_text(json.dumps(data, indent=2) + \"\\n\", encoding=\"utf-8\")\n                os.replace(temporary, self.path)\n                self.data = data\n                self.dirty = False","lineStart":1,"lineEnd":94,"totalLines":94,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/services/state_store.py","time":{"start":1782271650637,"end":1782271650759}},"id":"prt_ef7ab2b35001NaVpwmqOSRI5DW","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab1f78001hegsxKhN17AYGh"}}
