"error\", error=message or \"unknown error\")\n68:         if event_type == \"step_end\":\n69:             return StreamEvent(event_type=\"step_end\")\n70:         return StreamEvent(event_type=event_type or \"unknown\")\n\n(End of file - total 70 lines)\n</content>","metadata":{"preview":"\"\"\"OpenCode agent adapter.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\n\nfrom pr_review.adapters.agents.base import provider_option_args\nfrom pr_review.core.ports import AgentInvocationRequest, CommandResult, Invocation, ParsedBackendResult, StreamEvent\n\n\nclass OpenCodeBackend:\n    \"\"\"OpenCode adapter.\"\"\"\n\n    name = \"opencode\"\n    supports_resume = True\n    output_mode = \"file_write\"\n\n    def build_invocation(self, request: AgentInvocationRequest) -> Invocation:\n        \"\"\"Build the `opencode run` invocation for this review.\"\"\"\n        command = [\"opencode\", \"run\", \"--dir\", str(request.worktree)]","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/adapters/agents/opencode.py","text":"\"\"\"OpenCode agent adapter.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\n\nfrom pr_review.adapters.agents.base import provider_option_args\nfrom pr_review.core.ports import AgentInvocationRequest, CommandResult, Invocation, ParsedBackendResult, StreamEvent\n\n\nclass OpenCodeBackend:\n    \"\"\"OpenCode adapter.\"\"\"\n\n    name = \"opencode\"\n    supports_resume = True\n    output_mode = \"file_write\"\n\n    def build_invocation(self, request: AgentInvocationRequest) -> Invocation:\n        \"\"\"Build the `opencode run` invocation for this review.\"\"\"\n        command = [\"opencode\", \"run\", \"--dir\", str(request.worktree)]\n        if request.is_revision and request.session_id:\n            command.extend([\"--session\", request.session_id])\n        command.extend([\"--agent\", request.agent, \"--format\", \"json\", \"--file\", str(request.prompt_file)])\n        if not request.is_revision:\n            command.extend([\"--title\", f\"pr-review-{request.agent}\"])\n        if request.model:\n            command.extend([\"--model\", request.model])\n        command.extend(provider_option_args(request.provider_options))\n        command.extend([\"--\", \"Run PR review prompt from attached file\"])\n        return Invocation(command)\n\n    def parse_result(self, result: CommandResult) -> ParsedBackendResult:\n        \"\"\"Extract the session id from OpenCode JSONL output.\"\"\"\n        session_id = \"\"\n        errors: list[str] = []\n        for line in result.stdout.splitlines():\n            try:\n                event = json.loads(line)\n            except json.JSONDecodeError:\n                continue\n            event_type = event.get(\"type\")\n            if event_type == \"step_start\" and not session_id:\n                session_id = event.get(\"sessionID\") or event.get(\"part\", {}).get(\"sessionID\", \"\")\n            elif event_type == \"error\":\n                error = event.get(\"error\", {})\n                message = error.get(\"data\", {}).get(\"message\", \"\") if isinstance(error, dict) else str(error)\n                if message:\n                    errors.append(message)\n        return ParsedBackendResult(\"\", session_id, tuple(errors))\n\n    def parse_stream_line(self, line: str) -> StreamEvent | None:\n        \"\"\"Map one OpenCode stream event into the dashboard event schema.\"\"\"\n        try:\n            event = json.loads(line)\n        except json.JSONDecodeError:\n            return None\n        event_type = event.get(\"type\")\n        if event_type == \"step_start\":\n            sid = event.get(\"sessionID\") or event.get(\"part\", {}).get(\"sessionID\", \"\")\n            return StreamEvent(event_type=\"session_start\", session_id=sid)\n        if event_type == \"text\":\n            text = event.get(\"part\", {}).get(\"text\", \"\")\n            return StreamEvent(event_type=\"text\", text=text)\n        if event_type == \"error\":\n            error = event.get(\"error\", {})\n            message = error.get(\"data\", {}).get(\"message\", \"\") if isinstance(error, dict) else str(error)\n            return StreamEvent(event_type=\"error\", error=message or \"unknown error\")\n        if event_type == \"step_end\":\n            return StreamEvent(event_type=\"step_end\")\n        return StreamEvent(event_type=event_type or \"unknown\")","lineStart":1,"lineEnd":70,"totalLines":70,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/adapters/agents/opencode.py","time":{"start":1782271647120,"end":1782271647137}},"id":"prt_ef7ab1d87001XCN46Jkv8300rX","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab0a68001pKfQDW7DSoKZxZ"}}
