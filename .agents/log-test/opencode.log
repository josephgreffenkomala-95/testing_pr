he session id from Claude Code output if present.\"\"\"\n32:         stdout = result.stdout.strip()\n33:         if not stdout:\n34:             return ParsedBackendResult(\"\", \"\", tuple(filter(None, [result.stderr.strip()])))\n35:         try:\n36:             payload = json.loads(stdout)\n37:         except json.JSONDecodeError:\n38:             return ParsedBackendResult(\"\", \"\", tuple(filter(None, [result.stderr.strip()])))\n39:         session_id = str(payload.get(\"session_id\", \"\")).strip()\n40:         errors: list[str] = []\n41:         if not session_id:\n42:             errors.append(\"missing session_id in Claude Code response\")\n43:         return ParsedBackendResult(\"\", session_id, tuple(errors))\n44: \n45:     def parse_stream_line(self, line: str) -> StreamEvent | None:\n46:         \"\"\"Map one Claude Code stream event into the dashboard event schema.\"\"\"\n47:         try:\n48:             event = json.loads(line)\n49:         except json.JSONDecodeError:\n50:             return None\n51:         if \"structured_output\" in event:\n52:             return StreamEvent(event_type=\"text\", text=line)\n53:         if \"session_id\" in event:\n54:             return StreamEvent(event_type=\"session_start\", session_id=str(event.get(\"session_id\", \"\")).strip())\n55:         if \"result\" in event:\n56:             return StreamEvent(event_type=\"text\", text=str(event.get(\"result\", \"\")))\n57:         return StreamEvent(event_type=event.get(\"type\", \"unknown\"))\n\n(End of file - total 57 lines)\n</content>","metadata":{"preview":"\"\"\"Claude Code agent adapter.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\n\nfrom pr_review.adapters.agents.base import provider_option_args\nfrom pr_review.core.ports import AgentInvocationRequest, CommandResult, Invocation, ParsedBackendResult, StreamEvent\n\n\nclass ClaudeCodeBackend:\n    \"\"\"Claude Code adapter.\"\"\"\n\n    name = \"claude-code\"\n    supports_resume = True\n    output_mode = \"file_write\"\n\n    def build_invocation(self, request: AgentInvocationRequest) -> Invocation:\n        \"\"\"Build the `claude` invocation for this review.\"\"\"\n        command = [\"claude\", \"--bare\", \"-p\", \"-\", \"--output-format\", \"json\", \"--dangerously-skip-permissions\"]","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/adapters/agents/claude_code.py","text":"\"\"\"Claude Code agent adapter.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\n\nfrom pr_review.adapters.agents.base import provider_option_args\nfrom pr_review.core.ports import AgentInvocationRequest, CommandResult, Invocation, ParsedBackendResult, StreamEvent\n\n\nclass ClaudeCodeBackend:\n    \"\"\"Claude Code adapter.\"\"\"\n\n    name = \"claude-code\"\n    supports_resume = True\n    output_mode = \"file_write\"\n\n    def build_invocation(self, request: AgentInvocationRequest) -> Invocation:\n        \"\"\"Build the `claude` invocation for this review.\"\"\"\n        command = [\"claude\", \"--bare\", \"-p\", \"-\", \"--output-format\", \"json\", \"--dangerously-skip-permissions\"]\n        if request.agent_prompt:\n            command.extend([\"--append-system-prompt\", request.agent_prompt])\n        if request.session_id and request.is_revision:\n            command.extend([\"--resume\", request.session_id])\n        if request.model:\n            command.extend([\"--model\", request.model])\n        command.extend(provider_option_args(request.provider_options))\n        return Invocation(command, input_text=request.prompt_file.read_text(encoding=\"utf-8\"))\n\n    def parse_result(self, result: CommandResult) -> ParsedBackendResult:\n        \"\"\"Extract the session id from Claude Code output if present.\"\"\"\n        stdout = result.stdout.strip()\n        if not stdout:\n            return ParsedBackendResult(\"\", \"\", tuple(filter(None, [result.stderr.strip()])))\n        try:\n            payload = json.loads(stdout)\n        except json.JSONDecodeError:\n            return ParsedBackendResult(\"\", \"\", tuple(filter(None, [result.stderr.strip()])))\n        session_id = str(payload.get(\"session_id\", \"\")).strip()\n        errors: list[str] = []\n        if not session_id:\n            errors.append(\"missing session_id in Claude Code response\")\n        return ParsedBackendResult(\"\", session_id, tuple(errors))\n\n    def parse_stream_line(self, line: str) -> StreamEvent | None:\n        \"\"\"Map one Claude Code stream event into the dashboard event schema.\"\"\"\n        try:\n            event = json.loads(line)\n        except json.JSONDecodeError:\n            return None\n        if \"structured_output\" in event:\n            return StreamEvent(event_type=\"text\", text=line)\n        if \"session_id\" in event:\n            return StreamEvent(event_type=\"session_start\", session_id=str(event.get(\"session_id\", \"\")).strip())\n        if \"result\" in event:\n            return StreamEvent(event_type=\"text\", text=str(event.get(\"result\", \"\")))\n        return StreamEvent(event_type=event.get(\"type\", \"unknown\"))","lineStart":1,"lineEnd":57,"totalLines":57,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/adapters/agents/claude_code.py","time":{"start":1782271691034,"end":1782271691046}},"id":"prt_ef7abc912001dCmS8GcmtlxWAO","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7abb0dc00104BBao98xptfEA"}}
