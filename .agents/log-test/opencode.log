 pr_port: PullRequestPort | None = None,\n46: ) -> SubmissionResult:\n47:     \"\"\"Submit one persisted draft as a single GitHub review event.\"\"\"\n48:     return DraftSubmissionService(\n49:         config=config,\n50:         pr_port=pr_port or GhCliPullRequestAdapter(),\n51:         state=state,\n52:     ).submit(pr_number)\n\n(End of file - total 52 lines)\n</content>","metadata":{"preview":"\"\"\"Shared human-review actions for drafted PR reviews.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pr_review.adapters.github.gh_cli import GhCliPullRequestAdapter\nfrom pr_review.config import Config\nfrom pr_review.core.draft_submission import DraftSubmissionService\nfrom pr_review.core.models import DraftDetail, SubmissionResult\nfrom pr_review.core.ports import PullRequestPort\nfrom pr_review.core.revision_feedback import build_revision_feedback\nfrom pr_review.log import get_logger\nfrom pr_review.services.state_store import StateStore\n\nlog = get_logger()\n\n__all__ = [\n    \"DraftDetail\",\n    \"SubmissionResult\",\n    \"build_revision_feedback\",\n    \"load_draft_detail\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/services/draft_actions.py","text":"\"\"\"Shared human-review actions for drafted PR reviews.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pr_review.adapters.github.gh_cli import GhCliPullRequestAdapter\nfrom pr_review.config import Config\nfrom pr_review.core.draft_submission import DraftSubmissionService\nfrom pr_review.core.models import DraftDetail, SubmissionResult\nfrom pr_review.core.ports import PullRequestPort\nfrom pr_review.core.revision_feedback import build_revision_feedback\nfrom pr_review.log import get_logger\nfrom pr_review.services.state_store import StateStore\n\nlog = get_logger()\n\n__all__ = [\n    \"DraftDetail\",\n    \"SubmissionResult\",\n    \"build_revision_feedback\",\n    \"load_draft_detail\",\n    \"submit_draft_review\",\n]\n\n\ndef load_draft_detail(\n    pr_number: int,\n    config: Config,\n    state: StateStore,\n    *,\n    pr_port: PullRequestPort | None = None,\n) -> DraftDetail:\n    \"\"\"Load one persisted draft and compute its submission preview.\"\"\"\n    return DraftSubmissionService(\n        config=config,\n        pr_port=pr_port or GhCliPullRequestAdapter(),\n        state=state,\n    ).load_detail(pr_number)\n\n\ndef submit_draft_review(\n    pr_number: int,\n    config: Config,\n    state: StateStore,\n    *,\n    pr_port: PullRequestPort | None = None,\n) -> SubmissionResult:\n    \"\"\"Submit one persisted draft as a single GitHub review event.\"\"\"\n    return DraftSubmissionService(\n        config=config,\n        pr_port=pr_port or GhCliPullRequestAdapter(),\n        state=state,\n    ).submit(pr_number)","lineStart":1,"lineEnd":52,"totalLines":52,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/services/draft_actions.py","time":{"start":1782271747543,"end":1782271747559}},"id":"prt_ef7aca5ce001kaSU5Ptbr9Enrx","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ac9a8d0018cAKIdiUItMrVb"}}
