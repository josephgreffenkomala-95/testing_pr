{"type":"tool_use","timestamp":1782271683688,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_1j1ac0vo","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/web.py"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/web.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"Thin web UI for launching PR review runs.\"\"\"\n3: \n4: from __future__ import annotations\n5: \n6: import argparse\n7: import asyncio\n8: import json\n9: from dataclasses import asdict\n10: from pathlib import Path\n11: from typing import Any, Callable, cast\n12: \n13: import uvicorn\n14: from fastapi import FastAPI, HTTPException\n15: from fastapi.responses import HTMLResponse, StreamingResponse\n16: from fastapi.staticfiles import StaticFiles\n17: from pydantic import BaseModel\n18: \n19: from .adapters.process.subprocess_runner import run_command\n20: from .config import Config, ConfigError, load_config\n21: from .core.review_parser import InlineComment\n22: from .log import get_logger\n23: from .paths import APP_ROOT, STATE_FILE, init_dirs\n24: from .services.draft_actions import (\n25:     build_revision_feedback,\n26:     load_draft_detail,\n27:     submit_draft_review,\n28: )\n29: from .services.file_drafts import utc_now\n30: from .services.polling_runtime import run_once\n31: from .services.review_events import RuntimeCoordinator\n32: from .services.review_execution import run_review_streaming\n33: from .services.state_store import StateStore\n34: \n35: \n36: def _load_fresh_config() -> Config:\n37:     \"\"\"Load config from disk (expensive: reads JSON + git subprocess).\"\"\"\n38:     return load_config()\n39: \n40: \n41: def _state(config: Config) -> StateStore:\n42:     \"\"\"Build a fresh StateStore from the cached config (cheap: one file read).\"\"\"\n43:     state = StateStore(STATE_FILE, config.repo)\n44:     state.initialize()\n45:     return state\n46: \n47: \n48: def _run_pr_task(\n49:     pr_number: int,\n50:     task: Callable[[Config, StateStore], str],\n51:     *,\n52:     status_on_error: str | None = None,\n53: ) -> str:\n54:     config = _config_cache[0]\n55:     state = _state(config)\n56:     try:\n57:         return task(config, state)\n58:     except Exception as exc:\n59:         state.update_pr(\n60:             pr_number,\n61:             status=status_on_error or str(state.get(pr_number, \"status\") or \"failed\"),\n62:             error_message=str(exc)[:500],\n63:             updated_at=utc_now(),\n64:         )\n65:         state.flush()\n66:         raise\n67: \n68: \n69: def _run_pr_task_streaming(\n70:     pr_number: int,\n71:     task: Callable[[Config, StateStore], str],\n72:     *,\n73:     status_on_error: str | None = None,\n74: ) -> str:\n75:     config = _config_cache[0]\n76:     state = _state(config)\n77:     try:\n78:         return task(config, state)\n79:     except Exception as exc:\n80:         coordinator.stream_bus.publish(pr_number, \"error\", {\"message\": str(exc)[:500]})\n81:         state.update_pr(\n82:             pr_number,\n83:             status=status_on_error or str(state.get(pr_number, \"status\") or \"failed\"),\n84:             error_message=str(exc)[:500],\n85:             updated_at=utc_now(),\n86:         )\n87:         state.flush()\n88:         raise\n89: \n90: \n91: def _read_pr_states(active_ops: dict[str, object] | None = None) -> list[dict[str, object]]:\n92:     state = StateStore(STATE_FILE, \"\")\n93:     prs: list[dict[str, object]] = []\n94:     active_ops = active_ops or {}\n95:     for number in state.pr_numbers():\n96:         record = state.data[\"pr_states\"].get(str(number))\n97:         if isinstance(record, dict):\n98:             op = cast(dict[str, object], active_ops.get(str(number), {}))\n99:             prs.append(\n100:                 {\n101:                     \"pr_number\": number,\n102:                     **record,\n103:                     \"active_operation\": op.get(\"operation\", \"\"),\n104:                     \"active_source\": op.get(\"source\", \"\"),\n105:                     \"active_started_at\": op.get(\"started_at\", \"\"),\n106:                 }\n107:             )\n108:     prs.sort(key=lambda item: cast(int, item[\"pr_number\"]), reverse=True)\n109:     return prs\n110: \n111: \n112: def _load_config_payload() -> dict[str, object]:\n113:     try:\n114:         return asdict(_config_cache[0])\n115:     except ConfigError as exc:\n116:         return {\"error\": str(exc)}\n117:     except Exception as exc:\n118:         return {\"error\": str(exc)[:500]}\n119: \n120: \n121: def _draft_payload(pr_number: int) -> dict[str, object]:\n122:     config = _config_cache[0]\n123:     state = _state(config)\n124:     if not state.get(pr_number, \"status\"):\n125:         raise RuntimeError(f\"PR #{pr_number} not found in saved state\")\n126:     detail = load_draft_detail(pr_number, config, state)\n127:     active_prs = cast(dict[str, dict[str, object]], coordinator.snapshot()[\"active_prs\"])\n128:     active = active_prs.get(str(pr_number), {})\n129:     return {\n130:         \"pr_number\": pr_number,\n131:         \"title\": state.get(pr_number, \"title\"),\n132:         \"status\": state.get(pr_number, \"status\"),\n133:         \"draft_file\": str(detail.draft_file),\n134:         \"updated_at\": state.get(pr_number, \"updated_at\"),\n135:         \"needs_review\": bool(state.get(pr_number, \"needs_review\", False)),\n136:         \"active_operation\": active.get(\"operation\", \"\"),\n137:         \"active_source\": active.get(\"source\", \"\"),\n138:         \"summary\": detail.parsed.summary,\n139:         \"findings\": detail.parsed.findings,\n140:         \"assessment\": detail.parsed.assessment,\n141:         \"body\": detail.parsed.body,\n142:         \"errors\": detail.parsed.errors,\n143:         \"inline_comments\": [\n144:             {\n145:                 \"path\": comment.path,\n146:                 \"line\": comment.line,\n147:                 \"body\": comment.body,\n148:                 \"key\": f\"{comment.path}:{comment.line}\",\n149:             }\n150:             for comment in detail.parsed.comments\n151:         ],\n152:         \"preview\": {\n153:             \"assessment\": detail.preview.assessment,\n154:             \"valid_comment_count\": len(detail.preview.valid_comments),\n155:             \"detached_comment_count\": len(detail.preview.detached_comments),\n156:             \"skipped_reasons\": detail.preview.skipped_reasons,\n157:         },\n158:     }\n159: \n160: \n161: def _parse_unified_diff(diff_text: str) -> list[dict[str, object]]:\n162:     files: list[dict[str, object]] = []\n163:     current: dict[str, object] | None = None\n164:     current_lines: list[dict[str, str]] = []\n165:     pending_file = \"\"\n166:     for raw_line in diff_text.splitlines():\n167:         if raw_line.startswith(\"diff --git \"):\n168:             if current is not None:\n169:                 current[\"lines\"] = current_lines\n170:                 files.append(current)\n171:             parts = raw_line.split()\n172:             pending_file = parts[3][2:] if len(parts) >= _DIFF_GIT_FIELDS and parts[3].startswith(\"b/\") else \"\"\n173:             current = None\n174:             current_lines = []\n175:             continue\n176:         if raw_line.startswith(\"+++ \"):\n177:             file_name = raw_line[6:] if raw_line.startswith(\"+++ b/\") else raw_line[4:]\n178:             if file_name == \"/dev/null\":\n179:                 file_name = pending_file\n180:             current = {\"file\": file_name or pending_file, \"lines\": []}\n181:             continue\n182:         if current is None:\n183:             continue\n184:         line_type = \"ctx\"\n185:         if raw_line.startswith(\"+\") and not raw_line.startswith(\"+++\"):\n186:             line_type = \"add\"\n187:         elif raw_line.startswith(\"-\") and not raw_line.startswith(\"---\"):\n188:             line_type = \"del\"\n189:         current_lines.append({\"t\": line_type, \"c\": raw_line})\n190:     if current is not None:\n191:         current[\"lines\"] = current_lines\n192:         files.append(current)\n193:     return files\n194: \n195: \n196: def _diff_payload(pr_number: int) -> dict[str, object]:\n197:     config = _config_cache[0]\n198:     state = _state(config)\n199:     if not state.get(pr_number, \"status\"):\n200:         raise HTTPException(status_code=400, detail=f\"PR #{pr_number} not found in saved state\")\n201:     worktree = Path(str(state.get(pr_number, \"worktree_path\", \"\")))\n202:     if not str(worktree) or not worktree.exists():\n203:         raise HTTPException(status_code=400, detail=f\"Worktree not found for PR #{pr_number}\")\n204:     base_sha = str(state.get(pr_number, \"base_sha\", \"\"))\n205:     head_sha = str(state.get(pr_number, \"head_sha\", \"\"))\n206:     result = run_command(\n207:         [\"git\", \"-C\", str(worktree), \"diff\", f\"{base_sha}..{head_sha}\", \"--no-color\"],\n208:         timeout=config.timeout,\n209:     )\n210:     if not result.ok:\n211:         raise HTTPException(status_code=500, detail=(result.stderr or \"git diff failed\")[:500])\n212:     return {\"pr_number\": pr_number, \"files\": _parse_unified_diff(result.stdout)}\n213: \n214: \n215: def _spa_assets_dir() -> Path:\n216:     return APP_ROOT / \"web\" / \"dist\" / \"assets\"\n217: \n218: \n219: def _spa_index_path() -> Path:\n220:     return APP_ROOT / \"web\" / \"dist\" / \"index.html\"\n221: \n222: \n223: def _spa_stub_html() -> str:\n224:     return \"\"\"<!DOCTYPE html>\n225: <html lang=\"en\">\n226: <head>\n227:   <meta charset=\"utf-8\" />\n228:   <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n229:   <title>Agent Reviewer</title>\n230:   <style>\n231:     body { background: #09090b; color: #e4e4e7; font-family: sans-serif; margin: 0; }\n232:     main { max-width: 42rem; margin: 10vh auto; padding: 2rem; }\n233:     code { background: #18181b; border-radius: 0.375rem; padding: 0.125rem 0.375rem; }\n234:   </style>\n235: </head>\n236: <body>\n237:   <main>\n238:     <h1>UI build missing</h1>\n239:     <p>Run <code>npm install</code> and <code>npm run build</code> in <code>web/</code>, then reload.</p>\n240:   </main>\n241: </body>\n242: </html>\n243: \"\"\"\n244: \n245: \n246: def _dashboard_html() -> str:\n247:     index_path = _spa_index_path()\n248:     if index_path.exists():\n249:         return index_path.read_text(encoding=\"utf-8\")\n250:     return _spa_stub_html()\n251: \n252: \n253: def _event_timestamp(event: dict[str, object]) -> float:\n254:     \"\"\"Return the event timestamp as a float for SSE bookkeeping.\"\"\"\n255:     ts = event.get(\"ts\")\n256:     return ts if isinstance(ts, float) else 0.0\n257: \n258: \n259: init_dirs()\n260: coordinator = RuntimeCoordinator(utc_now)\n261: _config_cache: list[Config] = [_load_fresh_config()]\n262: _DIFF_GIT_FIELDS = 4\n263: \n264: app = FastAPI(title=\"PR Review Dashboard\")\n265: if _spa_assets_dir().exists():\n266:     app.mount(\"/assets\", StaticFiles(directory=_spa_assets_dir()), name=\"assets\")\n267: \n268: \n269: class ReviseBody(BaseModel):\n270:     \"\"\"Request body for revising a draft review.\"\"\"\n271: \n272:     feedback: str = \"\"\n273:     inline_feedback: dict[str, str] = {}\n274: \n275: \n276: @app.get(\"/\")\n277: async def serve_root() -> HTMLResponse:\n278:     \"\"\"Serve the dashboard HTML.\"\"\"\n279:     return HTMLResponse(_dashboard_html())\n280: \n281: \n282: @app.get(\"/draft/{pr_number}\")\n283: async def serve_draft(pr_number: int) -> HTMLResponse:  # noqa: ARG001\n284:     \"\"\"Serve the dashboard HTML (SPA handles routing).\"\"\"\n285:     return HTMLResponse(_dashboard_html())\n286: \n287: \n288: @app.get(\"/api/status\")\n289: async def api_status() -> dict[str, Any]:\n290:     \"\"\"Return the current job state, config, and PR list.\"\"\"\n291:     snap = cast(dict[str, object], coordinator.snapshot())\n292:     poller = cast(dict[str, object], snap[\"poller\"])\n293:     if poller[\"running\"]:\n294:         status = \"running\"\n295:     elif poller[\"error\"]:\n296:         status = \"failed\"\n297:     elif poller[\"finished_at\"]:\n298:         status = \"done\"\n299:     else:\n300:         status = \"idle\"\n301:     run_payload = {\n302:         \"status\": status,\n303:         \"mode\": \"all\" if poller[\"running\"] or poller[\"finished_at\"] else \"-\",\n304:         \"started_at\": poller[\"started_at\"],\n305:         \"finished_at\": poller[\"finished_at\"],\n306:         \"last_error\": poller[\"error\"],\n307:         \"last_result\": poller[\"result\"],\n308:     }\n309:     return {\n310:         \"run\": run_payload,\n311:         \"config\": _load_config_payload(),\n312:         \"prs\": _read_pr_states(cast(dict[str, object], snap[\"active_prs\"])),\n313:         \"active_prs\": cast(dict[str, object], snap[\"active_prs\"]),\n314:     }\n315: \n316: \n317: @app.get(\"/api/drafts/{pr_number}\")\n318: async def api_draft(pr_number: int) -> dict[str, Any]:\n319:     \"\"\"Return parsed draft data for a PR.\"\"\"\n320:     try:\n321:         return _draft_payload(pr_number)\n322:     except (ConfigError, RuntimeError) as exc:\n323:         raise HTTPException(status_code=400, detail=str(exc)) from exc\n324: \n325: \n326: @app.get(\"/api/diff/{pr_number}\")\n327: async def api_diff(pr_number: int) -> dict[str, Any]:\n328:     \"\"\"Return unified diff lines for one PR.\"\"\"\n329:     return _diff_payload(pr_number)\n330: \n331: \n332: @app.post(\"/api/review-all\")\n333: async def api_review_all() -> dict[str, str]:\n334:     \"\"\"Start reviewing all open PRs.\"\"\"\n335: \n336:     def review_all() -> str:\n337:         _config_cache[0] = _load_fresh_config()\n338:         config = _config_cache[0]\n339:         state = _state(config)\n340:         queued, skipped, reviewed, failed = run_once(\n341:             config,\n342:             state,\n343:             claim_pr=lambda pr_number: coordinator.try_acquire_pr(pr_number, \"review\", \"poller\")[0],\n344:             release_pr=coordinator.release_pr,\n345:             stream_bus=coordinator.stream_bus,\n346:         )\n347:         return f\"Done: queued={queued} skipped={skipped} reviewed={reviewed} failed={failed}\"\n348: \n349:     ok, message = coordinator.try_start_poller(review_all)\n350:     if not ok:\n351:         raise HTTPException(status_code=409, detail=message)\n352:     return {\"message\": message}\n353: \n354: \n355: @app.post(\"/api/drafts/{pr_number}/revise\")\n356: async def api_revise(pr_number: int, body: ReviseBody) -> dict[str, str]:\n357:     \"\"\"Request a revision with human feedback.\"\"\"\n358:     if not isinstance(body.feedback, str):\n359:         raise HTTPException(status_code=400, detail=\"feedback must be a string\")\n360:     if not isinstance(body.inline_feedback, dict) or not all(\n361:         isinstance(k, str) and isinstance(v, str) for k, v in body.inline_feedback.items()\n362:     ):\n363:         raise HTTPException(status_code=400, detail=\"inline_feedback must be an object of strings\")\n364:     if not body.feedback.strip() and not any(v.strip() for v in body.inline_feedback.values()):\n365:         raise HTTPException(status_code=400, detail=\"Provide feedback before requesting a revision\")\n366: \n367:     def revise() -> str:\n368:         def task(config: Config, state: StateStore) -> str:\n369:             detail = load_draft_detail(pr_number, config, state)\n370:             indexed = {f\"{comment.path}:{comment.line}\": comment for comment in detail.parsed.comments}\n371:             notes: list[tuple[InlineComment, str]] = []\n372:             for key, note in body.inline_feedback.items():\n373:                 comment = indexed.get(key)\n374:                 if comment is not None:\n375:                     notes.append((comment, note))\n376:             feedback = build_revision_feedback(body.feedback, notes)\n377:             worktree = Path(str(state.get(pr_number, \"worktree_path\")))\n378:             if not worktree.exists():\n379:                 raise RuntimeError(f\"Worktree not found: {worktree}\")\n380:             if not run_review_streaming(pr_number, worktree, config, state, coordinator.stream_bus, feedback=feedback):\n381:                 raise RuntimeError(str(state.get(pr_number, \"error_message\")) or \"Revision run failed\")\n382:             return f\"Revision requested for PR #{pr_number}\"\n383: \n384:         return _run_pr_task_streaming(pr_number, task)\n385: \n386:     ok, message = coordinator.try_start_pr_operation(pr_number, \"revise\", \"manual\", revise)\n387:     if not ok:\n388:         raise HTTPException(status_code=409, detail=message)\n389:     return {\"message\": message}\n390: \n391: \n392: @app.post(\"/api/drafts/{pr_number}/accept\")\n393: async def api_accept(pr_number: int) -> dict[str, str]:\n394:     \"\"\"Accept and submit a draft review to GitHub.\"\"\"\n395: \n396:     def accept() -> str:\n397:         def task(config: Config, state: StateStore) -> str:\n398:             state.update_pr(pr_number, status=\"accepting\", error_message=\"\", updated_at=utc_now())\n399:             state.flush()\n400:             submitted = submit_draft_review(pr_number, config, state)\n401:             skipped = len(submitted.preview.skipped_reasons)\n402:             skipped_suffix = f\"; skipped {skipped}\" if skipped else \"\"\n403:             message = (\n404:                 f\"Submitted review for PR #{pr_number}\"\n405:                 f\" ({len(submitted.preview.valid_comments)} inline comments\"\n406:                 f\"{skipped_suffix})\"\n407:             )\n408:             if submitted.warning:\n409:                 message += f\" {submitted.warning}\"\n410:             return message\n411: \n412:         return _run_pr_task(pr_number, task, status_on_error=\"drafted\")\n413: \n414:     ok, message = coordinator.try_start_pr_operation(pr_number, \"accept\", \"manual\", accept)\n415:     if not ok:\n416:         raise HTTPException(status_code=409, detail=message)\n417:     return {\"message\": message}\n418: \n419: \n420: @app.get(\"/api/stream/{pr_number}\")\n421: async def api_stream(pr_number: int, last_event_id: str = \"\") -> StreamingResponse:\n422:     \"\"\"SSE endpoint that streams agent events for a specific PR.\"\"\"\n423: \n424:     async def event_generator() -> Any:\n425:         since = float(last_event_id) if last_event_id else 0.0\n426:         try:\n427:             while True:\n428:                 events = coordinator.stream_bus.get_events(pr_number, since=since)\n429:                 for event in events:\n430:                     since = max(since, _event_timestamp(event))\n431:                     data = json.dumps(event, default=str)\n432:                     yield f\"id: {event.get('ts', 0)}\\ndata: {data}\\n\\n\"\n433:                 if events:\n434:                     continue\n435:                 await asyncio.sleep(0.5)\n436:         except asyncio.CancelledError:\n437:             pass\n438: \n439:     return StreamingResponse(event_generator(), media_type=\"text/event-stream\")\n440: \n441: \n442: def main(argv: list[str] | None = None) -> int:\n443:     \"\"\"Run the web server.\"\"\"\n444:     parser = argparse.ArgumentParser(description=\"Web launcher for automated PR review\")\n445:     parser.add_argument(\"--host\", default=\"127.0.0.1\", help=\"Host to bind\")\n446:     parser.add_argument(\"--port\", type=int, default=8765, help=\"Port to bind\")\n447:     args = parser.parse_args(argv)\n448: \n449:     log = get_logger()\n450:     log.info(\"PR review dashboard starting: http://%s:%d\", args.host, args.port)\n451:     uvicorn.run(\n452:         app,\n453:         host=args.host,\n454:         port=args.port,\n455:         log_level=\"warning\",\n456:         timeout_graceful_shutdown=2,\n457:     )\n458:     return 0\n459: \n460: \n461: if __name__ == \"__main__\":\n462:     raise SystemExit(main())\n\n(End of file - total 462 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Thin web UI for launching PR review runs.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport asyncio\nimport json\nfrom dataclasses import asdict\nfrom pathlib import Path\nfrom typing import Any, Callable, cast\n\nimport uvicorn\nfrom fastapi import FastAPI, HTTPException\nfrom fastapi.responses import HTMLResponse, StreamingResponse\nfrom fastapi.staticfiles import StaticFiles\nfrom pydantic import BaseModel\n\nfrom .adapters.process.subprocess_runner import run_command\nfrom .config import Config, ConfigError, load_config","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/web.py","text":"#!/usr/bin/env python3\n\"\"\"Thin web UI for launching PR review runs.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport asyncio\nimport json\nfrom dataclasses import asdict\nfrom pathlib import Path\nfrom typing import Any, Callable, cast\n\nimport uvicorn\nfrom fastapi import FastAPI, HTTPException\nfrom fastapi.responses import HTMLResponse, StreamingResponse\nfrom fastapi.staticfiles import StaticFiles\nfrom pydantic import BaseModel\n\nfrom .adapters.process.subprocess_runner import run_command\nfrom .config import Config, ConfigError, load_config\nfrom .core.review_parser import InlineComment\nfrom .log import get_logger\nfrom .paths import APP_ROOT, STATE_FILE, init_dirs\nfrom .services.draft_actions import (\n    build_revision_feedback,\n    load_draft_detail,\n    submit_draft_review,\n)\nfrom .services.file_drafts import utc_now\nfrom .services.polling_runtime import run_once\nfrom .services.review_events import RuntimeCoordinator\nfrom .services.review_execution import run_review_streaming\nfrom .services.state_store import StateStore\n\n\ndef _load_fresh_config() -> Config:\n    \"\"\"Load config from disk (expensive: reads JSON + git subprocess).\"\"\"\n    return load_config()\n\n\ndef _state(config: Config) -> StateStore:\n    \"\"\"Build a fresh StateStore from the cached config (cheap: one file read).\"\"\"\n    state = StateStore(STATE_FILE, config.repo)\n    state.initialize()\n    return state\n\n\ndef _run_pr_task(\n    pr_number: int,\n    task: Callable[[Config, StateStore], str],\n    *,\n    status_on_error: str | None = None,\n) -> str:\n    config = _config_cache[0]\n    state = _state(config)\n    try:\n        return task(config, state)\n    except Exception as exc:\n        state.update_pr(\n            pr_number,\n            status=status_on_error or str(state.get(pr_number, \"status\") or \"failed\"),\n            error_message=str(exc)[:500],\n            updated_at=utc_now(),\n        )\n        state.flush()\n        raise\n\n\ndef _run_pr_task_streaming(\n    pr_number: int,\n    task: Callable[[Config, StateStore], str],\n    *,\n    status_on_error: str | None = None,\n) -> str:\n    config = _config_cache[0]\n    state = _state(config)\n    try:\n        return task(config, state)\n    except Exception as exc:\n        coordinator.stream_bus.publish(pr_number, \"error\", {\"message\": str(exc)[:500]})\n        state.update_pr(\n            pr_number,\n            status=status_on_error or str(state.get(pr_number, \"status\") or \"failed\"),\n            error_message=str(exc)[:500],\n            updated_at=utc_now(),\n        )\n        state.flush()\n        raise\n\n\ndef _read_pr_states(active_ops: dict[str, object] | None = None) -> list[dict[str, object]]:\n    state = StateStore(STATE_FILE, \"\")\n    prs: list[dict[str, object]] = []\n    active_ops = active_ops or {}\n    for number in state.pr_numbers():\n        record = state.data[\"pr_states\"].get(str(number))\n        if isinstance(record, dict):\n            op = cast(dict[str, object], active_ops.get(str(number), {}))\n            prs.append(\n                {\n                    \"pr_number\": number,\n                    **record,\n                    \"active_operation\": op.get(\"operation\", \"\"),\n                    \"active_source\": op.get(\"source\", \"\"),\n                    \"active_started_at\": op.get(\"started_at\", \"\"),\n                }\n            )\n    prs.sort(key=lambda item: cast(int, item[\"pr_number\"]), reverse=True)\n    return prs\n\n\ndef _load_config_payload() -> dict[str, object]:\n    try:\n        return asdict(_config_cache[0])\n    except ConfigError as exc:\n        return {\"error\": str(exc)}\n    except Exception as exc:\n        return {\"error\": str(exc)[:500]}\n\n\ndef _draft_payload(pr_number: int) -> dict[str, object]:\n    config = _config_cache[0]\n    state = _state(config)\n    if not state.get(pr_number, \"status\"):\n        raise RuntimeError(f\"PR #{pr_number} not found in saved state\")\n    detail = load_draft_detail(pr_number, config, state)\n    active_prs = cast(dict[str, dict[str, object]], coordinator.snapshot()[\"active_prs\"])\n    active = active_prs.get(str(pr_number), {})\n    return {\n        \"pr_number\": pr_number,\n        \"title\": state.get(pr_number, \"title\"),\n        \"status\": state.get(pr_number, \"status\"),\n        \"draft_file\": str(detail.draft_file),\n        \"updated_at\": state.get(pr_number, \"updated_at\"),\n        \"needs_review\": bool(state.get(pr_number, \"needs_review\", False)),\n        \"active_operation\": active.get(\"operation\", \"\"),\n        \"active_source\": active.get(\"source\", \"\"),\n        \"summary\": detail.parsed.summary,\n        \"findings\": detail.parsed.findings,\n        \"assessment\": detail.parsed.assessment,\n        \"body\": detail.parsed.body,\n        \"errors\": detail.parsed.errors,\n        \"inline_comments\": [\n            {\n                \"path\": comment.path,\n                \"line\": comment.line,\n                \"body\": comment.body,\n                \"key\": f\"{comment.path}:{comment.line}\",\n            }\n            for comment in detail.parsed.comments\n        ],\n        \"preview\": {\n            \"assessment\": detail.preview.assessment,\n            \"valid_comment_count\": len(detail.preview.valid_comments),\n            \"detached_comment_count\": len(detail.preview.detached_comments),\n            \"skipped_reasons\": detail.preview.skipped_reasons,\n        },\n    }\n\n\ndef _parse_unified_diff(diff_text: str) -> list[dict[str, object]]:\n    files: list[dict[str, object]] = []\n    current: dict[str, object] | None = None\n    current_lines: list[dict[str, str]] = []\n    pending_file = \"\"\n    for raw_line in diff_text.splitlines():\n        if raw_line.startswith(\"diff --git \"):\n            if current is not None:\n                current[\"lines\"] = current_lines\n                files.append(current)\n            parts = raw_line.split()\n            pending_file = parts[3][2:] if len(parts) >= _DIFF_GIT_FIELDS and parts[3].startswith(\"b/\") else \"\"\n            current = None\n            current_lines = []\n            continue\n        if raw_line.startswith(\"+++ \"):\n            file_name = raw_line[6:] if raw_line.startswith(\"+++ b/\") else raw_line[4:]\n            if file_name == \"/dev/null\":\n                file_name = pending_file\n            current = {\"file\": file_name or pending_file, \"lines\": []}\n            continue\n        if current is None:\n            continue\n        line_type = \"ctx\"\n        if raw_line.startswith(\"+\") and not raw_line.startswith(\"+++\"):\n            line_type = \"add\"\n        elif raw_line.startswith(\"-\") and not raw_line.startswith(\"---\"):\n            line_type = \"del\"\n        current_lines.append({\"t\": line_type, \"c\": raw_line})\n    if current is not None:\n        current[\"lines\"] = current_lines\n        files.append(current)\n    return files\n\n\ndef _diff_payload(pr_number: int) -> dict[str, object]:\n    config = _config_cache[0]\n    state = _state(config)\n    if not state.get(pr_number, \"status\"):\n        raise HTTPException(status_code=400, detail=f\"PR #{pr_number} not found in saved state\")\n    worktree = Path(str(state.get(pr_number, \"worktree_path\", \"\")))\n    if not str(worktree) or not worktree.exists():\n        raise HTTPException(status_code=400, detail=f\"Worktree not found for PR #{pr_number}\")\n    base_sha = str(state.get(pr_number, \"base_sha\", \"\"))\n    head_sha = str(state.get(pr_number, \"head_sha\", \"\"))\n    result = run_command(\n        [\"git\", \"-C\", str(worktree), \"diff\", f\"{base_sha}..{head_sha}\", \"--no-color\"],\n        timeout=config.timeout,\n    )\n    if not result.ok:\n        raise HTTPException(status_code=500, detail=(result.stderr or \"git diff failed\")[:500])\n    return {\"pr_number\": pr_number, \"files\": _parse_unified_diff(result.stdout)}\n\n\ndef _spa_assets_dir() -> Path:\n    return APP_ROOT / \"web\" / \"dist\" / \"assets\"\n\n\ndef _spa_index_path() -> Path:\n    return APP_ROOT / \"web\" / \"dist\" / \"index.html\"\n\n\ndef _spa_stub_html() -> str:\n    return \"\"\"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Agent Reviewer</title>\n  <style>\n    body { background: #09090b; color: #e4e4e7; font-family: sans-serif; margin: 0; }\n    main { max-width: 42rem; margin: 10vh auto; padding: 2rem; }\n    code { background: #18181b; border-radius: 0.375rem; padding: 0.125rem 0.375rem; }\n  </style>\n</head>\n<body>\n  <main>\n    <h1>UI build missing</h1>\n    <p>Run <code>npm install</code> and <code>npm run build</code> in <code>web/</code>, then reload.</p>\n  </main>\n</body>\n</html>\n\"\"\"\n\n\ndef _dashboard_html() -> str:\n    index_path = _spa_index_path()\n    if index_path.exists():\n        return index_path.read_text(encoding=\"utf-8\")\n    return _spa_stub_html()\n\n\ndef _event_timestamp(event: dict[str, object]) -> float:\n    \"\"\"Return the event timestamp as a float for SSE bookkeeping.\"\"\"\n    ts = event.get(\"ts\")\n    return ts if isinstance(ts, float) else 0.0\n\n\ninit_dirs()\ncoordinator = RuntimeCoordinator(utc_now)\n_config_cache: list[Config] = [_load_fresh_config()]\n_DIFF_GIT_FIELDS = 4\n\napp = FastAPI(title=\"PR Review Dashboard\")\nif _spa_assets_dir().exists():\n    app.mount(\"/assets\", StaticFiles(directory=_spa_assets_dir()), name=\"assets\")\n\n\nclass ReviseBody(BaseModel):\n    \"\"\"Request body for revising a draft review.\"\"\"\n\n    feedback: str = \"\"\n    inline_feedback: dict[str, str] = {}\n\n\n@app.get(\"/\")\nasync def serve_root() -> HTMLResponse:\n    \"\"\"Serve the dashboard HTML.\"\"\"\n    return HTMLResponse(_dashboard_html())\n\n\n@app.get(\"/draft/{pr_number}\")\nasync def serve_draft(pr_number: int) -> HTMLResponse:  # noqa: ARG001\n    \"\"\"Serve the dashboard HTML (SPA handles routing).\"\"\"\n    return HTMLResponse(_dashboard_html())\n\n\n@app.get(\"/api/status\")\nasync def api_status() -> dict[str, Any]:\n    \"\"\"Return the current job state, config, and PR list.\"\"\"\n    snap = cast(dict[str, object], coordinator.snapshot())\n    poller = cast(dict[str, object], snap[\"poller\"])\n    if poller[\"running\"]:\n        status = \"running\"\n    elif poller[\"error\"]:\n        status = \"failed\"\n    elif poller[\"finished_at\"]:\n        status = \"done\"\n    else:\n        status = \"idle\"\n    run_payload = {\n        \"status\": status,\n        \"mode\": \"all\" if poller[\"running\"] or poller[\"finished_at\"] else \"-\",\n        \"started_at\": poller[\"started_at\"],\n        \"finished_at\": poller[\"finished_at\"],\n        \"last_error\": poller[\"error\"],\n        \"last_result\": poller[\"result\"],\n    }\n    return {\n        \"run\": run_payload,\n        \"config\": _load_config_payload(),\n        \"prs\": _read_pr_states(cast(dict[str, object], snap[\"active_prs\"])),\n        \"active_prs\": cast(dict[str, object], snap[\"active_prs\"]),\n    }\n\n\n@app.get(\"/api/drafts/{pr_number}\")\nasync def api_draft(pr_number: int) -> dict[str, Any]:\n    \"\"\"Return parsed draft data for a PR.\"\"\"\n    try:\n        return _draft_payload(pr_number)\n    except (ConfigError, RuntimeError) as exc:\n        raise HTTPException(status_code=400, detail=str(exc)) from exc\n\n\n@app.get(\"/api/diff/{pr_number}\")\nasync def api_diff(pr_number: int) -> dict[str, Any]:\n    \"\"\"Return unified diff lines for one PR.\"\"\"\n    return _diff_payload(pr_number)\n\n\n@app.post(\"/api/review-all\")\nasync def api_review_all() -> dict[str, str]:\n    \"\"\"Start reviewing all open PRs.\"\"\"\n\n    def review_all() -> str:\n        _config_cache[0] = _load_fresh_config()\n        config = _config_cache[0]\n        state = _state(config)\n        queued, skipped, reviewed, failed = run_once(\n            config,\n            state,\n            claim_pr=lambda pr_number: coordinator.try_acquire_pr(pr_number, \"review\", \"poller\")[0],\n            release_pr=coordinator.release_pr,\n            stream_bus=coordinator.stream_bus,\n        )\n        return f\"Done: queued={queued} skipped={skipped} reviewed={reviewed} failed={failed}\"\n\n    ok, message = coordinator.try_start_poller(review_all)\n    if not ok:\n        raise HTTPException(status_code=409, detail=message)\n    return {\"message\": message}\n\n\n@app.post(\"/api/drafts/{pr_number}/revise\")\nasync def api_revise(pr_number: int, body: ReviseBody) -> dict[str, str]:\n    \"\"\"Request a revision with human feedback.\"\"\"\n    if not isinstance(body.feedback, str):\n        raise HTTPException(status_code=400, detail=\"feedback must be a string\")\n    if not isinstance(body.inline_feedback, dict) or not all(\n        isinstance(k, str) and isinstance(v, str) for k, v in body.inline_feedback.items()\n    ):\n        raise HTTPException(status_code=400, detail=\"inline_feedback must be an object of strings\")\n    if not body.feedback.strip() and not any(v.strip() for v in body.inline_feedback.values()):\n        raise HTTPException(status_code=400, detail=\"Provide feedback before requesting a revision\")\n\n    def revise() -> str:\n        def task(config: Config, state: StateStore) -> str:\n            detail = load_draft_detail(pr_number, config, state)\n            indexed = {f\"{comment.path}:{comment.line}\": comment for comment in detail.parsed.comments}\n            notes: list[tuple[InlineComment, str]] = []\n            for key, note in body.inline_feedback.items():\n                comment = indexed.get(key)\n                if comment is not None:\n                    notes.append((comment, note))\n            feedback = build_revision_feedback(body.feedback, notes)\n            worktree = Path(str(state.get(pr_number, \"worktree_path\")))\n            if not worktree.exists():\n                raise RuntimeError(f\"Worktree not found: {worktree}\")\n            if not run_review_streaming(pr_number, worktree, config, state, coordinator.stream_bus, feedback=feedback):\n                raise RuntimeError(str(state.get(pr_number, \"error_message\")) or \"Revision run failed\")\n            return f\"Revision requested for PR #{pr_number}\"\n\n        return _run_pr_task_streaming(pr_number, task)\n\n    ok, message = coordinator.try_start_pr_operation(pr_number, \"revise\", \"manual\", revise)\n    if not ok:\n        raise HTTPException(status_code=409, detail=message)\n    return {\"message\": message}\n\n\n@app.post(\"/api/drafts/{pr_number}/accept\")\nasync def api_accept(pr_number: int) -> dict[str, str]:\n    \"\"\"Accept and submit a draft review to GitHub.\"\"\"\n\n    def accept() -> str:\n        def task(config: Config, state: StateStore) -> str:\n            state.update_pr(pr_number, status=\"accepting\", error_message=\"\", updated_at=utc_now())\n            state.flush()\n            submitted = submit_draft_review(pr_number, config, state)\n            skipped = len(submitted.preview.skipped_reasons)\n            skipped_suffix = f\"; skipped {skipped}\" if skipped else \"\"\n            message = (\n                f\"Submitted review for PR #{pr_number}\"\n                f\" ({len(submitted.preview.valid_comments)} inline comments\"\n                f\"{skipped_suffix})\"\n            )\n            if submitted.warning:\n                message += f\" {submitted.warning}\"\n            return message\n\n        return _run_pr_task(pr_number, task, status_on_error=\"drafted\")\n\n    ok, message = coordinator.try_start_pr_operation(pr_number, \"accept\", \"manual\", accept)\n    if not ok:\n        raise HTTPException(status_code=409, detail=message)\n    return {\"message\": message}\n\n\n@app.get(\"/api/stream/{pr_number}\")\nasync def api_stream(pr_number: int, last_event_id: str = \"\") -> StreamingResponse:\n    \"\"\"SSE endpoint that streams agent events for a specific PR.\"\"\"\n\n    async def event_generator() -> Any:\n        since = float(last_event_id) if last_event_id else 0.0\n        try:\n            while True:\n                events = coordinator.stream_bus.get_events(pr_number, since=since)\n                for event in events:\n                    since = max(since, _event_timestamp(event))\n                    data = json.dumps(event, default=str)\n                    yield f\"id: {event.get('ts', 0)}\\ndata: {data}\\n\\n\"\n                if events:\n                    continue\n                await asyncio.sleep(0.5)\n        except asyncio.CancelledError:\n            pass\n\n    return StreamingResponse(event_generator(), media_type=\"text/event-stream\")\n\n\ndef main(argv: list[str] | None = None) -> int:\n    \"\"\"Run the web server.\"\"\"\n    parser = argparse.ArgumentParser(description=\"Web launcher for automated PR review\")\n    parser.add_argument(\"--host\", default=\"127.0.0.1\", help=\"Host to bind\")\n    parser.add_argument(\"--port\", type=int, default=8765, help=\"Port to bind\")\n    args = parser.parse_args(argv)\n\n    log = get_logger()\n    log.info(\"PR review dashboard starting: http://%s:%d\", args.host, args.port)\n    uvicorn.run(\n        app,\n        host=args.host,\n        port=args.port,\n        log_level=\"warning\",\n        timeout_graceful_shutdown=2,\n    )\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())","lineStart":1,"lineEnd":462,"totalLines":462,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/web.py","time":{"start":1782271683665,"end":1782271683680}},"id":"prt_ef7abac48001lvDzt4ukpXxjKv","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab9fa8001NuVfKv3t45Pdkz"}}
{"type":"tool_use","timestamp":1782271684147,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_egaafv6r","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/.opencode/agents/pr-review.md"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/.opencode/agents/pr-review.md</path>\n<type>file</type>\n<content>\n1: ---\n2: description: Reviews pull requests. Produces draft reviews by writing to the draft file. Never submits to GitHub.\n3: mode: primary\n4: temperature: 0.1\n5: permission:\n6:   \"*\": allow\n7: ---\n8: \n9: You are an automated PR review agent. Your job is to review code changes and produce a thorough draft review.\n10: \n11: ## Required Skills\n12: \n13: Before reviewing, read and apply all skill files supplied in the run prompt:\n14: \n15: - `pr-review` owns review analysis, severity, changed-line findings, and draft structure.\n16: - `gh-cli` owns all GitHub PR read operations and comment-type distinctions.\n17: - `pr-revise` owns feedback triage and re-review analysis when revising an existing draft.\n18: \n19: Use `pr-revise` in analysis-only mode. Ignore its implementation, commit, push, reply, polling, and sleep steps because\n20: this agent is read-only. When skill instructions conflict, the Absolute Rules below take precedence.\n21: \n22: ## Absolute Rules\n23: \n24: - NEVER modify any files EXCEPT the draft review file specified in the run prompt\n25: - NEVER submit reviews to GitHub — do not use `gh pr review` or `gh api .../reviews`\n26: - NEVER ask the user questions — complete the review autonomously\n27: - If you cannot access a file or command, note it in your review and continue\n28: \n29: ## Review Process\n30: \n31: 1. Load the required skills listed in the run prompt\n32: 2. Follow `gh-cli` to fetch the PR description, reviews, comments, and changed files\n33: 3. Use `git diff`, `git show`, and `git log` to examine the changes in detail\n34: 4. Read source files referenced in the diff for additional context\n35: 5. Identify issues across all focus areas listed below\n36: 6. Produce a structured review in the exact format specified\n37: \n38: ## Output Format\n39: \n40: You MUST write your review to the draft file path specified in the run prompt using your built-in file edit tool (not bash). Do NOT output the review to stdout and do NOT use bash to write the file. Write it using the edit tool only. The file must contain exactly this markdown structure and nothing else:\n41: \n42: ```markdown\n43: ## PR Review: #{pr_number} — {title}\n44: \n45: ### Summary\n46: {1-3 sentence summary of what this PR does and why}\n47: \n48: ### Findings\n49: \n50: #### [CRITICAL] {short description}\n51: - **File**: `path/to/file.ext:line_number`\n52: - **Detail**: {explanation of the issue}\n53: - **Suggestion**: {concrete fix recommendation}\n54: \n55: #### [HIGH] {short description}\n56: ...\n57: \n58: #### [MEDIUM] {short description}\n59: ...\n60: \n61: #### [LOW] {short description}\n62: ...\n63: \n64: #### [INFO] {observation or note}\n65: ...\n66: \n67: ### Overall Assessment\n68: {APPROVE / REQUEST_CHANGES / COMMENT} — {one-line justification}\n69: \n70: ### Inline Comments\n71: - `path/to/file.ext:42`: {comment text about this specific line}\n72: - `path/to/other.ext:15`: {comment text about this specific line}\n73: \n74: ---\n75: \n76: <!-- PR Review Automation: Edit below to provide feedback, then close the editor -->\n77: <!-- Use #feedback for inline annotations on specific parts of the review above -->\n78: \n79: ## Feedback\n80: \n81: <!-- Write revision feedback here. -->\n82: ```\n83: \n84: **CRITICAL**: The `### Inline Comments` section is REQUIRED. Every finding from the Findings section that references a specific file and line MUST also appear as an inline comment. Each inline comment MUST be on its own line in this exact format:\n85: \n86: ```\n87: - `path/to/file.ext:line_number`: comment text\n88: ```\n89: \n90: The parser accepts `:`, `-`, `–`, or `—` between the location and comment text. A path, positive line number,\n91: and non-empty comment are required. Malformed comments are shown to the user and skipped only after confirmation.\n92: \n93: ## Severity Levels\n94: \n95: - **CRITICAL**: Security vulnerabilities, data loss risks, breaking bugs\n96: - **HIGH**: Likely bugs, missing error handling, significant performance issues\n97: - **MEDIUM**: Code quality issues, potential edge cases, missing tests\n98: - **LOW**: Style issues, naming improvements, minor optimizations\n99: - **INFO**: Observations, suggestions, or notes that don't require changes\n100: \n101: ## Focus Areas\n102: \n103: - **Security**: Injection vulnerabilities, auth/authz issues, exposed secrets, unsafe deserialization\n104: - **Correctness**: Logic errors, null/edge-case handling, race conditions, off-by-one errors\n105: - **Performance**: O(n^2) operations, unnecessary allocations, N+1 queries, missing caching\n106: - **Error handling**: Unhandled errors, swallowed exceptions, missing validations\n107: - **Testing**: Missing test coverage, flaky tests, untested edge cases\n108: - **Maintainability**: Code duplication, unclear naming, missing documentation, overly complex logic\n109: - **API design**: Breaking changes, inconsistent interfaces, missing pagination\n110: \n111: ## Revision Handling\n112: \n113: If this is a revised review (review_count > 1), you will receive previous feedback from a human reviewer. Address all feedback points specifically:\n114: \n115: - Mark each feedback item as addressed or explain why it was not addressed\n116: - If the human asked you to dig deeper into a specific area, do so\n117: - If the human disagrees with a finding, reconsider it — but explain your reasoning if you still believe it's valid\n118: \n119: Be thorough but fair. Not every PR needs findings at every severity level. If the code is clean, say so.\n\n(End of file - total 119 lines)\n</content>","metadata":{"preview":"---\ndescription: Reviews pull requests. Produces draft reviews by writing to the draft file. Never submits to GitHub.\nmode: primary\ntemperature: 0.1\npermission:\n  \"*\": allow\n---\n\nYou are an automated PR review agent. Your job is to review code changes and produce a thorough draft review.\n\n## Required Skills\n\nBefore reviewing, read and apply all skill files supplied in the run prompt:\n\n- `pr-review` owns review analysis, severity, changed-line findings, and draft structure.\n- `gh-cli` owns all GitHub PR read operations and comment-type distinctions.\n- `pr-revise` owns feedback triage and re-review analysis when revising an existing draft.\n\nUse `pr-revise` in analysis-only mode. Ignore its implementation, commit, push, reply, polling, and sleep steps because\nthis agent is read-only. When skill instructions conflict, the Absolute Rules below take precedence.","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/.opencode/agents/pr-review.md","text":"---\ndescription: Reviews pull requests. Produces draft reviews by writing to the draft file. Never submits to GitHub.\nmode: primary\ntemperature: 0.1\npermission:\n  \"*\": allow\n---\n\nYou are an automated PR review agent. Your job is to review code changes and produce a thorough draft review.\n\n## Required Skills\n\nBefore reviewing, read and apply all skill files supplied in the run prompt:\n\n- `pr-review` owns review analysis, severity, changed-line findings, and draft structure.\n- `gh-cli` owns all GitHub PR read operations and comment-type distinctions.\n- `pr-revise` owns feedback triage and re-review analysis when revising an existing draft.\n\nUse `pr-revise` in analysis-only mode. Ignore its implementation, commit, push, reply, polling, and sleep steps because\nthis agent is read-only. When skill instructions conflict, the Absolute Rules below take precedence.\n\n## Absolute Rules\n\n- NEVER modify any files EXCEPT the draft review file specified in the run prompt\n- NEVER submit reviews to GitHub — do not use `gh pr review` or `gh api .../reviews`\n- NEVER ask the user questions — complete the review autonomously\n- If you cannot access a file or command, note it in your review and continue\n\n## Review Process\n\n1. Load the required skills listed in the run prompt\n2. Follow `gh-cli` to fetch the PR description, reviews, comments, and changed files\n3. Use `git diff`, `git show`, and `git log` to examine the changes in detail\n4. Read source files referenced in the diff for additional context\n5. Identify issues across all focus areas listed below\n6. Produce a structured review in the exact format specified\n\n## Output Format\n\nYou MUST write your review to the draft file path specified in the run prompt using your built-in file edit tool (not bash). Do NOT output the review to stdout and do NOT use bash to write the file. Write it using the edit tool only. The file must contain exactly this markdown structure and nothing else:\n\n```markdown\n## PR Review: #{pr_number} — {title}\n\n### Summary\n{1-3 sentence summary of what this PR does and why}\n\n### Findings\n\n#### [CRITICAL] {short description}\n- **File**: `path/to/file.ext:line_number`\n- **Detail**: {explanation of the issue}\n- **Suggestion**: {concrete fix recommendation}\n\n#### [HIGH] {short description}\n...\n\n#### [MEDIUM] {short description}\n...\n\n#### [LOW] {short description}\n...\n\n#### [INFO] {observation or note}\n...\n\n### Overall Assessment\n{APPROVE / REQUEST_CHANGES / COMMENT} — {one-line justification}\n\n### Inline Comments\n- `path/to/file.ext:42`: {comment text about this specific line}\n- `path/to/other.ext:15`: {comment text about this specific line}\n\n---\n\n<!-- PR Review Automation: Edit below to provide feedback, then close the editor -->\n<!-- Use #feedback for inline annotations on specific parts of the review above -->\n\n## Feedback\n\n<!-- Write revision feedback here. -->\n```\n\n**CRITICAL**: The `### Inline Comments` section is REQUIRED. Every finding from the Findings section that references a specific file and line MUST also appear as an inline comment. Each inline comment MUST be on its own line in this exact format:\n\n```\n- `path/to/file.ext:line_number`: comment text\n```\n\nThe parser accepts `:`, `-`, `–`, or `—` between the location and comment text. A path, positive line number,\nand non-empty comment are required. Malformed comments are shown to the user and skipped only after confirmation.\n\n## Severity Levels\n\n- **CRITICAL**: Security vulnerabilities, data loss risks, breaking bugs\n- **HIGH**: Likely bugs, missing error handling, significant performance issues\n- **MEDIUM**: Code quality issues, potential edge cases, missing tests\n- **LOW**: Style issues, naming improvements, minor optimizations\n- **INFO**: Observations, suggestions, or notes that don't require changes\n\n## Focus Areas\n\n- **Security**: Injection vulnerabilities, auth/authz issues, exposed secrets, unsafe deserialization\n- **Correctness**: Logic errors, null/edge-case handling, race conditions, off-by-one errors\n- **Performance**: O(n^2) operations, unnecessary allocations, N+1 queries, missing caching\n- **Error handling**: Unhandled errors, swallowed exceptions, missing validations\n- **Testing**: Missing test coverage, flaky tests, untested edge cases\n- **Maintainability**: Code duplication, unclear naming, missing documentation, overly complex logic\n- **API design**: Breaking changes, inconsistent interfaces, missing pagination\n\n## Revision Handling\n\nIf this is a revised review (review_count > 1), you will receive previous feedback from a human reviewer. Address all feedback points specifically:\n\n- Mark each feedback item as addressed or explain why it was not addressed\n- If the human asked you to dig deeper into a specific area, do so\n- If the human disagrees with a finding, reconsider it — but explain your reasoning if you still believe it's valid\n\nBe thorough but fair. Not every PR needs findings at every severity level. If the code is clean, say so.","lineStart":1,"lineEnd":119,"totalLines":119,"truncated":false}},"title":"applications/auto-review-pr/.opencode/agents/pr-review.md","time":{"start":1782271684122,"end":1782271684139}},"id":"prt_ef7abae0b0011bWn2kyWGv8sAE","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab9fa8001NuVfKv3t45Pdkz"}}
