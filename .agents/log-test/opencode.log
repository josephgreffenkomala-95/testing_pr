la\"}],\"committedDate\":\"2026-06-16T14:06:30Z\",\"messageBody\":\"\",\"messageHeadline\":\"refactor(auto-review-pr): replace BaseHTTPRequestHandler with FastAPI\",\"oid\":\"1a903d77b8aada360399d081f86c0dacf4983382\"},{\"authoredDate\":\"2026-06-16T15:12:21Z\",\"authors\":[{\"email\":\"josephgreffenkomala@mail.ugm.ac.id\",\"id\":\"U_kgDOCKZcdg\",\"login\":\"josephgreffenkomala\",\"name\":\"josephgreffenkomala\"}],\"committedDate\":\"2026-06-16T15:12:21Z\",\"messageBody\":\"Move _run_poll, _run_single_pr, and _load_runtime from pr-review-web.py\\ninto pr_review/daemon.py as run_poll, run_single_pr, and load_runtime.\\nReplace duplicate utc_now with import from pr_review.review.\",\"messageHeadline\":\"refactor(pr-review): extract core logic from web UI into daemon module\",\"oid\":\"fc8dca67ac58f3ae260243a8260a9832512ba212\"},{\"authoredDate\":\"2026-06-17T04:29:24Z\",\"authors\":[{\"email\":\"josephgreffenkomala@mail.ugm.ac.id\",\"id\":\"U_kgDOCKZcdg\",\"login\":\"josephgreffenkomala\",\"name\":\"josephgreffenkomala\"}],\"committedDate\":\"2026-06-17T04:29:24Z\",\"messageBody\":\"\",\"messageHeadline\":\"fix(auto-review-pr): preserve state updates across concurrent flushes\",\"oid\":\"1f9156699bdc85c67129c36242749314f2d2b2cd\"},{\"authoredDate\":\"2026-06-17T05:56:48Z\",\"authors\":[{\"email\":\"josephgreffenkomala@mail.ugm.ac.id\",\"id\":\"U_kgDOCKZcdg\",\"login\":\"josephgreffenkomala\",\"name\":\"josephgreffenkomala\"}],\"committedDate\":\"2026-06-17T05:56:48Z\",\"messageBody\":\"\",\"messageHeadline\":\"feat(auto-review-pr): coordinate concurrent review actions\",\"oid\":\"4d645903f3aa05e541668283be0013a75cd9c0e0\"},{\"authoredDate\":\"2026-06-17T06:57:23Z\",\"authors\":[{\"email\":\"josephgreffenkomala@mail.ugm.ac.id\",\"id\":\"U_kgDOCKZcdg\",\"login\":\"josephgreffenkomala\",\"name\":\"josephgreffenkomala\"}],\"committedDate\":\"2026-06-17T06:57:23Z\",\"messageBody\":\"\",\"messageHeadline\":\"fix(auto-review-pr): preserve concurrent state updates\",\"oid\":\