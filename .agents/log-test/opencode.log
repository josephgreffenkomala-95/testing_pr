_review/adapters/agents/pi.py\napplications/auto-review-pr/src/pr_review/adapters/github/__init__.py\napplications/auto-review-pr/src/pr_review/adapters/github/gh_cli.py\napplications/auto-review-pr/src/pr_review/adapters/process/__init__.py\napplications/auto-review-pr/src/pr_review/adapters/process/subprocess_runner.py\napplications/auto-review-pr/src/pr_review/config.py\napplications/auto-review-pr/src/pr_review/core/__init__.py\napplications/auto-review-pr/src/pr_review/core/draft_submission.py\napplications/auto-review-pr/src/pr_review/core/errors.py\napplications/auto-review-pr/src/pr_review/core/models.py\napplications/auto-review-pr/src/pr_review/core/polling.py\napplications/auto-review-pr/src/pr_review/core/ports.py\napplications/auto-review-pr/src/pr_review/core/prompts.py\napplications/auto-review-pr/src/pr_review/core/review_parser.py\napplications/auto-review-pr/src/pr_review/core/review_pipeline.py\napplications/auto-review-pr/src/pr_review/core/revision_feedback.py\napplications/auto-review-pr/src/pr_review/log.py\napplications/auto-review-pr/src/pr_review/paths.py\napplications/auto-review-pr/src/pr_review/services/__init__.py\napplications/auto-review-pr/src/pr_review/services/draft_actions.py\napplications/auto-review-pr/src/pr_review/services/file_drafts.py\napplications/auto-review-pr/src/pr_review/services/git_worktree.py\napplications/auto-review-pr/src/pr_review/services/polling_runtime.py\napplications/auto-review-pr/src/pr_review/services/review_events.py\napplications/auto-review-pr/src/pr_review/services/review_execution.py\napplications/auto-review-pr/src/pr_review/services/state_store.py\napplications/auto-review-pr/src/pr_review/web.py\napplications/auto-review-pr/tests/integration/test_pr_review_workflow.py\napplications/auto-review-pr/tests/unit/pr_review/test_agent_backend_factory.py\napplications/auto-review-pr/tests/unit/pr_review/test_agent_backends.py\napplications/auto-review-pr/tests/unit/pr_review/test_commands.py\napplications/auto-review-pr/tests/unit/pr_review/test_coordinator.py\napplications/auto-review-pr/tests/unit/pr_review/test_daemon.py\napplications/auto-review-pr/tests/unit/pr_review/test_draft_review.py\napplications/auto-review-pr/tests/unit/pr_review/test_github.py\napplications/auto-review-pr/tests/unit/pr_review/test_parser.py\napplications/auto-review-pr/tests/unit/pr_review/test_pr_review_config.py\napplications/auto-review-pr/tests/unit/pr_review/test_review.py\napplications/auto-review-pr/tests/unit/pr_review/test_review_pipeline.py\napplications/auto-review-pr/tests/unit/pr_review/test_state.py\napplications/auto-review-pr/tests/unit/pr_review/test_web_review_all_only.py\napplications/auto-review-pr/tests/unit/pr_review/test_worktree.py\napplications/auto-review-pr/uv.lock\napplications/auto-review-pr/web/design-reference.html\napplications/auto-review-pr/web/index.html\napplications/auto-review-pr/web/package-lock.json\napplications/auto-review-pr/web/package.json\napplications/auto-review-pr/web/postcss.config.js\napplications/auto-review-pr/web/src/App.tsx\napplications/auto-review-pr/web/src/api.ts\napplications/auto-review-pr/web/src/components.tsx\napplications/auto-review-pr/web/src/main.tsx\napplications/auto-review-pr/web/src/styles.css\napplications/auto-review-pr/web/src/types.ts\napplications/auto-review-pr/web/src/utils.ts\napplications/auto-review-pr/web/tailwind.config.ts\napplications/auto-review-pr/web/tsconfig.json\napplications/auto-review-pr/web/tsconfig.tsbuildinfo\napplications/auto-review-pr/web/vite.config.ts\n","metadata":{"output":".coverage\n.gitignore\napplications/auto-review-pr/.agents/pr-review-agent.md\napplications/auto-review-pr/.agents/skills/gh-cli/SKILL.md\napplications/auto-review-pr/.agents/skills/gh-cli/scripts/gh-pr-fmt.sh\napplications/auto-review-pr/.agents/skills/pr-review/SKILL.md\napplications/auto-review-pr/.agents/skills/pr-revise/SKILL.md\napplications/auto-review-pr/.opencode/agents/pr-review.md\napplications/auto-r