ors: list[str] = []\n34:         for line in result.stdout.splitlines():\n35:             try:\n36:                 event = json.loads(line)\n37:             except json.JSONDecodeError:\n38:                 continue\n39:             event_type = event.get(\"type\")\n40:             if event_type == \"session\" and not session_id:\n41:                 session_id = str(event.get(\"id\", \"\")).strip()\n42:             elif event_type == \"error\":\n43:                 errors.append(str(event.get(\"message\", \"\")).strip())\n44:         return ParsedBackendResult(\"\", session_id, tuple(errors))\n45: \n46:     def parse_stream_line(self, line: str) -> StreamEvent | None:\n47:         \"\"\"Map one Pi stream event into the dashboard event schema.\"\"\"\n48:         try:\n49:             event = json.loads(line)\n50:         except json.JSONDecodeError:\n51:             return None\n52:         event_type = event.get(\"type\")\n53:         if event_type == \"session\":\n54:             return StreamEvent(event_type=\"session_start\", session_id=str(event.get(\"id\", \"\")).strip())\n55:         if event_type == \"agent_end\":\n56:             return StreamEvent(event_type=\"agent_end\")\n57:         if event_type == \"error\":\n58:             return StreamEvent(event_type=\"error\", error=str(event.get(\"message\", \"\")).strip())\n59:         return StreamEvent(event_type=str(event_type or \"unknown\"))\n\n(End of file - total 59 lines)\n</content>","metadata":{"preview":"\"\"\"Pi agent adapter.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\n\nfrom pr_review.adapters.agents.base import provider_option_args\nfrom pr_review.core.ports import AgentInvocationRequest, CommandResult, Invocation, ParsedBackendResult, StreamEvent\n\n\nclass PiBackend:\n    \"\"\"Pi coding agent adapter.\"\"\"\n\n    name = \"pi\"\n    supports_resume = True\n    output_mode = \"file_write\"\n\n    def build_invocation(self, request: AgentInvocationRequest) -> Invocation:\n        \"\"\"Build the `pi` invocation for this review.\"\"\"\n        command = [\"pi\", \"-p\", \"-\", \"--approve\", \"--mode\", \"json\"]","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/adapters/agents/pi.py","text":"\"\"\"Pi agent adapter.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\n\nfrom pr_review.adapters.agents.base import provider_option_args\nfrom pr_review.core.ports import AgentInvocationRequest, CommandResult, Invocation, ParsedBackendResult, StreamEvent\n\n\nclass PiBackend:\n    \"\"\"Pi coding agent adapter.\"\"\"\n\n    name = \"pi\"\n    supports_resume = True\n    output_mode = \"file_write\"\n\n    def build_invocation(self, request: AgentInvocationRequest) -> Invocation:\n        \"\"\"Build the `pi` invocation for this review.\"\"\"\n        command = [\"pi\", \"-p\", \"-\", \"--approve\", \"--mode\", \"json\"]\n        if request.agent_prompt:\n            command.extend([\"--append-system-prompt\", request.agent_prompt])\n        if request.session_id and request.is_revision:\n            command.extend([\"--session\", request.session_id])\n        if request.model:\n            command.extend([\"--model\", request.model])\n        command.extend(provider_option_args(request.provider_options))\n        return Invocation(command, input_text=request.prompt_file.read_text(encoding=\"utf-8\"))\n\n    def parse_result(self, result: CommandResult) -> ParsedBackendResult:\n        \"\"\"Extract the session id from Pi JSONL output.\"\"\"\n        session_id = \"\"\n        errors: list[str] = []\n        for line in result.stdout.splitlines():\n            try:\n                event = json.loads(line)\n            except json.JSONDecodeError:\n                continue\n            event_type = event.get(\"type\")\n            if event_type == \"session\" and not session_id:\n                session_id = str(event.get(\"id\", \"\")).strip()\n            elif event_type == \"error\":\n                errors.append(str(event.get(\"message\", \"\")).strip())\n        return ParsedBackendResult(\"\", session_id, tuple(errors))\n\n    def parse_stream_line(self, line: str) -> StreamEvent | None:\n        \"\"\"Map one Pi stream event into the dashboard event schema.\"\"\"\n        try:\n            event = json.loads(line)\n        except json.JSONDecodeError:\n            return None\n        event_type = event.get(\"type\")\n        if event_type == \"session\":\n            return StreamEvent(event_type=\"session_start\", session_id=str(event.get(\"id\", \"\")).strip())\n        if event_type == \"agent_end\":\n            return StreamEvent(event_type=\"agent_end\")\n        if event_type == \"error\":\n            return StreamEvent(event_type=\"error\", error=str(event.get(\"message\", \"\")).strip())\n        return StreamEvent(event_type=str(event_type or \"unknown\"))","lineStart":1,"lineEnd":59,"totalLines":59,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/adapters/agents/pi.py","time":{"start":1782271692003,"end":1782271692021}},"id":"prt_ef7abccd800109ARSzgBMTrOtl","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7abb0dc00104BBao98xptfEA"}}
