raft?.active_source || \"\",\n43:     needs_review: draft?.needs_review || false,\n44:   };\n45: }\n46: \n47: export default function App() {\n48:   const [statusData, setStatusData] = useState<ApiStatus | null>(null);\n49:   const [selected, setSelected] = useState<number | null>(routePrNumber());\n50:   const [draft, setDraft] = useState<DraftDetail | null>(null);\n\n(Showing lines 1-50 of 223. Use offset=51 to continue.)\n</content>","metadata":{"preview":"import { useEffect, useMemo, useState } from \"react\";\n\nimport { getDiff, getDraft, getStatus, postAccept, postReviewAll, postRevise, useStream } from \"./api\";\nimport {\n  DiffPanel,\n  EmptyState,\n  PrHeader,\n  ReviewAllButton,\n  ReviewPanel,\n  Sidebar,\n  StreamPanel,\n  TopBar,\n} from \"./components\";\nimport type { ApiStatus, DiffResponse, DraftDetail, PrState } from \"./types\";\nimport { parseSeverity, prRoute } from \"./utils\";\n\nfunction routePrNumber(): number | null {\n  const match = window.location.pathname.match(/^\\/draft\\/(\\d+)$/);\n  return match ? Number(match[1]) : null;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/web/src/App.tsx","text":"import { useEffect, useMemo, useState } from \"react\";\n\nimport { getDiff, getDraft, getStatus, postAccept, postReviewAll, postRevise, useStream } from \"./api\";\nimport {\n  DiffPanel,\n  EmptyState,\n  PrHeader,\n  ReviewAllButton,\n  ReviewPanel,\n  Sidebar,\n  StreamPanel,\n  TopBar,\n} from \"./components\";\nimport type { ApiStatus, DiffResponse, DraftDetail, PrState } from \"./types\";\nimport { parseSeverity, prRoute } from \"./utils\";\n\nfunction routePrNumber(): number | null {\n  const match = window.location.pathname.match(/^\\/draft\\/(\\d+)$/);\n  return match ? Number(match[1]) : null;\n}\n\nfunction configRepoLabel(statusData: ApiStatus | null): string {\n  if (!statusData) {\n    return \"\";\n  }\n  return \"error\" in statusData.config ? \"Config error\" : statusData.config.repo;\n}\n\nfunction selectedPr(prs: PrState[], prNumber: number | null): PrState | null {\n  return prs.find((pr) => pr.pr_number === prNumber) || null;\n}\n\nfunction fallbackPr(selected: number | null, draft: DraftDetail | null): PrState | null {\n  if (!selected) {\n    return null;\n  }\n  return {\n    pr_number: selected,\n    title: draft?.title || `PR #${selected}`,\n    status: draft?.status || \"pending\",\n    active_operation: draft?.active_operation || \"\",\n    active_source: draft?.active_source || \"\",\n    needs_review: draft?.needs_review || false,\n  };\n}\n\nexport default function App() {\n  const [statusData, setStatusData] = useState<ApiStatus | null>(null);\n  const [selected, setSelected] = useState<number | null>(routePrNumber());\n  const [draft, setDraft] = useState<DraftDetail | null>(null);","lineStart":1,"lineEnd":50,"totalLines":223,"truncated":true}},"title":"applications/auto-review-pr/web/src/App.tsx","time":{"start":1782271733858,"end":1782271733874}},"id":"prt_ef7ac705a001xQkvIpG8GnVJY8","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ac656b001SOsJY3MZnhqa4I"}}
{"type":"tool_use","timestamp":1782271734153,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"bash","callID":"call_4pgiy8a8","state":{"status":"completed","input":{"command":"git show HEAD:applications/auto-review-pr/README.md | head -130","description":"Show README from HEAD commit"},"output":"# GitHub PR Auto-Review with Selectable Coding Agents\n\nThis directory is a standalone Python app. Its package, tests, skills, runtime files, and project metadata all live under `applications/auto-review-pr/`.\n\nThe app code lives under `src/pr_review/`. The web dashboard polls open GitHub pull requests, runs a read-only review agent, saves each result as a draft, and lets humans approve or revise through the browser.\n\nSupported backends:\n\n- `opencode`\n- `codex`\n- `claude-code`\n- `pi`\n\nThe agent cannot edit files or submit reviews. Only the Python tool can submit after approval through the web dashboard.\n\nEach review run explicitly loads three repository skills:\n\n- `pr-review` for analysis, severity, and draft structure\n- `gh-cli` for GitHub PR reads\n- `pr-revise` for feedback triage and re-review analysis\n\n`pr-revise` is restricted to analysis. Its implementation, commit, push, reply, polling, and sleep steps are not used.\n\n## Architecture\n\n```text\napplications/auto-review-pr/pyproject.toml                   standalone project metadata\napplications/auto-review-pr/src/main.py                      top-level app entrypoint\napplications/auto-review-pr/src/pr_review/config.py          local configuration and validation\napplications/auto-review-pr/src/pr_review/web.py             FastAPI dashboard entry point\napplications/auto-review-pr/src/pr_review/paths.py           app/runtime path constants\napplications/auto-review-pr/src/pr_review/log.py             shared logging setup\napplications/auto-review-pr/src/pr_review/core/models.py     domain DTOs crossing ports\napplications/auto-review-pr/src/pr_review/core/ports.py      backend, PR host, and command-runner ports\napplications/auto-review-pr/src/pr_review/core/review_pipeline.py review orchestration with injected backend/runner\napplications/auto-review-pr/src/pr_review/core/draft_submission.py approved-review submission rules\napplications/auto-review-pr/src/pr_review/core/polling.py    PR queueing and bounded/continuous polling\napplications/auto-review-pr/src/pr_review/core/review_parser.py assessment and inline-comment parsing\napplications/auto-review-pr/src/pr_review/core/review_schema.py structured review output schema\napplications/auto-review-pr/src/pr_review/adapters/agents/   OpenCode, Codex, Claude Code, Pi adapters plus factory\napplications/auto-review-pr/src/pr_review/adapters/github/gh_cli.py GitHub CLI PR host adapter\napplications/auto-review-pr/src/pr_review/adapters/process/  subprocess-backed command runner\napplications/auto-review-pr/src/pr_review/services/          state, worktrees, drafts, polling runtime, web actions, events\napplications/auto-review-pr/.opencode/agents/pr-review.md    OpenCode agent definition\napplications/auto-review-pr/opencode.json                    OpenCode config for editor validation\napplications/auto-review-pr/.agents/skills/{pr-review,pr-revise,gh-cli}/ app-bundled skills\napplications/auto-review-pr/tests/unit/pr_review/             unit tests\napplications/auto-review-pr/tests/integration/                integration tests\n```\n\nFoldering rule for provider-boundary work:\n\n- `src/pr_review/` root is the app shell: package metadata, web entrypoint, config, paths, and logging. It is not a `utils` bucket.\n- `src/pr_review/core/` is for app policy: review pipeline, polling decisions, submission rules, prompt contracts, parsing, and schema rules.\n- `src/pr_review/adapters/` is for external integration quirks: agent CLIs, `gh`, and subprocess execution.\n- `src/pr_review/services/` is for concrete local mechanics with one expected implementation: git worktrees, draft files, and event helpers.\n\nUse this test when placing code: app-wide setup goes in the root package, business decisions go in `core`, outside-world translation goes in `adapters`, and local app chores go in `services`.\n\nRuntime files:\n\n```text\napplications/auto-review-pr/pr-review.json     local configuration, gitignored\napplications/auto-review-pr/state_PR.json      runtime state, gitignored\napplications/auto-review-pr/.pr-review/drafts/ editable review drafts\napplications/auto-review-pr/.pr-review/logs/   backend command logs\napplications/auto-review-pr/.pr-review/worktrees/ one worktree per pull request\n```\n\nState and draft files are written atomically. SIGINT and SIGTERM flush pending state before exit.\n\n## Configuration\n\nCreate local configuration from the committed example:\n\n```bash\ncp applications/auto-review-pr/pr-review.json.example applications/auto-review-pr/pr-review.json\n```\n\nThe file is optional. Repository detection and these defaults apply when it is absent:\n\n```json\n{\n  \"repository\": \"\",\n  \"provider\": \"opencode\",\n  \"model\": \"\",\n  \"agent\": \"pr-review\",\n  \"provider_options\": {},\n  \"interval_seconds\": 600,\n  \"timeout_seconds\": 300,\n  \"skip_draft_prs\": false,\n  \"skip_bot_authors\": false,\n  \"notify_command\": \"\",\n  \"editor\": \"code\",\n  \"max_workers\": 4\n}\n```\n\nRules:\n\n- `interval_seconds` and `timeout_seconds` must be positive integers.\n- `timeout_seconds` cannot exceed `interval_seconds`.\n- Unknown keys and incorrect value types stop startup with an error.\n- `max_workers` must be a positive integer.\n- `provider` must be one of `opencode`, `codex`, `claude-code`, or `pi`.\n- Empty `repository` uses the `origin` remote.\n- Empty `model` uses the agent default.\n- `provider_options` passes backend-specific CLI flags when needed.\n- `skip_draft_prs` and `skip_bot_authors` are enforced before queueing.\n\n## Usage\n\nRun these commands from `applications/auto-review-pr/`:\n\n```bash\n# Run the web dashboard\nuv run pr-review-web\n\n# Run through the top-level src entrypoint\nuv run python src/main.py\n\n# Run as a package module\nuv run python -m pr_review.web\n```\n\nEligible pending PRs are processed in parallel once per poll cycle, bounded by `max_workers`. One failure does not prevent later PRs in the queue from running.\n\n## Draft Contract\n\nThe agent produces:\n","metadata":{"output":"# GitHub PR Auto-Review with Selectable Coding Agents\n\nThis directory is a standalone Python app. Its package, tests, skills, runtime files, and project metadata all live under `applications/auto-review-pr/`.\n\nThe app code lives under `src/pr_review/`. The web dashboard polls open GitHub pull requests, runs a read-only review agent, saves each result as a draft, and lets humans approve or revise through the browser.\n\nSupported backends:\n\n- `opencode`\n- `codex`\n- `claude-code`\n- `pi`\n\nThe agent cannot edit files or submit reviews. Only the Python tool can submit after approval through the web dashboard.\n\nEach review run explicitly loads three repository skills:\n\n- `pr-review` for analysis, severity, and draft structure\n- `gh-cli` for GitHub PR reads\n- `pr-revise` for feedback triage and re-review analysis\n\n`pr-revise` is restricted to analysis. Its implementation, commit, push, reply, polling, and sleep steps are not used.\n\n## Architecture\n\n```text\napplications/auto-review-pr/pyproject.toml                   standalone project metadata\napplications/auto-review-pr/src/main.py                      top-level app entrypoint\napplications/auto-review-pr/src/pr_review/config.py          local configuration and validation\napplications/auto-review-pr/src/pr_review/web.py             FastAPI dashboard entry point\napplications/auto-review-pr/src/pr_review/paths.py           app/runtime path constants\napplications/auto-review-pr/src/pr_review/log.py             shared logging setup\napplications/auto-review-pr/src/pr_review/core/models.py     do