s(frozen=True)\nclass CommandResult:\n    \"\"\"Normalized command result.\"\"\"\n\n    args: list[str]\n    returncode: int\n    stdout: str = \"\"\n    stderr: str = \"\"\n    timed_out: bool = False\n\n    @property\n    def ok(self) -> bool:\n        \"\"\"Return whether the command completed successfully.\"\"\"\n        return not self.timed_out and self.returncode == 0\n\n\n@dataclass(frozen=True)\nclass Invocation:\n    \"\"\"Provider command and any required runtime metadata.\"\"\"\n\n    command: list[str]\n    input_text: str | None = None\n\n\n@dataclass(frozen=True)\nclass ParsedBackendResult:\n    \"\"\"Normalized backend output.\"\"\"\n\n    review_text: str\n    session_id: str = \"\"\n    errors: tuple[str, ...] = ()\n\n\n@dataclass(frozen=True)\nclass StreamEvent:\n    \"\"\"A single parsed streaming event from an agent backend.\"\"\"\n\n    event_type: str\n    text: str = \"\"\n    session_id: str = \"\"\n    error: str = \"\"\n\n\n@dataclass(frozen=True)\nclass AgentInvocationRequest:\n    \"\"\"Provider-relevant inputs for one agent invocation.\"\"\"\n\n    worktree: Path\n    prompt_file: Path\n    draft_file: Path\n    model: str\n    agent: str\n    provider_options: Mapping[str, object]\n    agent_prompt: str = \"\"\n    session_id: str = \"\"\n    is_revision: bool = False\n\n\nclass AgentBackendPort(Protocol):\n    \"\"\"Provider adapter interface for agent execution.\"\"\"\n\n    name: str\n    supports_resume: bool\n    output_mode: str\n\n    def build_invocation(self, request: AgentInvocationRequest) -> Invocation:\n        \"\"\"Build the command and input for one agent run.\"\"\"\n\n    def parse_result(self, result: CommandResult) -> ParsedBackendResult:\n        \"\"\"Normalize command output into backend result text and metadata.\"\"\"\n\n    def parse_stream_line(self, line: str) -> StreamEvent | None:\n        \"\"\"Normalize one provider stream event.\"\"\"\n\n\nclass PullRequestPort(Protocol):\n    \"\"\"Host pull request operations used by core services.\"\"\"\n\n    def list_open(self, repo: str) -> list[PullRequestSnapshot]:\n        \"\"\"Return open pull requests for queueing.\"\"\"\n\n    def get_open(self, repo: str, pr_number: int) -> PullRequestSnapshot | None:\n        \"\"\"Return one open pull request or None.\"\"\"\n\n    def get_authenticated_login(self) -> str:\n        \"\"\"Return current host user login.\"\"\"\n\n    def get_commentable_lines(self, repo: str, pr_number: int) -> set[tuple[str, int]]:\n        \"\"\"Return changed right-side lines that can receive comments.\"\"\"\n\n    def submit_review(self, request: SubmitReviewRequest) -> CommandResult:\n        \"\"\"Submit one host review event.\"\"\"\n\n\nclass CommandRunnerPort(Protocol):\n    \"\"\"Process execution boundary.\"\"\"\n\n    def run(\n        self,\n        args: Sequence[str],\n        *,\n        cwd: Path | str | None = None,\n        timeout: int | float | None = None,\n        input_text: str | None = None,\n    ) -> CommandResult:\n        \"\"\"Run a command and return normalized output.\"\"\"\n\n    def stream(\n        self,\n        args: Sequence[str],\n        *,\n        cwd: Path | str | None = None,\n        timeout: int | float | None = None,\n        input_text: str | None = None,\n        on_line: Callable[[str], None] | None = None,\n    ) -> CommandResult:\n        \"\"\"Run a command while streaming stdout lines.\"\"\"","lineStart":1,"lineEnd":129,"totalLines":129,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/core/ports.py","time":{"start":1782271645971,"end":1782271645990}},"id":"prt_ef7ab1906001zCVhU8tXPPM4em","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab0a68001pKfQDW7DSoKZxZ"}}
{"type":"tool_use","timestamp":1782271646367,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_e5ek8hap","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/config.py"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/config.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Configuration loading and validation.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import json\n6: import re\n7: from dataclasses import dataclass\n8: from pathlib import Path\n9: from typing import Any, Callable\n10: \n11: from .adapters.agents.factory import supported_agent_backends\n12: from .adapters.process.subprocess_runner import run_command\n13: from .core.errors import ConfigError\n14: from .core.ports import CommandResult\n15: from .log import get_logger\n16: from .paths import CONFIG_FILE, REPO_ROOT\n17: \n18: log = get_logger()\n19: \n20: DEFAULT_INTERVAL = 600\n21: DEFAULT_TIMEOUT = 300\n22: DEFAULT_MAX_WORKERS = 4\n23: SUPPORTED_PROVIDERS = set(supported_agent_backends())\n24: ALLOWED_KEYS = {\n25:     \"repository\",\n26:     \"provider\",\n27:     \"model\",\n28:     \"agent\",\n29:     \"provider_options\",\n30:     \"interval_seconds\",\n31:     \"timeout_seconds\",\n32:     \"max_workers\",\n33: }\n34: \n35: \n36: @dataclass(frozen=True)\n37: class Config:\n38:     \"\"\"Validated PR review configuration.\"\"\"\n39: \n40:     repo: str\n41:     remote: str\n42:     provider: str = \"opencode\"\n43:     model: str = \"\"\n44:     agent: str = \"pr-review\"\n45:     provider_options: dict[str, object] | None = None\n46:     interval: int = DEFAULT_INTERVAL\n47:     timeout: int = DEFAULT_TIMEOUT\n48:     max_workers: int = DEFAULT_MAX_WORKERS\n49: \n50: \n51: Runner = Callable[..., CommandResult]\n52: \n53: \n54: def _require_type(data: dict[str, Any], key: str, expected: type, default: Any) -> Any:\n55:     value = data.get(key, default)\n56:     if type(value) is not expected:\n57:         raise ConfigError(f\"{key} must be {expected.__name__}\")\n58:     return value\n59: \n60: \n61: def _repo_from_url(url: str) -> str:\n62:     normalized = re.sub(r\"\\.git$\", \"\", url.strip())\n63:     match = re.search(r\"[:/]([^/]+/[^/]+)$\", normalized)\n64:     return match.group(1) if match else \"\"\n65: \n66: \n67: def _detect_repository(runner: Runner, repo_root: Path) -> str:\n68:     result = runner([\"git\", \"remote\", \"get-url\", \"origin\"], cwd=repo_root, timeout=30)\n69:     return _repo_from_url(result.stdout) if result.ok else \"\"\n70: \n71: \n72: def _find_remote(repo: str, runner: Runner, repo_root: Path) -> str:\n73:     remotes = runner([\"git\", \"remote\"], cwd=repo_root, timeout=30)\n74:     if remotes.ok:\n75:         for remote in remotes.stdout.splitlines():\n76:             result = runner([\"git\", \"remote\", \"get-url\", remote], cwd=repo_root, timeout=30)\n77:             if result.ok and _repo_from_url(result.stdout) == repo:\n78:                 return remote\n79:     raise ConfigError(\n80:         f\"cannot find a git remote for {repo}; configure an existing remote or set repository to a tracked repo\"\n81:     )\n82: \n83: \n84: def load_config(\n85:     override_model: str | None = None,\n86:     *,\n87:     path: Path = CONFIG_FILE,\n88:     repo_root: Path = REPO_ROOT,\n89:     runner: Runner = run_command,\n90: ) -> Config:\n91:     \"\"\"Load local JSON configuration and derive repository defaults.\"\"\"\n92:     data: dict[str, Any] = {}\n93:     if path.exists():\n94:         try:\n95:             parsed = json.loads(path.read_text(encoding=\"utf-8\"))\n96:         except json.JSONDecodeError as exc:\n97:             raise ConfigError(f\"invalid config JSON: {exc}\") from exc\n98:         if not isinstance(parsed, dict):\n99:             raise ConfigError(\"config root must be a JSON object\")\n100:         data = parsed\n101: \n102:     unknown = sorted(set(data) - ALLOWED_KEYS)\n103:     if unknown:\n104:         raise ConfigError(f\"unknown config key(s): {', '.join(unknown)}\")\n105: \n106:     repo = _require_type(data, \"repository\", str, \"\")\n107:     provider = _require_type(data, \"provider\", str, \"opencode\")\n108:     model = _require_type(data, \"model\", str, \"\")\n109:     agent = _require_type(data, \"agent\", str, \"pr-review\")\n110:     provider_options = data.get(\"provider_options\", {})\n111:     if not isinstance(provider_options, dict):\n112:         raise ConfigError(\"provider_options must be dict\")\n113:     interval = _require_type(data, \"interval_seconds\", int, DEFAULT_INTERVAL)\n114:     timeout = _require_type(data, \"timeout_seconds\", int, DEFAULT_TIMEOUT)\n115:     max_workers = _require_type(data, \"max_workers\", int, DEFAULT_MAX_WORKERS)\n116: \n117:     if interval <= 0:\n118:         raise ConfigError(\"interval_seconds must be greater than 0\")\n119:     if timeout <= 0:\n120:         raise ConfigError(\"timeout_seconds must be greater than 0\")\n121:     if timeout > interval:\n122:         raise ConfigError(\"timeout_seconds cannot exceed interval_seconds\")\n123:     if max_workers < 1:\n124:         raise ConfigError(\"max_workers must be at least 1\")\n125:     if provider not in SUPPORTED_PROVIDERS:\n126:         raise ConfigError(f\"provider must be one of: {', '.join(sorted(SUPPORTED_PROVIDERS))}\")\n127: \n128:     repo = repo or _detect_repository(runner, repo_root)\n129:     if not repo:\n130:         raise ConfigError(\"cannot detect repository; set repository in pr-review.json\")\n131:     if override_model:\n132:         model = override_model\n133: \n134:     log.debug(\"load_config: repo=%s provider=%s\", repo, provider)\n135:     return Config(\n136:         repo=repo,\n137:         remote=_find_remote(repo, runner, repo_root),\n138:         provider=provider,\n139:         model=model,\n140:         agent=agent,\n141:         provider_options=provider_options,\n142:         interval=interval,\n143:         timeout=timeout,\n144:         max_workers=max_workers,\n145:     )\n\n(End of file - total 145 lines)\n</content>","metadata":{"preview":"\"\"\"Configuration loading and validation.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport re\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any, Callable\n\nfrom .adapters.agents.factory import supported_agent_backends\nfrom .adapters.process.subprocess_runner import run_command\nfrom .core.errors import ConfigError\nfrom .core.ports import CommandResult\nfrom .log import get_logger\nfrom .paths import CONFIG_FILE, REPO_ROOT\n\nlog = get_logger()\n\nDEFAULT_INTERVAL = 600","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/config.py","text":"\"\"\"Configuration loading and validation.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport re\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any, Callable\n\nfrom .adapters.agents.factory import supported_agent_backends\nfrom .adapters.process.subprocess_runner import run_command\nfrom .core.errors import ConfigError\nfrom .core.ports import CommandResult\nfrom .log import get_logger\nfrom .paths import CONFIG_FILE, REPO_ROOT\n\nlog = get_logger()\n\nDEFAULT_INTERVAL = 600\nDEFAULT_TIMEOUT = 300\nDEFAULT_MAX_WORKERS = 4\nSUPPORTED_PROVIDERS = set(supported_agent_backends())\nALLOWED_KEYS = {\n    \"repository\",\n    \"provider\",\n    \"model\",\n    \"agent\",\n    \"provider_options\",\n    \"interval_seconds\",\n    \"timeout_seconds\",\n    \"max_workers\",\n}\n\n\n@dataclass(frozen=True)\nclass Config:\n    \"\"\"Validated PR review configuration.\"\"\"\n\n    repo: str\n    remote: str\n    provider: str = \"opencode\"\n    model: str = \"\"\n    agent: str = \"pr-review\"\n    provider_options: dict[str, object] | None = None\n    interval: int = DEFAULT_INTERVAL\n    timeout: int = DEFAULT_TIMEOUT\n    max_workers: int = DEFAULT_MAX_WORKERS\n\n\nRunner = Callable[..., CommandResult]\n\n\ndef _require_type(data: dict[str, Any], key: str, expected: type, default: Any) -> Any:\n    value = data.get(key, default)\n    if type(value) is not expected:\n        raise ConfigError(f\"{key} must be {expected.__name__}\")\n    return value\n\n\ndef _repo_from_url(url: str) -> str:\n    normalized = re.sub(r\"\\.git$\", \"\", url.strip())\n    match = re.search(r\"[:/]([^/]+/[^/]+)$\", normalized)\n    return match.group(1) if match else \"\"\n\n\ndef _detect_repository(runner: Runner, repo_root: Path) -> str:\n    result = runner([\"git\", \"remote\", \"get-url\", \"origin\"], cwd=repo_root, timeout=30)\n    return _repo_from_url(result.stdout) if result.ok else \"\"\n\n\ndef _find_remote(repo: str, runner: Runner, repo_root: Path) -> str:\n    remotes = runner([\"git\", \"remote\"], cwd=repo_root, timeout=30)\n    if remotes.ok:\n        for remote in remotes.stdout.splitlines():\n            result = runner([\"git\", \"remote\", \"get-url\", remote], cwd=repo_root, timeout=30)\n            if result.ok and _repo_from_url(result.stdout) == repo:\n                return remote\n    raise ConfigError(\n        f\"cannot find a git remote for {repo}; configure an existing remote or set repository to a tracked repo\"\n    )\n\n\ndef load_config(\n    override_model: str | None = None,\n    *,\n    path: Path = CONFIG_FILE,\n    repo_root: Path = REPO_ROOT,\n    runner: Runner = run_command,\n) -> Config:\n    \"\"\"Load local JSON configuration and derive repository defaults.\"\"\"\n    data: dict[str, Any] = {}\n    if path.exists():\n        try:\n            parsed = json.loads(path.read_text(encoding=\"utf-8\"))\n        except json.JSONDecodeError as exc:\n            raise ConfigError(f\"invalid config JSON: {exc}\") from exc\n        if not isinstance(parsed, dict):\n            raise ConfigError(\"config root must be a JSON object\")\n        data = parsed\n\n    unknown = sorted(set(data) - ALLOWED_KEYS)\n    if unknown:\n        raise ConfigError(f\"unknown config key(s): {', '.join(unknown)}\")\n\n    repo = _require_type(data, \"repository\", str, \"\")\n    provider = _require_type(data, \"provider\", str, \"opencode\")\n    model = _require_type(data, \"model\", str, \"\")\n    agent = _require_type(data, \"agent\", str, \"pr-review\")\n    provider_options = data.get(\"provider_options\", {})\n    if not isinstance(provider_options, dict):\n        raise ConfigError(\"provider_options must be dict\")\n    interval = _require_type(data, \"interval_seconds\", int, DEFAULT_INTERVAL)\n    timeout = _require_type(data, \"timeout_seconds\", int, DEFAULT_TIMEOUT)\n    max_workers = _require_type(data, \"max_workers\", int, DEFAULT_MAX_WORKERS)\n\n    if interval <= 0:\n        raise ConfigError(\"interval_seconds must be greater than 0\")\n    if timeout <= 0:\n        raise ConfigError(\"timeout_seconds must be greater than 0\")\n    if timeout > interval:\n        raise ConfigError(\"timeout_seconds cannot exceed interval_seconds\")\n    if max_workers < 1:\n        raise ConfigError(\"max_workers must be at least 1\")\n    if provider not in SUPPORTED_PROVIDERS:\n        raise ConfigError(f\"provider must be one of: {', '.join(sorted(SUPPORTED_PROVIDERS))}\")\n\n    repo = repo or _detect_repository(runner, repo_root)\n    if not repo:\n        raise ConfigError(\"cannot detect repository; set repository in pr-review.json\")\n    if override_model:\n        model = override_model\n\n    log.debug(\"load_config: repo=%s provider=%s\", repo, provider)\n    return Config(\n        repo=repo,\n        remote=_find_remote(repo, runner, repo_root),\n        provider=provider,\n        model=model,\n        agent=agent,\n        provider_options=provider_options,\n        interval=interval,\n        timeout=timeout,\n        max_workers=max_workers,\n    )","lineStart":1,"lineEnd":145,"totalLines":145,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/config.py","time":{"start":1782271646342,"end":1782271646361}},"id":"prt_ef7ab1a7c001hG43wTH1F6CPKL","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab0a68001pKfQDW7DSoKZxZ"}}
{"type":"tool_use","timestamp":1782271646892,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_motls4op","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/core/review_pipeline.py"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/core/review_pipeline.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Core review execution pipeline.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from pathlib import Path\n6: from typing import Protocol\n7: \n8: from pr_review.config import Config\n9: from pr_review.core.models import PullRequestSnapshot, ReviewDraft, ReviewRequest, ReviewRunResult\n10: from pr_review.core.ports import AgentBackendPort, AgentInvocationRequest, CommandResult, CommandRunnerPort, Invocation\n11: from pr_review.core.prompts import build_review_prompt\n12: from pr_review.log import get_logger\n13: from pr_review.paths import APP_ROOT, DATA_DIR, LOGS_DIR\n14: from pr_review.services.file_drafts import FileDraftStore, atomic_write, utc_now\n15: from pr_review.services.state_store import StateStore\n16: \n17: log = get_logger()\n18: \n19: \n20: class EventPublisher(Protocol):\n21:     \"\"\"Minimal event sink used by review runs.\"\"\"\n22: \n23:     def publish(self, pr_number: int, event_type: str, data: dict[str, object] | None = None) -> None:\n24:         \"\"\"Publish one event.\"\"\"\n25: \n26: \n27: class NullEventPublisher:\n28:     \"\"\"Event sink that discards all events.\"\"\"\n29: \n30:     def publish(self, _pr_number: int, _event_type: str, _data: dict[str, object] | None = None) -> None:\n31:         \"\"\"Discard one event.\"\"\"\n32: \n33: \n34: class ReviewPipeline:\n35:     \"\"\"Run one provider-backed review and persist its draft.\"\"\"\n36: \n37:     def __init__(  # noqa: PLR0913\n38:         self,\n39:         *,\n40:         config: Config,\n41:         backend: AgentBackendPort,\n42:         command_runner: CommandRunnerPort,\n43:         draft_store: FileDraftStore,\n44:         state: StateStore,\n45:         data_dir: Path = DATA_DIR,\n46:         logs_dir: Path = LOGS_DIR,\n47:     ) -> None:\n48:         \"\"\"Initialize pipeline dependencies.\"\"\"\n49:         self._config = config\n50:         self._backend = backend\n51:         self._command_runner = command_runner\n52:         self._draft_store = draft_store\n53:         self._state = state\n54:         self._data_dir = data_dir\n55:         self._logs_dir = logs_dir\n56: \n57:     def run(self, request: ReviewRequest, events: EventPublisher | None = None) -> ReviewRunResult:\n58:         \"\"\"Run one review and publish normalized backend events.\"\"\"\n59:         event_sink = events or NullEventPublisher()\n60:         pr_number = request.pr.number\n61:         action = \"revising\" if request.feedback else \"reviewing\"\n62:         log.info(\"PR #%d %s with %s backend\", pr_number, action, self._config.provider)\n63:         self._start_review_run(pr_number, request.feedback)\n64:         event_sink.publish(pr_number, \"status\", {\"status\": \"reviewing\", \"provider\": self._config.provider})\n65:         invocation = self._build_invocation(request)\n66:         event_sink.publish(pr_number, \"command\", {\"args\": invocation.command})\n67:         result = self._command_runner.stream(\n68:             invocation.command,\n69:             cwd=request.worktree,\n70:             timeout=self._config.timeout,\n71:             input_text=invocation.input_text,\n72:             on_line=lambda line: self._publish_stream_line(pr_number, line, event_sink),\n73:         )\n74:         log.debug(\"PR #%d agent exited rc=%d\", pr_number, result.returncode)\n75:         event_sink.publish(pr_number, \"exit\", {\"returncode\": result.returncode, \"timed_out\": result.timed_out})\n76:         self._write_review_log(pr_number, invocation, result, request.feedback)\n77:         try:\n78:             draft_text, session_id, draft_source = self._finalize_review_result(pr_number, request, result)\n79:         except ValueError as exc:\n80:             message = str(exc) or result.stderr or \"Model did not write draft file\"\n81:             log.warning(\"PR #%d draft failed: %s\", pr_number, message[:200])\n82:             event_sink.publish(pr_number, \"error\", {\"message\": message[:500]})\n83:             self._state.update_pr(pr_number, status=\"failed\", error_message=message[:500], updated_at=utc_now())\n84:             self._state.flush()\n85:             return ReviewRunResult(ok=False, error=message[:500])\n86:         if session_id:\n87:             self._state.update_pr(pr_number, session_id=session_id)\n88:         self._draft_store.adopt(pr_number, draft_source, self._state)\n89:         event_sink.publish(pr_number, \"status\", {\"status\": \"drafted\"})\n90:         log.info(\"PR #%d draft saved\", pr_number)\n91:         return ReviewRunResult(ok=True, draft=ReviewDraft(text=draft_text, session_id=session_id))\n92: \n93:     def _start_review_run(self, pr_number: int, feedback: str | None) -> None:\n94:         review_count = int(self._state.get(pr_number, \"review_count\", 0)) + 1\n95:         self._state.update_pr(\n96:             pr_number,\n97:             status=\"revision_requested\" if feedback else \"reviewing\",\n98:             review_count=review_count,\n99:             review_provider=self._config.provider,\n100:             needs_review=False,\n101:             error_message=\"\",\n102:             updated_at=utc_now(),\n103:         )\n104:         self._state.flush()\n105: \n106:     def _build_invocation(self, request: ReviewRequest) -> Invocation:\n107:         draft_file = request.worktree / \".pr-review\" / f\"pr-{request.pr.number}-review.md\"\n108:         draft_file.parent.mkdir(parents=True, exist_ok=True)\n109:         prompt = build_review_prompt(\n110:             request.pr.number,\n111:             request.pr.title,\n112:             request.repo,\n113:             request.pr.branch,\n114:             draft_file,\n115:             request.feedback,\n116:             request.existing_draft,\n117:         )\n118:         prompt_file = self._data_dir / f\"pr-{request.pr.number}-{'revise-' if request.feedback else ''}prompt.txt\"\n119:         atomic_write(prompt_file, prompt)\n120:         agent_prompt_file = APP_ROOT / \".agents\" / \"pr-review-agent.md\"\n121:         agent_prompt = \"\"\n122:         if agent_prompt_file.exists():\n123:             agent_prompt = agent_prompt_file.read_text(encoding=\"utf-8\")\n124:         if agent_prompt:\n125:             atomic_write(request.worktree / \"AGENTS.md\", agent_prompt)\n126:         return self._backend.build_invocation(\n127:             AgentInvocationRequest(\n128:                 worktree=request.worktree,\n129:                 prompt_file=prompt_file,\n130:                 draft_file=draft_file,\n131:                 model=self._config.model,\n132:                 agent=self._config.agent,\n133:                 provider_options=self._config.provider_options or {},\n134:                 agent_prompt=agent_prompt,\n135:                 session_id=request.session_id if self._backend.supports_resume else \"\",\n136:                 is_revision=request.feedback is not None,\n137:             )\n138:         )\n139: \n140:     def _publish_stream_line(self, pr_number: int, line: str, events: EventPublisher) -> None:\n141:         parsed = self._backend.parse_stream_line(line)\n142:         if parsed is None:\n143:             return\n144:         event_data: dict[str, object] = {\"backend_type\": parsed.event_type}\n145:         if parsed.text:\n146:             event_data[\"text\"] = parsed.text\n147:         if parsed.session_id:\n148:             event_data[\"session_id\"] = parsed.session_id\n149:         if parsed.error:\n150:             event_data[\"error\"] = parsed.error\n151:         events.publish(pr_number, parsed.event_type, event_data)\n152: \n153:     def _write_review_log(\n154:         self,\n155:         pr_number: int,\n156:         invocation: Invocation,\n157:         result: CommandResult,\n158:         feedback: str | None,\n159:     ) -> None:\n160:         log_file = self._logs_dir / f\"pr-{pr_number}{'-revise' if feedback else ''}.log\"\n161:         atomic_write(\n162:             log_file,\n163:             f\"COMMAND: {' '.join(invocation.command)}\\nEXIT CODE: {result.returncode}\\n\"\n164:             f\"\\n--- STDOUT ---\\n{result.stdout}\\n\\n--- STDERR ---\\n{result.stderr or '(empty)'}\\n\",\n165:         )\n166: \n167:     def _finalize_review_result(\n168:         self,\n169:         pr_number: int,\n170:         request: ReviewRequest,\n171:         result: CommandResult,\n172:     ) -> tuple[str, str, Path]:\n173:         parsed = self._backend.parse_result(result)\n174:         draft_source = request.worktree / \".pr-review\" / f\"pr-{pr_number}-review.md\"\n175:         if not draft_source.exists():\n176:             raise ValueError(f\"model did not write draft file: {draft_source}\")\n177:         draft_text = draft_source.read_text(encoding=\"utf-8\").strip()\n178:         if not draft_text:\n179:             raise ValueError(f\"model wrote empty draft file: {draft_source}\")\n180:         return draft_text, parsed.session_id, draft_source\n181: \n182: \n183: def snapshot_from_state(pr_number: int, state: StateStore) -> PullRequestSnapshot:\n184:     \"\"\"Build a PR snapshot from persisted state for compatibility wrappers.\"\"\"\n185:     return PullRequestSnapshot(\n186:         number=pr_number,\n187:         title=str(state.get(pr_number, \"title\")),\n188:         head_sha=str(state.get(pr_number, \"head_sha\", \"\")),\n189:         base_sha=str(state.get(pr_number, \"base_sha\", \"\")),\n190:         branch=str(state.get(pr_number, \"branch\")),\n191:         author_login=str(state.get(pr_number, \"author\", \"\")),\n192:         state=str(state.get(pr_number, \"pr_state\", \"open\")),\n193:     )\n\n(End of file - total 193 lines)\n</content>","metadata":{"preview":"\"\"\"Core review execution pipeline.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Protocol\n\nfrom pr_review.config import Config\nfrom pr_review.core.models import PullRequestSnapshot, ReviewDraft, ReviewRequest, ReviewRunResult\nfrom pr_review.core.ports import AgentBackendPort, AgentInvocationRequest, CommandResult, CommandRunnerPort, Invocation\nfrom pr_review.core.prompts import build_review_prompt\nfrom pr_review.log import get_logger\nfrom pr_review.paths import APP_ROOT, DATA_DIR, LOGS_DIR\nfrom pr_review.services.file_drafts import FileDraftStore, atomic_write, utc_now\nfrom pr_review.services.state_store import StateStore\n\nlog = get_logger()\n\n\nclass EventPublisher(Protocol):","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/core/review_pipeline.py","text":"\"\"\"Core review execution pipeline.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom typing import Protocol\n\nfrom pr_review.config import Config\nfrom pr_review.core.models import PullRequestSnapshot, ReviewDraft, ReviewRequest, ReviewRunResult\nfrom pr_review.core.ports import AgentBackendPort, AgentInvocationRequest, CommandResult, CommandRunnerPort, Invocation\nfrom pr_review.core.prompts import build_review_prompt\nfrom pr_review.log import get_logger\nfrom pr_review.paths import APP_ROOT, DATA_DIR, LOGS_DIR\nfrom pr_review.services.file_drafts import FileDraftStore, atomic_write, utc_now\nfrom pr_review.services.state_store import StateStore\n\nlog = get_logger()\n\n\nclass EventPublisher(Protocol):\n    \"\"\"Minimal event sink used by review runs.\"\"\"\n\n    def publish(self, pr_number: int, event_type: str, data: dict[str, object] | None = None) -> None:\n        \"\"\"Publish one event.\"\"\"\n\n\nclass NullEventPublisher:\n    \"\"\"Event sink that discards all events.\"\"\"\n\n    def publish(self, _pr_number: int, _event_type: str, _data: dict[str, object] | None = None) -> None:\n        \"\"\"Discard one event.\"\"\"\n\n\nclass ReviewPipeline:\n    \"\"\"Run one provider-backed review and persist its draft.\"\"\"\n\n    def __init__(  # noqa: PLR0913\n        self,\n        *,\n        config: Config,\n        backend: AgentBackendPort,\n        command_runner: CommandRunnerPort,\n        draft_store: FileDraftStore,\n        state: StateStore,\n        data_dir: Path = DATA_DIR,\n        logs_dir: Path = LOGS_DIR,\n    ) -> None:\n        \"\"\"Initialize pipeline dependencies.\"\"\"\n        self._config = config\n        self._backend = backend\n        self._command_runner = command_runner\n        self._draft_store = draft_store\n        self._state = state\n        self._data_dir = data_dir\n        self._logs_dir = logs_dir\n\n    def run(self, request: ReviewRequest, events: EventPublisher | None = None) -> ReviewRunResult:\n        \"\"\"Run one review and publish normalized backend events.\"\"\"\n        event_sink = events or NullEventPublisher()\n        pr_number = request.pr.number\n        action = \"revising\" if request.feedback else \"reviewing\"\n        log.info(\"PR #%d %s with %s backend\", pr_number, action, self._config.provider)\n        self._start_review_run(pr_number, request.feedback)\n        event_sink.publish(pr_number, \"status\", {\"status\": \"reviewing\", \"provider\": self._config.provider})\n        invocation = self._build_invocation(request)\n        event_sink.publish(pr_number, \"command\", {\"args\": invocation.command})\n        result = self._command_runner.stream(\n            invocation.command,\n            cwd=request.worktree,\n            timeout=self._config.timeout,\n            input_text=invocation.input_text,\n            on_line=lambda line: self._publish_stream_line(pr_number, line, event_sink),\n        )\n        log.debug(\"PR #%d agent exited rc=%d\", pr_number, result.returncode)\n        event_sink.publish(pr_number, \"exit\", {\"returncode\": result.returncode, \"timed_out\": result.timed_out})\n        self._write_review_log(pr_number, invocation, result, request.feedback)\n        try:\n            draft_text, session_id, draft_source = self._finalize_review_result(pr_number, request, result)\n        except ValueError as exc:\n            message = str(exc) or result.stderr or \"Model did not write draft file\"\n            log.warning(\"PR #%d draft failed: %s\", pr_number, message[:200])\n            event_sink.publish(pr_number, \"error\", {\"message\": message[:500]})\n            self._state.update_pr(pr_number, status=\"failed\", error_message=message[:500], updated_at=utc_now())\n            self._state.flush()\n            return ReviewRunResult(ok=False, error=message[:500])\n        if session_id:\n            self._state.update_pr(pr_number, session_id=session_id)\n        self._draft_store.adopt(pr_number, draft_source, self._state)\n        event_sink.publish(pr_number, \"status\", {\"status\": \"drafted\"})\n        log.info(\"PR #%d draft saved\", pr_number)\n        return ReviewRunResult(ok=True, draft=ReviewDraft(text=draft_text, session_id=session_id))\n\n    def _start_review_run(self, pr_number: int, feedback: str | None) -> None:\n        review_count = int(self._state.get(pr_number, \"review_count\", 0)) + 1\n        self._state.update_pr(\n            pr_number,\n            status=\"revision_requested\" if feedback else \"reviewing\",\n            review_count=review_count,\n            review_provider=self._config.provider,\n            needs_review=False,\n            error_message=\"\",\n            updated_at=utc_now(),\n        )\n        self._state.flush()\n\n    def _build_invocation(self, request: ReviewRequest) -> Invocation:\n        draft_file = request.worktree / \".pr-review\" / f\"pr-{request.pr.number}-review.md\"\n        draft_file.parent.mkdir(parents=True, exist_ok=True)\n        prompt = build_review_prompt(\n            request.pr.number,\n            request.pr.title,\n            request.repo,\n            request.pr.branch,\n            draft_file,\n            request.feedback,\n            request.existing_draft,\n        )\n        prompt_file = self._data_dir / f\"pr-{request.pr.number}-{'revise-' if request.feedback else ''}prompt.txt\"\n        atomic_write(prompt_file, prompt)\n        agent_prompt_file = APP_ROOT / \".agents\" / \"pr-review-agent.md\"\n        agent_prompt = \"\"\n        if agent_prompt_file.exists():\n            agent_prompt = agent_prompt_file.read_text(encoding=\"utf-8\")\n        if agent_prompt:\n            atomic_write(request.worktree / \"AGENTS.md\", agent_prompt)\n        return self._backend.build_invocation(\n            AgentInvocationRequest(\n                worktree=request.worktree,\n                prompt_file=prompt_file,\n                draft_file=draft_file,\n                model=self._config.model,\n                agent=self._config.agent,\n                provider_options=self._config.provider_options or {},\n                agent_prompt=agent_prompt,\n                session_id=request.session_id if self._backend.supports_resume else \"\",\n                is_revision=request.feedback is not None,\n            )\n        )\n\n    def _publish_stream_line(self, pr_number: int, line: str, events: EventPublisher) -> None:\n        parsed = self._backend.parse_stream_line(line)\n        if parsed is None:\n            return\n        event_data: dict[str, object] = {\"backend_type\": parsed.event_type}\n        if parsed.text:\n            event_data[\"text\"] = parsed.text\n        if parsed.session_id:\n            event_data[\"session_id\"] = parsed.session_id\n        if parsed.error:\n            event_data[\"error\"] = parsed.error\n        events.publish(pr_number, parsed.event_type, event_data)\n\n    def _write_review_log(\n        self,\n        pr_number: int,\n        invocation: Invocation,\n        result: CommandResult,\n        feedback: str | None,\n    ) -> None:\n        log_file = self._logs_dir / f\"pr-{pr_number}{'-revise' if feedback else ''}.log\"\n        atomic_write(\n            log_file,\n            f\"COMMAND: {' '.join(invocation.command)}\\nEXIT CODE: {result.returncode}\\n\"\n            f\"\\n--- STDOUT ---\\n{result.stdout}\\n\\n--- STDERR ---\\n{result.stderr or '(empty)'}\\n\",\n        )\n\n    def _finalize_review_result(\n        self,\n        pr_number: int,\n        request: ReviewRequest,\n        result: CommandResult,\n    ) -> tuple[str, str, Path]:\n        parsed = self._backend.parse_result(result)\n        draft_source = request.worktree / \".pr-review\" / f\"pr-{pr_number}-review.md\"\n        if not draft_source.exists():\n            raise ValueError(f\"model did not write draft file: {draft_source}\")\n        draft_text = draft_source.read_text(encoding=\"utf-8\").strip()\n        if not draft_text:\n            raise ValueError(f\"model wrote empty draft file: {draft_source}\")\n        return draft_text, parsed.session_id, draft_source\n\n\ndef snapshot_from_state(pr_number: int, state: StateStore) -> PullRequestSnapshot:\n    \"\"\"Build a PR snapshot from persisted state for compatibility wrappers.\"\"\"\n    return PullRequestSnapshot(\n        number=pr_number,\n        title=str(state.get(pr_number, \"title\")),\n        head_sha=str(state.get(pr_number, \"head_sha\", \"\")),\n        base_sha=str(state.get(pr_number, \"base_sha\", \"\")),\n        branch=str(state.get(pr_number, \"branch\")),\n        author_login=str(state.get(pr_number, \"author\", \"\")),\n        state=str(state.get(pr_number, \"pr_state\", \"open\")),\n    )","lineStart":1,"lineEnd":193,"totalLines":193,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/core/review_pipeline.py","time":{"start":1782271646867,"end":1782271646886}},"id":"prt_ef7ab1c88001t06oXZSlhyfyTg","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab0a68001pKfQDW7DSoKZxZ"}}
