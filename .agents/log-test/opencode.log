str(payload.get(\"headRefName\", \"\")),\n38:         author_login=str(author_payload.get(\"login\", \"unknown\")),\n39:         state=str(payload.get(\"state\", \"OPEN\")).lower(),\n40:     )\n41: \n42: \n43: class GhCliPullRequestAdapter:\n44:     \"\"\"Pull request operations backed by the GitHub CLI.\"\"\"\n45: \n46:     def __init__(self, runner: Runner = run_command) -> None:\n47:         \"\"\"Initialize the adapter with a command runner.\"\"\"\n48:         self._runner = runner\n49: \n50:     def list_open(self, repo: str) -> list[PullRequestSnapshot]:\n51:         \"\"\"Fetch all open pull requests with eligibility metadata.\"\"\"\n52:         result = self._runner(\n53:             [\n54:                 \"gh\",\n55:                 \"pr\",\n56:                 \"list\",\n57:                 \"--repo\",\n58:                 repo,\n59:                 \"--state\",\n60:                 \"open\",\n61:                 \"--json\",\n62:                 \"number,title,headRefOid,baseRefOid,headRefName,author,isDraft\",\n63:                 \"--limit\",\n64:                 \"100\",\n65:             ],\n66:             timeout=60,\n67:         )\n68:         if not result.ok:\n69:             raise RuntimeError(result.stderr or \"GitHub PR listing timed out\")\n70:         parsed = json.loads(result.stdout or \"[]\")\n71:         if not isinstance(parsed, list):\n72:             raise RuntimeError(\"GitHub PR listing returned invalid JSON\")\n73:         log.debug(\"list_open: %d open PRs\", len(parsed))\n74:         return [pull_request_snapshot_from_json(item) for item in parsed if isinstance(item, dict)]\n75: \n76:     def get_open(self, repo: str, pr_number: int) -> PullRequestSnapshot | None:\n77:         \"\"\"Fetch one open pull request with eligibility metadata.\"\"\"\n78:         result = self._runner(\n79:             [\n80:                 \"gh\",\n81:                 \"pr\",\n82:                 \"view\",\n83:                 str(pr_number),\n84:                 \"--repo\",\n85:                 repo,\n86:                 \"--json\",\n87:                 \"number,title,headRefOid,baseRefOid,headRefName,author,isDraft,state\",\n88:             ],\n89:             timeout=60,\n90:         )\n91:         if not result.ok:\n92:             log.warning(\"get_open %d failed: %s\", pr_number, result.stderr[:200])\n93:             return None\n94:         parsed = json.loads(result.stdout or \"{}\")\n95:         if not isinstance(parsed, dict):\n96:             raise RuntimeError(\"GitHub PR view returned invalid JSON\")\n97:         if str(parsed.get(\"state\", \"\")).upper() != \"OPEN\":\n98:             return None\n99:         return pull_request_snapshot_from_json(parsed)\n100: \n101:     def get_authenticated_login(self) -> str:\n102:         \"\"\"Return the login for the authenticated GitHub CLI user.\"\"\"\n103:         result = self._runner([\"gh\", \"api\", \"user\"], timeout=60)\n104:         if not result.ok:\n105:             raise RuntimeError(result.stderr or \"GitHub user lookup timed out\")\n106:         parsed = json.loads(result.stdout or \"{}\")\n107:         if not isinstance(parsed, dict) or not isinstance(parsed.get(\"login\"), str) or not parsed[\"login\"].strip():\n108:             raise RuntimeError(\"GitHub user lookup returned invalid JSON\")\n109:         return parsed[\"login\"].strip()\n110: \n111:     def get_commentable_lines(self, repo: str, pr_number: int) -> set[tuple[str, int]]:\n112:         \"\"\"Return right-side PR diff lines that can receive comments.\"\"\"\n113:         result = self._runner([\"gh\", \"pr\", \"diff\", str(pr_number), \"--repo\", repo], timeout=60)\n114:         if not result.ok:\n115:             raise RuntimeError(result.stderr or \"GitHub diff fetch timed out\")\n116: \n117:         commentable: set[tuple[str, int]] = set()\n118:         current_path: str | None = None\n119:         right_line = 0\n120:         for line in result.stdout.splitlines():\n121:             if line.startswith(\"diff --git\"):\n122:                 match = re.match(r\"diff --git a/.+ b/(.+)\", line)\n123:                 current_path = match.group(1) if match else None\n124:                 right_line = 0\n125:             elif line.startswith(\"@@\"):\n126:                 match = re.search(r\"\\+(\\d+)(?:,\\d+)?\", line)\n127:                 right_line = int(match.group(1)) if match else 0\n128:             elif current_path and right_line:\n129:                 if line.startswith(\"+\") and not line.startswith(\"+++\"):\n130:                     commentable.add((current_path, right_line))\n131:                     right_line += 1\n132:                 elif line.startswith(\"-\") and not line.startswith(\"---\"):\n133:                     continue\n134:                 elif not line.startswith(\"\\\\\"):\n135:                     right_line += 1\n136:         log.debug(\"get_commentable_lines: PR #%d has %d commentable lines\", pr_number, len(commentable))\n137:         return commentable\n138: \n139:     def submit_review(self, request: SubmitReviewRequest) -> CommandResult:\n140:         \"\"\"Submit the body and inline comments in one GitHub review event.\"\"\"\n141:         log.info(\n142:             \"submit_review: PR #%d assessment=%s inline=%d\",\n143:             request.pr_number,\n144:             request.assessment,\n145:             len(request.comments),\n146:         )\n147:         payload = {\n148:             \"body\": request.body,\n149:             \"event\": request.assessment,\n150:             \"commit_id\": request.head_sha,\n151:             \"comments\": [\n152:                 {\n153:                     \"path\": comment.path,\n154:                     \"line\": comment.line,\n155:                     \"side\": \"RIGHT\",\n156:                     \"body\": comment.body,\n157:                 }\n158:                 for comment in request.comments\n159:             ],\n160:         }\n161:         return self._runner(\n162:             [\"gh\", \"api\", \"-X\", \"POST\", f\"repos/{request.repo}/pulls/{request.pr_number}/reviews\", \"--input\", \"-\"],\n163:             input_text=json.dumps(payload),\n164:             timeout=60,\n165:         )\n\n(End of file - total 165 lines)\n</content>","metadata":{"preview":"\"\"\"GitHub CLI implementation of pull request operations.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport re\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom pr_review.adapters.process.subprocess_runner import run_command\nfrom pr_review.core.draft_submission import normalize_submission_assessment, prepare_submission\nfrom pr_review.core.models import PullRequestSnapshot, SubmitReviewRequest\nfrom pr_review.core.ports import CommandResult\nfrom pr_review.log import get_logger\n\nlog = get_logger()\nRunner = Callable[..., CommandResult]\n\n__all__ = [\n    \"GhCliPullRequestAdapter\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/adapters/github/gh_cli.py","text":"\"\"\"GitHub CLI implementation of pull request operations.\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport re\nfrom collections.abc import Callable\nfrom typing import Any\n\nfrom pr_review.adapters.process.subprocess_runner import run_command\nfrom pr_review.core.draft_submission import normalize_submission_assessment, prepare_submission\nfrom pr_review.core.models import PullRequestSnapshot, SubmitReviewRequest\nfrom pr_review.core.ports import CommandResult\nfrom pr_review.log import get_logger\n\nlog = get_logger()\nRunner = Callable[..., CommandResult]\n\n__all__ = [\n    \"GhCliPullRequestAdapter\",\n    \"Runner\",\n    \"normalize_submission_assessment\",\n    \"prepare_submission\",\n    \"pull_request_snapshot_from_json\",\n]\n\n\ndef pull_request_snapshot_from_json(payload: dict[str, Any]) -> PullRequestSnapshot:\n    \"\"\"Convert a GitHub PR JSON object into a domain snapshot.\"\"\"\n    author = payload.get(\"author\")\n    author_payload = author if isinstance(author, dict) else {}\n    return PullRequestSnapshot(\n        number=int(payload[\"number\"]),\n        title=str(payload.get(\"title\", \"\")),\n        head_sha=str(payload.get(\"headRefOid\", \"\")),\n        base_sha=str(payload.get(\"baseRefOid\", \"\")),\n        branch=str(payload.get(\"headRefName\", \"\")),\n        author_login=str(author_payload.get(\"login\", \"unknown\")),\n        state=str(payload.get(\"state\", \"OPEN\")).lower(),\n    )\n\n\nclass GhCliPullRequestAdapter:\n    \"\"\"Pull request operations backed by the GitHub CLI.\"\"\"\n\n    def __init__(self, runner: Runner = run_command) -> None:\n        \"\"\"Initialize the adapter with a command runner.\"\"\"\n        self._runner = runner\n\n    def list_open(self, repo: str) -> list[PullRequestSnapshot]:\n        \"\"\"Fetch all open pull requests with eligibility metadata.\"\"\"\n        result = self._runner(\n            [\n                \"gh\",\n                \"pr\",\n                \"list\",\n                \"--repo\",\n                repo,\n                \"--state\",\n                \"open\",\n                \"--json\",\n                \"number,title,headRefOid,baseRefOid,headRefName,author,isDraft\",\n                \"--limit\",\n                \"100\",\n            ],\n            timeout=60,\n        )\n        if not result.ok:\n            raise RuntimeError(result.stderr or \"GitHub PR listing timed out\")\n        parsed = json.loads(result.stdout or \"[]\")\n        if not isinstance(parsed, list):\n            raise RuntimeError(\"GitHub PR listing returned invalid JSON\")\n        log.debug(\"list_open: %d open PRs\", len(parsed))\n        return [pull_request_snapshot_from_json(item) for item in parsed if isinstance(item, dict)]\n\n    def get_open(self, repo: str, pr_number: int) -> PullRequestSnapshot | None:\n        \"\"\"Fetch one open pull request with eligibility metadata.\"\"\"\n        result = self._runner(\n            [\n                \"gh\",\n                \"pr\",\n                \"view\",\n                str(pr_number),\n                \"--repo\",\n                repo,\n                \"--json\",\n                \"number,title,headRefOid,baseRefOid,headRefName,author,isDraft,state\",\n            ],\n            timeout=60,\n        )\n        if not result.ok:\n            log.warning(\"get_open %d failed: %s\", pr_number, result.stderr[:200])\n            return None\n        parsed = json.loads(result.stdout or \"{}\")\n        if not isinstance(parsed, dict):\n            raise RuntimeError(\"GitHub PR view returned invalid JSON\")\n        if str(parsed.get(\"state\", \"\")).upper() != \"OPEN\":\n            return None\n        return pull_request_snapshot_from_json(parsed)\n\n    def get_authenticated_login(self) -> str:\n        \"\"\"Return the login for the authenticated GitHub CLI user.\"\"\"\n        result = self._runner([\"gh\", \"api\", \"user\"], timeout=60)\n        if not result.ok:\n            raise RuntimeError(result.stderr or \"GitHub user lookup timed out\")\n        parsed = json.loads(result.stdout or \"{}\")\n        if not isinstance(parsed, dict) or not isinstance(parsed.get(\"login\"), str) or not parsed[\"login\"].strip():\n            raise RuntimeError(\"GitHub user lookup returned invalid JSON\")\n        return parsed[\"login\"].strip()\n\n    def get_commentable_lines(self, repo: str, pr_number: int) -> set[tuple[str, int]]:\n        \"\"\"Return right-side PR diff lines that can receive comments.\"\"\"\n        result = self._runner([\"gh\", \"pr\", \"diff\", str(pr_number), \"--repo\", repo], timeout=60)\n        if not result.ok:\n            raise RuntimeError(result.stderr or \"GitHub diff fetch timed out\")\n\n        commentable: set[tuple[str, int]] = set()\n        current_path: str | None = None\n        right_line = 0\n        for line in result.stdout.splitlines():\n            if line.startswith(\"diff --git\"):\n                match = re.match(r\"diff --git a/.+ b/(.+)\", line)\n                current_path = match.group(1) if match else None\n                right_line = 0\n            elif line.startswith(\"@@\"):\n                match = re.search(r\"\\+(\\d+)(?:,\\d+)?\", line)\n                right_line = int(match.group(1)) if match else 0\n            elif current_path and right_line:\n                if line.startswith(\"+\") and not line.startswith(\"+++\"):\n                    commentable.add((current_path, right_line))\n                    right_line += 1\n                elif line.startswith(\"-\") and not line.startswith(\"---\"):\n                    continue\n                elif not line.startswith(\"\\\\\"):\n                    right_line += 1\n        log.debug(\"get_commentable_lines: PR #%d has %d commentable lines\", pr_number, len(commentable))\n        return commentable\n\n    def submit_review(self, request: SubmitReviewRequest) -> CommandResult:\n        \"\"\"Submit the body and inline comments in one GitHub review event.\"\"\"\n        log.info(\n            \"submit_review: PR #%d assessment=%s inline=%d\",\n            request.pr_number,\n            request.assessment,\n            len(request.comments),\n        )\n        payload = {\n            \"body\": request.body,\n            \"event\": request.assessment,\n            \"commit_id\": request.head_sha,\n            \"comments\": [\n                {\n                    \"path\": comment.path,\n                    \"line\": comment.line,\n                    \"side\": \"RIGHT\",\n                    \"body\": comment.body,\n                }\n                for comment in request.comments\n            ],\n        }\n        return self._runner(\n            [\"gh\", \"api\", \"-X\", \"POST\", f\"repos/{request.repo}/pulls/{request.pr_number}/reviews\", \"--input\", \"-\"],\n            input_text=json.dumps(payload),\n            timeout=60,\n        )","lineStart":1,"lineEnd":165,"totalLines":165,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/adapters/github/gh_cli.py","time":{"start":1782271651064,"end":1782271651080}},"id":"prt_ef7ab2cf000196sL6Y7jj9TOqG","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab1f78001hegsxKhN17AYGh"}}
{"type":"tool_use","timestamp":1782271651578,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_ez73vx6t","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/core/draft_submission.py"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/core/draft_submission.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Human-approved draft submission service.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: import time\n6: from collections.abc import Callable\n7: from pathlib import Path\n8: \n9: from pr_review.config import Config\n10: from pr_review.core.models import DraftDetail, SubmissionPreview, SubmissionResult, SubmitReviewRequest\n11: from pr_review.core.ports import PullRequestPort\n12: from pr_review.core.review_parser import InlineComment, parse_review\n13: from pr_review.log import get_logger\n14: from pr_review.services.state_store import StateStore\n15: \n16: log = get_logger()\n17: \n18: \n19: def prepare_submission(\n20:     assessment: str,\n21:     comments: list[InlineComment],\n22:     commentable_lines: set[tuple[str, int]],\n23:     parse_errors: list[str],\n24: ) -> SubmissionPreview:\n25:     \"\"\"Split comments into inline comments and explicit skipped reasons.\"\"\"\n26:     valid: list[InlineComment] = []\n27:     skipped_reasons = list(parse_errors)\n28:     for comment in comments:\n29:         if (comment.path, comment.line) in commentable_lines:\n30:             valid.append(comment)\n31:         else:\n32:             skipped_reasons.append(\n33:                 \"Skipped inline comment for \"\n34:                 f\"`{comment.path}:{comment.line}` because the line is not in the current PR diff\"\n35:             )\n36:     return SubmissionPreview(\n37:         assessment=assessment,\n38:         valid_comments=tuple(valid),\n39:         detached_comments=(),\n40:         skipped_reasons=tuple(skipped_reasons),\n41:     )\n42: \n43: \n44: def normalize_submission_assessment(assessment: str, pr_author: str, viewer_login: str) -> str:\n45:     \"\"\"Downgrade disallowed self-review events to a supported submission type.\"\"\"\n46:     if assessment == \"REQUEST_CHANGES\" and pr_author.strip().lower() == viewer_login.strip().lower():\n47:         return \"COMMENT\"\n48:     return assessment\n49: \n50: \n51: class DraftSubmissionService:\n52:     \"\"\"Load and submit human-approved draft reviews.\"\"\"\n53: \n54:     def __init__(\n55:         self,\n56:         *,\n57:         config: Config,\n58:         pr_port: PullRequestPort,\n59:         state: StateStore,\n60:         clock: Callable[[], str] | None = None,\n61:     ) -> None:\n62:         \"\"\"Initialize submission dependencies.\"\"\"\n63:         self._config = config\n64:         self._pr_port = pr_port\n65:         self._state = state\n66:         self._clock = clock or (lambda: time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime()))\n67: \n68:     def load_detail(self, pr_number: int) -> DraftDetail:\n69:         \"\"\"Load one persisted draft and compute its submission preview.\"\"\"\n70:         draft_file = Path(str(self._state.get(pr_number, \"draft_file\")))\n71:         if not draft_file.exists():\n72:             raise RuntimeError(f\"Draft file not found: {draft_file}\")\n73:         parsed = parse_review(draft_file.read_text(encoding=\"utf-8\"))\n74:         if not parsed.assessment:\n75:             raise RuntimeError(\"; \".join(parsed.errors) or \"missing review assessment\")\n76:         diff_lines = self._pr_port.get_commentable_lines(self._config.repo, pr_number)\n77:         preview = prepare_submission(parsed.assessment, parsed.comments, diff_lines, parsed.errors)\n78:         return DraftDetail(draft_file=draft_file, parsed=parsed, preview=preview)\n79: \n80:     def submit(self, pr_number: int) -> SubmissionResult:\n81:         \"\"\"Submit one persisted draft as a single host review event.\"\"\"\n82:         log.info(\"submit_draft_review: PR #%d\", pr_number)\n83:         if self._state.get(pr_number, \"needs_review\", False):\n84:             raise RuntimeError(f\"PR #{pr_number} changed after this draft was generated; run review again\")\n85:         current_pr = self._pr_port.get_open(self._config.repo, pr_number)\n86:         if current_pr is None:\n87:             raise RuntimeError(f\"PR #{pr_number} not found in {self._config.repo}\")\n88:         stored_head = str(self._state.get(pr_number, \"head_sha\", \"\"))\n89:         stored_base = str(self._state.get(pr_number, \"base_sha\", \"\"))\n90:         if (stored_head and stored_head != current_pr.head_sha) or (stored_base and stored_base != current_pr.base_sha):\n91:             raise RuntimeError(f\"PR #{pr_number} changed after this draft was generated; run review again\")\n92: \n93:         detail = self.load_detail(pr_number)\n94:         submitted_assessment = detail.preview.assessment\n95:         warning = \"\"\n96:         pr_author = str(self._state.get(pr_number, \"author\")) or current_pr.author_login\n97:         if pr_author:\n98:             viewer_login = self._pr_port.get_authenticated_login()\n99:             submitted_assessment = normalize_submission_assessment(detail.preview.assessment, pr_author, viewer_login)\n100:             if submitted_assessment != detail.preview.assessment:\n101:                 warning = \"GitHub does not allow REQUEST_CHANGES on your own pull request; submitted as COMMENT.\"\n102:         result = self._pr_port.submit_review(\n103:             SubmitReviewRequest(\n104:                 repo=self._config.repo,\n105:                 pr_number=pr_number,\n106:                 head_sha=current_pr.head_sha or stored_head,\n107:                 body=detail.parsed.body,\n108:                 assessment=submitted_assessment,\n109:                 comments=tuple(detail.preview.valid_comments),\n110:             )\n111:         )\n112:         if not result.ok:\n113:             raise RuntimeError(result.stderr[:200] or \"Failed to submit review\")\n114:         log.info(\"PR #%d review submitted to GitHub\", pr_number)\n115:         now = self._clock()\n116:         self._state.update_pr(\n117:             pr_number,\n118:             status=\"submitted\",\n119:             updated_at=now,\n120:             submitted_at=now,\n121:             needs_review=False,\n122:             error_message=\"\",\n123:         )\n124:         self._state.flush()\n125:         return SubmissionResult(preview=detail.preview, submitted_assessment=submitted_assessment, warning=warning)\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"\"\"\"Human-approved draft submission service.\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom collections.abc import Callable\nfrom pathlib import Path\n\nfrom pr_review.config import Config\nfrom pr_review.core.models import DraftDetail, SubmissionPreview, SubmissionResult, SubmitReviewRequest\nfrom pr_review.core.ports import PullRequestPort\nfrom pr_review.core.review_parser import InlineComment, parse_review\nfrom pr_review.log import get_logger\nfrom pr_review.services.state_store import StateStore\n\nlog = get_logger()\n\n\ndef prepare_submission(\n    assessment: str,","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/src/pr_review/core/draft_submission.py","text":"\"\"\"Human-approved draft submission service.\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom collections.abc import Callable\nfrom pathlib import Path\n\nfrom pr_review.config import Config\nfrom pr_review.core.models import DraftDetail, SubmissionPreview, SubmissionResult, SubmitReviewRequest\nfrom pr_review.core.ports import PullRequestPort\nfrom pr_review.core.review_parser import InlineComment, parse_review\nfrom pr_review.log import get_logger\nfrom pr_review.services.state_store import StateStore\n\nlog = get_logger()\n\n\ndef prepare_submission(\n    assessment: str,\n    comments: list[InlineComment],\n    commentable_lines: set[tuple[str, int]],\n    parse_errors: list[str],\n) -> SubmissionPreview:\n    \"\"\"Split comments into inline comments and explicit skipped reasons.\"\"\"\n    valid: list[InlineComment] = []\n    skipped_reasons = list(parse_errors)\n    for comment in comments:\n        if (comment.path, comment.line) in commentable_lines:\n            valid.append(comment)\n        else:\n            skipped_reasons.append(\n                \"Skipped inline comment for \"\n                f\"`{comment.path}:{comment.line}` because the line is not in the current PR diff\"\n            )\n    return SubmissionPreview(\n        assessment=assessment,\n        valid_comments=tuple(valid),\n        detached_comments=(),\n        skipped_reasons=tuple(skipped_reasons),\n    )\n\n\ndef normalize_submission_assessment(assessment: str, pr_author: str, viewer_login: str) -> str:\n    \"\"\"Downgrade disallowed self-review events to a supported submission type.\"\"\"\n    if assessment == \"REQUEST_CHANGES\" and pr_author.strip().lower() == viewer_login.strip().lower():\n        return \"COMMENT\"\n    return assessment\n\n\nclass DraftSubmissionService:\n    \"\"\"Load and submit human-approved draft reviews.\"\"\"\n\n    def __init__(\n        self,\n        *,\n        config: Config,\n        pr_port: PullRequestPort,\n        state: StateStore,\n        clock: Callable[[], str] | None = None,\n    ) -> None:\n        \"\"\"Initialize submission dependencies.\"\"\"\n        self._config = config\n        self._pr_port = pr_port\n        self._state = state\n        self._clock = clock or (lambda: time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime()))\n\n    def load_detail(self, pr_number: int) -> DraftDetail:\n        \"\"\"Load one persisted draft and compute its submission preview.\"\"\"\n        draft_file = Path(str(self._state.get(pr_number, \"draft_file\")))\n        if not draft_file.exists():\n            raise RuntimeError(f\"Draft file not found: {draft_file}\")\n        parsed = parse_review(draft_file.read_text(encoding=\"utf-8\"))\n        if not parsed.assessment:\n            raise RuntimeError(\"; \".join(parsed.errors) or \"missing review assessment\")\n        diff_lines = self._pr_port.get_commentable_lines(self._config.repo, pr_number)\n        preview = prepare_submission(parsed.assessment, parsed.comments, diff_lines, parsed.errors)\n        return DraftDetail(draft_file=draft_file, parsed=parsed, preview=preview)\n\n    def submit(self, pr_number: int) -> SubmissionResult:\n        \"\"\"Submit one persisted draft as a single host review event.\"\"\"\n        log.info(\"submit_draft_review: PR #%d\", pr_number)\n        if self._state.get(pr_number, \"needs_review\", False):\n            raise RuntimeError(f\"PR #{pr_number} changed after this draft was generated; run review again\")\n        current_pr = self._pr_port.get_open(self._config.repo, pr_number)\n        if current_pr is None:\n            raise RuntimeError(f\"PR #{pr_number} not found in {self._config.repo}\")\n        stored_head = str(self._state.get(pr_number, \"head_sha\", \"\"))\n        stored_base = str(self._state.get(pr_number, \"base_sha\", \"\"))\n        if (stored_head and stored_head != current_pr.head_sha) or (stored_base and stored_base != current_pr.base_sha):\n            raise RuntimeError(f\"PR #{pr_number} changed after this draft was generated; run review again\")\n\n        detail = self.load_detail(pr_number)\n        submitted_assessment = detail.preview.assessment\n        warning = \"\"\n        pr_author = str(self._state.get(pr_number, \"author\")) or current_pr.author_login\n        if pr_author:\n            viewer_login = self._pr_port.get_authenticated_login()\n            submitted_assessment = normalize_submission_assessment(detail.preview.assessment, pr_author, viewer_login)\n            if submitted_assessment != detail.preview.assessment:\n                warning = \"GitHub does not allow REQUEST_CHANGES on your own pull request; submitted as COMMENT.\"\n        result = self._pr_port.submit_review(\n            SubmitReviewRequest(\n                repo=self._config.repo,\n                pr_number=pr_number,\n                head_sha=current_pr.head_sha or stored_head,\n                body=detail.parsed.body,\n                assessment=submitted_assessment,\n                comments=tuple(detail.preview.valid_comments),\n            )\n        )\n        if not result.ok:\n            raise RuntimeError(result.stderr[:200] or \"Failed to submit review\")\n        log.info(\"PR #%d review submitted to GitHub\", pr_number)\n        now = self._clock()\n        self._state.update_pr(\n            pr_number,\n            status=\"submitted\",\n            updated_at=now,\n            submitted_at=now,\n            needs_review=False,\n            error_message=\"\",\n        )\n        self._state.flush()\n        return SubmissionResult(preview=detail.preview, submitted_assessment=submitted_assessment, warning=warning)","lineStart":1,"lineEnd":125,"totalLines":125,"truncated":false}},"title":"applications/auto-review-pr/src/pr_review/core/draft_submission.py","time":{"start":1782271651557,"end":1782271651572}},"id":"prt_ef7ab2edd001U1qFuDJHJqqvf3","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab1f78001hegsxKhN17AYGh"}}
{"type":"tool_use","timestamp":1782271652208,"sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","part":{"type":"tool","tool":"read","callID":"call_vuknv11g","state":{"status":"completed","input":{"filePath":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/README.md"},"output":"<path>/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/README.md</path>\n<type>file</type>\n<content>\n1: # GitHub PR Auto-Review with Selectable Coding Agents\n2: \n3: This directory is a standalone Python app. Its package, tests, skills, runtime files, and project metadata all live under `applications/auto-review-pr/`.\n4: \n5: The app code lives under `src/pr_review/`. The web dashboard polls open GitHub pull requests, runs a read-only review agent, saves each result as a draft, and lets humans approve or revise through the browser.\n6: \n7: Supported backends:\n8: \n9: - `opencode`\n10: - `codex`\n11: - `claude-code`\n12: - `pi`\n13: \n14: The agent cannot edit files or submit reviews. Only the Python tool can submit after approval through the web dashboard.\n15: \n16: Each review run explicitly loads three repository skills:\n17: \n18: - `pr-review` for analysis, severity, and draft structure\n19: - `gh-cli` for GitHub PR reads\n20: - `pr-revise` for feedback triage and re-review analysis\n21: \n22: `pr-revise` is restricted to analysis. Its implementation, commit, push, reply, polling, and sleep steps are not used.\n23: \n24: ## Architecture\n25: \n26: ```text\n27: applications/auto-review-pr/pyproject.toml                   standalone project metadata\n28: applications/auto-review-pr/src/main.py                      top-level app entrypoint\n29: applications/auto-review-pr/src/pr_review/config.py          local configuration and validation\n30: applications/auto-review-pr/src/pr_review/web.py             FastAPI dashboard entry point\n31: applications/auto-review-pr/src/pr_review/paths.py           app/runtime path constants\n32: applications/auto-review-pr/src/pr_review/log.py             shared logging setup\n33: applications/auto-review-pr/src/pr_review/core/models.py     domain DTOs crossing ports\n34: applications/auto-review-pr/src/pr_review/core/ports.py      backend, PR host, and command-runner ports\n35: applications/auto-review-pr/src/pr_review/core/review_pipeline.py review orchestration with injected backend/runner\n36: applications/auto-review-pr/src/pr_review/core/draft_submission.py approved-review submission rules\n37: applications/auto-review-pr/src/pr_review/core/polling.py    PR queueing and bounded/continuous polling\n38: applications/auto-review-pr/src/pr_review/core/review_parser.py assessment and inline-comment parsing\n39: applications/auto-review-pr/src/pr_review/core/review_schema.py structured review output schema\n40: applications/auto-review-pr/src/pr_review/adapters/agents/   OpenCode, Codex, Claude Code, Pi adapters plus factory\n41: applications/auto-review-pr/src/pr_review/adapters/github/gh_cli.py GitHub CLI PR host adapter\n42: applications/auto-review-pr/src/pr_review/adapters/process/  subprocess-backed command runner\n43: applications/auto-review-pr/src/pr_review/services/          state, worktrees, drafts, polling runtime, web actions, events\n44: applications/auto-review-pr/.opencode/agents/pr-review.md    OpenCode agent definition\n45: applications/auto-review-pr/opencode.json                    OpenCode config for editor validation\n46: applications/auto-review-pr/.agents/skills/{pr-review,pr-revise,gh-cli}/ app-bundled skills\n47: applications/auto-review-pr/tests/unit/pr_review/             unit tests\n48: applications/auto-review-pr/tests/integration/                integration tests\n49: ```\n50: \n51: Foldering rule for provider-boundary work:\n52: \n53: - `src/pr_review/` root is the app shell: package metadata, web entrypoint, config, paths, and logging. It is not a `utils` bucket.\n54: - `src/pr_review/core/` is for app policy: review pipeline, polling decisions, submission rules, prompt contracts, parsing, and schema rules.\n55: - `src/pr_review/adapters/` is for external integration quirks: agent CLIs, `gh`, and subprocess execution.\n56: - `src/pr_review/services/` is for concrete local mechanics with one expected implementation: git worktrees, draft files, and event helpers.\n57: \n58: Use this test when placing code: app-wide setup goes in the root package, business decisions go in `core`, outside-world translation goes in `adapters`, and local app chores go in `services`.\n59: \n60: Runtime files:\n61: \n62: ```text\n63: applications/auto-review-pr/pr-review.json     local configuration, gitignored\n64: applications/auto-review-pr/state_PR.json      runtime state, gitignored\n65: applications/auto-review-pr/.pr-review/drafts/ editable review drafts\n66: applications/auto-review-pr/.pr-review/logs/   backend command logs\n67: applications/auto-review-pr/.pr-review/worktrees/ one worktree per pull request\n68: ```\n69: \n70: State and draft files are written atomically. SIGINT and SIGTERM flush pending state before exit.\n71: \n72: ## Configuration\n73: \n74: Create local configuration from the committed example:\n75: \n76: ```bash\n77: cp applications/auto-review-pr/pr-review.json.example applications/auto-review-pr/pr-review.json\n78: ```\n79: \n80: The file is optional. Repository detection and these defaults apply when it is absent:\n81: \n82: ```json\n83: {\n84:   \"repository\": \"\",\n85:   \"provider\": \"opencode\",\n86:   \"model\": \"\",\n87:   \"agent\": \"pr-review\",\n88:   \"provider_options\": {},\n89:   \"interval_seconds\": 600,\n90:   \"timeout_seconds\": 300,\n91:   \"skip_draft_prs\": false,\n92:   \"skip_bot_authors\": false,\n93:   \"notify_command\": \"\",\n94:   \"editor\": \"code\",\n95:   \"max_workers\": 4\n96: }\n97: ```\n98: \n99: Rules:\n100: \n101: - `interval_seconds` and `timeout_seconds` must be positive integers.\n102: - `timeout_seconds` cannot exceed `interval_seconds`.\n103: - Unknown keys and incorrect value types stop startup with an error.\n104: - `max_workers` must be a positive integer.\n105: - `provider` must be one of `opencode`, `codex`, `claude-code`, or `pi`.\n106: - Empty `repository` uses the `origin` remote.\n107: - Empty `model` uses the agent default.\n108: - `provider_options` passes backend-specific CLI flags when needed.\n109: - `skip_draft_prs` and `skip_bot_authors` are enforced before queueing.\n110: \n111: ## Usage\n112: \n113: Run these commands from `applications/auto-review-pr/`:\n114: \n115: ```bash\n116: # Run the web dashboard\n117: uv run pr-review-web\n118: \n119: # Run through the top-level src entrypoint\n120: uv run python src/main.py\n121: \n122: # Run as a package module\n123: uv run python -m pr_review.web\n124: ```\n125: \n126: Eligible pending PRs are processed in parallel once per poll cycle, bounded by `max_workers`. One failure does not prevent later PRs in the queue from running.\n127: \n128: ## Draft Contract\n129: \n130: The agent produces:\n131: \n132: ```markdown\n133: ## PR Review: #42 - title\n134: \n135: ### Summary\n136: Summary text.\n137: \n138: ### Findings\n139: Findings text.\n140: \n141: ### Overall Assessment\n142: REQUEST_CHANGES - one issue remains\n143: \n144: ### Inline Comments\n145: - `src/app.py:42`: Handle the missing value.\n146: ```\n147: \n148: `Overall Assessment` must be exactly `APPROVE`, `REQUEST_CHANGES`, or `COMMENT`.\n149: \n150: Inline comments require a path, positive line number, and non-empty body. The parser accepts colon or dash separators. Ranges use their first line. Comments outside the right side of the PR diff are not submitted.\n151: \n152: Before submission, the prompt shows:\n153: \n154: - assessment\n155: - valid inline-comment count\n156: - skipped comment count\n157: - reason for every skipped comment\n158: \n159: Any skipped comment requires explicit confirmation.\n160: \n161: ## GitHub Submission\n162: \n163: Approval sends one request to:\n164: \n165: ```text\n166: POST repos/{owner}/{repo}/pulls/{number}/reviews\n167: ```\n168: \n169: The request contains:\n170: \n171: - review body\n172: - assessment mapped to the GitHub review event\n173: - current head commit\n174: - all valid inline comments\n175: \n176: Body and inline comments therefore belong to one GitHub review event. Success is reported only after that request succeeds.\n177: \n178: ## Revision\n179: \n180: The web dashboard can request a revised draft with human feedback before submission. Revision runs keep the same read-only agent constraints as fresh reviews and reuse the stored backend session ID when the provider supports resume.\n181: \n182: Editor settings may contain arguments, such as `code --wait` or `vim -R`.\n183: \n184: ## Notifications\n185: \n186: `notify_command` is split into arguments and run without a shell. Supported placeholders:\n187: \n188: - `{PR_NUMBER}`\n189: - `{DRAFT_FILE}`\n190: \n191: Example:\n192: \n193: ```json\n194: {\n195:   \"notify_command\": \"notify-send \\\"PR Review\\\" \\\"PR #{PR_NUMBER} draft ready: {DRAFT_FILE}\\\"\"\n196: }\n197: ```\n198: \n199: Shell pipelines, redirection, and command substitution are intentionally unsupported.\n200: \n201: ## Safety\n202: \n203: Agent permissions live only in `applications/auto-review-pr/.opencode/agents/pr-review.md`. The agent can inspect git and GitHub data but cannot edit files or submit reviews.\n204: \n205: `applications/auto-review-pr/opencode.json` retains the remote `$schema` URL for optional editor validation. The review runtime does not fetch or require that schema.\n206: \n207: All git fetch, pull, checkout, branch, prune, remove, and worktree operations have timeouts.\n208: \n209: ## Verification\n210: \n211: Run from `applications/auto-review-pr/`:\n212: \n213: ```bash\n214: uv run ruff check src/pr_review tests\n215: uv run pytest\n216: uv run mypy src/pr_review --ignore-missing-imports\n217: ```\n218: \n219: Manual agent discovery check:\n220: \n221: ```bash\n222: opencode agent list\n223: ```\n224: \n225: Confirm that `pr-review` is loaded from `.opencode/agents/pr-review.md`.\n226: Confirm that the worktree copy came from `applications/auto-review-pr/.opencode/agents/pr-review.md`.\n\n(End of file - total 226 lines)\n</content>","metadata":{"preview":"# GitHub PR Auto-Review with Selectable Coding Agents\n\nThis directory is a standalone Python app. Its package, tests, skills, runtime files, and project metadata all live under `applications/auto-review-pr/`.\n\nThe app code lives under `src/pr_review/`. The web dashboard polls open GitHub pull requests, runs a read-only review agent, saves each result as a draft, and lets humans approve or revise through the browser.\n\nSupported backends:\n\n- `opencode`\n- `codex`\n- `claude-code`\n- `pi`\n\nThe agent cannot edit files or submit reviews. Only the Python tool can submit after approval through the web dashboard.\n\nEach review run explicitly loads three repository skills:\n\n- `pr-review` for analysis, severity, and draft structure\n- `gh-cli` for GitHub PR reads\n- `pr-revise` for feedback triage and re-review analysis","truncated":false,"loaded":[],"display":{"type":"file","path":"/home/joseph/work/gl-tabular/main/applications/auto-review-pr/.pr-review/worktrees/pr-64/applications/auto-review-pr/README.md","text":"# GitHub PR Auto-Review with Selectable Coding Agents\n\nThis directory is a standalone Python app. Its package, tests, skills, runtime files, and project metadata all live under `applications/auto-review-pr/`.\n\nThe app code lives under `src/pr_review/`. The web dashboard polls open GitHub pull requests, runs a read-only review agent, saves each result as a draft, and lets humans approve or revise through the browser.\n\nSupported backends:\n\n- `opencode`\n- `codex`\n- `claude-code`\n- `pi`\n\nThe agent cannot edit files or submit reviews. Only the Python tool can submit after approval through the web dashboard.\n\nEach review run explicitly loads three repository skills:\n\n- `pr-review` for analysis, severity, and draft structure\n- `gh-cli` for GitHub PR reads\n- `pr-revise` for feedback triage and re-review analysis\n\n`pr-revise` is restricted to analysis. Its implementation, commit, push, reply, polling, and sleep steps are not used.\n\n## Architecture\n\n```text\napplications/auto-review-pr/pyproject.toml                   standalone project metadata\napplications/auto-review-pr/src/main.py                      top-level app entrypoint\napplications/auto-review-pr/src/pr_review/config.py          local configuration and validation\napplications/auto-review-pr/src/pr_review/web.py             FastAPI dashboard entry point\napplications/auto-review-pr/src/pr_review/paths.py           app/runtime path constants\napplications/auto-review-pr/src/pr_review/log.py             shared logging setup\napplications/auto-review-pr/src/pr_review/core/models.py     domain DTOs crossing ports\napplications/auto-review-pr/src/pr_review/core/ports.py      backend, PR host, and command-runner ports\napplications/auto-review-pr/src/pr_review/core/review_pipeline.py review orchestration with injected backend/runner\napplications/auto-review-pr/src/pr_review/core/draft_submission.py approved-review submission rules\napplications/auto-review-pr/src/pr_review/core/polling.py    PR queueing and bounded/continuous polling\napplications/auto-review-pr/src/pr_review/core/review_parser.py assessment and inline-comment parsing\napplications/auto-review-pr/src/pr_review/core/review_schema.py structured review output schema\napplications/auto-review-pr/src/pr_review/adapters/agents/   OpenCode, Codex, Claude Code, Pi adapters plus factory\napplications/auto-review-pr/src/pr_review/adapters/github/gh_cli.py GitHub CLI PR host adapter\napplications/auto-review-pr/src/pr_review/adapters/process/  subprocess-backed command runner\napplications/auto-review-pr/src/pr_review/services/          state, worktrees, drafts, polling runtime, web actions, events\napplications/auto-review-pr/.opencode/agents/pr-review.md    OpenCode agent definition\napplications/auto-review-pr/opencode.json                    OpenCode config for editor validation\napplications/auto-review-pr/.agents/skills/{pr-review,pr-revise,gh-cli}/ app-bundled skills\napplications/auto-review-pr/tests/unit/pr_review/             unit tests\napplications/auto-review-pr/tests/integration/                integration tests\n```\n\nFoldering rule for provider-boundary work:\n\n- `src/pr_review/` root is the app shell: package metadata, web entrypoint, config, paths, and logging. It is not a `utils` bucket.\n- `src/pr_review/core/` is for app policy: review pipeline, polling decisions, submission rules, prompt contracts, parsing, and schema rules.\n- `src/pr_review/adapters/` is for external integration quirks: agent CLIs, `gh`, and subprocess execution.\n- `src/pr_review/services/` is for concrete local mechanics with one expected implementation: git worktrees, draft files, and event helpers.\n\nUse this test when placing code: app-wide setup goes in the root package, business decisions go in `core`, outside-world translation goes in `adapters`, and local app chores go in `services`.\n\nRuntime files:\n\n```text\napplications/auto-review-pr/pr-review.json     local configuration, gitignored\napplications/auto-review-pr/state_PR.json      runtime state, gitignored\napplications/auto-review-pr/.pr-review/drafts/ editable review drafts\napplications/auto-review-pr/.pr-review/logs/   backend command logs\napplications/auto-review-pr/.pr-review/worktrees/ one worktree per pull request\n```\n\nState and draft files are written atomically. SIGINT and SIGTERM flush pending state before exit.\n\n## Configuration\n\nCreate local configuration from the committed example:\n\n```bash\ncp applications/auto-review-pr/pr-review.json.example applications/auto-review-pr/pr-review.json\n```\n\nThe file is optional. Repository detection and these defaults apply when it is absent:\n\n```json\n{\n  \"repository\": \"\",\n  \"provider\": \"opencode\",\n  \"model\": \"\",\n  \"agent\": \"pr-review\",\n  \"provider_options\": {},\n  \"interval_seconds\": 600,\n  \"timeout_seconds\": 300,\n  \"skip_draft_prs\": false,\n  \"skip_bot_authors\": false,\n  \"notify_command\": \"\",\n  \"editor\": \"code\",\n  \"max_workers\": 4\n}\n```\n\nRules:\n\n- `interval_seconds` and `timeout_seconds` must be positive integers.\n- `timeout_seconds` cannot exceed `interval_seconds`.\n- Unknown keys and incorrect value types stop startup with an error.\n- `max_workers` must be a positive integer.\n- `provider` must be one of `opencode`, `codex`, `claude-code`, or `pi`.\n- Empty `repository` uses the `origin` remote.\n- Empty `model` uses the agent default.\n- `provider_options` passes backend-specific CLI flags when needed.\n- `skip_draft_prs` and `skip_bot_authors` are enforced before queueing.\n\n## Usage\n\nRun these commands from `applications/auto-review-pr/`:\n\n```bash\n# Run the web dashboard\nuv run pr-review-web\n\n# Run through the top-level src entrypoint\nuv run python src/main.py\n\n# Run as a package module\nuv run python -m pr_review.web\n```\n\nEligible pending PRs are processed in parallel once per poll cycle, bounded by `max_workers`. One failure does not prevent later PRs in the queue from running.\n\n## Draft Contract\n\nThe agent produces:\n\n```markdown\n## PR Review: #42 - title\n\n### Summary\nSummary text.\n\n### Findings\nFindings text.\n\n### Overall Assessment\nREQUEST_CHANGES - one issue remains\n\n### Inline Comments\n- `src/app.py:42`: Handle the missing value.\n```\n\n`Overall Assessment` must be exactly `APPROVE`, `REQUEST_CHANGES`, or `COMMENT`.\n\nInline comments require a path, positive line number, and non-empty body. The parser accepts colon or dash separators. Ranges use their first line. Comments outside the right side of the PR diff are not submitted.\n\nBefore submission, the prompt shows:\n\n- assessment\n- valid inline-comment count\n- skipped comment count\n- reason for every skipped comment\n\nAny skipped comment requires explicit confirmation.\n\n## GitHub Submission\n\nApproval sends one request to:\n\n```text\nPOST repos/{owner}/{repo}/pulls/{number}/reviews\n```\n\nThe request contains:\n\n- review body\n- assessment mapped to the GitHub review event\n- current head commit\n- all valid inline comments\n\nBody and inline comments therefore belong to one GitHub review event. Success is reported only after that request succeeds.\n\n## Revision\n\nThe web dashboard can request a revised draft with human feedback before submission. Revision runs keep the same read-only agent constraints as fresh reviews and reuse the stored backend session ID when the provider supports resume.\n\nEditor settings may contain arguments, such as `code --wait` or `vim -R`.\n\n## Notifications\n\n`notify_command` is split into arguments and run without a shell. Supported placeholders:\n\n- `{PR_NUMBER}`\n- `{DRAFT_FILE}`\n\nExample:\n\n```json\n{\n  \"notify_command\": \"notify-send \\\"PR Review\\\" \\\"PR #{PR_NUMBER} draft ready: {DRAFT_FILE}\\\"\"\n}\n```\n\nShell pipelines, redirection, and command substitution are intentionally unsupported.\n\n## Safety\n\nAgent permissions live only in `applications/auto-review-pr/.opencode/agents/pr-review.md`. The agent can inspect git and GitHub data but cannot edit files or submit reviews.\n\n`applications/auto-review-pr/opencode.json` retains the remote `$schema` URL for optional editor validation. The review runtime does not fetch or require that schema.\n\nAll git fetch, pull, checkout, branch, prune, remove, and worktree operations have timeouts.\n\n## Verification\n\nRun from `applications/auto-review-pr/`:\n\n```bash\nuv run ruff check src/pr_review tests\nuv run pytest\nuv run mypy src/pr_review --ignore-missing-imports\n```\n\nManual agent discovery check:\n\n```bash\nopencode agent list\n```\n\nConfirm that `pr-review` is loaded from `.opencode/agents/pr-review.md`.\nConfirm that the worktree copy came from `applications/auto-review-pr/.opencode/agents/pr-review.md`.","lineStart":1,"lineEnd":226,"totalLines":226,"truncated":false}},"title":"applications/auto-review-pr/README.md","time":{"start":1782271652190,"end":1782271652203}},"id":"prt_ef7ab3155001FtwKi8fbIAClg6","sessionID":"ses_108557056ffeZ4F0zj9y2EiqOH","messageID":"msg_ef7ab1f78001hegsxKhN17AYGh"}}
